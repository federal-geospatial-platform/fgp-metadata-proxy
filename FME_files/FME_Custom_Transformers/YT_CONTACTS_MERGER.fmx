FACTORY_DEF * TeeFactory   FACTORY_NAME "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_INPUT1762281884 Input Splitter"   INPUT FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_INPUT"   OUTPUT FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_INPUT"
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_AttributeExposer }    INPUT  FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_INPUT"    OUTPUT { FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_AttributeExposer_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_UUIDGenerator }    INPUT  FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_AttributeExposer_OUTPUT"    OUTPUT { FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT"             "_uuidContacts" @UUID(SIMPLE, UUID_FORMAT, UUID_ONLY)              }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_UUIDGenerator OUTPUT Splitter"   INPUT FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT"   OUTPUT FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_0_YOT1zaVTFTI="   OUTPUT FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_1_fghrwfmYVMA="
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC }    } else {        puts "MACRO $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_AttributeRemover_2 }    INPUT  FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_0_YOT1zaVTFTI="    OUTPUT { FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"        @RemoveAttributes(fme_encoded,contact,contact_role,author_email)        $($(YT_CONTACTS_MERGER_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttributeKeeperFactory    FACTORY_NAME { $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_AttributeKeeper_2 }    INPUT  FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_1_fghrwfmYVMA="    KEEP_ATTRS { contact,_uuidContacts,default_contact_role,contact_role,author_email,default_contact_name }    KEEP_LISTS {  }    KEEP_FME_ATTRIBUTES Yes    BUILD_FEATURE_TABLES { No }    OUTPUT_ON_ATTRIBUTE_CHANGE {  }    OUTPUT { OUTPUT FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_AttributeKeeper_2_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    COMMAND_PARM_EVALUATION SINGLE_PASS    FACTORY_NAME { $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_AttributeRenamer_4 }    INPUT  FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_AttributeKeeper_2_OUTPUT" 	ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    MISSING_INPUT_ATTR_HANDLING { RENAME_SET_DEFAULT PRESERVE }    KEEP_OUTPUT_ATTRS_ONLY { no } 	ATTR_ACTION { "contact" "name" "RENAME_SET_DEFAULT" "" }      ATTR_ACTION { "author_email" "email" "RENAME_SET_DEFAULT" "" }      ATTR_ACTION { "contact_role" "role" "RENAME_SET_DEFAULT" "" }    OUTPUT { OUTPUT FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_AttributeRenamer_4_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_Tester_5 }    INPUT  FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_AttributeRenamer_4_OUTPUT"    TEST { email ATTRIBUTE_HAS_A_VALUE "" ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    OUTPUT { PASSED FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_Tester_5_PASSED"         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} StringValueFactory    FACTORY_NAME { $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_StringCaseChanger }    INPUT  FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_Tester_5_PASSED"    FACTORY_MODE ATTRIBUTE_CASE_CHANGER    ATTRCHOICE { SELECTED }       ATTRLIST { email }       CHANGE_TYPE { lower }    OUTPUT { OUTPUT FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_StringCaseChanger_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} StringReplacerFactory    FACTORY_NAME { $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_StringReplacer }    INPUT  FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_StringCaseChanger_OUTPUT"    USE_REGEX { NO }    CASE_SENSITIVE { NO }    SOURCE_ATTRIBUTES { email }    FIND_TEXT { "mailto:" }    REPLACE_TEXT { "" }    REPLACE_NO_MATCH { "_FME_NO_OP_" }    OUTPUT { OUTPUT FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_StringReplacer_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_Tester }    INPUT  FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_StringReplacer_OUTPUT"    TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>role<closeparen>,$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_Tester)" != "" ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    OUTPUT { PASSED FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_Tester_PASSED"         }    OUTPUT { FAILED FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_Tester_FAILED"         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_AttributeCreator }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_Tester_FAILED"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "role" "SET_TO" "<at>Value<openparen>default_contact_role<closeparen>" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_AttributeCreator_OUTPUT"        }
# -------------------------------------------------------------------------
INCLUDE [if { {ATTRIBUTES} == {ATTRIBUTES} } {                puts "MACRO $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO ATTRIBUTES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {POLYGONS}} {                puts "MACRO $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {AGGREGATES}} {                puts "MACRO $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {POLYGONS}} {                puts "MACRO $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {AGGREGATES}} {                puts "MACRO $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} } {                puts "MACRO $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} } {                puts "MACRO $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          else {}; ]
FACTORY_DEF {*} ReferenceFactory    FACTORY_NAME { $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_FeatureMerger }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT REFERENCER FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"    INPUT REFERENCEE FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_Tester_PASSED"    INPUT REFERENCEE FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_AttributeCreator_OUTPUT"    REFERENCE_INFO { $($(YT_CONTACTS_MERGER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO) }    REFERENCE_TABLE { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_uuidContacts<closeparen>,$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_FeatureMerger) @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_uuidContacts<closeparen>,$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_FeatureMerger) AUTO }    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "REQUESTOR_IF_CONFLICT" }    IGNORE_NULLS { "No" }    HANDLE_NULL_MISSING_KEYS_LIKE_FME2013 { No }    LIST_NAME { "contacts" }    LIST_ATTRS_TO_INCLUDE { email name role }    LIST_ATTRS_TO_INCLUDE_MODE { SELECTED }    MERGE_ATTRIBUTES Yes    MANAGE_FME_TYPE Yes    MODE COMPLETE    PROCESS_DUPLICATE_REFERENCEES { NO }    REFERENCEES_FIRST { No }    REJECT_INVALID_GEOM YES    CLEANING_TOLERANCE { <Unused> }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    COMPARE_WHITESPACE Yes    OUTPUT { COMPLETE FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_FeatureMerger_MERGED"         }    OUTPUT { INCOMPLETE FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_FeatureMerger_UNMERGED_REQUESTOR"         }    OUTPUT { UNREFERENCED FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_FeatureMerger_UNUSED_SUPPLIER"         }    OUTPUT { REJECTED FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_FeatureMerger_<REJECTED>"         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_AttributeCreator_3 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_FeatureMerger_UNMERGED_REQUESTOR"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "contacts<opencurly>0<closecurly>.email" "SET_TO" "<at>Value<openparen>default_contact_email<closeparen>" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "contacts<opencurly>0<closecurly>.role" "SET_TO" "<at>Value<openparen>default_contact_role<closeparen>" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_AttributeCreator_3_OUTPUT"        }
# -------------------------------------------------------------------------
Tcl2 proc $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_ListDuplicateRemover_removeDups {} {    set srcIndex 0;    regsub \"{}\" {contacts{}.email} \"{$srcIndex}\"    listKeyAttrName;    regsub \"{}.*$\" {contacts{}.email} \"\{\"          listBase;    regsub \"{}.*$\" {contacts{}.email} \"\{*\"         listBasePattern;    regsub \"{(}.*)$\" {contacts{}.email} {\1}          listSuffix;    regsub \"{}\" {contacts{}.email} \"\\{\[0-9\]*\\}\" listPatternRegExp;    set listPatternRegExp \"^$listPatternRegExp\$\";    set listIndexRegExp   \"^$listBase\(\[0-9\]+\)\}.*\";    set attributeNames [FME_AttributeNames];    set COMMENT {      = Iterate over all attributes. For any that look like src_list{n}.something,      = keep a list in the associative array "listAttributesByIndex(n)". If they      = actually match the key on which we're comparing, store a "true" in the      = associative array "listKeyAttrNameExists()"    };    foreach attrname $attributeNames {       if [regsub $listIndexRegExp $attrname {\1} listIndex] {         lappend listAttributesByIndex($listIndex) $attrname;         if {$attrname ==  \"$listBase$listIndex$listSuffix\"} {           set listKeyAttrNameExists($attrname) true;         };       };    };    set destIndex 0;    set listElementsPattern {};    set haveMissingLast true;    if [catch { set haveNextKey $listKeyAttrNameExists($listKeyAttrName); }] { set haveNextKey false; };    while {[array size listKeyAttrNameExists] > 0 || $haveMissingLast } {        set keyVal [FME_GetAttribute $listKeyAttrName];        if {![info exists dups($keyVal)] && [info exists listAttributesByIndex($srcIndex)]} {            set listElementsPattern \"$listBase$srcIndex\}*\"; 				   set foundSibling 0;            set COMMENT {              = We already have the list of attributes associated with this index. Deal              = with each one of these.            };            foreach listAttrName $listAttributesByIndex($srcIndex)            {               set destAttrName [string replace $listAttrName 0                                 [expr [string length $listElementsPattern] - 3]                                 \"$listBase$destIndex\""];               set destAttrVal [FME_GetAttribute $listAttrName];               if {$destAttrVal == {} && [FME_IsAttributeNull $listAttrName]} {               	   set destAttrVal {FME_NULL_VALUE};               };               set holder($destAttrName) $destAttrVal;               if {$foundSibling == 0  } {                   set dups($keyVal) {};                   set foundSibling 1;               };            };            if {$foundSibling && $keyVal == {} && ![FME_AttributeExists $listKeyAttrName]}            {               set dups($keyVal) {};               set missingAttrName [string replace $listKeyAttrName 0                                 [expr [string length $listElementsPattern] - 3]                                 \"$listBase$destIndex\""];               set holder($missingAttrName) {FME_MISSING_VAL};            };            if {$foundSibling} {                incr destIndex;            };        };        if $haveNextKey {          unset listKeyAttrNameExists($listKeyAttrName);        };        incr srcIndex;        regsub \"{}\" {contacts{}.email} \"{$srcIndex}\" listKeyAttrName;        if [catch { set haveNextKey $listKeyAttrNameExists($listKeyAttrName); }] { set haveNextKey false; };        if {[array size listKeyAttrNameExists] == 0} {            set COMMENT {              = Once we've exhausted all of the actual sort keys, keep looking for structured              = elements within the list that don't have an accompanying sort key.            };            set haveMissingLast [info exists listAttributesByIndex($srcIndex)];        };    };    foreach attrname $attributeNames { 		 if {[string match $listBasePattern $attrname]} { 		   FME_UnsetAttributes $attrname; 		 };    };    foreach newListAttrName [array names holder] {        if {$holder($newListAttrName) == {FME_NULL_VALUE}} {           FME_SetAttributeNull $newListAttrName        } elseif { $holder($newListAttrName) != {FME_MISSING_VAL} } {           FME_SetAttribute $newListAttrName $holder($newListAttrName);        };    }; };
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_ListDuplicateRemover }    INPUT  FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_FeatureMerger_MERGED"    INPUT  FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_AttributeCreator_3_OUTPUT"    OUTPUT { FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_ListDuplicateRemover_OUTPUT"         @Tcl2("$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_ListDuplicateRemover_removeDups")          }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_AttributeRemover_5_LIST_FUNC }    } else {        puts "MACRO $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_AttributeRemover_5_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_AttributeRemover_5 }    INPUT  FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_ListDuplicateRemover_OUTPUT"    OUTPUT { FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_AttributeRemover_5_OUTPUT"        @RemoveAttributes(fme_encoded,_uuidContacts,default_contact_role)        $($(YT_CONTACTS_MERGER_WORKSPACE_NAME)_AttributeRemover_5_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Input Input Collector"   INPUT FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_AttributeRemover_5_OUTPUT"   OUTPUT FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Input"
MACRO ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_XFORMER_NAME $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
INCLUDE_CUSTOM_TRANSFORMER_VER ATTRIBUTE_UNEXPOSER:1
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Output Output Renamer/Nuker"   INPUT FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(YT_CONTACTS_MERGER_WORKSPACE_NAME)_Terminator }    INPUT  FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_FeatureMerger_UNUSED_SUPPLIER"    INPUT  FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_FeatureMerger_<REJECTED>"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"Translation<space>Terminated")       @SupplyAttributes(_wb_termination_xformer,"$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_Terminator")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"Translation<space>Terminated") }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_OUTPUT1762281884 Output Collector"   INPUT FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(YT_CONTACTS_MERGER_WORKSPACE_NAME)_OUTPUT"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(YT_CONTACTS_MERGER_WORKSPACE_NAME))}]
