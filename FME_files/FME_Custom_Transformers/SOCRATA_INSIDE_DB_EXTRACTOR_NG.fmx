# -------------------------------------------------------------------------
Tcl2 proc $(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_ListDuplicateRemover_removeDups {} {    set srcIndex 0;    regsub \"{}\" {columns{}.fieldName} \"{$srcIndex}\"    listKeyAttrName;    regsub \"{}.*$\" {columns{}.fieldName} \"\{\"          listBase;    regsub \"{}.*$\" {columns{}.fieldName} \"\{*\"         listBasePattern;    regsub \"{(}.*)$\" {columns{}.fieldName} {\1}          listSuffix;    regsub \"{}\" {columns{}.fieldName} \"\\{\[0-9\]*\\}\" listPatternRegExp;    set listPatternRegExp \"^$listPatternRegExp\$\";    set listIndexRegExp   \"^$listBase\(\[0-9\]+\)\}.*\";    set attributeNames [FME_AttributeNames];    set COMMENT {      = Iterate over all attributes. For any that look like src_list{n}.something,      = keep a list in the associative array "listAttributesByIndex(n)". If they      = actually match the key on which we're comparing, store a "true" in the      = associative array "listKeyAttrNameExists()"    };    foreach attrname $attributeNames {       if [regsub $listIndexRegExp $attrname {\1} listIndex] {         lappend listAttributesByIndex($listIndex) $attrname;         if {$attrname ==  \"$listBase$listIndex$listSuffix\"} {           set listKeyAttrNameExists($attrname) true;         };       };    };    set destIndex 0;    set listElementsPattern {};    set haveMissingLast true;    if [catch { set haveNextKey $listKeyAttrNameExists($listKeyAttrName); }] { set haveNextKey false; };    while {[array size listKeyAttrNameExists] > 0 || $haveMissingLast } {        set keyVal [FME_GetAttribute $listKeyAttrName];        if {![info exists dups($keyVal)] && [info exists listAttributesByIndex($srcIndex)]} {            set listElementsPattern \"$listBase$srcIndex\}*\"; 				   set foundSibling 0;            set COMMENT {              = We already have the list of attributes associated with this index. Deal              = with each one of these.            };            foreach listAttrName $listAttributesByIndex($srcIndex)            {               set destAttrName [string replace $listAttrName 0                                 [expr [string length $listElementsPattern] - 3]                                 \"$listBase$destIndex\""];               set destAttrVal [FME_GetAttribute $listAttrName];               if {$destAttrVal == {} && [FME_IsAttributeNull $listAttrName]} {               	   set destAttrVal {FME_NULL_VALUE};               };               set holder($destAttrName) $destAttrVal;               if {$foundSibling == 0  } {                   set dups($keyVal) {};                   set foundSibling 1;               };            };            if {$foundSibling && $keyVal == {} && ![FME_AttributeExists $listKeyAttrName]}            {               set dups($keyVal) {};               set missingAttrName [string replace $listKeyAttrName 0                                 [expr [string length $listElementsPattern] - 3]                                 \"$listBase$destIndex\""];               set holder($missingAttrName) {FME_MISSING_VAL};            };            if {$foundSibling} {                incr destIndex;            };        };        if $haveNextKey {          unset listKeyAttrNameExists($listKeyAttrName);        };        incr srcIndex;        regsub \"{}\" {columns{}.fieldName} \"{$srcIndex}\" listKeyAttrName;        if [catch { set haveNextKey $listKeyAttrNameExists($listKeyAttrName); }] { set haveNextKey false; };        if {[array size listKeyAttrNameExists] == 0} {            set COMMENT {              = Once we've exhausted all of the actual sort keys, keep looking for structured              = elements within the list that don't have an accompanying sort key.            };            set haveMissingLast [info exists listAttributesByIndex($srcIndex)];        };    };    foreach attrname $attributeNames { 		 if {[string match $listBasePattern $attrname]} { 		   FME_UnsetAttributes $attrname; 		 };    };    foreach newListAttrName [array names holder] {        if {$holder($newListAttrName) == {FME_NULL_VALUE}} {           FME_SetAttributeNull $newListAttrName        } elseif { $holder($newListAttrName) != {FME_MISSING_VAL} } {           FME_SetAttribute $newListAttrName $holder($newListAttrName);        };    }; };
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_ListDuplicateRemover }    INPUT  FEATURE_TYPE "$(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_ListBuilder_OUTPUT"    OUTPUT { FEATURE_TYPE "$(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_ListDuplicateRemover_OUTPUT"         @Tcl2("$(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_ListDuplicateRemover_removeDups")          }
# -------------------------------------------------------------------------
INCLUDE [if { {ATTRIBUTES} == {ATTRIBUTES} } {                puts "MACRO $(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_FeatureMerger_6_REFERENCE_INFO ATTRIBUTES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {POLYGONS}} {                puts "MACRO $(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_FeatureMerger_6_REFERENCE_INFO GEOM_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {AGGREGATES}} {                puts "MACRO $(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_FeatureMerger_6_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO $(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_FeatureMerger_6_REFERENCE_INFO GEOM_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {POLYGONS}} {                puts "MACRO $(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_FeatureMerger_6_REFERENCE_INFO GEOM_AND_ATTR_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {AGGREGATES}} {                puts "MACRO $(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_FeatureMerger_6_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO $(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_FeatureMerger_6_REFERENCE_INFO GEOM_AND_ATTR_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} } {                puts "MACRO $(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_FeatureMerger_6_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} } {                puts "MACRO $(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_FeatureMerger_6_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          else {}; ]
FACTORY_DEF {*} ReferenceFactory    FACTORY_NAME { $(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_FeatureMerger_6 }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT REFERENCER FEATURE_TYPE "$(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"    INPUT REFERENCEE FEATURE_TYPE "$(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_ListDuplicateRemover_OUTPUT"    REFERENCE_INFO { $($(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_FeatureMerger_6_REFERENCE_INFO) }    REFERENCE_TABLE { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_sub_uuid<closeparen>,$(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_FeatureMerger_6) @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_sub_uuid<closeparen>,$(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_FeatureMerger_6) AUTO }    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "REQUESTOR_IF_CONFLICT" }    IGNORE_NULLS { "No" }    HANDLE_NULL_MISSING_KEYS_LIKE_FME2013 { No }    LIST_ATTRS_TO_INCLUDE { <Unused> }    LIST_ATTRS_TO_INCLUDE_MODE { <Unused> }    MERGE_ATTRIBUTES Yes    MANAGE_FME_TYPE Yes    MODE COMPLETE    PROCESS_DUPLICATE_REFERENCEES { NO }    REFERENCEES_FIRST { No }    REJECT_INVALID_GEOM YES    CLEANING_TOLERANCE { <Unused> }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    COMPARE_WHITESPACE Yes    OUTPUT { COMPLETE FEATURE_TYPE "$(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_FeatureMerger_6_MERGED"         }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "columns<opencurly><closecurly>._element_index columns<opencurly><closecurly>.datatype columns<opencurly><closecurly>.name"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_AttributeRemover_3_LIST_FUNC }    } else {        puts "MACRO $(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_AttributeRemover_3_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_AttributeRemover_3 }    INPUT  FEATURE_TYPE "$(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_FeatureMerger_6_MERGED"    OUTPUT { FEATURE_TYPE "$(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_AttributeRemover_3_OUTPUT"        @RemoveAttributes(fme_encoded,)        $($(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_AttributeRemover_3_LIST_FUNC)         }
# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {$(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_ListSearcher_6598cb1e_1d94_4acf_a1a1_0133be0666bd0} ]
# most of this is close to the code from listindexer but not exact beucase
# we have a type LIST_ATTR rather than type LIST_NAME so need
# to figure out the list name
Tcl2 proc $(FME_UUID_SAFE)_indexer {index prefix} {    set fullListAttrName [FME_DecodeText columns<opencurly><closecurly>.fgp_publish];    set lastBrace [string last  \"{}\" $fullListAttrName];    set listAttr [string range $fullListAttrName 0 [expr $lastBrace+1]];    regsub \"{}\" $listAttr \"{$index}\" listWithIndex;    regsub \"{}\" $listAttr {} listBase;    set complexListExp "$listWithIndex\.";    set prefixLength [expr [string length $complexListExp]-1];    set prefix [FME_DecodeText $prefix];    foreach attr [FME_AttributeNames] {      set newAttr {};      if {$attr == $listWithIndex} {        set newAttr $listBase;      } elseif {[string first $complexListExp $attr] == 0} {        set newAttr [string replace $attr 0 $prefixLength];      };      if {$newAttr != {}} {          if {$prefix != {} } {            set newAttr $prefix$newAttr;          };          if {[string first {fme_} $newAttr] != 0} {              set first [string first {fme_} $newAttr];              lappend attrsToCopy $newAttr $attr;          };      };    };    if {[info exists attrsToCopy] && [llength $attrsToCopy] > 0} {      eval FME_Execute CopyAttributes $attrsToCopy;    }; }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_ListSearcher }    INPUT  FEATURE_TYPE "$(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_AttributeRemover_3_OUTPUT"    OUTPUT { FEATURE_TYPE $(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_ListSearcher__IndexedFeatures___         "$(FME_UUID_SAFE)" @SearchList(fme_encoded,"columns<opencurly><closecurly>.fgp_publish","oui",FIRST_MATCHED_ENCODED,CASE_SENSITIVE) }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_ListSearcher__Tester }    INPUT { FEATURE_TYPE $(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_ListSearcher__IndexedFeatures___ }    TEST { @Value($(FME_UUID_SAFE)) == "-1" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE  "$(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_ListSearcher_NOT_FOUND" @RemoveAttributes($(FME_UUID_SAFE)) }    OUTPUT { FAILED FEATURE_TYPE  $(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_ListSearcher__IndexFound__  }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_ListSearcher__Tester2 }    INPUT { FEATURE_TYPE $(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_ListSearcher__IndexFound__ }    TEST { NO == "NO" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE "$(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_ListSearcher_FOUND" @CopyAttributes(_list_index, $(FME_UUID_SAFE)) @RemoveAttributes($(FME_UUID_SAFE)) }    OUTPUT { FAILED FEATURE_TYPE "$(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_ListSearcher_FOUND"  @Tcl2("$(FME_UUID_SAFE)_indexer {@Value($(FME_UUID_SAFE))} {<Unused>}") @CopyAttributes(_list_index, $(FME_UUID_SAFE)) @RemoveAttributes($(FME_UUID_SAFE)) }
