# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "columns<opencurly><closecurly>"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC }    } else {        puts "MACRO $(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_AttributeRemover_2 }    INPUT  FEATURE_TYPE "$(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_0_mv5e0XphzVw="    OUTPUT { FEATURE_TYPE "$(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"        @RemoveAttributes(fme_encoded,)        $($(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC)         }
