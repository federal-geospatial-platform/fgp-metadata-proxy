CATE_FROM_OS { "<Unused>" }    CLIENT_CERTIFICATE_FILE { "<Unused>" }    CLIENT_CERTIFICATE_PRIVATE_KEY_FILE { "<Unused>" }    CLIENT_CERTIFICATE_PASSWORD { "<Unused>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_HTTPCaller_2_Output"          }    OUTPUT { REJECTED FEATURE_TYPE "$(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_HTTPCaller_2_<REJECTED>"          }
