losecurly>.fieldName" "columns<opencurly><closecurly>.fieldName" "" "varchar<openparen>200<closeparen>" "NO_OP" }      ATTR_ACTION { "columns<opencurly><closecurly>.dataTypeName" "columns<opencurly><closecurly>.dataTypeName" "" "varchar<openparen>200<closeparen>" "NO_OP" }      ATTR_ACTION { "columns<opencurly><closecurly>._sub_uuid" "columns<opencurly><closecurly>._sub_uuid" "" "char<openparen>36<closeparen>" "NO_OP" }      ATTR_ACTION { "columns<opencurly><closecurly>.fgp_publish" "columns<opencurly><closecurly>.fgp_publish" "" "varchar<openparen>200<closeparen>" "NO_OP" }      ATTR_ACTION { "_list_index" "_list_index" "" "uint32" "NO_OP" }    OUTPUT { OUTPUT FEATURE_TYPE "$(SOCRATA_INSIDE_DB_EXTRACTOR_NG_WORKSPACE_NAME)_AttributeManager_OUTPUT"        }
