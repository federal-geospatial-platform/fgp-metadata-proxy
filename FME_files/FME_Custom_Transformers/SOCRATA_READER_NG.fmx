FME_PYTHON_VERSION 313
# ============================================================================
DEFAULT_MACRO $(SOCRATA_READER_NG_WORKSPACE_NAME)_DOMAIN 

DEFAULT_MACRO $(SOCRATA_READER_NG_WORKSPACE_NAME)_FME_DATA_REPOSITORY 

DEFAULT_MACRO $(SOCRATA_READER_NG_WORKSPACE_NAME)_FME_ENGINE 

DEFAULT_MACRO $(SOCRATA_READER_NG_WORKSPACE_NAME)_FME_JOB_ID 

DEFAULT_MACRO $(SOCRATA_READER_NG_WORKSPACE_NAME)_FME_SECURITY_ROLES 

DEFAULT_MACRO $(SOCRATA_READER_NG_WORKSPACE_NAME)_FME_SECURITY_USER 

DEFAULT_MACRO $(SOCRATA_READER_NG_WORKSPACE_NAME)_FME_SERVER_DEST_DIR 

DEFAULT_MACRO $(SOCRATA_READER_NG_WORKSPACE_NAME)_FME_SERVER_HOST 

DEFAULT_MACRO $(SOCRATA_READER_NG_WORKSPACE_NAME)_FME_SERVER_PORT 

DEFAULT_MACRO $(SOCRATA_READER_NG_WORKSPACE_NAME)_FME_SERVER_REQUEST_HEADERS 

DEFAULT_MACRO $(SOCRATA_READER_NG_WORKSPACE_NAME)_FME_SERVER_REQUEST_METHOD 

DEFAULT_MACRO $(SOCRATA_READER_NG_WORKSPACE_NAME)_FME_SERVER_REQUEST_PARAMETERS 

DEFAULT_MACRO $(SOCRATA_READER_NG_WORKSPACE_NAME)_FME_SERVER_REQUEST_URI 

DEFAULT_MACRO $(SOCRATA_READER_NG_WORKSPACE_NAME)_FME_SERVER_RUNTIME_USER 

DEFAULT_MACRO $(SOCRATA_READER_NG_WORKSPACE_NAME)_FME_SERVER_RUNTIME_USER_ID 

DEFAULT_MACRO $(SOCRATA_READER_NG_WORKSPACE_NAME)_FME_SERVER_WEB_URL 

DEFAULT_MACRO $(SOCRATA_READER_NG_WORKSPACE_NAME)_FME_SHAREDRESOURCE_BACKUP 

DEFAULT_MACRO $(SOCRATA_READER_NG_WORKSPACE_NAME)_FME_SHAREDRESOURCE_DASHBOARD 

DEFAULT_MACRO $(SOCRATA_READER_NG_WORKSPACE_NAME)_FME_SHAREDRESOURCE_DATA 

DEFAULT_MACRO $(SOCRATA_READER_NG_WORKSPACE_NAME)_FME_SHAREDRESOURCE_ENGINE 

DEFAULT_MACRO $(SOCRATA_READER_NG_WORKSPACE_NAME)_FME_SHAREDRESOURCE_LOG 

DEFAULT_MACRO $(SOCRATA_READER_NG_WORKSPACE_NAME)_FME_SHAREDRESOURCE_SYSTEM 

DEFAULT_MACRO $(SOCRATA_READER_NG_WORKSPACE_NAME)_FME_SHAREDRESOURCE_TEMP 

DEFAULT_MACRO $(SOCRATA_READER_NG_WORKSPACE_NAME)_FME_TOPIC 

DEFAULT_MACRO $(SOCRATA_READER_NG_WORKSPACE_NAME)_FME_TOPIC_MESSAGE 

# ============================================================================
#! START_HEADER
#! END_HEADER

DEFAULT_MACRO WB_CURRENT_CONTEXT
DEFAULT_MACRO SOCRATA_READER_NG_WORKSPACE_NAME ""
INCLUDE [puts {MACRO WB_OLD_CONTEXT_$(SOCRATA_READER_NG_WORKSPACE_NAME) $(WB_CURRENT_CONTEXT)};          puts {MACRO WB_CURRENT_CONTEXT $(SOCRATA_READER_NG_WORKSPACE_NAME)}]
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(SOCRATA_READER_NG_WORKSPACE_NAME)_Input1762281053 Input Splitter"   INPUT FEATURE_TYPE "$(SOCRATA_READER_NG_WORKSPACE_NAME)_Input"   OUTPUT FEATURE_TYPE "$(SOCRATA_READER_NG_WORKSPACE_NAME)_Input"
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(SOCRATA_READER_NG_WORKSPACE_NAME)_AttributeCreator }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(SOCRATA_READER_NG_WORKSPACE_NAME)_Input"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "_url_socrata" "SET_TO" "$($(SOCRATA_READER_NG_WORKSPACE_NAME)_DOMAIN$encode)" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(SOCRATA_READER_NG_WORKSPACE_NAME)_AttributeCreator_OUTPUT"        }
# -------------------------------------------------------------------------
FME_PYTHON_PATH "$(FME_MF_DIR)"
FACTORY_DEF {*} PythonFactory    FACTORY_NAME { $(SOCRATA_READER_NG_WORKSPACE_NAME)_PythonCaller }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT  FEATURE_TYPE "$(SOCRATA_READER_NG_WORKSPACE_NAME)_AttributeCreator_OUTPUT"    SYMBOL_NAME { ManageHttpCall }    SOURCE_CODE { import<space>fme<lf>import<space>fmeobjects<lf><lf>from<space>Python.SOCRATA_READER_NG<space>import<space>ManageHttpCall }    PY_OUTPUT_TAGS { PYOUTPUT <Rejected> }    OUTPUT { PYOUTPUT FEATURE_TYPE "$(SOCRATA_READER_NG_WORKSPACE_NAME)_PythonCaller_OUTPUT"         }    OUTPUT { <Rejected> FEATURE_TYPE "$(SOCRATA_READER_NG_WORKSPACE_NAME)_PythonCaller_<Rejected>"         }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(SOCRATA_READER_NG_WORKSPACE_NAME)_PythonCaller <Rejected> Transformer Output Nuker"   INPUT FEATURE_TYPE "$(SOCRATA_READER_NG_WORKSPACE_NAME)_PythonCaller_<Rejected>"
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttributeKeeperFactory    FACTORY_NAME { $(SOCRATA_READER_NG_WORKSPACE_NAME)_AttributeKeeper_2 }    INPUT  FEATURE_TYPE "$(SOCRATA_READER_NG_WORKSPACE_NAME)_PythonCaller_OUTPUT"    KEEP_ATTRS { id,_response_body,_status_code }    KEEP_LISTS {  }    KEEP_FME_ATTRIBUTES Yes    BUILD_FEATURE_TABLES { NO }    OUTPUT_ON_ATTRIBUTE_CHANGE { <Unused> }    OUTPUT { OUTPUT FEATURE_TYPE "$(SOCRATA_READER_NG_WORKSPACE_NAME)_AttributeKeeper_2_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} JSONQueryFactory    FACTORY_NAME { $(SOCRATA_READER_NG_WORKSPACE_NAME)_JSONFlattener_2 }    INPUT  FEATURE_TYPE "$(SOCRATA_READER_NG_WORKSPACE_NAME)_AttributeKeeper_2_OUTPUT"    MODE FLATTEN    JSON_DOCUMENT { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_response_body<closeparen>,$(SOCRATA_READER_NG_WORKSPACE_NAME)_JSONFlattener_2)" }    READ_FROM_FILE { NO }    FILEPATH_OR_URL { "<Unused>" }    EXPLODE_QUERY "json"    RECURSIVE_FLATTEN { YES }    ERROR_LIST_ATTR { "_json_error" }    OUTPUT { EXPLODED FEATURE_TYPE "$(SOCRATA_READER_NG_WORKSPACE_NAME)_JSONFlattener_2_OUTPUT"        }    OUTPUT { REJECTED FEATURE_TYPE "$(SOCRATA_READER_NG_WORKSPACE_NAME)_JSONFlattener_2_<REJECTED>"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(SOCRATA_READER_NG_WORKSPACE_NAME)_AttributeExposer_2 }    INPUT  FEATURE_TYPE "$(SOCRATA_READER_NG_WORKSPACE_NAME)_JSONFlattener_2_OUTPUT"    OUTPUT { FEATURE_TYPE "$(SOCRATA_READER_NG_WORKSPACE_NAME)_AttributeExposer_2_OUTPUT"          }
# -------------------------------------------------------------------------
   FACTORY_DEF {*} NullAttributeMapperFactory       FACTORY_NAME { $(SOCRATA_READER_NG_WORKSPACE_NAME)_NullAttributeMapper_2Factory }       INPUT  FEATURE_TYPE "$(SOCRATA_READER_NG_WORKSPACE_NAME)_AttributeExposer_2_OUTPUT"       ATTRCHOICE { SELECTED }       ATTRLIST { licenseId }       SOURCE_ATTR_VAL { SETNULL }       OTHER_VAL {  }       REG_EXPR {  }       NULL_TREATMENT { SETVALUE }       NEW_VAL { none }       OUTPUT { OUTPUT FEATURE_TYPE "$(SOCRATA_READER_NG_WORKSPACE_NAME)_NullAttributeMapper_2_OUTPUT" }
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(SOCRATA_READER_NG_WORKSPACE_NAME)_Terminator_6 }    INPUT  FEATURE_TYPE "$(SOCRATA_READER_NG_WORKSPACE_NAME)_JSONFlattener_2_<REJECTED>"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"Translation<space>Terminated:<space>Unable<space>to<space>flatten<space>the<space>JSON<space>document")       @SupplyAttributes(_wb_termination_xformer,"$(SOCRATA_READER_NG_WORKSPACE_NAME)_Terminator_6")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"Translation<space>Terminated:<space>Unable<space>to<space>flatten<space>the<space>JSON<space>document") }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(SOCRATA_READER_NG_WORKSPACE_NAME)_Output1762281053 Output Collector"   INPUT FEATURE_TYPE "$(SOCRATA_READER_NG_WORKSPACE_NAME)_NullAttributeMapper_2_OUTPUT"   OUTPUT FEATURE_TYPE "$(SOCRATA_READER_NG_WORKSPACE_NAME)_Output"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(SOCRATA_READER_NG_WORKSPACE_NAME))}]
