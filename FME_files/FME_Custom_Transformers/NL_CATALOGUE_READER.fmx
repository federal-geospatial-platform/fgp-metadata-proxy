# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(NL_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2_INPUT }    INPUT  FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_Junction_2_Output"    OUTPUT { FEATURE_TYPE $(NL_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2_INPUTLINE }
FACTORY_DEF {*} TestFactory FACTORY_NAME { $(NL_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2 } INPUT FEATURE_TYPE $(NL_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2_INPUTLINE FEATURE_TABLE_SHIM_SUPPORT Yes PASSED_TEST_GROUP_OUTPUT FIRST TEST_GROUP TEST { _url_error ATTRIBUTE_IS_MISSING "" ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_0 FEATURE_TYPE $(NL_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2_Valid<space>URL OUTPUT FAILED FEATURE_TYPE $(NL_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2_Invalid<space>URL
# -------------------------------------------------------------------------
FACTORY_DEF {*} XFMapFactory    FACTORY_NAME { $(NL_CATALOGUE_READER_WORKSPACE_NAME)_XMLFlattener_3 }    INPUT  FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2_Valid<space>URL"    XML_STREAM { "_html_detail"    }    XFMAP_FEATURE_PATHS_EXPRESSION { "<lt>html<gt>" }    XFMAP_FEATURE_PATHS_STRUCTURE { "<lf><lt>structure<space>separator=<quote>.<quote><space>map-empty-elements=<quote>yes<quote><space>matched-prefix=<quote>attributes<quote><space>matched-attributes=<quote>yes<quote><space>cardinality=<quote>+<opencurly>?<closecurly><quote><space>structure-prefix=<quote>_html_s_<quote><space>child-position-attribute=<quote><quote><space>except-expression=<quote><quote><space>ui-mode=<quote>basic<quote><space>matched-ancestor-attributes=<quote><quote><solidus><gt><lf>" }    IGNORE_DATASET_EXTERNAL_DTD { No }    DISABLE_EXTERNAL_ENTITY_PROCESSING { Yes }    ENTITY_RESOLVER { Yes }    OUTPUT_ONE_FEATURE_PER_INPUT yes    OUTPUT { MAPPED FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_XMLFlattener_3_OUTPUT"       }    OUTPUT { INVALID FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_XMLFlattener_3_<REJECTED>"        }
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(NL_CATALOGUE_READER_WORKSPACE_NAME)_Terminator_2 }    INPUT  FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_XMLFlattener_3_<REJECTED>"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"Translation<space>Terminated.<space>Unable<space>to<space>flatten<space>the<space>XHTML<space>file.")       @SupplyAttributes(_wb_termination_xformer,"$(NL_CATALOGUE_READER_WORKSPACE_NAME)_Terminator_2")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"Translation<space>Terminated.<space>Unable<space>to<space>flatten<space>the<space>XHTML<space>file.") }
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(NL_CATALOGUE_READER_WORKSPACE_NAME)_Terminator_3 }    INPUT  FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_XMLFlattener_4_<REJECTED>"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"Translation<space>Terminated.<space>Unable<space>to<space>flatten<space>the<space>non<space>geospatial<space>XHTML<space>file.")       @SupplyAttributes(_wb_termination_xformer,"$(NL_CATALOGUE_READER_WORKSPACE_NAME)_Terminator_3")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"Translation<space>Terminated.<space>Unable<space>to<space>flatten<space>the<space>non<space>geospatial<space>XHTML<space>file.") }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(NL_CATALOGUE_READER_WORKSPACE_NAME)_Junction }    INPUT  FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_Invalid<space>URL"    INPUT  FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2_Invalid<space>URL"    OUTPUT { FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_Junction_Output"         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttributeKeeperFactory    FACTORY_NAME { $(NL_CATALOGUE_READER_WORKSPACE_NAME)_AttributeKeeper }    INPUT  FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_Junction_Output"    KEEP_ATTRS { _url_dataset_geo,_url_root }    KEEP_LISTS {  }    KEEP_FME_ATTRIBUTES Yes    BUILD_FEATURE_TABLES { NO }    OUTPUT_ON_ATTRIBUTE_CHANGE { <Unused> }    OUTPUT { OUTPUT FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_AttributeKeeper_OUTPUT"        }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_OUTPUT1762279323 Output Collector"   INPUT FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_XMLFlattener_3_OUTPUT"   OUTPUT FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_OUTPUT"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_BROKEN_URL1762279323 Output Collector"   INPUT FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_AttributeKeeper_OUTPUT"   OUTPUT FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_BROKEN_URL"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(NL_CATALOGUE_READER_WORKSPACE_NAME))}]
