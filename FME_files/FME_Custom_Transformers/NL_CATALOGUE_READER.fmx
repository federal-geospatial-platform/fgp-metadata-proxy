INCLUDE [puts {MACRO WB_OLD_CONTEXT_$(NL_CATALOGUE_READER_WORKSPACE_NAME) $(WB_CURRENT_CONTEXT)};          puts {MACRO WB_CURRENT_CONTEXT $(NL_CATALOGUE_READER_WORKSPACE_NAME)}]
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_INPUT1762279323 Input Splitter"   INPUT FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_INPUT"   OUTPUT FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_INPUT"
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(NL_CATALOGUE_READER_WORKSPACE_NAME)_AttributeCreator_2 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_INPUT"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "_url_dataset_geo" "SET_TO" "$($(NL_CATALOGUE_READER_WORKSPACE_NAME)_URL_DATASET_GEO$encode)" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "_url_dataset_non_geo" "SET_TO" "$($(NL_CATALOGUE_READER_WORKSPACE_NAME)_URL_DATASET_NON_GEO$encode)" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "_url_root" "SET_TO" "$($(NL_CATALOGUE_READER_WORKSPACE_NAME)_URL_ROOT$encode)" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_AttributeCreator_2_OUTPUT"        }
# -------------------------------------------------------------------------
FME_PYTHON_PATH "$(FME_MF_DIR)"
FACTORY_DEF {*} PythonFactory    FACTORY_NAME { $(NL_CATALOGUE_READER_WORKSPACE_NAME)_PythonCaller }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT  FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_AttributeCreator_2_OUTPUT"    SYMBOL_NAME { catalogue_reader_primary }    SOURCE_CODE { import<space>fme<lf>import<space>fmeobjects<lf>from<space>Python.NL_CATALOGUE_READER<space>import<space>catalogue_reader_primary<lf><space><space><space><space> }    PY_OUTPUT_TAGS { PYOUTPUT <Rejected> }    OUTPUT { PYOUTPUT FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_PythonCaller_OUTPUT"         }    OUTPUT { <Rejected> FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_PythonCaller_<Rejected>"         }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_PythonCaller <Rejected> Transformer Output Nuker"   INPUT FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_PythonCaller_<Rejected>"
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(NL_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_INPUT }    INPUT  FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_PythonCaller_OUTPUT"    OUTPUT { FEATURE_TYPE $(NL_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_INPUTLINE }
FACTORY_DEF {*} TestFactory FACTORY_NAME { $(NL_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter } INPUT FEATURE_TYPE $(NL_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_INPUTLINE FEATURE_TABLE_SHIM_SUPPORT Yes PASSED_TEST_GROUP_OUTPUT FIRST TEST_GROUP TEST { _url_error ATTRIBUTE_IS_MISSING "" ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_0 FEATURE_TYPE $(NL_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_Valid<space>URL OUTPUT FAILED FEATURE_TYPE $(NL_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_Invalid<space>URL
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter Valid<space>URL Splitter"   INPUT FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_Valid<space>URL"   OUTPUT FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_Valid<space>URL_0_rT0yG7l/Fwo="   OUTPUT FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_Valid<space>URL_1_3b7wQclhG6s="
# -------------------------------------------------------------------------
FACTORY_DEF {*} XFMapFactory    FACTORY_NAME { $(NL_CATALOGUE_READER_WORKSPACE_NAME)_XMLFlattener_2 }    INPUT  FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_Valid<space>URL_0_rT0yG7l/Fwo="    XML_STREAM { "_html_geo_full"    }    XFMAP_FEATURE_PATHS_EXPRESSION { "<lt>div<space>id=<quote>Master_ContentPlaceHolder1_DataSets<quote><gt>" }    XFMAP_FEATURE_PATHS_STRUCTURE { "<lf><lt>structure<space>separator=<quote>.<quote><space>map-empty-elements=<quote>yes<quote><space>matched-prefix=<quote>attributes<quote><space>matched-attributes=<quote>yes<quote><space>cardinality=<quote>+<opencurly>?<closecurly><quote><space>structure-prefix=<quote>_html_p_<quote><space>child-position-attribute=<quote><quote><space>except-expression=<quote><quote><space>ui-mode=<quote>basic<quote><space>matched-ancestor-attributes=<quote><quote><solidus><gt><lf>" }    IGNORE_DATASET_EXTERNAL_DTD { No }    DISABLE_EXTERNAL_ENTITY_PROCESSING { Yes }    ENTITY_RESOLVER { Yes }    OUTPUT_ONE_FEATURE_PER_INPUT yes    OUTPUT { MAPPED FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_XMLFlattener_2_OUTPUT"       }    OUTPUT { INVALID FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_XMLFlattener_2_<REJECTED>"        }
# -------------------------------------------------------------------------
FME_PYTHON_PATH "$(FME_MF_DIR)"
FACTORY_DEF {*} PythonFactory    FACTORY_NAME { $(NL_CATALOGUE_READER_WORKSPACE_NAME)_PythonCaller_3 }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT  FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_XMLFlattener_2_OUTPUT"    SYMBOL_NAME { CatalogueReaderSecondary }    SOURCE_CODE { import<space>fme<lf>import<space>fmeobjects<lf>from<space>Python.NL_CATALOGUE_READER<space>import<space>CatalogueReaderSecondary }    PY_OUTPUT_TAGS { PYOUTPUT <Rejected> }    OUTPUT { PYOUTPUT FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_PythonCaller_3_OUTPUT"         }    OUTPUT { <Rejected> FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_PythonCaller_3_<Rejected>"         }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_PythonCaller_3 <Rejected> Transformer Output Nuker"   INPUT FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_PythonCaller_3_<Rejected>"
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(NL_CATALOGUE_READER_WORKSPACE_NAME)_Terminator }    INPUT  FEATURE_TYPE "$(NL_CATALOGUE_READER_WORKSPACE_NAME)_XMLFlattener_2_<REJECTED>"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"Translation<space>Terminated.<space>Unable<space>to<space>flatten<space>the<space>XHTML<space>file.")       @SupplyAttributes(_wb_termination_xformer,"$(NL_CATALOGUE_READER_WORKSPACE_NAME)_Terminator")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"Translation<space>Terminated.<space>Unable<space>to<space>flatten<space>the<space>XHTML<space>file.") }
