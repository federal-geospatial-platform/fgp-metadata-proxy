# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(PEI_TopicExtractor_WORKSPACE_NAME)_AttributeCreator_2 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_AttributeExposer_2_OUTPUT"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "_ordre" "SET_TO" "1" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "_type" "SET_TO" "lut" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_AttributeCreator_2_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(PEI_TopicExtractor_WORKSPACE_NAME)_AttributeExposer }    INPUT  FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_Input"    OUTPUT { FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_AttributeExposer_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(PEI_TopicExtractor_WORKSPACE_NAME)_AttributeCreator }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_AttributeExposer_OUTPUT"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "_ordre" "SET_TO" "2" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "_type" "SET_TO" "data" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_AttributeCreator_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} SortFactory    FACTORY_NAME { $(PEI_TopicExtractor_WORKSPACE_NAME)_Sorter }    INPUT  FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_AttributeCreator_OUTPUT"    INPUT  FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_AttributeCreator_2_OUTPUT"    SORT_ALPHA_AS_UTF8 { YES }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    SORT_BY { _ordre NUMERIC ASCENDING }    OUTPUT { SORTED FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_Sorter_SORTED"          }
# -------------------------------------------------------------------------
FME_PYTHON_PATH "$(FME_MF_DIR)"
FACTORY_DEF {*} PythonFactory    FACTORY_NAME { $(PEI_TopicExtractor_WORKSPACE_NAME)_PythonCaller }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT  FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_Sorter_SORTED"    SYMBOL_NAME { FeatureProcessor }    SOURCE_CODE { import<space>fme<lf>import<space>fmeobjects<lf>from<space>Python.FME_utils<space>import<space>FME_utils<lf>#<space>Template<space>Function<space>interface:<lf>#<space>When<space>using<space>this<space>function<comma><space>make<space>sure<space>its<space>name<space>is<space>set<space>as<space>the<space>value<space>of<lf>#<space>the<space><apos>Class<space>or<space>Function<space>to<space>Process<space>Features<apos><space>transformer<space>parameter<lf>def<space>processFeature<openparen>feature<closeparen>:<lf><space><space><space><space>pass<lf><lf>#<space>Template<space>Class<space>Interface:<lf>#<space>When<space>using<space>this<space>class<comma><space>make<space>sure<space>its<space>name<space>is<space>set<space>as<space>the<space>value<space>of<lf>#<space>the<space><apos>Class<space>or<space>Function<space>to<space>Process<space>Features<apos><space>transformer<space>parameter<lf>class<space>FeatureProcessor<openparen>object<closeparen>:<lf><space><space><space><space>def<space>__init__<openparen>self<closeparen>:<lf><space><space><space><space><space><space><space><space>self.list_topic=<openbracket><closebracket><lf><space><space><space><space><space><space><space><space><lf><space><space><space><space>def<space>input<openparen>self<comma>feature<closeparen>:<lf><space><space><space><space><space><space><space><space>if<space>feature.getAttribute<openparen><apos>_type<apos><closeparen>==<apos>lut<apos>:<lf><space><space><space><space><space><space><space><space><space><space><space><space><space>self.list_topic.append<openparen>feature.getAttribute<openparen><apos>topic_keyword<apos><closeparen>.lower<openparen><closeparen><closeparen><lf><space><space><space><space><space><space><space><space>else:<lf><space><space><space><space><space><space><space><space><space><space><space><space>iso_topic=<openbracket><closebracket><lf><space><space><space><space><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space><space><space><space><space>max_index=FME_utils.max_index_attribute_list<openparen>feature<comma><apos>tags<opencurly><closecurly><apos><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space><space><space><space><space>i=0<lf><space><space><space><space><space><space><space><space><space><space><space><space>for<space>j<space>in<space>range<openparen>max_index+1<closeparen>:<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>temp=feature.getAttribute<openparen><apos>tags<opencurly>%i<closecurly>.value<apos>%<openparen>j<closeparen><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>if<space>temp.lower<openparen><closeparen><space>in<space>self.list_topic:<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>iso_topic<opencurly>%i<closecurly>.topic_value<apos>%<openparen>i<closeparen><comma>temp<closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>i=i+1<lf><space><space><space><space><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space><space><space><space><space>self.pyoutput<openparen>feature<closeparen><lf><space><space><space><space>def<space>close<openparen>self<closeparen>:<lf><space><space><space><space><space><space><space><space>pass }    PY_OUTPUT_TAGS { PYOUTPUT <Rejected> }    OUTPUT { PYOUTPUT FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_PythonCaller_OUTPUT"         }    OUTPUT { <Rejected> FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_PythonCaller_<Rejected>"         }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(PEI_TopicExtractor_WORKSPACE_NAME)_PythonCaller <Rejected> Transformer Output Nuker"   INPUT FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_PythonCaller_<Rejected>"
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(PEI_TopicExtractor_WORKSPACE_NAME)_ListElementCounter }    INPUT  FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_PythonCaller_OUTPUT"    OUTPUT { FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_ListElementCounter_OUTPUT"         @SupplyAttributes(ENCODED, _element_count, @NumElements("iso_topic<opencurly><closecurly>",ENCODED))          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(PEI_TopicExtractor_WORKSPACE_NAME)_Tester }    INPUT  FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_ListElementCounter_OUTPUT"    TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_element_count<closeparen>,$(PEI_TopicExtractor_WORKSPACE_NAME)_Tester)" != 0 ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_Tester_PASSED"         }    OUTPUT { FAILED FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_Tester_FAILED"         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(PEI_TopicExtractor_WORKSPACE_NAME)_AttributeExposer_3 }    INPUT  FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_Tester_FAILED"    OUTPUT { FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_AttributeExposer_3_OUTPUT"          }
# -------------------------------------------------------------------------
INCLUDE [if { {ATTRIBUTES} == {ATTRIBUTES} } {                puts "MACRO $(PEI_TopicExtractor_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO ATTRIBUTES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {POLYGONS}} {                puts "MACRO $(PEI_TopicExtractor_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {AGGREGATES}} {                puts "MACRO $(PEI_TopicExtractor_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO $(PEI_TopicExtractor_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {POLYGONS}} {                puts "MACRO $(PEI_TopicExtractor_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {AGGREGATES}} {                puts "MACRO $(PEI_TopicExtractor_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO $(PEI_TopicExtractor_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} } {                puts "MACRO $(PEI_TopicExtractor_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} } {                puts "MACRO $(PEI_TopicExtractor_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          else {}; ]
FACTORY_DEF {*} ReferenceFactory    FACTORY_NAME { $(PEI_TopicExtractor_WORKSPACE_NAME)_FeatureMerger }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT REFERENCER FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_AttributeExposer_3_OUTPUT"    INPUT REFERENCEE FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_AttributeExposer_4_OUTPUT"    REFERENCE_INFO { $($(PEI_TopicExtractor_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO) }    REFERENCE_TABLE { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>id<closeparen>,$(PEI_TopicExtractor_WORKSPACE_NAME)_FeatureMerger) @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>id<closeparen>,$(PEI_TopicExtractor_WORKSPACE_NAME)_FeatureMerger) AUTO }    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "REQUESTOR_IF_CONFLICT" }    IGNORE_NULLS { "No" }    HANDLE_NULL_MISSING_KEYS_LIKE_FME2013 { No }    LIST_ATTRS_TO_INCLUDE { <Unused> }    LIST_ATTRS_TO_INCLUDE_MODE { <Unused> }    MERGE_ATTRIBUTES Yes    MANAGE_FME_TYPE Yes    MODE COMPLETE    PROCESS_DUPLICATE_REFERENCEES { NO }    REFERENCEES_FIRST { No }    REJECT_INVALID_GEOM YES    CLEANING_TOLERANCE { <Unused> }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    COMPARE_WHITESPACE Yes    OUTPUT { COMPLETE FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_FeatureMerger_MERGED"         }    OUTPUT { INCOMPLETE FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_FeatureMerger_UNMERGED_REQUESTOR"         }    OUTPUT { REJECTED FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_FeatureMerger_<REJECTED>"         }
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(PEI_TopicExtractor_WORKSPACE_NAME)_Terminator }    INPUT  FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_FeatureMerger_<REJECTED>"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"Translation<space>Terminated")       @SupplyAttributes(_wb_termination_xformer,"$(PEI_TopicExtractor_WORKSPACE_NAME)_Terminator")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"Translation<space>Terminated") }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(PEI_TopicExtractor_WORKSPACE_NAME)_Output1762279807 Output Collector"   INPUT FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_Tester_PASSED"   INPUT FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_FeatureMerger_MERGED"   OUTPUT FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_Output"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(PEI_TopicExtractor_WORKSPACE_NAME)_Unknown_topic1762279807 Output Collector"   INPUT FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_FeatureMerger_UNMERGED_REQUESTOR"   OUTPUT FEATURE_TYPE "$(PEI_TopicExtractor_WORKSPACE_NAME)_Unknown_topic"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(PEI_TopicExtractor_WORKSPACE_NAME))}]
