FACTORY_DEF * TeeFactory   FACTORY_NAME "$(Spatial_extent_validator_WORKSPACE_NAME)_EXTENT_TO_VALIDATE1762281069 Output Collector"   INPUT FEATURE_TYPE "$(Spatial_extent_validator_WORKSPACE_NAME)_FeatureMerger_UNMERGED_REQUESTOR"   OUTPUT FEATURE_TYPE "$(Spatial_extent_validator_WORKSPACE_NAME)_EXTENT_TO_VALIDATE" @RemoveAttributes(default_north_latitude,default_south_latitude,default_east_longitude,default_west_longitude,north_latitude,south_latitude,east_longitude,west_longitude,north_latitude_name_att,south_latitude_name_att,east_longitude_name_att,west_longitude_name_att)
