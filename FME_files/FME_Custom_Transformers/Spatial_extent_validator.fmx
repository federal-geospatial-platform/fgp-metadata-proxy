# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(Spatial_extent_validator_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(Spatial_extent_validator_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(Spatial_extent_validator_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(Spatial_extent_validator_WORKSPACE_NAME)_Junction_Output"    OUTPUT { FEATURE_TYPE "$(Spatial_extent_validator_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,coor_valid,default_east_longitude,default_north_latitude,default_south_latitude,default_west_longitude,east_bound_longitude_valid,east_longitude,north_bound_latitude_valid,north_latitude,south_bound_latitude_valid,south_latitude,west_bound_longitude_valid,west_longitude,east_longitude_name_att,north_latitude_name_att,south_latitude_name_att,west_longitude_name_att,east_bound_longitude_to_validate,north_bound_latitude_to_validate,south_bound_latitude_to_validate,west_bound_longitude_to_validate)        $($(Spatial_extent_validator_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
