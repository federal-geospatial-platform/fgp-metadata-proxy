# most of this is close to the code from listindexer but not exact beucase
# we have a type LIST_ATTR rather than type LIST_NAME so need
# to figure out the list name
Tcl2 proc $(FME_UUID_SAFE)_indexer {index prefix} {    set fullListAttrName [FME_DecodeText _list<opencurly><closecurly>.list_name];    set lastBrace [string last  \"{}\" $fullListAttrName];    set listAttr [string range $fullListAttrName 0 [expr $lastBrace+1]];    regsub \"{}\" $listAttr \"{$index}\" listWithIndex;    regsub \"{}\" $listAttr {} listBase;    set complexListExp "$listWithIndex\.";    set prefixLength [expr [string length $complexListExp]-1];    set prefix [FME_DecodeText $prefix];    foreach attr [FME_AttributeNames] {      set newAttr {};      if {$attr == $listWithIndex} {        set newAttr $listBase;      } elseif {[string first $complexListExp $attr] == 0} {        set newAttr [string replace $attr 0 $prefixLength];      };      if {$newAttr != {}} {          if {$prefix != {} } {            set newAttr $prefix$newAttr;          };          if {[string first {fme_} $newAttr] != 0} {              set first [string first {fme_} $newAttr];              lappend attrsToCopy $newAttr $attr;          };      };    };    if {[info exists attrsToCopy] && [llength $attrsToCopy] > 0} {      eval FME_Execute CopyAttributes $attrsToCopy;    }; }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_ListSearcher }    INPUT  FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_ListElementCounter_2_OUTPUT"    OUTPUT { FEATURE_TYPE $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_ListSearcher__IndexedFeatures___         "$(FME_UUID_SAFE)" @SearchList(fme_encoded,"_list<opencurly><closecurly>.list_name","",FIRST_NOT_MATCHED_ENCODED,CASE_SENSITIVE) }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_ListSearcher__Tester }    INPUT { FEATURE_TYPE $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_ListSearcher__IndexedFeatures___ }    TEST { @Value($(FME_UUID_SAFE)) == "-1" }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    OUTPUT { PASSED FEATURE_TYPE  "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_ListSearcher_NOT_FOUND" @RemoveAttributes($(FME_UUID_SAFE)) }    OUTPUT { FAILED FEATURE_TYPE  $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_ListSearcher__IndexFound__  }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_ListSearcher__Tester2 }    INPUT { FEATURE_TYPE $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_ListSearcher__IndexFound__ }    TEST { YES == "NO" }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    OUTPUT { PASSED FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_ListSearcher_FOUND" @CopyAttributes(_list_index, $(FME_UUID_SAFE)) @RemoveAttributes($(FME_UUID_SAFE)) }    OUTPUT { FAILED FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_ListSearcher_FOUND"  @Tcl2("$(FME_UUID_SAFE)_indexer {@Value($(FME_UUID_SAFE))} {extracted_}") @CopyAttributes(_list_index, $(FME_UUID_SAFE)) @RemoveAttributes($(FME_UUID_SAFE)) }
