FME_PYTHON_PATH "$(FME_MF_DIR)"
FACTORY_DEF {*} PythonFactory    FACTORY_NAME { $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_PythonCaller_4 }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT  FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_AttributeExposer_5_OUTPUT"    SYMBOL_NAME { processFeature }    SOURCE_CODE { import<space>fme<lf>import<space>fmeobjects<lf>#<space>Template<space>Function<space>interface:<lf>#<space>When<space>using<space>this<space>function<comma><space>make<space>sure<space>its<space>name<space>is<space>set<space>as<space>the<space>value<space>of<lf>#<space>the<space><apos>Class<space>or<space>Function<space>to<space>Process<space>Features<apos><space>transformer<space>parameter<lf>def<space>processFeature<openparen>feature<closeparen>:<lf><space><space><space><space>json_file=feature.getAttribute<openparen><apos>json_file<apos><closeparen><lf><space><space><space><space><lf><space><space><space><space><lf><space><space><space><space>email=<apos><apos><lf><space><space><space><space>contact_form_en=<apos><apos><lf><space><space><space><space>contact_form_fr=<apos><apos><lf><space><space><space><space>metadata_contact_fr=feature.getAttribute<openparen><apos>metadata_contact_fr<apos><closeparen><lf><space><space><space><space>metadata_contact_en=feature.getAttribute<openparen><apos>metadata_contact_en<apos><closeparen><lf><space><space><space><space><lf><space><space><space><space>if<space>feature.getAttribute<openparen><apos>email<apos><closeparen>:<lf><space><space><space><space><space><space><space><space>email=r<apos><comma><backslash><quote>electronic_mail_address<backslash><quote>:<space><backslash><quote>%s<backslash><quote><apos>%<openparen>feature.getAttribute<openparen><apos>email<apos><closeparen><closeparen><lf><space><space><space><space><space><space><space><space><lf><space><space><space><space>if<space>feature.getAttribute<openparen><apos>contact_form_en<apos><closeparen>:<lf><space><space><space><space><space><space><space><space>contact_form_en=r<apos><comma><backslash><quote>contact_form<backslash><quote>:<space><backslash><quote>%s<backslash><quote><apos>%<openparen>feature.getAttribute<openparen><apos>contact_form_en<apos><closeparen><closeparen><lf><space><space><space><space>if<space><space>feature.getAttribute<openparen><apos>contact_form_fr<apos><closeparen>:<lf><space><space><space><space><space><space><space><space>contact_form_fr=r<apos><comma><backslash><quote>contact_form<backslash><quote>:<space><backslash><quote>%s<backslash><quote><apos>%<openparen>feature.getAttribute<openparen><apos>contact_form_fr<apos><closeparen><closeparen><lf><space><space><space><space><space><space><space><space><lf><space><space><space><space>remplacement=r<apos><quote><opencurly><backslash><quote>fr<backslash><quote>:<space><opencurly><backslash><quote>organization_name<backslash><quote>:<space><backslash><quote>%s<backslash><quote>%s%s<closecurly><comma><backslash><quote>en<backslash><quote>:<space><opencurly><backslash><quote>organization_name<backslash><quote>:<space><backslash><quote>%s<backslash><quote>%s%s<closecurly><closecurly><quote><apos>%<openparen>metadata_contact_fr<comma>email<comma>contact_form_fr<comma>metadata_contact_en<comma>email<comma>contact_form_en<closeparen><lf><space><space><space><space><lf><space><space><space><space>json_new=json_file.replace<openparen>r<apos><quote>FME_CONTACT_INFORMATION_VALUES<quote><apos><comma>remplacement<closeparen><lf><space><space><space><space>feature.setAttribute<openparen><apos>json_file<apos><comma>json_new<closeparen><lf><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><lf><space><space><space><space><space><space><space><space><lf> }    PY_OUTPUT_TAGS { PYOUTPUT <Rejected> }    OUTPUT { PYOUTPUT FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_PythonCaller_4_OUTPUT"         }    OUTPUT { <Rejected> FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_PythonCaller_4_<Rejected>"         }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_PythonCaller_4 <Rejected> Transformer Output Nuker"   INPUT FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_PythonCaller_4_<Rejected>"
# -------------------------------------------------------------------------
FACTORY_DEF {*} StringReplacerFactory    FACTORY_NAME { $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_StringReplacer_3 }    INPUT  FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_PythonCaller_4_OUTPUT"    USE_REGEX { NO }    CASE_SENSITIVE { NO }    SOURCE_ATTRIBUTES { json_file }    FIND_TEXT { "<quote>FME_KEYWORDS_FR<quote>" }    REPLACE_TEXT { "@EvaluateExpression(FDIV,STRING_ENCODED,<openbracket><quote><at>Value<openparen>keywords_fr<closeparen><quote><closebracket>,$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_StringReplacer_3)" }    REPLACE_NO_MATCH { "_FME_NO_OP_" }    OUTPUT { OUTPUT FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_StringReplacer_3_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} StringReplacerFactory    FACTORY_NAME { $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_StringReplacer_4 }    INPUT  FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_StringReplacer_3_OUTPUT"    USE_REGEX { NO }    CASE_SENSITIVE { NO }    SOURCE_ATTRIBUTES { json_file }    FIND_TEXT { "<quote>FME_KEYWORDS_EN<quote>" }    REPLACE_TEXT { "@EvaluateExpression(FDIV,STRING_ENCODED,<openbracket><quote><at>Value<openparen>keywords_en<closeparen><quote><closebracket>,$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_StringReplacer_4)" }    REPLACE_NO_MATCH { "_FME_NO_OP_" }    OUTPUT { OUTPUT FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_StringReplacer_4_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} StringReplacerFactory    FACTORY_NAME { $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_StringReplacer_6 }    INPUT  FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_StringReplacer_4_OUTPUT"    USE_REGEX { NO }    CASE_SENSITIVE { NO }    SOURCE_ATTRIBUTES { json_file }    FIND_TEXT { "<quote>FME_SUBJECT_VALUES<quote>" }    REPLACE_TEXT { "@EvaluateExpression(FDIV,STRING_ENCODED,<openbracket><quote><at>Value<openparen>TBS_subject<closeparen><quote><closebracket>,$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_StringReplacer_6)" }    REPLACE_NO_MATCH { "_FME_NO_OP_" }    OUTPUT { OUTPUT FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_StringReplacer_6_OUTPUT"          }
