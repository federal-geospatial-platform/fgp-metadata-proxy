ren><comma>i<openbracket><apos>FEATURE_ATTRIBUTES<apos><closebracket>.split<openparen><apos><opencurly><closecurly>.<apos><closeparen><openbracket>1<closebracket><closeparen><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>else:<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>new_values=feature.getAttribute<openparen>i<openbracket><apos>FEATURE_ATTRIBUTES<apos><closebracket><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>new_feature.setAttribute<openparen>new_att<comma>new_values<closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>self.pyoutput<openparen>new_feature<closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>else:<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>#No<space>list<space>related<space>to<space>metasection<comma><space>just<space>need<space>to<space>parse<space>regular<space>attributes<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>new_feature=fmeobjects.FMEFeature<openparen><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>new_feature.setAttribute<openparen><apos>SECTION<apos><comma>keys<closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>for<space>i<space>in<space>self.config<openbracket>keys<closebracket>:<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>new_att=i<openbracket><apos>TBS_ATTRIBUTES<apos><closebracket><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>new_values=feature.getAttribute<openparen>i<openbracket><apos>FEATURE_ATTRIBUTES<apos><closebracket><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>new_feature.setAttribute<openparen>new_att<comma>new_values<closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>self.pyoutput<openparen>new_feature<closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><lf><space><space><space><space>def<space>close<openparen>self<closeparen>:<lf><space><space><space><space><space><space><space><space>pass }    PY_OUTPUT_TAGS { PYOUTPUT <Rejected> }    OUTPUT { PYOUTPUT FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_PythonCaller_2_OUTPUT"         }    OUTPUT { <Rejected> FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_PythonCaller_2_<Rejected>"         }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_PythonCaller_2 <Rejected> Transformer Output Nuker"   INPUT FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_PythonCaller_2_<Rejected>"
