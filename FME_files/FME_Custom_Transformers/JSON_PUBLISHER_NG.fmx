FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_AttributeFilter }    INPUT  FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_PythonCaller_2_OUTPUT"    OUTPUT { FEATURE_TYPE $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_AttributeFilter_FILTER }
FACTORY_DEF {*} AttributeFilterFactory FACTORY_NAME $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_AttributeFilter_Filter COMMAND_PARM_EVALUATION SINGLE_PASS INPUT FEATURE_TYPE $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_AttributeFilter_FILTER FILTER_ATTRIBUTE { SECTION } FILTER_VALUES { <lt>EMPTY<gt> <lt>MISSING<gt> <lt>NULL<gt> <lt>UNFILTERED<gt> ROOT RESOURCES } PRESERVE_FEATURE_ORDER PER_OUTPUT_PORT OUTPUT <lt>EMPTY<gt> FEATURE_TYPE $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_AttributeFilter_<lt>EMPTY<gt> OUTPUT <lt>MISSING<gt> FEATURE_TYPE $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_AttributeFilter_<lt>MISSING<gt> OUTPUT <lt>NULL<gt> FEATURE_TYPE $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_AttributeFilter_<lt>NULL<gt> OUTPUT <lt>UNFILTERED<gt> FEATURE_TYPE $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_AttributeFilter_<lt>UNFILTERED<gt> OUTPUT ROOT FEATURE_TYPE $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_AttributeFilter_ROOT OUTPUT RESOURCES FEATURE_TYPE $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_AttributeFilter_RESOURCES
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_Terminator_4 }    INPUT  FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_AttributeFilter_<lt>EMPTY<gt>"    INPUT  FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_AttributeFilter_<lt>MISSING<gt>"    INPUT  FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_AttributeFilter_<lt>NULL<gt>"    INPUT  FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_AttributeFilter_<lt>UNFILTERED<gt>"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"ERROR:<space>Unknown<space>SECTION<space>in<space>JSON<space>config<space>file")       @SupplyAttributes(_wb_termination_xformer,"$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_Terminator_4")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"ERROR:<space>Unknown<space>SECTION<space>in<space>JSON<space>config<space>file") }
# -------------------------------------------------------------------------
FACTORY_DEF {*} XMLTemplaterFactory FACTORY_NAME { $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_JSONTemplater } INPUT CONTROL_FEATURE FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_AttributeFilter_ROOT" INPUT DATA_FEATURE FEATURE_TYPE $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_JSONTemplater_DataFeatures RESULT_ATTR { "json_file" } OUTPUT_XML_HEADER NO GROUP_BY { id } CONSECUTIVE_GROUPS NO BUCKET_ATTR_NAME __xml_templater_bucket__ CONTROL_TEMPLATE_FILE "@EvaluateExpression(FDIV,STRING,$($(JSON_PUBLISHER_NG_WORKSPACE_NAME)_JSON_ROOT_TEMPLATE$encode),$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_JSONTemplater)" OUTPUT XML_DOCUMENT FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_JSONTemplater_OUTPUT"
# -------------------------------------------------------------------------
FACTORY_DEF {*} XMLTemplaterFactory FACTORY_NAME { $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_JSONTemplater_2 } INPUT CONTROL_FEATURE FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_AttributeFilter_RESOURCES" INPUT DATA_FEATURE FEATURE_TYPE $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_JSONTemplater_2_DataFeatures RESULT_ATTR { "json_file_resource" } OUTPUT_XML_HEADER NO GROUP_BY { id } CONSECUTIVE_GROUPS NO BUCKET_ATTR_NAME __xml_templater_bucket__ CONTROL_TEMPLATE_FILE "@EvaluateExpression(FDIV,STRING,$($(JSON_PUBLISHER_NG_WORKSPACE_NAME)_JSON_RESOURCE_TEMPLATE$encode),$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_JSONTemplater_2)" OUTPUT XML_DOCUMENT FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_JSONTemplater_2_OUTPUT"
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_AttributeExposer_2 }    INPUT  FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_JSONTemplater_2_OUTPUT"    OUTPUT { FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_AttributeExposer_2_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} StringReplacerFactory    FACTORY_NAME { $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_StringReplacer_5 }    INPUT  FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_AttributeExposer_2_OUTPUT"    USE_REGEX { NO }    CASE_SENSITIVE { NO }    SOURCE_ATTRIBUTES { json_file_resource }    FIND_TEXT { "<quote>resource_language<quote>" }    REPLACE_TEXT { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>resource_language<closeparen>,$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_StringReplacer_5)" }    REPLACE_NO_MATCH { "_FME_NO_OP_" }    OUTPUT { OUTPUT FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_StringReplacer_5_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_ListBuilder_fme_type_remover }    INPUT  FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_StringReplacer_5_OUTPUT"    OUTPUT { FEATURE_TYPE $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_ListBuilder_no_fme_type       @RemoveAttributes(fme_type,fme_geometry) }
FACTORY_DEF {*} ListFactory    FACTORY_NAME { $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_ListBuilder }    INPUT { FEATURE_TYPE $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_ListBuilder_no_fme_type }    LIST_NAME { "_list" }    LIST_ATTRS_TO_INCLUDE { json_file_resource }    LIST_ATTRS_TO_INCLUDE_MODE { SELECTED }    GROUP_BY { id }    FLUSH_WHEN_GROUPS_CHANGE { No }    OUTPUT { LIST FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_ListBuilder_OUTPUT"          }
# -------------------------------------------------------------------------
INCLUDE [if { {ATTRIBUTES} == {ATTRIBUTES} } {                puts "MACRO $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO ATTRIBUTES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {POLYGONS}} {                puts "MACRO $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO GEOM_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {AGGREGATES}} {                puts "MACRO $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO GEOM_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {POLYGONS}} {                puts "MACRO $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO GEOM_AND_ATTR_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {AGGREGATES}} {                puts "MACRO $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO GEOM_AND_ATTR_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} } {                puts "MACRO $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} } {                puts "MACRO $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          else {}; ]
FACTORY_DEF {*} ReferenceFactory    FACTORY_NAME { $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_FeatureMerger_2 }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT REFERENCER FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_JSONTemplater_OUTPUT"    INPUT REFERENCEE FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_ListBuilder_OUTPUT"    REFERENCE_INFO { $($(JSON_PUBLISHER_NG_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO) }    REFERENCE_TABLE { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>id<closeparen>,$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_FeatureMerger_2) @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>id<closeparen>,$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_FeatureMerger_2) AUTO }    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "REQUESTOR_IF_CONFLICT" }    IGNORE_NULLS { "No" }    HANDLE_NULL_MISSING_KEYS_LIKE_FME2013 { No }    LIST_ATTRS_TO_INCLUDE { <Unused> }    LIST_ATTRS_TO_INCLUDE_MODE { <Unused> }    MERGE_ATTRIBUTES Yes    MANAGE_FME_TYPE Yes    MODE COMPLETE    PROCESS_DUPLICATE_REFERENCEES { NO }    REFERENCEES_FIRST { No }    REJECT_INVALID_GEOM YES    CLEANING_TOLERANCE { <Unused> }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    COMPARE_WHITESPACE Yes    OUTPUT { COMPLETE FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_FeatureMerger_2_MERGED"         }    OUTPUT { INCOMPLETE FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_FeatureMerger_2_UNMERGED_REQUESTOR"         }    OUTPUT { UNREFERENCED FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_FeatureMerger_2_UNUSED_SUPPLIER"         }    OUTPUT { REJECTED FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_FeatureMerger_2_<REJECTED>"         }
# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_ListConcatenator_5_3b9f6613_d814_4ac3_88a1_3312494024490} ]
Tcl2 set $(FME_UUID_SAFE)__separator [FME_DecodeText {<comma>}];      regsub -all \"{}\" [FME_DecodeText {_list<opencurly><closecurly>.json_file_resource}] [FME_DecodeText {<opencurly><backslash>d+<closecurly>}] $(FME_UUID_SAFE)__listPattern;      set $(FME_UUID_SAFE)__listPattern ^$$(FME_UUID_SAFE)__listPattern$;
Tcl2 proc $(FME_UUID_SAFE)__Concatenate {} {   upvar \#0 $(FME_UUID_SAFE)__separator separator             $(FME_UUID_SAFE)__listPattern listPattern;   set allAttrs [lsort -dictionary [FME_AttributeNames]];   set keepEmptyParts [string equal {No} {No}];   set result {};   foreach attrName $allAttrs {     if {[regexp $listPattern $attrName]} {       set attrValue [FME_GetAttribute $attrName];       if {$keepEmptyParts || $attrValue != {}} {         lappend result $attrValue;       };     };   };   FME_SetAttribute [FME_DecodeText {"resources2replace"}] [join $result $separator]; }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_ListConcatenator_5 }    INPUT  FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_FeatureMerger_2_MERGED"    OUTPUT { FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_ListConcatenator_5_OUTPUT"         @Tcl2($(FME_UUID_SAFE)__Concatenate)          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} StringReplacerFactory    FACTORY_NAME { $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_StringReplacer_2 }    INPUT  FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_ListConcatenator_5_OUTPUT"    USE_REGEX { NO }    CASE_SENSITIVE { NO }    SOURCE_ATTRIBUTES { json_file }    FIND_TEXT { "<quote>FME_RESOURCES_SUB_TEMPLATE<quote>" }    REPLACE_TEXT { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>resources2replace<closeparen>,$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_StringReplacer_2)" }    REPLACE_NO_MATCH { "_FME_NO_OP_" }    OUTPUT { OUTPUT FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_StringReplacer_2_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_AttributeExposer_5 }    INPUT  FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_StringReplacer_2_OUTPUT"    OUTPUT { FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_AttributeExposer_5_OUTPUT"          }
