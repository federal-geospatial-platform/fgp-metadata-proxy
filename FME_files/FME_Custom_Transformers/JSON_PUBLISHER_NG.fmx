FACTORY_DEF {*} StringReplacerFactory    FACTORY_NAME { $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_StringReplacer_7 }    INPUT  FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_StringReplacer_6_OUTPUT"    USE_REGEX { NO }    CASE_SENSITIVE { NO }    SOURCE_ATTRIBUTES { json_file }    FIND_TEXT { "<quote>FME_TOPIC_CATEGORY<quote>" }    REPLACE_TEXT { "@EvaluateExpression(FDIV,STRING_ENCODED,<openbracket><quote><at>Value<openparen>TBS_topic<closeparen><quote><closebracket>,$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_StringReplacer_7)" }    REPLACE_NO_MATCH { "_FME_NO_OP_" }    OUTPUT { OUTPUT FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_StringReplacer_7_OUTPUT"          }
