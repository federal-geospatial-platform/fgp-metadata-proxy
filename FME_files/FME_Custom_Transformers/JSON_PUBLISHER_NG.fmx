FACTORY_DEF {*} StringReplacerFactory    FACTORY_NAME { $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_StringReplacer }    INPUT  FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_StringReplacer_7_OUTPUT"    USE_REGEX { NO }    CASE_SENSITIVE { NO }    SOURCE_ATTRIBUTES { json_file }    FIND_TEXT { "<openbracket><quote><quote><closebracket>" }    REPLACE_TEXT { "<openbracket><space><closebracket>" }    REPLACE_NO_MATCH { "_FME_NO_OP_" }    OUTPUT { OUTPUT FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_StringReplacer_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttributeKeeperFactory    FACTORY_NAME { $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_AttributeKeeper_3 }    INPUT  FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_StringReplacer_OUTPUT"    KEEP_ATTRS { id,json_file }    KEEP_LISTS {  }    KEEP_FME_ATTRIBUTES Yes    BUILD_FEATURE_TABLES { NO }    OUTPUT_ON_ATTRIBUTE_CHANGE { <Unused> }    OUTPUT { OUTPUT FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_AttributeKeeper_3_OUTPUT"        }
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_Terminator }    INPUT  FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_FeatureMerger_2_UNMERGED_REQUESTOR"    INPUT  FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_FeatureMerger_2_UNUSED_SUPPLIER"    INPUT  FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_FeatureMerger_2_<REJECTED>"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"Translation<space>Terminated")       @SupplyAttributes(_wb_termination_xformer,"$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_Terminator")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"Translation<space>Terminated") }
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_Terminator_6 }    INPUT  FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_FeatureMerger_UNMERGED_REQUESTOR"    INPUT  FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_FeatureMerger_<REJECTED>"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"Translation<space>Terminated")       @SupplyAttributes(_wb_termination_xformer,"$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_Terminator_6")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"Translation<space>Terminated") }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_OUTPUT_LOCAL1762277819 Output Collector"   INPUT FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_AttributeKeeper_3_OUTPUT"   OUTPUT FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_OUTPUT_LOCAL"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(JSON_PUBLISHER_NG_WORKSPACE_NAME))}]
