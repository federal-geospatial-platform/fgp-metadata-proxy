FACTORY_DEF * TeeFactory   FACTORY_NAME "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_INPUT1762277819 Input Splitter"   INPUT FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_INPUT"   OUTPUT FEATURE_TYPE "$(JSON_PUBLISHER_NG_WORKSPACE_NAME)_INPUT"
