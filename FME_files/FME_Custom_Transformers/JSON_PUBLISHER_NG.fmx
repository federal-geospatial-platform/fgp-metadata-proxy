Tcl2 proc $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_Creator_CoordSysRemover {} {   global FME_CoordSys;   set FME_CoordSys {}; }
MACRO $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_Creator_XML     NOT_ACTIVATED
MACRO $(JSON_PUBLISHER_NG_WORKSPACE_NAME)_Creator_GEOJSON NOT_ACTIVATED
