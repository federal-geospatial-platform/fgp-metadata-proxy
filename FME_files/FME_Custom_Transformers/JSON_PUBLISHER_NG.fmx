ace><space><space>n2=<openbracket><closebracket><lf><space><space><space><space><space><space><space><space><space><space><space>for<space>i<space>in<space>range<openparen>feature.getAttribute<openparen><apos>_element_count<apos><closeparen><closeparen>:<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>n3=<opencurly><closecurly><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>n3<openbracket><apos>TBS_ATTRIBUTES<apos><closebracket>=feature.getAttribute<openparen><apos>_list<opencurly>%s<closecurly>.TBS_ATTRIBUTES<apos>%<openparen>str<openparen>i<closeparen><closeparen><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>n3<openbracket><apos>FEATURE_ATTRIBUTES<apos><closebracket>=feature.getAttribute<openparen><apos>_list<opencurly>%s<closecurly>.FEATURE_ATTRIBUTES<apos>%<openparen>str<openparen>i<closeparen><closeparen><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>n3<openbracket><apos>LIST_NAME<apos><closebracket>=feature.getAttribute<openparen><apos>extracted_list_name<apos><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><lf><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>n2.append<openparen>n3<closeparen><lf><lf><space><space><space><space><space><space><space><space><space><space><space>self.config<openbracket>feature.getAttribute<openparen><apos>SECTION<apos><closeparen><closebracket>=n2<lf><space><space><space><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space>else:<lf><lf><space><space><space><space><space><space><space><space><space><space><space><space>#Process<space>metadata<space>records<lf><space><space><space><space><space><space><space><space><space><space><space><space>for<space>keys<space>in<space>self.config:<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>if<space>self.config<openbracket>keys<closebracket><openbracket>0<closebracket><openbracket><apos>LIST_NAME<apos><closebracket>:<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>#Need<space>to<space>look<space>in<space>list<space>to<space>create<space>multiple<space>feature<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>#<space>Only<space>if<space>metadatasection<space>exists<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>max_index=FME_utils.max_index_attribute_list<openparen>feature<comma><apos>%s<opencurly><closecurly><apos>%<openparen>self.config<openbracket>keys<closebracket><openbracket>0<closebracket><openbracket><apos>LIST_NAME<apos><closebracket><closeparen><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>for<space>index<space>in<space>range<openparen>max_index+1<closeparen>:<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>new_featu