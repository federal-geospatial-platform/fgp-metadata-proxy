# -------------------------------------------------------------------------
FACTORY_DEF {*} DateTimeConverterFactory    FACTORY_NAME { $(YT_DATE_FORMATTER_WORKSPACE_NAME)_DateTimeConverter }    DATETIME_ATTR { "data_collection_start_date date_created date_last_modified date_published data_collection_end_date" }    IN_FORMAT { "" }    OUT_FORMAT { "%Y-%m-%d" }    REPAIR_INPUT { "YES" }    PASSTHROUGH { "YES" }    INPUT  FEATURE_TYPE "$(YT_DATE_FORMATTER_WORKSPACE_NAME)_Tester_2_PASSED"    INPUT  FEATURE_TYPE "$(YT_DATE_FORMATTER_WORKSPACE_NAME)_AttributeCreator_4_OUTPUT"    OUTPUT { OUTPUT FEATURE_TYPE "$(YT_DATE_FORMATTER_WORKSPACE_NAME)_DateTimeConverter_OUTPUT"        }    OUTPUT { REJECTED FEATURE_TYPE "$(YT_DATE_FORMATTER_WORKSPACE_NAME)_DateTimeConverter_<REJECTED>"        }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(YT_DATE_FORMATTER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(YT_DATE_FORMATTER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(YT_DATE_FORMATTER_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(YT_DATE_FORMATTER_WORKSPACE_NAME)_DateTimeConverter_OUTPUT"    OUTPUT { FEATURE_TYPE "$(YT_DATE_FORMATTER_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,fme_rejection_code)        $($(YT_DATE_FORMATTER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(YT_DATE_FORMATTER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Input Input Collector"   INPUT FEATURE_TYPE "$(YT_DATE_FORMATTER_WORKSPACE_NAME)_AttributeRemover_OUTPUT"   OUTPUT FEATURE_TYPE "$(YT_DATE_FORMATTER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Input"
MACRO ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME $(YT_DATE_FORMATTER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_XFORMER_NAME $(YT_DATE_FORMATTER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
INCLUDE_CUSTOM_TRANSFORMER_VER ATTRIBUTE_UNEXPOSER:1
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(YT_DATE_FORMATTER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Output Output Renamer/Nuker"   INPUT FEATURE_TYPE "$(YT_DATE_FORMATTER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(YT_DATE_FORMATTER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(YT_DATE_FORMATTER_WORKSPACE_NAME)_OUTPUT1762281664 Output Collector"   INPUT FEATURE_TYPE "$(YT_DATE_FORMATTER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(YT_DATE_FORMATTER_WORKSPACE_NAME)_OUTPUT"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(YT_DATE_FORMATTER_WORKSPACE_NAME)_Invalid_date_format1762281664 Output Collector"   INPUT FEATURE_TYPE "$(YT_DATE_FORMATTER_WORKSPACE_NAME)_DateTimeConverter_<REJECTED>"   OUTPUT FEATURE_TYPE "$(YT_DATE_FORMATTER_WORKSPACE_NAME)_Invalid_date_format"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(YT_DATE_FORMATTER_WORKSPACE_NAME))}]
