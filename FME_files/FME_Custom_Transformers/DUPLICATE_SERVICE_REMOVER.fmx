FACTORY_DEF {*} DuplicateRemoverFactory    FACTORY_NAME { $(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_DuplicateFilter }    COMMAND_PARM_EVALUATION SINGLE_PASS    SUPPORTS_FEATURE_TABLES    INPUT  FEATURE_TYPE "$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_Sorter_SORTED"    KEY_ATTRIBUTES { protocol _uuid_duplicate xlink_role }    INPUT_IS_ORDERED { NO }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { DUPLICATE FEATURE_TYPE "$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_DuplicateFilter_DUPLICATE"         }    OUTPUT { UNIQUE FEATURE_TYPE "$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_DuplicateFilter_UNIQUE"         }
