FACTORY_DEF {*} ListFactory    FACTORY_NAME { $(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_ListBuilder }    INPUT { FEATURE_TYPE $(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_ListBuilder_no_fme_type }    LIST_NAME { "resources" }    LIST_ATTRS_TO_INCLUDE { <Unused> }    LIST_ATTRS_TO_INCLUDE_MODE { ALL }    GROUP_BY { _uuid_duplicate }    FLUSH_WHEN_GROUPS_CHANGE { No }    OUTPUT { LIST FEATURE_TYPE "$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_ListBuilder_OUTPUT"          }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "resources<opencurly><closecurly>"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC }    } else {        puts "MACRO $(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_AttributeRemover_2 }    INPUT  FEATURE_TYPE "$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_1_9Z0/BWPfJPk="    OUTPUT { FEATURE_TYPE "$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"        @RemoveAttributes(fme_encoded,)        $($(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC)         }
# -------------------------------------------------------------------------
INCLUDE [if { {ATTRIBUTES} == {ATTRIBUTES} } {                puts "MACRO $(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO ATTRIBUTES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {POLYGONS}} {                puts "MACRO $(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {AGGREGATES}} {                puts "MACRO $(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO $(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {POLYGONS}} {                puts "MACRO $(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {AGGREGATES}} {                puts "MACRO $(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO $(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} } {                puts "MACRO $(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} } {                puts "MACRO $(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          else {}; ]
FACTORY_DEF {*} ReferenceFactory    FACTORY_NAME { $(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_FeatureMerger }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT REFERENCER FEATURE_TYPE "$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"    INPUT REFERENCEE FEATURE_TYPE "$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_ListBuilder_OUTPUT"    REFERENCE_INFO { $($(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO) }    REFERENCE_TABLE { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_uuid_duplicate<closeparen>,$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_FeatureMerger) @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_uuid_duplicate<closeparen>,$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_FeatureMerger) AUTO }    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "REQUESTOR_IF_CONFLICT" }    IGNORE_NULLS { "No" }    HANDLE_NULL_MISSING_KEYS_LIKE_FME2013 { No }    LIST_ATTRS_TO_INCLUDE { <Unused> }    LIST_ATTRS_TO_INCLUDE_MODE { <Unused> }    MERGE_ATTRIBUTES Yes    MANAGE_FME_TYPE Yes    MODE COMPLETE    PROCESS_DUPLICATE_REFERENCEES { NO }    REFERENCEES_FIRST { No }    REJECT_INVALID_GEOM YES    CLEANING_TOLERANCE { <Unused> }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    COMPARE_WHITESPACE Yes    OUTPUT { COMPLETE FEATURE_TYPE "$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_FeatureMerger_MERGED"         }    OUTPUT { INCOMPLETE FEATURE_TYPE "$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_FeatureMerger_UNMERGED_REQUESTOR"         }    OUTPUT { UNREFERENCED FEATURE_TYPE "$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_FeatureMerger_UNUSED_SUPPLIER"         }    OUTPUT { REJECTED FEATURE_TYPE "$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_FeatureMerger_<REJECTED>"         }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "_histogram<opencurly><closecurly>.count _histogram<opencurly><closecurly>.value resources<opencurly><closecurly>._element_index resources<opencurly><closecurly>._uuid_duplicate"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_AttributeRemover_3_LIST_FUNC }    } else {        puts "MACRO $(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_AttributeRemover_3_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_AttributeRemover_3 }    INPUT  FEATURE_TYPE "$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_FeatureMerger_MERGED"    OUTPUT { FEATURE_TYPE "$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_AttributeRemover_3_OUTPUT"        @RemoveAttributes(fme_encoded,_uuid_duplicate)        $($(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_AttributeRemover_3_LIST_FUNC)         }
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_Terminator }    INPUT  FEATURE_TYPE "$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_FeatureMerger_UNMERGED_REQUESTOR"    INPUT  FEATURE_TYPE "$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_FeatureMerger_UNUSED_SUPPLIER"    INPUT  FEATURE_TYPE "$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_FeatureMerger_<REJECTED>"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"@EvaluateExpression(FDIV,STRING_ENCODED,Translation<space>Terminated<space>in<space>at<space>FeatureMerger<space>in<space>DUPLICATE_SERVICE_REMOVER<space>transformer.<space><space>Verify<space>data<space>record<space>with<space>ID<space><at>Value<openparen>id<closeparen>,$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_Terminator)")       @SupplyAttributes(_wb_termination_xformer,"$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_Terminator")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"@EvaluateExpression(FDIV,STRING_ENCODED,Translation<space>Terminated<space>in<space>at<space>FeatureMerger<space>in<space>DUPLICATE_SERVICE_REMOVER<space>transformer.<space><space>Verify<space>data<space>record<space>with<space>ID<space><at>Value<openparen>id<closeparen>,$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_Terminator)") }
# -------------------------------------------------------------------------
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Input Input Collector"   INPUT FEATURE_TYPE "$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_AttributeRemover_3_OUTPUT"   INPUT FEATURE_TYPE "$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_Tester_FAILED"   OUTPUT FEATURE_TYPE "$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Input"
MACRO ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME $(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_XFORMER_NAME $(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
INCLUDE_CUSTOM_TRANSFORMER_VER ATTRIBUTE_UNEXPOSER:1
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Output Output Renamer/Nuker"   INPUT FEATURE_TYPE "$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_OUTPUT1762277325 Output Collector"   INPUT FEATURE_TYPE "$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(DUPLICATE_SERVICE_REMOVER_WORKSPACE_NAME)_OUTPUT"
