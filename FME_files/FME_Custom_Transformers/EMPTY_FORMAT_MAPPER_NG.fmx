FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_AttributeCreator_3 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_LOOKUP_TABLES_READER_NG_2_Output"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "_order" "SET_TO" "1" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "_p-t_abbr" "SET_TO" "$($(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_P-T_ABBR$encode)" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_AttributeCreator_3_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_AttributeCreator }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_LOOKUP_TABLES_READER_NG_Output"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "_order" "SET_TO" "2" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "_p-t_abbr" "SET_TO" "$($(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_P-T_ABBR$encode)" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_AttributeCreator_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_AttributeCreator_2 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_DATA_INPUT"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "_order" "SET_TO" "3" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "_url_validation" "SET_TO" "$($(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_URL_VALIDATION$encode)" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "_p-t_abbr" "SET_TO" "$($(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_P-T_ABBR$encode)" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_AttributeCreator_2_OUTPUT"        }
