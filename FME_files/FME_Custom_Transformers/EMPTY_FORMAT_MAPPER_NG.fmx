FACTORY_DEF * TeeFactory   FACTORY_NAME "$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_PythonCaller_2 <Rejected> Transformer Output Nuker"   INPUT FEATURE_TYPE "$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_PythonCaller_2_<Rejected>"
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_TestFilter_INPUT }    INPUT  FEATURE_TYPE "$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_PythonCaller_2_OUTPUT"    OUTPUT { FEATURE_TYPE $(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_TestFilter_INPUTLINE }
FACTORY_DEF {*} TestFactory FACTORY_NAME { $(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_TestFilter } INPUT FEATURE_TYPE $(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_TestFilter_INPUTLINE FEATURE_TABLE_SHIM_SUPPORT Yes PASSED_TEST_GROUP_OUTPUT FIRST TEST_GROUP TEST { _unknown_mime_type ATTRIBUTE_IS_MISSING "" ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_0 FEATURE_TYPE $(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_TestFilter_VALID OUTPUT FAILED FEATURE_TYPE $(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_TestFilter_INVALID
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_TestFilter_VALID"    OUTPUT { FEATURE_TYPE "$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,_order,_url_validation,_p-t_abbr)        $($(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Input Input Collector"   INPUT FEATURE_TYPE "$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover_OUTPUT"   OUTPUT FEATURE_TYPE "$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Input"
MACRO ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME $(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_XFORMER_NAME $(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
INCLUDE_CUSTOM_TRANSFORMER_VER ATTRIBUTE_UNEXPOSER:1
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Output Output Renamer/Nuker"   INPUT FEATURE_TYPE "$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"
# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_Logger_8dbcc530_ea1a_44b2_93a0_9678fb7efd330} ]
# If the Logger was in a custom transformer, the custom transformer's name was not being
# properly logged -- instead we saw "$(<customXformerName_WORKSPACE_NAME)" being logged as the prefix of the
# message. By deferencing and expanding out the XFORMER_NAME below, and then "WWJD" encoding it when it is
# used in the @Log call via the $encode macro name suffix trick, we get the right result, and the right result
# safely.
MACRO LOGGABLE_XFORMER_NAME $(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_Logger
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_Logger_Logger }    INPUT  FEATURE_TYPE "$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_TestFilter_INVALID"    OUTPUT { FEATURE_TYPE "$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_Logger_LOGGED"                  @Log(ENCODED, "$(LOGGABLE_XFORMER_NAME$encode):<space>@EvaluateExpression(FDIV,STRING_ENCODED,UUID:<space><at>Value<openparen>id<closeparen><space>has<space>an<space>unknown<space>MIME<space>Type<space><openparen><at>Value<openparen>_unknown_mime_type<closeparen><closeparen>.<space>Adjust<space>CSV<space>file.,$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_Logger)","20","20","",INFO,LOG_ONLY,$(FME_UUID_SAFE))                   }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_DATA_OUTPUT1762277602 Output Collector"   INPUT FEATURE_TYPE "$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_DATA_OUTPUT"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_UNKNOWN_MIME_TYPE1762277602 Output Collector"   INPUT FEATURE_TYPE "$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_Logger_LOGGED"   OUTPUT FEATURE_TYPE "$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME)_UNKNOWN_MIME_TYPE"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(EMPTY_FORMAT_MAPPER_NG_WORKSPACE_NAME))}]
