FACTORY_DEF * TeeFactory   FACTORY_NAME "$(URL_CHARACTER_ENCODER_WORKSPACE_NAME)_INPUT1762281228 Input Splitter"   INPUT FEATURE_TYPE "$(URL_CHARACTER_ENCODER_WORKSPACE_NAME)_INPUT"   OUTPUT FEATURE_TYPE "$(URL_CHARACTER_ENCODER_WORKSPACE_NAME)_INPUT"
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(URL_CHARACTER_ENCODER_WORKSPACE_NAME)_AttributeExposer }    INPUT  FEATURE_TYPE "$(URL_CHARACTER_ENCODER_WORKSPACE_NAME)_INPUT"    OUTPUT { FEATURE_TYPE "$(URL_CHARACTER_ENCODER_WORKSPACE_NAME)_AttributeExposer_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(URL_CHARACTER_ENCODER_WORKSPACE_NAME)_UUIDGenerator }    INPUT  FEATURE_TYPE "$(URL_CHARACTER_ENCODER_WORKSPACE_NAME)_AttributeExposer_OUTPUT"    OUTPUT { FEATURE_TYPE "$(URL_CHARACTER_ENCODER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT"             "_uuid_url_char" @UUID(SIMPLE, UUID_FORMAT, UUID_ONLY)              }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(URL_CHARACTER_ENCODER_WORKSPACE_NAME)_UUIDGenerator OUTPUT Splitter"   INPUT FEATURE_TYPE "$(URL_CHARACTER_ENCODER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT"   OUTPUT FEATURE_TYPE "$(URL_CHARACTER_ENCODER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_0_AA99q567/7o="   OUTPUT FEATURE_TYPE "$(URL_CHARACTER_ENCODER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_1_vqC6fYmI5Kc="
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "resources<opencurly><closecurly>"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(URL_CHARACTER_ENCODER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(URL_CHARACTER_ENCODER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(URL_CHARACTER_ENCODER_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(URL_CHARACTER_ENCODER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_0_AA99q567/7o="    OUTPUT { FEATURE_TYPE "$(URL_CHARACTER_ENCODER_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,)        $($(URL_CHARACTER_ENCODER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
