FACTORY_DEF * TeeFactory   FACTORY_NAME "$(QC_MISSING_EMAIL_SETTER_WORKSPACE_NAME)_INPUT1762279824 Input Splitter"   INPUT FEATURE_TYPE "$(QC_MISSING_EMAIL_SETTER_WORKSPACE_NAME)_INPUT"   OUTPUT FEATURE_TYPE "$(QC_MISSING_EMAIL_SETTER_WORKSPACE_NAME)_INPUT"
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(QC_MISSING_EMAIL_SETTER_WORKSPACE_NAME)_AttributeExposer }    INPUT  FEATURE_TYPE "$(QC_MISSING_EMAIL_SETTER_WORKSPACE_NAME)_INPUT"    OUTPUT { FEATURE_TYPE "$(QC_MISSING_EMAIL_SETTER_WORKSPACE_NAME)_AttributeExposer_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(QC_MISSING_EMAIL_SETTER_WORKSPACE_NAME)_Tester_6 }    INPUT  FEATURE_TYPE "$(QC_MISSING_EMAIL_SETTER_WORKSPACE_NAME)_AttributeExposer_OUTPUT"    CASE_INSENSITIVE_TEST { contacts<opencurly>0<closecurly>.email ATTRIBUTE_HAS_A_VALUE "" ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    OUTPUT { PASSED FEATURE_TYPE "$(QC_MISSING_EMAIL_SETTER_WORKSPACE_NAME)_Tester_6_PASSED"         }    OUTPUT { FAILED FEATURE_TYPE "$(QC_MISSING_EMAIL_SETTER_WORKSPACE_NAME)_Tester_6_FAILED"         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(QC_MISSING_EMAIL_SETTER_WORKSPACE_NAME)_AttributeCreator }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(QC_MISSING_EMAIL_SETTER_WORKSPACE_NAME)_Tester_6_FAILED"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "contacts<opencurly>0<closecurly>.email" "SET_TO" "<at>Value<openparen>default_contact_email<closeparen>" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(QC_MISSING_EMAIL_SETTER_WORKSPACE_NAME)_AttributeCreator_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(QC_MISSING_EMAIL_SETTER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Input Input Collector"   INPUT FEATURE_TYPE "$(QC_MISSING_EMAIL_SETTER_WORKSPACE_NAME)_Tester_6_PASSED"   INPUT FEATURE_TYPE "$(QC_MISSING_EMAIL_SETTER_WORKSPACE_NAME)_AttributeCreator_OUTPUT"   OUTPUT FEATURE_TYPE "$(QC_MISSING_EMAIL_SETTER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Input"
MACRO ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME $(QC_MISSING_EMAIL_SETTER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_XFORMER_NAME $(QC_MISSING_EMAIL_SETTER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
INCLUDE_CUSTOM_TRANSFORMER_VER ATTRIBUTE_UNEXPOSER:1
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(QC_MISSING_EMAIL_SETTER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Output Output Renamer/Nuker"   INPUT FEATURE_TYPE "$(QC_MISSING_EMAIL_SETTER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(QC_MISSING_EMAIL_SETTER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(QC_MISSING_EMAIL_SETTER_WORKSPACE_NAME)_DATA_OUTPUT_PASSED1762279824 Output Collector"   INPUT FEATURE_TYPE "$(QC_MISSING_EMAIL_SETTER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(QC_MISSING_EMAIL_SETTER_WORKSPACE_NAME)_DATA_OUTPUT_PASSED"
