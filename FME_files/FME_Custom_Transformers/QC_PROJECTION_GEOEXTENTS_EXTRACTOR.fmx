# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(QC_PROJECTION_GEOEXTENTS_EXTRACTOR_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC }    } else {        puts "MACRO $(QC_PROJECTION_GEOEXTENTS_EXTRACTOR_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(QC_PROJECTION_GEOEXTENTS_EXTRACTOR_WORKSPACE_NAME)_AttributeRemover_2 }    INPUT  FEATURE_TYPE "$(QC_PROJECTION_GEOEXTENTS_EXTRACTOR_WORKSPACE_NAME)_XMLFormatter_PASSED"    OUTPUT { FEATURE_TYPE "$(QC_PROJECTION_GEOEXTENTS_EXTRACTOR_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"        @RemoveAttributes(fme_encoded,_response_body)        $($(QC_PROJECTION_GEOEXTENTS_EXTRACTOR_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC)         }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(QC_PROJECTION_GEOEXTENTS_EXTRACTOR_WORKSPACE_NAME)_AttributeRemover_2 OUTPUT Splitter"   INPUT FEATURE_TYPE "$(QC_PROJECTION_GEOEXTENTS_EXTRACTOR_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"   OUTPUT FEATURE_TYPE "$(QC_PROJECTION_GEOEXTENTS_EXTRACTOR_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT_0_ZESDX7tqnnw="   OUTPUT FEATURE_TYPE "$(QC_PROJECTION_GEOEXTENTS_EXTRACTOR_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT_1_KmtsKq5db1s="
