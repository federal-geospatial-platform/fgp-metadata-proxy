FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(QC_PROJECTION_GEOEXTENTS_EXTRACTOR_WORKSPACE_NAME)_Cloner_5_Cloner }    INPUT  FEATURE_TYPE "$(QC_PROJECTION_GEOEXTENTS_EXTRACTOR_WORKSPACE_NAME)_XMLFormatter_FAILED"    NUMBER_OF_COPIES { "1" }    COPY_NUMBER_ATTRIBUTE { _copynum }    REJECT_INVALID YES
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(QC_PROJECTION_GEOEXTENTS_EXTRACTOR_WORKSPACE_NAME)_Cloner_4_Cloner }    INPUT  FEATURE_TYPE "$(QC_PROJECTION_GEOEXTENTS_EXTRACTOR_WORKSPACE_NAME)_HTTPCaller_<REJECTED>"    NUMBER_OF_COPIES { "1" }    COPY_NUMBER_ATTRIBUTE { _copynum }    REJECT_INVALID YES
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(QC_PROJECTION_GEOEXTENTS_EXTRACTOR_WORKSPACE_NAME)_Terminator_3 }    INPUT  FEATURE_TYPE "$(QC_PROJECTION_GEOEXTENTS_EXTRACTOR_WORKSPACE_NAME)_ListExploder_2_<REJECTED>"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"Translation<space>Terminated")       @SupplyAttributes(_wb_termination_xformer,"$(QC_PROJECTION_GEOEXTENTS_EXTRACTOR_WORKSPACE_NAME)_Terminator_3")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"Translation<space>Terminated") }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(QC_PROJECTION_GEOEXTENTS_EXTRACTOR_WORKSPACE_NAME)_DATA_OUTPUT1762279921 Output Collector"   INPUT FEATURE_TYPE "$(QC_PROJECTION_GEOEXTENTS_EXTRACTOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(QC_PROJECTION_GEOEXTENTS_EXTRACTOR_WORKSPACE_NAME)_DATA_OUTPUT"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(QC_PROJECTION_GEOEXTENTS_EXTRACTOR_WORKSPACE_NAME))}]
