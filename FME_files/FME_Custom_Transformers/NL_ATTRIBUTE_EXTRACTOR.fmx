DEFAULT_MACRO WB_CURRENT_CONTEXT
DEFAULT_MACRO NL_ATTRIBUTE_EXTRACTOR_WORKSPACE_NAME ""
INCLUDE [puts {MACRO WB_OLD_CONTEXT_$(NL_ATTRIBUTE_EXTRACTOR_WORKSPACE_NAME) $(WB_CURRENT_CONTEXT)};          puts {MACRO WB_CURRENT_CONTEXT $(NL_ATTRIBUTE_EXTRACTOR_WORKSPACE_NAME)}]
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NL_ATTRIBUTE_EXTRACTOR_WORKSPACE_NAME)_INPUT1762279190 Input Splitter"   INPUT FEATURE_TYPE "$(NL_ATTRIBUTE_EXTRACTOR_WORKSPACE_NAME)_INPUT"   OUTPUT FEATURE_TYPE "$(NL_ATTRIBUTE_EXTRACTOR_WORKSPACE_NAME)_INPUT"
# -------------------------------------------------------------------------
FME_PYTHON_PATH "$(FME_MF_DIR)"
FACTORY_DEF {*} PythonFactory    FACTORY_NAME { $(NL_ATTRIBUTE_EXTRACTOR_WORKSPACE_NAME)_PythonCaller_4 }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT  FEATURE_TYPE "$(NL_ATTRIBUTE_EXTRACTOR_WORKSPACE_NAME)_INPUT"    SYMBOL_NAME { extract_html_tags }    SOURCE_CODE { import<space>fme<lf>import<space>fmeobjects<lf><lf>from<space>Python.NL_ATTRIBUTE_EXTRACTOR<space>import<space>extract_html_tags<lf> }    PY_OUTPUT_TAGS { PYOUTPUT <Rejected> }    OUTPUT { PYOUTPUT FEATURE_TYPE "$(NL_ATTRIBUTE_EXTRACTOR_WORKSPACE_NAME)_PythonCaller_4_OUTPUT"         }    OUTPUT { <Rejected> FEATURE_TYPE "$(NL_ATTRIBUTE_EXTRACTOR_WORKSPACE_NAME)_PythonCaller_4_<Rejected>"         }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NL_ATTRIBUTE_EXTRACTOR_WORKSPACE_NAME)_PythonCaller_4 <Rejected> Transformer Output Nuker"   INPUT FEATURE_TYPE "$(NL_ATTRIBUTE_EXTRACTOR_WORKSPACE_NAME)_PythonCaller_4_<Rejected>"
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(NL_ATTRIBUTE_EXTRACTOR_WORKSPACE_NAME)_BulkAttributeRemover }    INPUT  FEATURE_TYPE "$(NL_ATTRIBUTE_EXTRACTOR_WORKSPACE_NAME)_PythonCaller_4_OUTPUT"    OUTPUT { FEATURE_TYPE "$(NL_ATTRIBUTE_EXTRACTOR_WORKSPACE_NAME)_BulkAttributeRemover_OUTPUT"        @RemoveAttributes(fme_pcre_match,fme_encoded,"_html_*.", NONPROTECTEDFME)         }
# -------------------------------------------------------------------------
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NL_ATTRIBUTE_EXTRACTOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Input Input Collector"   INPUT FEATURE_TYPE "$(NL_ATTRIBUTE_EXTRACTOR_WORKSPACE_NAME)_BulkAttributeRemover_OUTPUT"   OUTPUT FEATURE_TYPE "$(NL_ATTRIBUTE_EXTRACTOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Input"
MACRO ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME $(NL_ATTRIBUTE_EXTRACTOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_XFORMER_NAME $(NL_ATTRIBUTE_EXTRACTOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
INCLUDE_CUSTOM_TRANSFORMER_VER ATTRIBUTE_UNEXPOSER:1
