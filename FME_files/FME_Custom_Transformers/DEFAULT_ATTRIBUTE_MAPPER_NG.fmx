MACRO $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_FEATURE_TYPE $($(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_FEATURE_TYPE)
MACRO $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_CSV_PATH $($(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_IN_CSV_LOOKUP_TABLES_DIR$encode)
MACRO $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_PT $($(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_P-T_ABBR$encode)
MACRO $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_CSV_ENCODING utf-8
INCLUDE_CUSTOM_TRANSFORMER_VER LOOKUP_TABLES_READER_NG:1
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_LOOKUP_TABLES_READER_NG Output Output Renamer/Nuker"   INPUT FEATURE_TYPE "$(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_LOOKUP_TABLES_READER_NG_Output"   OUTPUT FEATURE_TYPE "$(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_LOOKUP_TABLES_READER_NG_Output"
FACTORY_DEF * BranchingFactory   FACTORY_NAME "$(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_LOOKUP_TABLES_READER_NG_Output Brancher -1 23"   INPUT FEATURE_TYPE "$(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_LOOKUP_TABLES_READER_NG_Output"   TARGET_FACTORY "$(WB_CURRENT_CONTEXT)_CREATOR_BRANCH_TARGET"   MAXIMUM_COUNT None   OUTPUT PASSED FEATURE_TYPE *
# -------------------------------------------------------------------------
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(WB_CURRENT_CONTEXT)_CREATOR_BRANCH_TARGET"   INPUT FEATURE_TYPE *  OUTPUT FEATURE_TYPE *
# -------------------------------------------------------------------------
INCLUDE [if { {ATTRIBUTES} == {ATTRIBUTES} } {                puts "MACRO $(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_FEATURE_MERGER_REFERENCE_INFO ATTRIBUTES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {POLYGONS} == {POLYGONS}} {                puts "MACRO $(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_FEATURE_MERGER_REFERENCE_INFO GEOM_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {POLYGONS} == {AGGREGATES}} {                puts "MACRO $(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_FEATURE_MERGER_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {POLYGONS} == {LINESFROMPOINTS}} {                puts "MACRO $(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_FEATURE_MERGER_REFERENCE_INFO GEOM_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {POLYGONS} == {POLYGONS}} {                puts "MACRO $(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_FEATURE_MERGER_REFERENCE_INFO GEOM_AND_ATTR_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {POLYGONS} == {AGGREGATES}} {                puts "MACRO $(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_FEATURE_MERGER_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {POLYGONS} == {LINESFROMPOINTS}} {                puts "MACRO $(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_FEATURE_MERGER_REFERENCE_INFO GEOM_AND_ATTR_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} } {                puts "MACRO $(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_FEATURE_MERGER_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} } {                puts "MACRO $(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_FEATURE_MERGER_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          else {}; ]
FACTORY_DEF {*} ReferenceFactory    FACTORY_NAME { $(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_FEATURE_MERGER }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT REFERENCER FEATURE_TYPE "$(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_INPUT"    INPUT REFERENCEE FEATURE_TYPE "$(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_LOOKUP_TABLES_READER_NG_Output"    CONNECT_Z_MODE { FIRST_WINS }    REFERENCE_INFO { $($(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_FEATURE_MERGER_REFERENCE_INFO) }    REFERENCE_TABLE { 1 1 AUTO }    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "SUPPLIER_IF_CONFLICT" }    IGNORE_NULLS { "No" }    HANDLE_NULL_MISSING_KEYS_LIKE_FME2013 { Yes }    LIST_ATTRS_TO_INCLUDE { <Unused> }    LIST_ATTRS_TO_INCLUDE_MODE { <Unused> }    MERGE_ATTRIBUTES Yes    MANAGE_FME_TYPE Yes    MODE COMPLETE    PROCESS_DUPLICATE_REFERENCEES { YES }    REFERENCEES_FIRST { No }    REJECT_INVALID_GEOM YES    CLEANING_TOLERANCE { AUTO }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    COMPARE_WHITESPACE Yes    OUTPUT { COMPLETE FEATURE_TYPE "$(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_FEATURE_MERGER_MERGED"         }    OUTPUT { INCOMPLETE FEATURE_TYPE "$(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_FEATURE_MERGER_UNMERGED_REQUESTOR"         }    OUTPUT { REJECTED FEATURE_TYPE "$(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_FEATURE_MERGER_<REJECTED>"         }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_FEATURE_MERGER_MERGED"    OUTPUT { FEATURE_TYPE "$(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,default_key,default_value)        $($(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Input Input Collector"   INPUT FEATURE_TYPE "$(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover_OUTPUT"   OUTPUT FEATURE_TYPE "$(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Input"
MACRO ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME $(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_XFORMER_NAME $(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
INCLUDE_CUSTOM_TRANSFORMER_VER ATTRIBUTE_UNEXPOSER:1
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Output Output Renamer/Nuker"   INPUT FEATURE_TYPE "$(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_Terminator_3 }    INPUT  FEATURE_TYPE "$(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_FEATURE_MERGER_UNMERGED_REQUESTOR"    INPUT  FEATURE_TYPE "$(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_FEATURE_MERGER_<REJECTED>"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"Feature<space>Merger<space>error:<space>Translation<space>Terminated")       @SupplyAttributes(_wb_termination_xformer,"$(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_Terminator_3")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"Feature<space>Merger<space>error:<space>Translation<space>Terminated") }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_OUTPUT1762276646 Output Collector"   INPUT FEATURE_TYPE "$(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME)_OUTPUT"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(DEFAULT_ATTRIBUTE_MAPPER_NG_WORKSPACE_NAME))}]
