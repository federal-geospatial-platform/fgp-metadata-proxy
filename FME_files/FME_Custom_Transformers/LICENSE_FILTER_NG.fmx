#! <?xml version="1.0" encoding="UTF-8" ?>
#! <TRANSFORMER
# TRANSFORMER_BEGIN LICENSE_FILTER_NG,1,"""FGP Tools""",9a865a4c-b428-475f-b44f-54db2e9c742e,"Linked by Default",No,NO_PARALLELISM,,No,25241,YES,No,313,No,
# <p><strong>Description</strong> </p>
# <p>This custom transformer allows to sort the metadata records based on the type of license.  If the licence allows to publish the metadata records in the FGP, the metadata records  are sent to the LICENSE_FILTER_PASSED port.</p>
# <p><strong>Input Ports</strong> </p>
# <ul>
# <li>DATA_INPUT: The input metadata records to process.</li>
# </ul>
# <p><strong>Output Ports</strong> </p>
# <ul>
# <li>
# <p>LICENSE_FILTER_PASSED: The metadata records that have a license allowing to be publish in the FGP;</p>
# </li>
# <li>
# <p>LICENSE_FILTER_UNPASSED: The metadata records that <strong>do not</strong> have a license allowing to be publish in the FGP;</p>
# </li>
# <li>
# <p>UNKNOWN_LICENCE: The metadata records with a license not found in the lookup table.</p>
# </li>
# </ul>
# <p><strong>Parameters</strong> </p>
# <ul>
# <li>
# <p>LICENCE_ATT: Name of the attribute of the metadata record containing the licence type used to determine if the metadata records can be published in the FGP;</p>
# </li>
# <li>
# <p>FEATURE_TYPE: The name of the CSV file containing the information on the licensing;</p>
# </li>
# <li>
# <p>IN_CSV_LOOKUP_TABLES_DIR: The path to the directory containing the CSV file;</p>
# </li>
# <li>
# <p>P-T_ABBR: Two letters abbreviation of the province or territory</p>
# </li>
# </ul>
# TRANSFORMER_END
#!   A0_PREVIEW_IMAGE="data:image/png;base64,"
#!   ARCGIS_COMPATIBILITY="ARCGIS_AUTO"
#!   ATTR_TYPE_ENCODING="SDF"
#!   BLOCKED_LOOPING="No"
#!   CATEGORY="&quot;FGP Tools&quot;"
