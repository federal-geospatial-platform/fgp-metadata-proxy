MACRO $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_FEATURE_TYPE $($(LICENSE_FILTER_NG_WORKSPACE_NAME)_FEATURE_TYPE)
MACRO $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_CSV_PATH $($(LICENSE_FILTER_NG_WORKSPACE_NAME)_IN_CSV_LOOKUP_TABLES_DIR$encode)
MACRO $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_PT $($(LICENSE_FILTER_NG_WORKSPACE_NAME)_P-T_ABBR$encode)
MACRO $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_CSV_ENCODING utf-8
