DEFAULT_MACRO START_DATETIME
DEFAULT_MACRO END_DATETIME
DEFAULT_MACRO OPERATOR
DEFAULT_MACRO YEARS
DEFAULT_MACRO MONTHS
DEFAULT_MACRO DAYS
DEFAULT_MACRO HOURS
DEFAULT_MACRO MINUTES
DEFAULT_MACRO SECONDS
DEFAULT_MACRO ISO_INTERVAL
DEFAULT_MACRO EXPRESSION
DEFAULT_MACRO RESULT_TYPE
DEFAULT_MACRO RESULT_INTERVAL
DEFAULT_MACRO RESULT_DATETIME
DEFAULT_MACRO RESULT
DEFAULT_MACRO $(ON_DATE_FORMATTER_WORKSPACE_NAME)_DateTimeCalculator_EXPRESSION expression
DEFAULT_MACRO $(ON_DATE_FORMATTER_WORKSPACE_NAME)_DateTimeCalculator_RESULT_ATTR attr
INCLUDE [    proc stripEvaluateExpression {val} {       if {[regexp {@EvaluateExpression\([^)]*STRING_ENCODED,([^,]*),.+\)} $val -> unwrapped] && [string first {FME_CONDITIONAL:} $unwrapped] < 0}  {          return $unwrapped       } else {          return $val       };    }; ]
INCLUDE [    set start_datetime_stripped [stripEvaluateExpression {@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_timestamp<closeparen>,$(ON_DATE_FORMATTER_WORKSPACE_NAME)_DateTimeCalculator)}];    set end_datetime_stripped [stripEvaluateExpression {$(END_DATETIME)}];    set years_stripped [stripEvaluateExpression {0}];    set months_stripped [stripEvaluateExpression {0}];    set days_stripped [stripEvaluateExpression {8}];    set hours_stripped [stripEvaluateExpression {0}];    set minutes_stripped [stripEvaluateExpression {0}];    set seconds_stripped [stripEvaluateExpression {0}];    set iso_interval_stripped [stripEvaluateExpression {$(ISO_INTERVAL)}];    set result_type_stripped [stripEvaluateExpression {$(RESULT_TYPE)}];    set expression {};    set result_attr {};    if { "DATETIMECALC_1_ADD_INTERVAL" eq "DATETIMECALC_1_ADD_INTERVAL" ||         "DATETIMECALC_1_ADD_INTERVAL" eq "DATETIMECALC_2_ADD_ISO_INTERVAL" } {       set interval $iso_interval_stripped;       if { "DATETIMECALC_1_ADD_INTERVAL" eq "DATETIMECALC_1_ADD_INTERVAL" } {          set interval <at>DateTimeIntervalCreate<openparen><quote>$years_stripped<quote><comma><quote>$months_stripped<quote><comma><quote>$days_stripped<quote><comma><quote>$hours_stripped<quote><comma><quote>$minutes_stripped<quote><comma><quote>$seconds_stripped<quote><closeparen>;       };       set signed_interval $interval;       if { "SUBTRACT" eq "SUBTRACT" } {          set signed_interval <at>DateTimeIntervalNegate<openparen><quote>$interval<quote><closeparen>;       };       set result_attr {record_publish_date};       set expression <at>DateTimeAdd<openparen><quote>$start_datetime_stripped<quote><comma><quote>$signed_interval<quote><closeparen>;    } elseif { "DATETIMECALC_1_ADD_INTERVAL" eq "DATETIMECALC_3_CALCULATE_INTERVAL" } {       set result_attr {$(RESULT_INTERVAL)};       set expression <at>DateTimeDiff<openparen><quote>$end_datetime_stripped<quote><comma><quote>$start_datetime_stripped<quote><comma><quote>$result_type_stripped<quote><closeparen>;    } elseif { "DATETIMECALC_1_ADD_INTERVAL" eq "DATETIMECALC_4_EXPRESSION" } {       set result_attr {$(RESULT)};       set expression {$(EXPRESSION)};    };    puts "MACRO $(ON_DATE_FORMATTER_WORKSPACE_NAME)_DateTimeCalculator_EXPRESSION $expression";    puts "MACRO $(ON_DATE_FORMATTER_WORKSPACE_NAME)_DateTimeCalculator_RESULT_ATTR $result_attr"; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(ON_DATE_FORMATTER_WORKSPACE_NAME)_DateTimeCalculator_1 }    INPUT  FEATURE_TYPE "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_DateTimeStamper_OUTPUT"    OUTPUT { FEATURE_TYPE __TEST_NULL__       @EvaluateExpression(ATTR_CREATE_EXPR_PROPAGATE_MISSING_FDIV,$($(ON_DATE_FORMATTER_WORKSPACE_NAME)_DateTimeCalculator_RESULT_ATTR),"$($(ON_DATE_FORMATTER_WORKSPACE_NAME)_DateTimeCalculator_EXPRESSION)",$(ON_DATE_FORMATTER_WORKSPACE_NAME)_DateTimeCalculator) }
