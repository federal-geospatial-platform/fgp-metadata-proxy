DEFAULT_MACRO $(ON_DATE_FORMATTER_WORKSPACE_NAME)_DateTimeStamper_EXPRESSION
INCLUDE [    set expression {<at>DateTimeCast<openparen><at>DateTimeNow<openparen>local<comma>feature<closeparen><comma>datetime<closeparen>};    if { {NO} eq {NO} } {        set expression <at>TimeZoneRemove<openparen>$expression<closeparen>;    };    if { {YES} eq {NO} } {        set expression <at>DateTimeRound<openparen>$expression<comma>down<comma>seconds<comma>1<closeparen>;    };    puts "MACRO $(ON_DATE_FORMATTER_WORKSPACE_NAME)_DateTimeStamper_EXPRESSION $expression"; ]
