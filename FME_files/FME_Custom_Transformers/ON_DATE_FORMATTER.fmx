DEFAULT_MACRO WB_CURRENT_CONTEXT
DEFAULT_MACRO ON_DATE_FORMATTER_WORKSPACE_NAME ""
INCLUDE [puts {MACRO WB_OLD_CONTEXT_$(ON_DATE_FORMATTER_WORKSPACE_NAME) $(WB_CURRENT_CONTEXT)};          puts {MACRO WB_CURRENT_CONTEXT $(ON_DATE_FORMATTER_WORKSPACE_NAME)}]
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_INPUT1762279558 Input Splitter"   INPUT FEATURE_TYPE "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_INPUT"   OUTPUT FEATURE_TYPE "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_INPUT"
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(ON_DATE_FORMATTER_WORKSPACE_NAME)_AttributeExposer }    INPUT  FEATURE_TYPE "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_INPUT"    OUTPUT { FEATURE_TYPE "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_AttributeExposer_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} DateTimeConverterFactory    FACTORY_NAME { $(ON_DATE_FORMATTER_WORKSPACE_NAME)_DateTimeConverter_3 }    DATETIME_ATTR { "record_create_date record_last_modified record_publish_date" }    IN_FORMAT { "" }    OUT_FORMAT { "%Y-%m-%d" }    REPAIR_INPUT { "YES" }    PASSTHROUGH { "NO" }    INPUT  FEATURE_TYPE "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_AttributeExposer_OUTPUT"    OUTPUT { OUTPUT FEATURE_TYPE "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_DateTimeConverter_3_OUTPUT"        }    OUTPUT { REJECTED FEATURE_TYPE "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_DateTimeConverter_3_<REJECTED>"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(ON_DATE_FORMATTER_WORKSPACE_NAME)_UUIDGenerator_2 }    INPUT  FEATURE_TYPE "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_DateTimeConverter_3_OUTPUT"    OUTPUT { FEATURE_TYPE "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_UUIDGenerator_2_OUTPUT"             "uuid_date" @UUID(SIMPLE, UUID_FORMAT, UUID_ONLY)              }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_UUIDGenerator_2 OUTPUT Splitter"   INPUT FEATURE_TYPE "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_UUIDGenerator_2_OUTPUT"   OUTPUT FEATURE_TYPE "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_UUIDGenerator_2_OUTPUT_0_SXgqsnRScPk="   OUTPUT FEATURE_TYPE "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_UUIDGenerator_2_OUTPUT_1_RuWswomm4MM="
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttributeKeeperFactory    FACTORY_NAME { $(ON_DATE_FORMATTER_WORKSPACE_NAME)_AttributeKeeper_2 }    INPUT  FEATURE_TYPE "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_UUIDGenerator_2_OUTPUT_0_SXgqsnRScPk="    KEEP_ATTRS { uuid_date }    KEEP_LISTS { resources<opencurly><closecurly> }    KEEP_FME_ATTRIBUTES Yes    BUILD_FEATURE_TABLES { NO }    OUTPUT_ON_ATTRIBUTE_CHANGE { <Unused> }    OUTPUT { OUTPUT FEATURE_TYPE "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_AttributeKeeper_2_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} ElementFactory    FACTORY_NAME { $(ON_DATE_FORMATTER_WORKSPACE_NAME)_ListExploder_2 }    INPUT  FEATURE_TYPE "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_AttributeKeeper_2_OUTPUT"    LIST_NAME { "resources{}" }    ELEMENT_NUMBER_FIELD { "_element_index" }    CLONE_GEOMETRY    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "INCOMING_IF_CONFLICT" }    INCOMING_PREFIX { "<Unused>" }    OUTPUT { ELEMENT FEATURE_TYPE "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_ListExploder_2_ELEMENTS"         @RemoveAttributes(ElementFactory.baseCloned)          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} DateTimeConverterFactory    FACTORY_NAME { $(ON_DATE_FORMATTER_WORKSPACE_NAME)_DateTimeConverter_4 }    DATETIME_ATTR { "data_range_end data_last_updated created data_range_start" }    IN_FORMAT { "" }    OUT_FORMAT { "%Y%m%d" }    REPAIR_INPUT { "YES" }    PASSTHROUGH { "YES" }    INPUT  FEATURE_TYPE "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_ListExploder_2_ELEMENTS"    OUTPUT { OUTPUT FEATURE_TYPE "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_DateTimeConverter_4_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(ON_DATE_FORMATTER_WORKSPACE_NAME)_ListBuilder_5_fme_type_remover }    INPUT  FEATURE_TYPE "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_DateTimeConverter_4_OUTPUT"    OUTPUT { FEATURE_TYPE $(ON_DATE_FORMATTER_WORKSPACE_NAME)_ListBuilder_5_no_fme_type       @RemoveAttributes(fme_type,fme_geometry) }
FACTORY_DEF {*} ListFactory    FACTORY_NAME { $(ON_DATE_FORMATTER_WORKSPACE_NAME)_ListBuilder_5 }    INPUT { FEATURE_TYPE $(ON_DATE_FORMATTER_WORKSPACE_NAME)_ListBuilder_5_no_fme_type }    LIST_NAME { "resources" }    LIST_ATTRS_TO_INCLUDE { <Unused> }    LIST_ATTRS_TO_INCLUDE_MODE { ALL }    GROUP_BY { uuid_date }    FLUSH_WHEN_GROUPS_CHANGE { No }    OUTPUT { LIST FEATURE_TYPE "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_ListBuilder_5_OUTPUT"          }
# -------------------------------------------------------------------------
Tcl2 proc $(ON_DATE_FORMATTER_WORKSPACE_NAME)_ListRangeExtractor_minmaxer {} {    set firstTime 1;    set min {};    set max {};    foreach attr [FME_AttributeNames] {    		 regsub -all \"{\[0-9\]+}\" $attr \"{}\" flatAttr;        if {$flatAttr == \"resources{}.data_range_end\" }        {          set attrVal [FME_GetAttribute $attr];          set checkAttr 1;          if {$attrVal == {} && [FME_IsAttributeNull $attr]}          {    	       set checkAttr 0;          };          if {$checkAttr} { 		         if {$firstTime} { 		           set min $attrVal; 		           set max $attrVal; 		           set firstTime 0; 		         } else { 		           if {$attrVal < $min} {set min $attrVal}; 		           if {$attrVal > $max} {set max $attrVal};  		         }; 		     }; 	     };    };    FME_SetAttribute {"_dump"} $min;    FME_SetAttribute {"data_collection_end_date"} $max; }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(ON_DATE_FORMATTER_WORKSPACE_NAME)_ListRangeExtractor }    INPUT  FEATURE_TYPE "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_ListBuilder_5_OUTPUT"    OUTPUT { FEATURE_TYPE "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_ListRangeExtractor_OUTPUT"         @Tcl2("$(ON_DATE_FORMATTER_WORKSPACE_NAME)_ListRangeExtractor_minmaxer")          }
# -------------------------------------------------------------------------
Tcl2 proc $(ON_DATE_FORMATTER_WORKSPACE_NAME)_ListRangeExtractor_2_minmaxer {} {    set firstTime 1;    set min {};    set max {};    foreach attr [FME_AttributeNames] {    		 regsub -all \"{\[0-9\]+}\" $attr \"{}\" flatAttr;        if {$flatAttr == \"resources{}.data_range_start\" }        {          set attrVal [FME_GetAttribute $attr];          set checkAttr 1;          if {$attrVal == {} && [FME_IsAttributeNull $attr]}          {    	       set checkAttr 0;          };          if {$checkAttr} { 		         if {$firstTime} { 		           set min $attrVal; 		           set max $attrVal; 		           set firstTime 0; 		         } else { 		           if {$attrVal < $min} {set min $attrVal}; 		           if {$attrVal > $max} {set max $attrVal};  		         }; 		     }; 	     };    };    FME_SetAttribute {"data_collection_start_date"} $min;    FME_SetAttribute {"_dump"} $max; }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(ON_DATE_FORMATTER_WORKSPACE_NAME)_ListRangeExtractor_2 }    INPUT  FEATURE_TYPE "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_ListRangeExtractor_OUTPUT"    OUTPUT { FEATURE_TYPE "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_ListRangeExtractor_2_OUTPUT"         @Tcl2("$(ON_DATE_FORMATTER_WORKSPACE_NAME)_ListRangeExtractor_2_minmaxer")          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttributeKeeperFactory    FACTORY_NAME { $(ON_DATE_FORMATTER_WORKSPACE_NAME)_AttributeKeeper_3 }    INPUT  FEATURE_TYPE "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_ListRangeExtractor_2_OUTPUT"    KEEP_ATTRS { data_collection_end_date,uuid_date,data_collection_start_date }    KEEP_LISTS {  }    KEEP_FME_ATTRIBUTES Yes    BUILD_FEATURE_TABLES { NO }    OUTPUT_ON_ATTRIBUTE_CHANGE { <Unused> }    OUTPUT { OUTPUT FEATURE_TYPE "$(ON_DATE_FORMATTER_WORKSPACE_NAME)_AttributeKeeper_3_OUTPUT"        }
# -------------------------------------------------------------------------
