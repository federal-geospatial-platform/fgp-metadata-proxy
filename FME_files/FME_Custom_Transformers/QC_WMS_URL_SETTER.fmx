FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(QC_WMS_URL_SETTER_WORKSPACE_NAME)_AttributeExposer_9 }    INPUT  FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_LOOKUP_TABLE_INPUT"    OUTPUT { FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_AttributeExposer_9_OUTPUT"          }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_AttributeExposer_9 OUTPUT Splitter"   INPUT FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_AttributeExposer_9_OUTPUT"   OUTPUT FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_AttributeExposer_9_OUTPUT_0_F0g/YdqA4O4="   OUTPUT FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_AttributeExposer_9_OUTPUT_1_qxc9g+2u8J8="
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(QC_WMS_URL_SETTER_WORKSPACE_NAME)_AttributeExposer_8 }    INPUT  FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_DATA_INPUT"    OUTPUT { FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_AttributeExposer_8_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(QC_WMS_URL_SETTER_WORKSPACE_NAME)_UUIDGenerator }    INPUT  FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_AttributeExposer_8_OUTPUT"    OUTPUT { FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT"             "uuid_wms" @UUID(SIMPLE, UUID_FORMAT, UUID_ONLY)              }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_UUIDGenerator OUTPUT Splitter"   INPUT FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT"   OUTPUT FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_0_Qc5JdJd5b+s="   OUTPUT FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_1_e1cTdyA3Euo="
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttributeKeeperFactory    FACTORY_NAME { $(QC_WMS_URL_SETTER_WORKSPACE_NAME)_AttributeKeeper }    INPUT  FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_0_Qc5JdJd5b+s="    KEEP_ATTRS { uuid_wms }    KEEP_LISTS { resources<opencurly><closecurly> }    KEEP_FME_ATTRIBUTES Yes    BUILD_FEATURE_TABLES { NO }    OUTPUT_ON_ATTRIBUTE_CHANGE { <Unused> }    OUTPUT { OUTPUT FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_AttributeKeeper_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} ElementFactory    FACTORY_NAME { $(QC_WMS_URL_SETTER_WORKSPACE_NAME)_ListExploder }    INPUT  FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_AttributeKeeper_OUTPUT"    LIST_NAME { "resources{}" }    ELEMENT_NUMBER_FIELD { "_element_index" }    CLONE_GEOMETRY    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "INCOMING_IF_CONFLICT" }    INCOMING_PREFIX { "<Unused>" }    OUTPUT { ELEMENT FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_ListExploder_ELEMENTS"         @RemoveAttributes(ElementFactory.baseCloned)          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttributeKeeperFactory    FACTORY_NAME { $(QC_WMS_URL_SETTER_WORKSPACE_NAME)_AttributeKeeper_2 }    INPUT  FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_ListExploder_ELEMENTS"    KEEP_ATTRS { uuid_wms,url,orig_id,format_resourceType_en,format,format_resourceType_fr,name }    KEEP_LISTS {  }    KEEP_FME_ATTRIBUTES Yes    BUILD_FEATURE_TABLES { NO }    OUTPUT_ON_ATTRIBUTE_CHANGE { <Unused> }    OUTPUT { OUTPUT FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_AttributeKeeper_2_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(QC_WMS_URL_SETTER_WORKSPACE_NAME)_Tester_8 }    INPUT  FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_AttributeKeeper_2_OUTPUT"    TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>format<closeparen>,$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_Tester_8)" = WMS ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    OUTPUT { PASSED FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_Tester_8_PASSED"         }    OUTPUT { FAILED FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_Tester_8_FAILED"         }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(QC_WMS_URL_SETTER_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC }    } else {        puts "MACRO $(QC_WMS_URL_SETTER_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(QC_WMS_URL_SETTER_WORKSPACE_NAME)_AttributeRemover_2 }    INPUT  FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_Tester_8_PASSED"    OUTPUT { FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"        @RemoveAttributes(fme_encoded,url)        $($(QC_WMS_URL_SETTER_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} SortFactory    FACTORY_NAME { $(QC_WMS_URL_SETTER_WORKSPACE_NAME)_Sorter }    INPUT  FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"    SORT_ALPHA_AS_UTF8 { YES }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    SORT_BY { orig_id ALPHA ASCENDING name ALPHA ASCENDING }    OUTPUT { SORTED FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_Sorter_SORTED"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} DuplicateRemoverFactory    FACTORY_NAME { $(QC_WMS_URL_SETTER_WORKSPACE_NAME)_DuplicateFilter }    COMMAND_PARM_EVALUATION SINGLE_PASS    SUPPORTS_FEATURE_TABLES    INPUT  FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_Sorter_SORTED"    KEY_ATTRIBUTES { orig_id }    INPUT_IS_ORDERED { NO }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { DUPLICATE FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_DuplicateFilter_DUPLICATE"         }    OUTPUT { UNIQUE FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_DuplicateFilter_UNIQUE"         }
