FACTORY_DEF * TeeFactory   FACTORY_NAME "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_LOOKUP_TABLE_INPUT1762279959 Input Splitter"   INPUT FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_LOOKUP_TABLE_INPUT"   OUTPUT FEATURE_TYPE "$(QC_WMS_URL_SETTER_WORKSPACE_NAME)_LOOKUP_TABLE_INPUT"
