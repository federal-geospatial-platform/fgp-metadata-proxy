MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_XFORMER_NAME $(REMOVE_BROKEN_URL_WMS_ESRI_REST_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
INCLUDE_CUSTOM_TRANSFORMER_VER ATTRIBUTE_UNEXPOSER:1
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(REMOVE_BROKEN_URL_WMS_ESRI_REST_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Output Output Renamer/Nuker"   INPUT FEATURE_TYPE "$(REMOVE_BROKEN_URL_WMS_ESRI_REST_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(REMOVE_BROKEN_URL_WMS_ESRI_REST_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"
