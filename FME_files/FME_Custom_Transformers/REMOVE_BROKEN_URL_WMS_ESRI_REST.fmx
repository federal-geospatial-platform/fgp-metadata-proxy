FACTORY_DEF {*} ReferenceFactory    FACTORY_NAME { $(REMOVE_BROKEN_URL_WMS_ESRI_REST_WORKSPACE_NAME)_FeatureMerger_3 }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT REFERENCER FEATURE_TYPE "$(REMOVE_BROKEN_URL_WMS_ESRI_REST_WORKSPACE_NAME)_AttributeRemover_6_OUTPUT"    INPUT REFERENCEE FEATURE_TYPE "$(REMOVE_BROKEN_URL_WMS_ESRI_REST_WORKSPACE_NAME)_Tester_6_FAILED"    REFERENCE_INFO { $($(REMOVE_BROKEN_URL_WMS_ESRI_REST_WORKSPACE_NAME)_FeatureMerger_3_REFERENCE_INFO) }    REFERENCE_TABLE { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_uuid_broken_url<closeparen>,$(REMOVE_BROKEN_URL_WMS_ESRI_REST_WORKSPACE_NAME)_FeatureMerger_3) @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_uuid_broken_url<closeparen>,$(REMOVE_BROKEN_URL_WMS_ESRI_REST_WORKSPACE_NAME)_FeatureMerger_3) AUTO }    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "REQUESTOR_IF_CONFLICT" }    IGNORE_NULLS { "No" }    HANDLE_NULL_MISSING_KEYS_LIKE_FME2013 { No }    LIST_NAME { "resources" }    LIST_ATTRS_TO_INCLUDE { <Unused> }    LIST_ATTRS_TO_INCLUDE_MODE { ALL }    MERGE_ATTRIBUTES Yes    MANAGE_FME_TYPE Yes    MODE COMPLETE    PROCESS_DUPLICATE_REFERENCEES { NO }    REFERENCEES_FIRST { No }    REJECT_INVALID_GEOM YES    CLEANING_TOLERANCE { <Unused> }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    COMPARE_WHITESPACE Yes    OUTPUT { COMPLETE FEATURE_TYPE "$(REMOVE_BROKEN_URL_WMS_ESRI_REST_WORKSPACE_NAME)_FeatureMerger_3_MERGED"         }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "resources<opencurly><closecurly>._element_index resources<opencurly><closecurly>._uuid_broken_url resources<opencurly><closecurly>.service_failed"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(REMOVE_BROKEN_URL_WMS_ESRI_REST_WORKSPACE_NAME)_AttributeRemover_4_LIST_FUNC }    } else {        puts "MACRO $(REMOVE_BROKEN_URL_WMS_ESRI_REST_WORKSPACE_NAME)_AttributeRemover_4_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(REMOVE_BROKEN_URL_WMS_ESRI_REST_WORKSPACE_NAME)_AttributeRemover_4 }    INPUT  FEATURE_TYPE "$(REMOVE_BROKEN_URL_WMS_ESRI_REST_WORKSPACE_NAME)_FeatureMerger_3_MERGED"    OUTPUT { FEATURE_TYPE "$(REMOVE_BROKEN_URL_WMS_ESRI_REST_WORKSPACE_NAME)_AttributeRemover_4_OUTPUT"        @RemoveAttributes(fme_encoded,format_version,format,_element_index,service_failed,url,_list_index,_uuid_broken_url)        $($(REMOVE_BROKEN_URL_WMS_ESRI_REST_WORKSPACE_NAME)_AttributeRemover_4_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(REMOVE_BROKEN_URL_WMS_ESRI_REST_WORKSPACE_NAME)_Tester }    INPUT  FEATURE_TYPE "$(REMOVE_BROKEN_URL_WMS_ESRI_REST_WORKSPACE_NAME)_AttributeRemover_4_OUTPUT"    TEST { resources<opencurly>0<closecurly>.format ATTRIBUTE_HAS_A_VALUE "" ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    OUTPUT { PASSED FEATURE_TYPE "$(REMOVE_BROKEN_URL_WMS_ESRI_REST_WORKSPACE_NAME)_Tester_PASSED"         }
