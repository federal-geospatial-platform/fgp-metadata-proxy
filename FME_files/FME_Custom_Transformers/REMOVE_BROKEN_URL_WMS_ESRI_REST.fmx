_KEY_FILE { "<Unused>" }    CLIENT_CERTIFICATE_PASSWORD { "<Unused>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(REMOVE_BROKEN_URL_WMS_ESRI_REST_WORKSPACE_NAME)_HTTPCaller_Output"          }    OUTPUT { REJECTED FEATURE_TYPE "$(REMOVE_BROKEN_URL_WMS_ESRI_REST_WORKSPACE_NAME)_HTTPCaller_<REJECTED>"          }
