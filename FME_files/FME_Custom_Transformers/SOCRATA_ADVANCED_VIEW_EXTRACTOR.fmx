FACTORY_DEF * TeeFactory   FACTORY_NAME "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Input Input Collector"   INPUT FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_FeatureMerger_MERGED"   INPUT FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_Tester_FAILED"   OUTPUT FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Input"
MACRO ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME $(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
