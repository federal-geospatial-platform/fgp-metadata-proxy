FACTORY_DEF * TeeFactory   FACTORY_NAME "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_Input1762280507 Input Splitter"   INPUT FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_Input"   OUTPUT FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_Input"
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_AttributeExposer }    INPUT  FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_Input"    OUTPUT { FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_AttributeExposer_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_UUIDGenerator }    INPUT  FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_AttributeExposer_OUTPUT"    OUTPUT { FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_UUIDGenerator_OUTPUT"             "adviewuuid" @UUID(SIMPLE, UUID_FORMAT, UUID_ONLY)              }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_Tester }    INPUT  FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_UUIDGenerator_OUTPUT"    TEST { advancedViewResources<opencurly>0<closecurly>.url ATTRIBUTE_HAS_A_VALUE "" ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    OUTPUT { PASSED FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_Tester_PASSED"         }    OUTPUT { FAILED FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_Tester_FAILED"         }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_Tester PASSED Splitter"   INPUT FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_Tester_PASSED"   OUTPUT FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_Tester_PASSED_0_WB2FSKMpZp0="   OUTPUT FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_Tester_PASSED_1_L3j9BBGh55M="
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "advancedViewResources<opencurly><closecurly>"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_Tester_PASSED_0_WB2FSKMpZp0="    OUTPUT { FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,)        $($(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttributeKeeperFactory    FACTORY_NAME { $(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_AttributeKeeper }    INPUT  FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_Tester_PASSED_1_L3j9BBGh55M="    KEEP_ATTRS { title,adviewuuid,title_fr }    KEEP_LISTS { advancedViewResources<opencurly><closecurly> }    KEEP_FME_ATTRIBUTES Yes    BUILD_FEATURE_TABLES { NO }    OUTPUT_ON_ATTRIBUTE_CHANGE { <Unused> }    OUTPUT { OUTPUT FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_AttributeKeeper_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} ElementFactory    FACTORY_NAME { $(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_ListExploder }    INPUT  FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_AttributeKeeper_OUTPUT"    LIST_NAME { "advancedViewResources{}" }    ELEMENT_NUMBER_FIELD { "_element_index" }    CLONE_GEOMETRY    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "INCOMING_IF_CONFLICT" }    INCOMING_PREFIX { "<Unused>" }    OUTPUT { ELEMENT FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_ListExploder_ELEMENTS"         @RemoveAttributes(ElementFactory.baseCloned)          }    OUTPUT { NOLIST FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_ListExploder_<REJECTED>"         @RemoveAttributes(ElementFactory.baseCloned)         fme_rejection_code MISSING_PARAMETER_LIST          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_AttributeExposer_2 }    INPUT  FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_ListExploder_ELEMENTS"    OUTPUT { FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_AttributeExposer_2_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_AttributeCreator }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_AttributeExposer_2_OUTPUT"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "name" "SET_TO" "<at>Value<openparen>title<closeparen><space>-<space>Advanced<space>View" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_AttributeCreator_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_Tester_2 }    INPUT  FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_AttributeCreator_OUTPUT"    TEST { title_fr ATTRIBUTE_HAS_A_VALUE "" ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    OUTPUT { PASSED FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_Tester_2_PASSED"         }    OUTPUT { FAILED FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_Tester_2_FAILED"         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_AttributeCreator_4 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_Tester_2_PASSED"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "name_fr" "SET_TO" "<at>Value<openparen>title_fr<closeparen><space>-<space>vue<space>avanc<u00e9>e" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_AttributeCreator_4_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_AttributeCreator_3 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_Tester_2_FAILED"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "name_fr" "SET_TO" "FME_NULL_VALUE" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_AttributeCreator_3_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttributeKeeperFactory    FACTORY_NAME { $(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_AttributeKeeper_2 }    INPUT  FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_AttributeCreator_3_OUTPUT"    INPUT  FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_AttributeCreator_4_OUTPUT"    KEEP_ATTRS { name,format,url,name_fr,adviewuuid }    KEEP_LISTS {  }    KEEP_FME_ATTRIBUTES Yes    BUILD_FEATURE_TABLES { NO }    OUTPUT_ON_ATTRIBUTE_CHANGE { <Unused> }    OUTPUT { OUTPUT FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_AttributeKeeper_2_OUTPUT"        }
# -------------------------------------------------------------------------
INCLUDE [if { {ATTRIBUTES} == {ATTRIBUTES} } {                puts "MACRO $(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO ATTRIBUTES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {POLYGONS}} {                puts "MACRO $(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {AGGREGATES}} {                puts "MACRO $(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO $(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {POLYGONS}} {                puts "MACRO $(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {AGGREGATES}} {                puts "MACRO $(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO $(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} } {                puts "MACRO $(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} } {                puts "MACRO $(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          else {}; ]
FACTORY_DEF {*} ReferenceFactory    FACTORY_NAME { $(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_FeatureMerger }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT REFERENCER FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_AttributeRemover_OUTPUT"    INPUT REFERENCEE FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_AttributeKeeper_2_OUTPUT"    REFERENCE_INFO { $($(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO) }    REFERENCE_TABLE { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>adviewuuid<closeparen>,$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_FeatureMerger) @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>adviewuuid<closeparen>,$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_FeatureMerger) AUTO }    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "REQUESTOR_IF_CONFLICT" }    IGNORE_NULLS { "No" }    HANDLE_NULL_MISSING_KEYS_LIKE_FME2013 { No }    LIST_NAME { "advancedview_resources" }    LIST_ATTRS_TO_INCLUDE { format name name_fr url }    LIST_ATTRS_TO_INCLUDE_MODE { SELECTED }    MERGE_ATTRIBUTES Yes    MANAGE_FME_TYPE Yes    MODE COMPLETE    PROCESS_DUPLICATE_REFERENCEES { NO }    REFERENCEES_FIRST { No }    REJECT_INVALID_GEOM YES    CLEANING_TOLERANCE { <Unused> }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    COMPARE_WHITESPACE Yes    OUTPUT { COMPLETE FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_FeatureMerger_MERGED"         }
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_Terminator }    INPUT  FEATURE_TYPE "$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_ListExploder_<REJECTED>"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"Translation<space>Terminated")       @SupplyAttributes(_wb_termination_xformer,"$(SOCRATA_ADVANCED_VIEW_EXTRACTOR_WORKSPACE_NAME)_Terminator")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"Translation<space>Terminated") }
