FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(NT_CATALOGUE_READER_WORKSPACE_NAME)_AttributeExposer }    INPUT  FEATURE_TYPE "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_PythonCaller_OUTPUT"    OUTPUT { FEATURE_TYPE "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_AttributeExposer_OUTPUT"          }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(NT_CATALOGUE_READER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(NT_CATALOGUE_READER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(NT_CATALOGUE_READER_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_AttributeExposer_OUTPUT"    OUTPUT { FEATURE_TYPE "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,_data_status,_data_url,_documents_status,_documents_url,_map_viewers_status,_map_viewers_url,_maps_status,_maps_url,_wms_status,_wms_url,_reports_status,_reports_url)        $($(NT_CATALOGUE_READER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} XFMapFactory    FACTORY_NAME { $(NT_CATALOGUE_READER_WORKSPACE_NAME)_XMLFlattener_3 }    INPUT  FEATURE_TYPE "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_AttributeRemover_OUTPUT"    XML_STREAM { "_html_code"    }    XFMAP_FEATURE_PATHS_EXPRESSION { "*" }    XFMAP_FEATURE_PATHS_STRUCTURE { "<lf><lt>structure<space>separator=<quote>.<quote><space>map-empty-elements=<quote>yes<quote><space>matched-prefix=<quote>attributes<quote><space>matched-attributes=<quote>yes<quote><space>cardinality=<quote>+<opencurly>?<closecurly><quote><space>structure-prefix=<quote>_html_p_<quote><space>child-position-attribute=<quote><quote><space>except-expression=<quote><quote><space>ui-mode=<quote>basic<quote><space>matched-ancestor-attributes=<quote><quote><solidus><gt><lf>" }    IGNORE_DATASET_EXTERNAL_DTD { No }    DISABLE_EXTERNAL_ENTITY_PROCESSING { Yes }    ENTITY_RESOLVER { Yes }    OUTPUT_ONE_FEATURE_PER_INPUT yes    OUTPUT { MAPPED FEATURE_TYPE "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_XMLFlattener_3_OUTPUT"       }
# -------------------------------------------------------------------------
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_ATTRIBUTE_VALUE_TEXT_CLEANER_3 Input Input Collector"   INPUT FEATURE_TYPE "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_XMLFlattener_3_OUTPUT"   OUTPUT FEATURE_TYPE "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_ATTRIBUTE_VALUE_TEXT_CLEANER_3_Input"
MACRO ATTRIBUTE_VALUE_TEXT_CLEANER_WORKSPACE_NAME $(NT_CATALOGUE_READER_WORKSPACE_NAME)_ATTRIBUTE_VALUE_TEXT_CLEANER_3
MACRO $(ATTRIBUTE_VALUE_TEXT_CLEANER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(ATTRIBUTE_VALUE_TEXT_CLEANER_WORKSPACE_NAME)_XFORMER_NAME $(NT_CATALOGUE_READER_WORKSPACE_NAME)_ATTRIBUTE_VALUE_TEXT_CLEANER_3
INCLUDE_CUSTOM_TRANSFORMER_VER ATTRIBUTE_VALUE_TEXT_CLEANER:1
