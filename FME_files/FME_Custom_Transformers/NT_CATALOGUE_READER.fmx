us>www.geomatics.gov.nt.ca<solidus>en<solidus>resources<solidus>field_resource_category<solidus>maps-1" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "_data_status" "SET_TO" "$($(NT_CATALOGUE_READER_WORKSPACE_NAME)_DATA_METADATA)" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "_data_url" "SET_TO" "https:<solidus><solidus>www.geomatics.gov.nt.ca<solidus>en<solidus>resources<solidus>field_resource_category<solidus>data-3" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_AttributeCreator_2_OUTPUT"        }
