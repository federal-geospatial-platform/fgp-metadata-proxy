FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2_INPUT }    INPUT  FEATURE_TYPE "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_BulkAttributeRemover_OUTPUT"    OUTPUT { FEATURE_TYPE $(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2_INPUTLINE }
FACTORY_DEF {*} TestFactory FACTORY_NAME { $(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2 } INPUT FEATURE_TYPE $(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2_INPUTLINE FEATURE_TABLE_SHIM_SUPPORT Yes PASSED_TEST_GROUP_OUTPUT FIRST TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_category<closeparen>,$(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2) = Data ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_0 FEATURE_TYPE $(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2_Data TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_category<closeparen>,$(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2) = Maps ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_1 FEATURE_TYPE $(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2_Maps TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_category<closeparen>,$(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2) = WMS ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_2 FEATURE_TYPE $(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2_WMS TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_category<closeparen>,$(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2) = Reports ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_3 FEATURE_TYPE $(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2_Reports TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_category<closeparen>,$(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2) = Documents ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_4 FEATURE_TYPE $(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2_Documents TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_category<closeparen>,$(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2) = Map<space>Viewers ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_5 FEATURE_TYPE $(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2_Map<space>Viewers OUTPUT FAILED FEATURE_TYPE $(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2_Invalid<space>URL
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2 Invalid<space>URL Transformer Output Nuker"   INPUT FEATURE_TYPE "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2_Invalid<space>URL"
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(NT_CATALOGUE_READER_WORKSPACE_NAME)_Terminator }    INPUT  FEATURE_TYPE "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_Invalid<space>URL"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"Translation<space>Terminated")       @SupplyAttributes(_wb_termination_xformer,"$(NT_CATALOGUE_READER_WORKSPACE_NAME)_Terminator")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"Translation<space>Terminated") }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_DATA1762279341 Output Collector"   INPUT FEATURE_TYPE "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2_Data"   OUTPUT FEATURE_TYPE "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_DATA"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_MAPS1762279341 Output Collector"   INPUT FEATURE_TYPE "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2_Maps"   OUTPUT FEATURE_TYPE "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_MAPS"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_WMS1762279341 Output Collector"   INPUT FEATURE_TYPE "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2_WMS"   OUTPUT FEATURE_TYPE "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_WMS"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_REPORTS1762279341 Output Collector"   INPUT FEATURE_TYPE "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2_Reports"   OUTPUT FEATURE_TYPE "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_REPORTS"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_DOCUMENTS1762279341 Output Collector"   INPUT FEATURE_TYPE "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2_Documents"   OUTPUT FEATURE_TYPE "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_DOCUMENTS"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_MAP_VIEWERS1762279341 Output Collector"   INPUT FEATURE_TYPE "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_2_Map<space>Viewers"   OUTPUT FEATURE_TYPE "$(NT_CATALOGUE_READER_WORKSPACE_NAME)_MAP_VIEWERS"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(NT_CATALOGUE_READER_WORKSPACE_NAME))}]
