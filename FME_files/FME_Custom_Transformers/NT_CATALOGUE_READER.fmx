FACTORY_DEF {*} TestFactory FACTORY_NAME { $(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter } INPUT FEATURE_TYPE $(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_INPUTLINE FEATURE_TABLE_SHIM_SUPPORT Yes PASSED_TEST_GROUP_OUTPUT FIRST TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_category<closeparen>,$(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter) = Data ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_0 FEATURE_TYPE $(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_Data TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_category<closeparen>,$(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter) = Maps ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_1 FEATURE_TYPE $(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_Maps TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_category<closeparen>,$(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter) = WMS ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_2 FEATURE_TYPE $(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_WMS TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_category<closeparen>,$(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter) = Reports ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_3 FEATURE_TYPE $(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_Reports TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_category<closeparen>,$(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter) = Documents ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_4 FEATURE_TYPE $(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_Documents TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_category<closeparen>,$(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter) = Map<space>Viewers ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_5 FEATURE_TYPE $(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_Map<space>Viewers OUTPUT FAILED FEATURE_TYPE $(NT_CATALOGUE_READER_WORKSPACE_NAME)_TestFilter_Invalid<space>URL
