FACTORY_DEF {*} AttrSetFactory    COMMAND_PARM_EVALUATION SINGLE_PASS    FACTORY_NAME { $(NT_metadata_merger_WORKSPACE_NAME)_AttributeRenamer }    INPUT  FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_ListSorter_4_OUTPUT" 	ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    MISSING_INPUT_ATTR_HANDLING { RENAME_SET_DEFAULT PRESERVE }    KEEP_OUTPUT_ATTRS_ONLY { no } 	ATTR_ACTION { "record_create_list<opencurly>0<closecurly>.record_create_date" "record_create_date" "RENAME_SET_DEFAULT" "" }    OUTPUT { OUTPUT FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_AttributeRenamer_OUTPUT"        }
