FACTORY_DEF {*} ReferenceFactory    FACTORY_NAME { $(NT_metadata_merger_WORKSPACE_NAME)_FeatureMerger }    GROUP_BY { title }    FLUSH_WHEN_GROUPS_CHANGE { No }    INPUT REFERENCER FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_ListDuplicateRemover_3_OUTPUT"    INPUT REFERENCEE FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_ListConcatenator_OUTPUT"    INPUT REFERENCEE FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_AttributeRenamer_OUTPUT"    INPUT REFERENCEE FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_ListRenamer_OUTPUT"    CONNECT_Z_MODE { FIRST_WINS }    REFERENCE_INFO { $($(NT_metadata_merger_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO) }    REFERENCE_TABLE { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>title<closeparen>,$(NT_metadata_merger_WORKSPACE_NAME)_FeatureMerger) @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>title<closeparen>,$(NT_metadata_merger_WORKSPACE_NAME)_FeatureMerger) AUTO }    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "REQUESTOR_IF_CONFLICT" }    IGNORE_NULLS { "No" }    HANDLE_NULL_MISSING_KEYS_LIKE_FME2013 { No }    LIST_ATTRS_TO_INCLUDE { <Unused> }    LIST_ATTRS_TO_INCLUDE_MODE { <Unused> }    MERGE_ATTRIBUTES Yes    MANAGE_FME_TYPE Yes    MODE COMPLETE    PROCESS_DUPLICATE_REFERENCEES { YES }    REFERENCEES_FIRST { No }    REJECT_INVALID_GEOM YES    CLEANING_TOLERANCE { AUTO }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    COMPARE_WHITESPACE Yes    OUTPUT { COMPLETE FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_FeatureMerger_MERGED"         }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "notes_list<opencurly><closecurly> record_create_list<opencurly><closecurly>"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(NT_metadata_merger_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(NT_metadata_merger_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(NT_metadata_merger_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_FeatureMerger_MERGED"    OUTPUT { FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,fme_rejection_code,title.total_count)        $($(NT_metadata_merger_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(NT_metadata_merger_WORKSPACE_NAME)_AttributeExposer_16 }    INPUT  FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_AttributeRemover_OUTPUT"    OUTPUT { FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_AttributeExposer_16_OUTPUT"          }
# -------------------------------------------------------------------------
   FACTORY_DEF {*} NullAttributeMapperFactory       FACTORY_NAME { $(NT_metadata_merger_WORKSPACE_NAME)_NullAttributeMapperFactory }       INPUT  FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_AttributeExposer_16_OUTPUT"       ATTRCHOICE { SELECTED }       ATTRLIST { iso_topic<opencurly>0<closecurly>.topic_value notes record_create_date }       SOURCE_ATTR_VAL { SETNULL EMPTY MISSINGATTR }       OTHER_VAL { <quote><quote> }       REG_EXPR {  }       NULL_TREATMENT { DELETEATTR }       NEW_VAL { <Unused> }       OUTPUT { OUTPUT FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_NullAttributeMapper_OUTPUT" }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(NT_metadata_merger_WORKSPACE_NAME)_Junction_3 }    INPUT  FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_NullAttributeMapper_OUTPUT"    INPUT  FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_TestFilter_6_<lt>UNFILTERED<gt>"    OUTPUT { FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_Junction_3_Output"         }
# -------------------------------------------------------------------------
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NT_metadata_merger_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_3 Input Input Collector"   INPUT FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_Junction_3_Output"   OUTPUT FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_3_Input"
MACRO ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME $(NT_metadata_merger_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_3
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_XFORMER_NAME $(NT_metadata_merger_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_3
INCLUDE_CUSTOM_TRANSFORMER_VER ATTRIBUTE_UNEXPOSER:1
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NT_metadata_merger_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_3 Output Output Renamer/Nuker"   INPUT FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_3_Output"   OUTPUT FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_3_Output"
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(NT_metadata_merger_WORKSPACE_NAME)_Terminator }    INPUT  FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_DateTimeConverter_<REJECTED>"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"Date<space>format<space>not<space>recognized<space>by<space>FME<semicolon><space>modify<space>NT_metadata_merger")       @SupplyAttributes(_wb_termination_xformer,"$(NT_metadata_merger_WORKSPACE_NAME)_Terminator")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"Date<space>format<space>not<space>recognized<space>by<space>FME<semicolon><space>modify<space>NT_metadata_merger") }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NT_metadata_merger_WORKSPACE_NAME)_Output1762279433 Output Collector"   INPUT FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_3_Output"   OUTPUT FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_Output"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(NT_metadata_merger_WORKSPACE_NAME))}]
