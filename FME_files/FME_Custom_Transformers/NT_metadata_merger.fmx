FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(NT_metadata_merger_WORKSPACE_NAME)_ListBuilder_3_fme_type_remover }    INPUT  FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_AttributeExposer_3_OUTPUT_1_rq/fbS/libc="    OUTPUT { FEATURE_TYPE $(NT_metadata_merger_WORKSPACE_NAME)_ListBuilder_3_no_fme_type       @RemoveAttributes(fme_type,fme_geometry) }
FACTORY_DEF {*} ListFactory    FACTORY_NAME { $(NT_metadata_merger_WORKSPACE_NAME)_ListBuilder_3 }    INPUT { FEATURE_TYPE $(NT_metadata_merger_WORKSPACE_NAME)_ListBuilder_3_no_fme_type }    LIST_NAME { "notes_list" }    LIST_ATTRS_TO_INCLUDE { notes }    LIST_ATTRS_TO_INCLUDE_MODE { SELECTED }    GROUP_BY { title }    FLUSH_WHEN_GROUPS_CHANGE { No }    OUTPUT { LIST FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_ListBuilder_3_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(NT_metadata_merger_WORKSPACE_NAME)_AttributeExposer_6 }    INPUT  FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_ListBuilder_3_OUTPUT"    OUTPUT { FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_AttributeExposer_6_OUTPUT"          }
# -------------------------------------------------------------------------
Tcl2 proc $(NT_metadata_merger_WORKSPACE_NAME)_ListDuplicateRemover_5_removeDups {} {    set srcIndex 0;    regsub \"{}\" {notes_list{}.notes} \"{$srcIndex}\"    listKeyAttrName;    regsub \"{}.*$\" {notes_list{}.notes} \"\{\"          listBase;    regsub \"{}.*$\" {notes_list{}.notes} \"\{*\"         listBasePattern;    regsub \"{(}.*)$\" {notes_list{}.notes} {\1}          listSuffix;    regsub \"{}\" {notes_list{}.notes} \"\\{\[0-9\]*\\}\" listPatternRegExp;    set listPatternRegExp \"^$listPatternRegExp\$\";    set listIndexRegExp   \"^$listBase\(\[0-9\]+\)\}.*\";    set attributeNames [FME_AttributeNames];    set COMMENT {      = Iterate over all attributes. For any that look like src_list{n}.something,      = keep a list in the associative array "listAttributesByIndex(n)". If they      = actually match the key on which we're comparing, store a "true" in the      = associative array "listKeyAttrNameExists()"    };    foreach attrname $attributeNames {       if [regsub $listIndexRegExp $attrname {\1} listIndex] {         lappend listAttributesByIndex($listIndex) $attrname;         if {$attrname ==  \"$listBase$listIndex$listSuffix\"} {           set listKeyAttrNameExists($attrname) true;         };       };    };    set destIndex 0;    set listElementsPattern {};    set haveMissingLast true;    if [catch { set haveNextKey $listKeyAttrNameExists($listKeyAttrName); }] { set haveNextKey false; };    while {[array size listKeyAttrNameExists] > 0 || $haveMissingLast } {        set keyVal [FME_GetAttribute $listKeyAttrName];        if {![info exists dups($keyVal)] && [info exists listAttributesByIndex($srcIndex)]} {            set listElementsPattern \"$listBase$srcIndex\}*\"; 				   set foundSibling 0;            set COMMENT {              = We already have the list of attributes associated with this index. Deal              = with each one of these.            };            foreach listAttrName $listAttributesByIndex($srcIndex)            {               set destAttrName [string replace $listAttrName 0                                 [expr [string length $listElementsPattern] - 3]                                 \"$listBase$destIndex\""];               set destAttrVal [FME_GetAttribute $listAttrName];               if {$destAttrVal == {} && [FME_IsAttributeNull $listAttrName]} {               	   set destAttrVal {FME_NULL_VALUE};               };               set holder($destAttrName) $destAttrVal;               if {$foundSibling == 0  } {                   set dups($keyVal) {};                   set foundSibling 1;               };            };            if {$foundSibling && $keyVal == {} && ![FME_AttributeExists $listKeyAttrName]}            {               set dups($keyVal) {};               set missingAttrName [string replace $listKeyAttrName 0                                 [expr [string length $listElementsPattern] - 3]                                 \"$listBase$destIndex\""];               set holder($missingAttrName) {FME_MISSING_VAL};            };            if {$foundSibling} {                incr destIndex;            };        };        if $haveNextKey {          unset listKeyAttrNameExists($listKeyAttrName);        };        incr srcIndex;        regsub \"{}\" {notes_list{}.notes} \"{$srcIndex}\" listKeyAttrName;        if [catch { set haveNextKey $listKeyAttrNameExists($listKeyAttrName); }] { set haveNextKey false; };        if {[array size listKeyAttrNameExists] == 0} {            set COMMENT {              = Once we've exhausted all of the actual sort keys, keep looking for structured              = elements within the list that don't have an accompanying sort key.            };            set haveMissingLast [info exists listAttributesByIndex($srcIndex)];        };    };    foreach attrname $attributeNames { 		 if {[string match $listBasePattern $attrname]} { 		   FME_UnsetAttributes $attrname; 		 };    };    foreach newListAttrName [array names holder] {        if {$holder($newListAttrName) == {FME_NULL_VALUE}} {           FME_SetAttributeNull $newListAttrName        } elseif { $holder($newListAttrName) != {FME_MISSING_VAL} } {           FME_SetAttribute $newListAttrName $holder($newListAttrName);        };    }; };
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(NT_metadata_merger_WORKSPACE_NAME)_ListDuplicateRemover_5 }    INPUT  FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_AttributeExposer_6_OUTPUT"    OUTPUT { FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_ListDuplicateRemover_5_OUTPUT"         @Tcl2("$(NT_metadata_merger_WORKSPACE_NAME)_ListDuplicateRemover_5_removeDups")          }
# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {$(NT_metadata_merger_WORKSPACE_NAME)_ListConcatenator_a5a0bfa9_f23d_4d28_98ed_e0b6d853cc3b0} ]
Tcl2 set $(FME_UUID_SAFE)__separator [FME_DecodeText {<lf><lf>}];      regsub -all \"{}\" [FME_DecodeText {notes_list<opencurly><closecurly>.notes}] [FME_DecodeText {<opencurly><backslash>d+<closecurly>}] $(FME_UUID_SAFE)__listPattern;      set $(FME_UUID_SAFE)__listPattern ^$$(FME_UUID_SAFE)__listPattern$;
Tcl2 proc $(FME_UUID_SAFE)__Concatenate {} {   upvar \#0 $(FME_UUID_SAFE)__separator separator             $(FME_UUID_SAFE)__listPattern listPattern;   set allAttrs [lsort -dictionary [FME_AttributeNames]];   set keepEmptyParts [string equal {No} {No}];   set result {};   foreach attrName $allAttrs {     if {[regexp $listPattern $attrName]} {       set attrValue [FME_GetAttribute $attrName];       if {$keepEmptyParts || $attrValue != {}} {         lappend result $attrValue;       };     };   };   FME_SetAttribute [FME_DecodeText {"notes"}] [join $result $separator]; }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(NT_metadata_merger_WORKSPACE_NAME)_ListConcatenator }    INPUT  FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_ListDuplicateRemover_5_OUTPUT"    OUTPUT { FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_ListConcatenator_OUTPUT"         @Tcl2($(FME_UUID_SAFE)__Concatenate)          }
