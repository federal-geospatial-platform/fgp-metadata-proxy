FACTORY_DEF {*} DateTimeConverterFactory    FACTORY_NAME { $(NT_metadata_merger_WORKSPACE_NAME)_DateTimeConverter }    DATETIME_ATTR { "record_create_date" }    IN_FORMAT { "" }    OUT_FORMAT { "FME" }    REPAIR_INPUT { "YES" }    PASSTHROUGH { "YES" }    INPUT  FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_AttributeExposer_3_OUTPUT_2_dv7TmKdSxgc="    OUTPUT { OUTPUT FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_DateTimeConverter_OUTPUT"        }    OUTPUT { REJECTED FEATURE_TYPE "$(NT_metadata_merger_WORKSPACE_NAME)_DateTimeConverter_<REJECTED>"        }
