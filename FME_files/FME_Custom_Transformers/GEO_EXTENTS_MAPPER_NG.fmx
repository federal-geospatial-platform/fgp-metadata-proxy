MACRO LOOKUP_TABLES_READER_NG_WORKSPACE_NAME $(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_LOOKUP_TABLES_READER_NG
MACRO $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_TRANSFORMER_GROUP 
