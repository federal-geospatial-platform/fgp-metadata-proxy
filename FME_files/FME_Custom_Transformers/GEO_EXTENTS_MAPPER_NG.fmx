FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester_4 }    INPUT  FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_AttributeExposer_4_OUTPUT"    TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>east_bound_longitude<closeparen>,$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester_4)" < "@EvaluateExpression(FDIV,STRING_ENCODED,$($(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_LONGITUDE_MAX$encode),$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester_4)" ENCODED } TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>east_bound_longitude<closeparen>,$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester_4)" > "@EvaluateExpression(FDIV,STRING_ENCODED,$($(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_LONGITUDE_MIN$encode),$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester_4)" ENCODED } TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>north_bound_latitude<closeparen>,$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester_4)" < "@EvaluateExpression(FDIV,STRING_ENCODED,$($(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_LATITUDE_MAX$encode),$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester_4)" ENCODED } TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>north_bound_latitude<closeparen>,$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester_4)" > "@EvaluateExpression(FDIV,STRING_ENCODED,$($(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_LATITUDE_MIN$encode),$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester_4)" ENCODED } TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>south_bound_latitude<closeparen>,$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester_4)" < "@EvaluateExpression(FDIV,STRING_ENCODED,$($(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_LATITUDE_MAX$encode),$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester_4)" ENCODED } TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>south_bound_latitude<closeparen>,$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester_4)" > "@EvaluateExpression(FDIV,STRING_ENCODED,$($(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_LATITUDE_MIN$encode),$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester_4)" ENCODED } TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>west_bound_longitude<closeparen>,$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester_4)" < "@EvaluateExpression(FDIV,STRING_ENCODED,$($(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_LONGITUDE_MAX$encode),$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester_4)" ENCODED } TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>west_bound_longitude<closeparen>,$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester_4)" > "@EvaluateExpression(FDIV,STRING_ENCODED,$($(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_LONGITUDE_MIN$encode),$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester_4)" ENCODED } TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>north_bound_latitude<closeparen>,$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester_4)" > "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>south_bound_latitude<closeparen>,$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester_4)" ENCODED } TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>east_bound_longitude<closeparen>,$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester_4)" > "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>west_bound_longitude<closeparen>,$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester_4)" ENCODED }    BOOLEAN_OPERATOR { COMPOSITE }    COMPOSITE_TEST_EXPR { "1 AND 2 AND 3 AND 4 AND 5 AND 6 AND 7 AND 8 AND 9 AND 10" }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    OUTPUT { PASSED FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester_4_PASSED"         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_AttributeExposer_2 }    INPUT  FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_INPUT"    OUTPUT { FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_AttributeExposer_2_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester }    INPUT  FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_AttributeExposer_2_OUTPUT"    TEST { east_bound_longitude ATTRIBUTE_HAS_A_VALUE "" ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    OUTPUT { PASSED FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester_PASSED"         }    OUTPUT { FAILED FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester_FAILED"         }
# -------------------------------------------------------------------------
INCLUDE [if { {ATTRIBUTES} == {ATTRIBUTES} } {                puts "MACRO $(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO ATTRIBUTES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {POLYGONS}} {                puts "MACRO $(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO GEOM_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {AGGREGATES}} {                puts "MACRO $(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO $(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO GEOM_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {POLYGONS}} {                puts "MACRO $(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO GEOM_AND_ATTR_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {AGGREGATES}} {                puts "MACRO $(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO $(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO GEOM_AND_ATTR_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} } {                puts "MACRO $(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} } {                puts "MACRO $(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          else {}; ]
FACTORY_DEF {*} ReferenceFactory    FACTORY_NAME { $(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_FeatureMerger_2 }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT REFERENCER FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester_FAILED"    INPUT REFERENCEE FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester_4_PASSED"    REFERENCE_INFO { $($(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO) }    REFERENCE_TABLE { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>location<closeparen>,$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_FeatureMerger_2) @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>location<closeparen>,$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_FeatureMerger_2) AUTO }    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "REQUESTOR_IF_CONFLICT" }    IGNORE_NULLS { "No" }    HANDLE_NULL_MISSING_KEYS_LIKE_FME2013 { No }    LIST_ATTRS_TO_INCLUDE { <Unused> }    LIST_ATTRS_TO_INCLUDE_MODE { <Unused> }    MERGE_ATTRIBUTES Yes    MANAGE_FME_TYPE Yes    MODE COMPLETE    PROCESS_DUPLICATE_REFERENCEES { NO }    REFERENCEES_FIRST { No }    REJECT_INVALID_GEOM YES    CLEANING_TOLERANCE { <Unused> }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    COMPARE_WHITESPACE Yes    OUTPUT { COMPLETE FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_FeatureMerger_2_MERGED"         }    OUTPUT { INCOMPLETE FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_FeatureMerger_2_UNMERGED_REQUESTOR"         }    OUTPUT { REJECTED FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_FeatureMerger_2_<REJECTED>"         }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_FeatureMerger_2_MERGED"    OUTPUT { FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,location,<dollar><openparen>LOCATION_ATT<closeparen>)        $($(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Logger_48f0ddc8_4e38_4d79_814a_993f56ecf5810} ]
# If the Logger was in a custom transformer, the custom transformer's name was not being
# properly logged -- instead we saw "$(<customXformerName_WORKSPACE_NAME)" being logged as the prefix of the
# message. By deferencing and expanding out the XFORMER_NAME below, and then "WWJD" encoding it when it is
# used in the @Log call via the $encode macro name suffix trick, we get the right result, and the right result
# safely.
MACRO LOGGABLE_XFORMER_NAME $(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Logger
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Logger_Logger }    INPUT  FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_FeatureMerger_2_UNMERGED_REQUESTOR"    OUTPUT { FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Logger_LOGGED"                  @Log(ENCODED, "$(LOGGABLE_XFORMER_NAME$encode):<space>@EvaluateExpression(FDIV,STRING_ENCODED,lAttribute<space>value<space><at>Value<openparen>location<closeparen><space>missing<space>from<space>Coord<space>lookup<space>table<space>in<space>GEO_EXTENTS_MAPPER<space>transformer.<space><space>Bounding<space>box<space>coordinates<space>could<space>not<space>be<space>mapped<space>See<space>PROCESS_REPORT_MANUAL_TASKS.xls<space>file<space>for<space>details<space>in<space>XLS<space>directory<space>for<space>details.,$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Logger)","20","20","",WARN,LOG_ONLY,$(FME_UUID_SAFE))                   }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttributeKeeperFactory    FACTORY_NAME { $(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_AttributeKeeper }    INPUT  FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Logger_LOGGED"    KEEP_ATTRS { location,id }    KEEP_LISTS {  }    KEEP_FME_ATTRIBUTES Yes    BUILD_FEATURE_TABLES { NO }    OUTPUT_ON_ATTRIBUTE_CHANGE { <Unused> }    OUTPUT { OUTPUT FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_AttributeKeeper_OUTPUT"        }
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Terminator_4 }    INPUT  FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_FeatureMerger_2_<REJECTED>"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"Process<space>failed<space>at<space>Feature<space>Merger<comma><space>GEO_EXTENTS_MAPPER<space>transformer.<space><space>Translation<space>terminated.")       @SupplyAttributes(_wb_termination_xformer,"$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Terminator_4")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"Process<space>failed<space>at<space>Feature<space>Merger<comma><space>GEO_EXTENTS_MAPPER<space>transformer.<space><space>Translation<space>terminated.") }
# -------------------------------------------------------------------------
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Input Input Collector"   INPUT FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover_OUTPUT"   INPUT FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_Tester_PASSED"   OUTPUT FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Input"
MACRO ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME $(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_XFORMER_NAME $(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
INCLUDE_CUSTOM_TRANSFORMER_VER ATTRIBUTE_UNEXPOSER:1
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Output Output Renamer/Nuker"   INPUT FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_EXTENT_DEFINED1762277709 Output Collector"   INPUT FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_EXTENT_DEFINED"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_UNKNOWN_EXTENT1762277709 Output Collector"   INPUT FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_AttributeKeeper_OUTPUT"   OUTPUT FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_UNKNOWN_EXTENT"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME))}]
