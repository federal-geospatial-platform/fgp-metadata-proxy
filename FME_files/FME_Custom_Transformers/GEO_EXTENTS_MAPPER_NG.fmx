FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_AttributeExposer_4 }    INPUT  FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_LOOKUP_TABLES_READER_NG_Output"    OUTPUT { FEATURE_TYPE "$(GEO_EXTENTS_MAPPER_NG_WORKSPACE_NAME)_AttributeExposer_4_OUTPUT"          }
