#! <?xml version="1.0" encoding="UTF-8" ?>
#! <TRANSFORMER
# TRANSFORMER_BEGIN GEO_EXTENTS_MAPPER_NG,1,"""FGP Tools""",f8ef35a6-0112-4eab-85f7-d3263248efe7,"Linked by Default",No,NO_PARALLELISM,,No,25241,YES,No,313,No,
# <p><strong>Description </strong></p>
# <p>This custom transformer will add spatial extents to metadata records that do not have spatial extents.  For the matadata records without a spatial extent, the spatial extents are extracted from a lookup table based on the location attribute of the metadata record.  If the spatial extent is not set and the location is not present in the lookup table the spatial extent cannot be set and a description is added in the log file.</p>
# <p><strong>Input Ports </strong></p>
# <ul>
# <li>INPUT: The input metadata records to process.</li>
# </ul>
# <p><strong>Output Ports </strong></p>
# <ul>
# <li>
# <p>EXTENT_DEFINED: The output metdata records for which the spatial extent is defined (already present and/or added).</p>
# </li>
# <li>
# <p>UNKNOWN_EXTENT: The output metdata records for which the spatial extent is unknown (not defined).</p>
# </li>
# </ul>
# <p><strong>Parameters</strong></p>
# <ul>
# <li>
# <p>LATITUDE_MIN: Minimum latitude for all the entries of the lookup table;</p>
# </li>
# <li>
# <p>LATITUDE_MAX: Maximum latitude for all the entries of the lookup table;</p>
# </li>
# <li>
# <p>LONGITUDE_MIN: Minimum longitude for all the entries of the lookup table;</p>
# </li>
# <li>
# <p>LONGITUDE_MAX: Maximum longitude for all the entries of the lookup table;</p>
# </li>
# <li>
# <p>FEATURE_TYPE: Name of the CSV file to read (without .csv extension);</p>
# </li>
# <li>
# <p>IN_CSV_LOOKUP_TABLES_DIR: Name of the directory path containing the CSV file to read;</p>
# </li>
# <li>
# <p>P-T_ABBR: Two letters abbreviation of the province or the territory.</p>
# </li>
# </ul>
# TRANSFORMER_END
#!   A0_PREVIEW_IMAGE="data:image/png;base64,"
#!   ARCGIS_COMPATIBILITY="ARCGIS_AUTO"
#!   ATTR_TYPE_ENCODING="SDF"
#!   BLOCKED_LOOPING="No"
#!   CATEGORY="&quot;FGP Tools&quot;"
#!   DESCRIPTION="&lt;p&gt;&lt;strong&gt;Description &lt;/strong&gt;&lt;/p&gt;&#10;&lt;p&gt;This custom transformer will add spatial extents to metadata records that do not have spatial extents.  For the matadata records without a spatial extent, the spatial extents are extracted from a lookup table based on the location attribute of the metadata record.  If the spatial extent is not set and the location is not present in the lookup table the spatial extent cannot be set and a description is added in the log file.&lt;/p&gt;&#10;&lt;p&gt;&lt;strong&gt;Input Ports &lt;/strong&gt;&lt;/p&gt;&#10;&lt;ul&gt;&#10;&lt;li&gt;INPUT: The input metadata records to process.&lt;/li&gt;&#10;&lt;/ul&gt;&#10;&lt;p&gt;&lt;strong&gt;Output Ports &lt;/strong&gt;&lt;/p&gt;&#10;&lt;ul&gt;&#10;&lt;li&gt;&#10;&lt;p&gt;EXTENT_DEFINED: The output metdata records for which the spatial extent is defined (already present and/or added).&lt;/p&gt;&#10;&lt;/li&gt;&#10;&lt;li&gt;&#10;&lt;p&gt;UNKNOWN_EXTENT: The output metdata records for which the spatial extent is unknown (not defined).&lt;/p&gt;&#10;&lt;/li&gt;&#10;&lt;/ul&gt;&#10;&lt;p&gt;&lt;strong&gt;Parameters&lt;/strong&gt;&lt;/p&gt;&#10;&lt;ul&gt;&#10;&lt;li&gt;&#10;&lt;p&gt;LATITUDE_MIN: Minimum latitude for all the entries of the lookup table;&lt;/p&gt;&#10;&lt;/li&gt;&#10;&lt;li&gt;&#10;&lt;p&gt;LATITUDE_MAX: Maximum latitude for all the entries of the lookup table;&lt;/p&gt;&#10;&lt;/li&gt;&#10;&lt;li&gt;&#10;&lt;p&gt;LONGITUDE_MIN: Minimum longitude for all the entries of the lookup table;&lt;/p&gt;&#10;&lt;/li&gt;&#10;&lt;li&gt;&#10;&lt;p&gt;LONGITUDE_MAX: Maximum longitude for all the entries of the lookup table;&lt;/p&gt;&#10;&lt;/li&gt;&#10;&lt;li&gt;&#10;&lt;p&gt;FEATURE_TYPE: Name of the CSV file to read (without .csv extension);&lt;/p&gt;&#10;&lt;/li&gt;&#10;&lt;li&gt;&#10;&lt;p&gt;IN_CSV_LOOKUP_TABLES_DIR: Name of the directory path containing the CSV file to read;&lt;/p&gt;&#10;&lt;/li&gt;&#10;&lt;li&gt;&#10;&lt;p&gt;P-T_ABBR: Two letters abbreviation of the province or the territory.&lt;/p&gt;&#10;&lt;/li&gt;&#10;&lt;/ul&gt;"
