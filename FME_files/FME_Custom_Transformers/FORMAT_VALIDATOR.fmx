FACTORY_DEF * TeeFactory   FACTORY_NAME "$(FORMAT_VALIDATOR_WORKSPACE_NAME)_Input1762277646 Input Splitter"   INPUT FEATURE_TYPE "$(FORMAT_VALIDATOR_WORKSPACE_NAME)_Input"   OUTPUT FEATURE_TYPE "$(FORMAT_VALIDATOR_WORKSPACE_NAME)_Input"
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(FORMAT_VALIDATOR_WORKSPACE_NAME)_AttributeExposer }    INPUT  FEATURE_TYPE "$(FORMAT_VALIDATOR_WORKSPACE_NAME)_Input"    OUTPUT { FEATURE_TYPE "$(FORMAT_VALIDATOR_WORKSPACE_NAME)_AttributeExposer_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(FORMAT_VALIDATOR_WORKSPACE_NAME)_ListElementCounter }    INPUT  FEATURE_TYPE "$(FORMAT_VALIDATOR_WORKSPACE_NAME)_AttributeExposer_OUTPUT"    OUTPUT { FEATURE_TYPE "$(FORMAT_VALIDATOR_WORKSPACE_NAME)_ListElementCounter_OUTPUT"         @SupplyAttributes(ENCODED, _element_count, @NumElements("resources<opencurly><closecurly>",ENCODED))          }
# -------------------------------------------------------------------------
FME_PYTHON_PATH "$(FME_MF_DIR)"
FACTORY_DEF {*} PythonFactory    FACTORY_NAME { $(FORMAT_VALIDATOR_WORKSPACE_NAME)_PythonCaller }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT  FEATURE_TYPE "$(FORMAT_VALIDATOR_WORKSPACE_NAME)_ListElementCounter_OUTPUT"    SYMBOL_NAME { processFeature }    SOURCE_CODE { import<space>fme<lf>import<space>fmeobjects<lf><lf>#<space>Template<space>Function<space>interface:<lf>#<space>When<space>using<space>this<space>function<comma><space>make<space>sure<space>its<space>name<space>is<space>set<space>as<space>the<space>value<space>of<lf>#<space>the<space><apos>Class<space>or<space>Function<space>to<space>Process<space>Features<apos><space>transformer<space>parameter<lf><lf>def<space>processFeature<openparen>feature<closeparen>:<lf><space><space><space><space><lf><space><space><space><space>#<space>Looping<space>over<space>all<space>the<space>resources<lf><space><space><space><space>for<space>i<space>in<space>range<openparen>int<openparen>feature.getAttribute<openparen><apos>_element_count<apos><closeparen><closeparen><closeparen>:<space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space>format=feature.getAttribute<openparen><apos>resources<opencurly>%d<closecurly>.format<apos>%<openparen>i<closeparen><closeparen><lf><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space>url=feature.getAttribute<openparen><apos>resources<opencurly>%d<closecurly>.url<apos>%<openparen>i<closeparen><closeparen><lf><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space>#<space>Check<space>the<space>format<space>is<space>wms<lf><space><space><space><space><space><space><space><space>if<space><apos>wms<apos><space>in<space>format.lower<openparen><closeparen>:<lf><space><space><space><space><space><space><space><space><space><space><space><space>#Check<space>if<space>URL<space>is<space>a<space>WMS<space>query<lf><space><space><space><space><space><space><space><space><space><space><space><space>if<space>not<space><apos>service=wms<apos><space>in<space>url.lower<openparen><closeparen>:<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>#Change<space>format<space>attribute<space>to<space>other<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>format=feature.setAttribute<openparen><apos>resources<opencurly>%d<closecurly>.format<apos>%<openparen>i<closeparen><comma><apos>other<apos><closeparen><lf><space><space><space><space><space><space><space><space><lf><space><space><space><space><lf> }    PY_OUTPUT_TAGS { PYOUTPUT <Rejected> }    OUTPUT { PYOUTPUT FEATURE_TYPE "$(FORMAT_VALIDATOR_WORKSPACE_NAME)_PythonCaller_OUTPUT"         }    OUTPUT { <Rejected> FEATURE_TYPE "$(FORMAT_VALIDATOR_WORKSPACE_NAME)_PythonCaller_<Rejected>"         }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(FORMAT_VALIDATOR_WORKSPACE_NAME)_PythonCaller <Rejected> Transformer Output Nuker"   INPUT FEATURE_TYPE "$(FORMAT_VALIDATOR_WORKSPACE_NAME)_PythonCaller_<Rejected>"
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(FORMAT_VALIDATOR_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(FORMAT_VALIDATOR_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(FORMAT_VALIDATOR_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(FORMAT_VALIDATOR_WORKSPACE_NAME)_PythonCaller_OUTPUT"    OUTPUT { FEATURE_TYPE "$(FORMAT_VALIDATOR_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,_element_count)        $($(FORMAT_VALIDATOR_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(FORMAT_VALIDATOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Input Input Collector"   INPUT FEATURE_TYPE "$(FORMAT_VALIDATOR_WORKSPACE_NAME)_AttributeRemover_OUTPUT"   OUTPUT FEATURE_TYPE "$(FORMAT_VALIDATOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Input"
MACRO ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME $(FORMAT_VALIDATOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_XFORMER_NAME $(FORMAT_VALIDATOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
INCLUDE_CUSTOM_TRANSFORMER_VER ATTRIBUTE_UNEXPOSER:1
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(FORMAT_VALIDATOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Output Output Renamer/Nuker"   INPUT FEATURE_TYPE "$(FORMAT_VALIDATOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(FORMAT_VALIDATOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(FORMAT_VALIDATOR_WORKSPACE_NAME)_Output1762277646 Output Collector"   INPUT FEATURE_TYPE "$(FORMAT_VALIDATOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(FORMAT_VALIDATOR_WORKSPACE_NAME)_Output"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(FORMAT_VALIDATOR_WORKSPACE_NAME))}]
