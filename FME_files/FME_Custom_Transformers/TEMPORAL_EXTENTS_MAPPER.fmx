Tcl2 proc $(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_ListIndexer_indexer {index numElements prefix suffix} {    if {$index < 0 } {       set index [expr $numElements + $index];    };    regsub \"{}\" {resources{}} \"{$index}\" listWithIndex;    regsub \"{}\" {resources{}} {} listBase;    set complexListExp "$listWithIndex\.";    set prefixLength [expr [string length $complexListExp]-1];    set prefix [FME_DecodeText $prefix];    set suffix [FME_DecodeText $suffix];    foreach attr [FME_AttributeNames] {      set newAttr {};      if {$attr == $listWithIndex} {        set newAttr $listBase;      } elseif {[string first $complexListExp $attr] == 0} {        set newAttr [string replace $attr 0 $prefixLength];      };      if {$newAttr != {}} {          if {$prefix != {} } {            set newAttr $prefix$newAttr;          };          if {$suffix != {} } {            set newAttr $newAttr$suffix;          };          if {[string first {fme_} $newAttr] != 0} {              set first [string first {fme_} $newAttr];              lappend attrsToCopy $newAttr $attr;          };      };    };    if {[info exists attrsToCopy] && [llength $attrsToCopy] > 0} {      eval FME_Execute CopyAttributes $attrsToCopy;    }; }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_ListIndexer_IntTester }    INPUT  FEATURE_TYPE "$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_ListSearcher_FOUND"    TEST { "@EvaluateExpression(FDIV,FLOAT,<at>Value<openparen>_list_index<closeparen>,$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_ListIndexer)" TYPE INT ENCODED }    PRESERVE_FEATURE_ORDER PER_OUTPUT_PORT    OUTPUT { PASSED FEATURE_TYPE __toOutput__ }    OUTPUT { FAILED FEATURE_TYPE "$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_ListIndexer_<REJECTED>"       fme_rejection_code "INVALID_PARAMETER_LIST_INDEX"        }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_ListIndexer_ListIndexer }    INPUT FEATURE_TYPE __toOutput__    TEST { "@EvaluateExpression(FDIV,FLOAT,<at>Value<openparen>_list_index<closeparen>,$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_ListIndexer)" >= 0 }    OUTPUT PASSED FEATURE_TYPE "$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_ListIndexer_OUTPUT" @Tcl2("$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_ListIndexer_indexer @EvaluateExpression(FDIV,FLOAT,<at>Value<openparen>_list_index<closeparen>,$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_ListIndexer) 0 {_temp_} {}")    OUTPUT FAILED FEATURE_TYPE "$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_ListIndexer_OUTPUT" @Tcl2("$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_ListIndexer_indexer @EvaluateExpression(FDIV,FLOAT,<at>Value<openparen>_list_index<closeparen>,$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_ListIndexer) @NumElements(resources{}) {_temp_} {}")
