FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_Terminator_2 }    INPUT  FEATURE_TYPE "$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_ListIndexer_2_<REJECTED>"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"ListIndexer<space>failed:<space>Translation<space>Terminated")       @SupplyAttributes(_wb_termination_xformer,"$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_Terminator_2")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"ListIndexer<space>failed:<space>Translation<space>Terminated") }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_AttributeCreator_6 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_ListSearcher_2_NOT_FOUND"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "data_collection_end_date" "SET_TO" "" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_AttributeCreator_6_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} DateTimeConverterFactory    FACTORY_NAME { $(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_DateTimeConverter_3 }    DATETIME_ATTR { "data_collection_start_date data_collection_end_date" }    IN_FORMAT { "" }    OUT_FORMAT { "%Y-%m-%d" }    REPAIR_INPUT { "YES" }    PASSTHROUGH { "YES" }    INPUT  FEATURE_TYPE "$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_BulkAttributeRemover_2_OUTPUT"    INPUT  FEATURE_TYPE "$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_AttributeCreator_6_OUTPUT"    OUTPUT { OUTPUT FEATURE_TYPE "$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_DateTimeConverter_3_OUTPUT"        }    OUTPUT { REJECTED FEATURE_TYPE "$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_DateTimeConverter_3_<REJECTED>"        }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "resources<opencurly><closecurly>.data_collection_end_date resources<opencurly><closecurly>.data_collection_start_date"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_DateTimeConverter_3_OUTPUT"    OUTPUT { FEATURE_TYPE "$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,_list_index)        $($(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Input Input Collector"   INPUT FEATURE_TYPE "$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_AttributeRemover_OUTPUT"   OUTPUT FEATURE_TYPE "$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Input"
MACRO ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME $(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_XFORMER_NAME $(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
INCLUDE_CUSTOM_TRANSFORMER_VER ATTRIBUTE_UNEXPOSER:1
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Output Output Renamer/Nuker"   INPUT FEATURE_TYPE "$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_Terminator_3 }    INPUT  FEATURE_TYPE "$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_DateTimeConverter_3_<REJECTED>"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"Date<space>Time<space>Converter<space>failed:<space>Translation<space>Terminated")       @SupplyAttributes(_wb_termination_xformer,"$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_Terminator_3")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"Date<space>Time<space>Converter<space>failed:<space>Translation<space>Terminated") }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_OUTPUT1762281120 Output Collector"   INPUT FEATURE_TYPE "$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME)_OUTPUT"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(TEMPORAL_EXTENTS_MAPPER_WORKSPACE_NAME))}]
