DEFAULT_MACRO WB_CURRENT_CONTEXT
DEFAULT_MACRO ON_KEYWORD_RENAMER_WORKSPACE_NAME ""
INCLUDE [puts {MACRO WB_OLD_CONTEXT_$(ON_KEYWORD_RENAMER_WORKSPACE_NAME) $(WB_CURRENT_CONTEXT)};          puts {MACRO WB_CURRENT_CONTEXT $(ON_KEYWORD_RENAMER_WORKSPACE_NAME)}]
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_DATA_INPUT1762279761 Input Splitter"   INPUT FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_DATA_INPUT"   OUTPUT FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_DATA_INPUT"
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_AttributeExposer_4 }    INPUT  FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_DATA_INPUT"    OUTPUT { FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_AttributeExposer_4_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_Tester }    INPUT  FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_AttributeExposer_4_OUTPUT"    TEST { keywords.en<opencurly>0<closecurly> ATTRIBUTE_HAS_A_VALUE "" ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    OUTPUT { PASSED FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_Tester_PASSED"         }    OUTPUT { FAILED FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_Tester_FAILED"         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_AttributeCreator }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_Tester_FAILED"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "keywords.en<opencurly>0<closecurly>" "SET_TO" "<at>Value<openparen>default_keyword_en<closeparen>" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_AttributeCreator_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_Tester_2 }    INPUT  FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_Tester_PASSED"    INPUT  FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_AttributeCreator_OUTPUT"    TEST { keywords.fr<opencurly>0<closecurly> ATTRIBUTE_HAS_A_VALUE "" ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    OUTPUT { PASSED FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_Tester_2_PASSED"         }    OUTPUT { FAILED FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_Tester_2_FAILED"         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_AttributeCreator_2 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_Tester_2_FAILED"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "keywords.en<opencurly>0<closecurly>" "SET_TO" "<at>Value<openparen>default_keyword_fr<closeparen>" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_AttributeCreator_2_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_ListElementCounter }    INPUT  FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_Tester_2_PASSED"    INPUT  FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_AttributeCreator_2_OUTPUT"    OUTPUT { FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_ListElementCounter_OUTPUT"         @SupplyAttributes(ENCODED, nb_keywords_en, @NumElements("keywords.en<opencurly><closecurly>",ENCODED))          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_ListElementCounter_2 }    INPUT  FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_ListElementCounter_OUTPUT"    OUTPUT { FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_ListElementCounter_2_OUTPUT"         @SupplyAttributes(ENCODED, nb_keywords_fr, @NumElements("keywords.fr<opencurly><closecurly>",ENCODED))          }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "tags<opencurly><closecurly>"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_ListElementCounter_2_OUTPUT"    OUTPUT { FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,)        $($(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
# -------------------------------------------------------------------------
FME_PYTHON_PATH "$(FME_MF_DIR)"
FACTORY_DEF {*} PythonFactory    FACTORY_NAME { $(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_PythonCaller }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT  FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_AttributeRemover_OUTPUT"    SYMBOL_NAME { processFeature }    SOURCE_CODE { import<space>fme<lf>import<space>fmeobjects<lf>#<space>Template<space>Function<space>interface:<lf>#<space>When<space>using<space>this<space>function<comma><space>make<space>sure<space>its<space>name<space>is<space>set<space>as<space>the<space>value<space>of<lf>#<space>the<space><apos>Class<space>or<space>Function<space>to<space>Process<space>Features<apos><space>transformer<space>parameter<lf>def<space>processFeature<openparen>feature<closeparen>:<lf><space><space><space><space>nb_fr=int<openparen>feature.getAttribute<openparen><apos>nb_keywords_fr<apos><closeparen><closeparen><lf><space><space><space><space>nb_en=int<openparen>feature.getAttribute<openparen><apos>nb_keywords_en<apos><closeparen><closeparen><lf><space><space><space><space><lf><space><space><space><space><lf><space><space><space><space>if<space>nb_en==nb_fr:<lf><space><space><space><space><space><space><space><space>for<space>i<space>in<space>range<openparen>nb_en<closeparen>:<lf><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>tags<opencurly>%i<closecurly>.display_name<apos>%<openparen>i<closeparen><comma>feature.getAttribute<openparen><apos>keywords.en<opencurly>%i<closecurly><apos>%<openparen>i<closeparen><closeparen><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>tags<opencurly>%i<closecurly>.display_name_fr<apos>%<openparen>i<closeparen><comma>feature.getAttribute<openparen><apos>keywords.fr<opencurly>%i<closecurly><apos>%<openparen>i<closeparen><closeparen><closeparen><lf><space><space><space><space><lf><space><space><space><space><lf><space><space><space><space>else:<lf><space><space><space><space><space><space><space><space>for<space>i<space>in<space>range<openparen>nb_en<closeparen>:<lf><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>tags<opencurly>%i<closecurly>.display_name<apos>%<openparen>i<closeparen><comma>feature.getAttribute<openparen><apos>keywords.en<opencurly>%i<closecurly><apos>%<openparen>i<closeparen><closeparen><closeparen><lf><space><space><space><space><lf> }    PY_OUTPUT_TAGS { PYOUTPUT <Rejected> }    OUTPUT { PYOUTPUT FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_PythonCaller_OUTPUT"         }    OUTPUT { <Rejected> FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_PythonCaller_<Rejected>"         }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_PythonCaller <Rejected> Transformer Output Nuker"   INPUT FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_PythonCaller_<Rejected>"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_DATA_OUTPUT1762279761 Output Collector"   INPUT FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_PythonCaller_OUTPUT"   OUTPUT FEATURE_TYPE "$(ON_KEYWORD_RENAMER_WORKSPACE_NAME)_DATA_OUTPUT"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(ON_KEYWORD_RENAMER_WORKSPACE_NAME))}]
