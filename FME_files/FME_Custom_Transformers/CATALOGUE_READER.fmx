FACTORY_DEF {*} XFMapFactory    FACTORY_NAME { $(Catalogue_Reader_WORKSPACE_NAME)_XMLFlattener }    INPUT  FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_3_200<space>OK"    XML_STREAM { "_response_body"    }    XFMAP_FEATURE_PATHS_EXPRESSION { "SearchResults<space>GetRecordByIdResponse" }    XFMAP_FEATURE_PATHS_STRUCTURE { "<lf><lt>structure<space>separator=<quote>.<quote><space>map-empty-elements=<quote>yes<quote><space>matched-prefix=<quote>attributes<quote><space>matched-attributes=<quote>yes<quote><space>cardinality=<quote>+<opencurly>?<closecurly><quote><space>structure-prefix=<quote><quote><space>child-position-attribute=<quote><quote><space>except-expression=<quote><quote><space>ui-mode=<quote>basic<quote><space>matched-ancestor-attributes=<quote><quote><solidus><gt><lf>" }    IGNORE_DATASET_EXTERNAL_DTD { No }    DISABLE_EXTERNAL_ENTITY_PROCESSING { Yes }    ENTITY_RESOLVER { Yes }    OUTPUT_ONE_FEATURE_PER_INPUT yes    OUTPUT { MAPPED FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_XMLFlattener_OUTPUT"       }    OUTPUT { INVALID FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_XMLFlattener_<REJECTED>"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(Catalogue_Reader_WORKSPACE_NAME)_Tester }    INPUT  FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_XMLFlattener_OUTPUT"    TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>SearchResults.numberOfRecordsReturned<closeparen>,$(Catalogue_Reader_WORKSPACE_NAME)_Tester)" >= 2 ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_Tester_PASSED"         }    OUTPUT { FAILED FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_Tester_FAILED"         }
