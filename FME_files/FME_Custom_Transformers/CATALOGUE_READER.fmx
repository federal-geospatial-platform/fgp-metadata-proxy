FACTORY_DEF {*} TestFactory FACTORY_NAME { $(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_4 } INPUT FEATURE_TYPE $(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_4_INPUTLINE FEATURE_TABLE_SHIM_SUPPORT Yes PASSED_TEST_GROUP_OUTPUT FIRST TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_status_code<closeparen>,$(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_4) = 200 ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_0 FEATURE_TYPE $(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_4_200<space>OK TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_status_code<closeparen>,$(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_4) = 404 ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_1 FEATURE_TYPE $(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_4_404<space>Not<space>found OUTPUT FAILED FEATURE_TYPE $(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_4_Other<space>Error
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_4 Other<space>Error Transformer Output Nuker"   INPUT FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_4_Other<space>Error"
# -------------------------------------------------------------------------
FACTORY_DEF {*} JSONQueryFactory    FACTORY_NAME { $(Catalogue_Reader_WORKSPACE_NAME)_JSONFlattener_4 }    INPUT  FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_4_200<space>OK"    MODE FLATTEN    JSON_DOCUMENT { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_response_body<closeparen>,$(Catalogue_Reader_WORKSPACE_NAME)_JSONFlattener_4)" }    READ_FROM_FILE { NO }    FILEPATH_OR_URL { "<Unused>" }    EXPLODE_QUERY "json"    RECURSIVE_FLATTEN { YES }    ERROR_LIST_ATTR { "_json_error" }    OUTPUT { EXPLODED FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_JSONFlattener_4_OUTPUT"        }    OUTPUT { REJECTED FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_JSONFlattener_4_<REJECTED>"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(Catalogue_Reader_WORKSPACE_NAME)_AttributeExposer_3 }    INPUT  FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_JSONFlattener_4_OUTPUT"    OUTPUT { FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_AttributeExposer_3_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(Catalogue_Reader_WORKSPACE_NAME)_Junction }    INPUT  FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_BulkAttributeRenamer_OUTPUT"    INPUT  FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_AttributeExposer_3_OUTPUT"    OUTPUT { FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_Junction_Output"         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(Catalogue_Reader_WORKSPACE_NAME)_AttributeExposer }    INPUT  FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_Junction_Output"    OUTPUT { FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_AttributeExposer_OUTPUT"          }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(Catalogue_Reader_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC }    } else {        puts "MACRO $(Catalogue_Reader_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(Catalogue_Reader_WORKSPACE_NAME)_AttributeRemover_2 }    INPUT  FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_AttributeExposer_OUTPUT"    OUTPUT { FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"        @RemoveAttributes(fme_encoded,ErreurUUID,_csw_constraint,_csw_constraint_language,_csw_list_name,_csw_output_schema,_csw_search_criteria,_csw_typenames,_csw_version,_element_index,_id,_response_body,_status_code,_status_code_description,_type_requete,root_url,_creation_instance,_toto,_OpenMapsFilter,help,success)        $($(Catalogue_Reader_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(Catalogue_Reader_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Input Input Collector"   INPUT FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"   OUTPUT FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Input"
MACRO ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME $(Catalogue_Reader_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_XFORMER_NAME $(Catalogue_Reader_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
INCLUDE_CUSTOM_TRANSFORMER_VER ATTRIBUTE_UNEXPOSER:1
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(Catalogue_Reader_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Output Output Renamer/Nuker"   INPUT FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(Catalogue_Reader_WORKSPACE_NAME)_Terminator_2 }    INPUT  FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_JSONFlattener_4_<REJECTED>"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"Translation<space>Terminated.<space><space>Error<space>during<space>JSON<space>flattenning.")       @SupplyAttributes(_wb_termination_xformer,"$(Catalogue_Reader_WORKSPACE_NAME)_Terminator_2")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"Translation<space>Terminated.<space><space>Error<space>during<space>JSON<space>flattenning.") }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(Catalogue_Reader_WORKSPACE_NAME)_Junction_4 }    INPUT  FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_Junction_8_Output"    INPUT  FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_4_404<space>Not<space>found"    OUTPUT { FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_Junction_4_Output"         }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(Catalogue_Reader_WORKSPACE_NAME)_UUID_invalide1762275755 Output Collector"   INPUT FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_Tester_17_PASSED"   OUTPUT FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_UUID_invalide" @RemoveAttributes(root_url,_csw_constraint,_csw_constraint_language,_csw_list_name,_csw_output_schema,_csw_typenames,_csw_version,_id,ErreurUUID)
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(Catalogue_Reader_WORKSPACE_NAME)_Résultats1762275755 Output Collector"   INPUT FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_Résultats"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(Catalogue_Reader_WORKSPACE_NAME)_Métadonnées_non_trouvées1762275755 Output Collector"   INPUT FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_Junction_4_Output"   OUTPUT FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_Métadonnées_non_trouvées"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(Catalogue_Reader_WORKSPACE_NAME))}]
