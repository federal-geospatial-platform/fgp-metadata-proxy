FACTORY_DEF * TeeFactory   FACTORY_NAME "$(Catalogue_Reader_WORKSPACE_NAME)_Input1762275755 Input Splitter"   INPUT FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_Input"   OUTPUT FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_Input"
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(Catalogue_Reader_WORKSPACE_NAME)_AttributeCreator_20 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_Input"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "_csw_constraint" "SET_TO" "" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "_csw_constraint_language" "SET_TO" "FILTER" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "_csw_list_name" "SET_TO" "$($(Catalogue_Reader_WORKSPACE_NAME)_CUSTOM_CSW_LIST_NAME$encode)" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "_csw_output_schema" "SET_TO" "$($(Catalogue_Reader_WORKSPACE_NAME)_CUSTOM_CSW_SCHEMA$encode)" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "_csw_typenames" "SET_TO" "$($(Catalogue_Reader_WORKSPACE_NAME)_CUSTOM_URL_CSW_TYPENAMES$encode)" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "_csw_version" "SET_TO" "$($(Catalogue_Reader_WORKSPACE_NAME)_CUSTOM_CSW_VERSION$encode)" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "_id" "SET_TO" "$($(Catalogue_Reader_WORKSPACE_NAME)_IDENTIFIANT)" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "root_url" "SET_TO" "$($(Catalogue_Reader_WORKSPACE_NAME)_SOURCE_URL)" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_AttributeCreator_20_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(Catalogue_Reader_WORKSPACE_NAME)_Tester_15 }    INPUT  FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_AttributeCreator_20_OUTPUT"    TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,$($(Catalogue_Reader_WORKSPACE_NAME)_CUSTOM_URL$encode),$(Catalogue_Reader_WORKSPACE_NAME)_Tester_15)" != "" ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    OUTPUT { PASSED FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_Tester_15_PASSED"         }    OUTPUT { FAILED FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_Tester_15_FAILED"         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(Catalogue_Reader_WORKSPACE_NAME)_AttributeCreator_21 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_Tester_15_PASSED"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "root_url" "SET_TO" "$($(Catalogue_Reader_WORKSPACE_NAME)_CUSTOM_URL$encode)" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_AttributeCreator_21_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_2_INPUT }    INPUT  FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_AttributeCreator_21_OUTPUT"    INPUT  FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_Tester_15_FAILED"    OUTPUT { FEATURE_TYPE $(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_2_INPUTLINE }
FACTORY_DEF {*} TestFactory FACTORY_NAME { $(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_2 } INPUT FEATURE_TYPE $(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_2_INPUTLINE FEATURE_TABLE_SHIM_SUPPORT Yes PASSED_TEST_GROUP_OUTPUT FIRST TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_id<closeparen>,$(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_2) = "" ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_0 FEATURE_TYPE $(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_2_All OUTPUT FAILED FEATURE_TYPE $(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_2_By<space>ID
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(Catalogue_Reader_WORKSPACE_NAME)_AttributeCreator_30 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_2_All"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "_type_requete" "SET_TO" "-AllRecords" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_AttributeCreator_30_OUTPUT"        }
# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {$(Catalogue_Reader_WORKSPACE_NAME)_Logger_3_a2a3f81a_1204_4b1e_975a_aac0518d78f50} ]
# If the Logger was in a custom transformer, the custom transformer's name was not being
# properly logged -- instead we saw "$(<customXformerName_WORKSPACE_NAME)" being logged as the prefix of the
# message. By deferencing and expanding out the XFORMER_NAME below, and then "WWJD" encoding it when it is
# used in the @Log call via the $encode macro name suffix trick, we get the right result, and the right result
# safely.
MACRO LOGGABLE_XFORMER_NAME $(Catalogue_Reader_WORKSPACE_NAME)_Logger_3
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(Catalogue_Reader_WORKSPACE_NAME)_Logger_3_Logger }    INPUT  FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_2_By<space>ID"    OUTPUT { FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_Logger_3_LOGGED"                  @Log(ENCODED, "$(LOGGABLE_XFORMER_NAME$encode):<space>La<space>pr<u00e9>sence<space>d<apos>un<space>attribut<space><quote>Identifiant<quote><space>bypass<space>le<space>tri<space>par<space>attribut<space><quote>provider<quote>.","20","20","",WARN,LOG_ONLY,$(FME_UUID_SAFE))                   }
# -------------------------------------------------------------------------
