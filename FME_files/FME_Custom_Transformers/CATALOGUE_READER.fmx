FACTORY_DEF {*} TestFactory FACTORY_NAME { $(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_3 } INPUT FEATURE_TYPE $(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_3_INPUTLINE FEATURE_TABLE_SHIM_SUPPORT Yes PASSED_TEST_GROUP_OUTPUT FIRST TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_status_code<closeparen>,$(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_3) = 200 ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_0 FEATURE_TYPE $(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_3_200<space>OK TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_status_code<closeparen>,$(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_3) = 404 ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_1 FEATURE_TYPE $(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_3_404<space>Not<space>found OUTPUT FAILED FEATURE_TYPE $(Catalogue_Reader_WORKSPACE_NAME)_TestFilter_3_Other<space>Error
