FACTORY_DEF {*} ElementFactory    FACTORY_NAME { $(Catalogue_Reader_WORKSPACE_NAME)_ListExploder_3 }    INPUT  FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_Tester_PASSED"    LIST_NAME { "$($(Catalogue_Reader_WORKSPACE_NAME)_CUSTOM_CSW_LIST_NAME)" }    ELEMENT_NUMBER_FIELD { "_element_index" }    CLONE_GEOMETRY    ATTR_ACCUM_MODE { "PREFIX_INCOMING" }    ATTR_CONFLICT_RES { "<Unused>" }    INCOMING_PREFIX { "temp_name_." }    OUTPUT { ELEMENT FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_ListExploder_3_ELEMENTS"         @RemoveAttributes(ElementFactory.baseCloned)          }    OUTPUT { NOLIST FEATURE_TYPE "$(Catalogue_Reader_WORKSPACE_NAME)_ListExploder_3_<REJECTED>"         @RemoveAttributes(ElementFactory.baseCloned)         fme_rejection_code MISSING_PARAMETER_LIST          }
