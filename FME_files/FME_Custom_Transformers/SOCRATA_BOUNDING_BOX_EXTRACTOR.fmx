# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "dataLayers<opencurly><closecurly>.east_bound_longitudes dataLayers<opencurly><closecurly>.north_bound_latitudes dataLayers<opencurly><closecurly>.south_bound_latitudes dataLayers<opencurly><closecurly>.west_bound_longitudes"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_AttributeRemover_6_LIST_FUNC }    } else {        puts "MACRO $(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_AttributeRemover_6_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_AttributeRemover_6 }    INPUT  FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_ListRangeExtractor_4_OUTPUT"    OUTPUT { FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_AttributeRemover_6_OUTPUT"        @RemoveAttributes(fme_encoded,coordinatestring,bbox_json,uuidjoinkey)        $($(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_AttributeRemover_6_LIST_FUNC)         }
