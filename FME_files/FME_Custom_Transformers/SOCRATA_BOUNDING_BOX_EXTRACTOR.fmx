space><space><space> }    PY_OUTPUT_TAGS { PYOUTPUT <Rejected> }    OUTPUT { PYOUTPUT FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_PythonCaller_OUTPUT"         }    OUTPUT { <Rejected> FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_PythonCaller_<Rejected>"         }
