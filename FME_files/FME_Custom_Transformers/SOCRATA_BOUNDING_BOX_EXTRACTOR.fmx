FACTORY_DEF * TeeFactory   FACTORY_NAME "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_feature_input1762280794 Input Splitter"   INPUT FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_feature_input"   OUTPUT FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_feature_input"
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_AttributeExposer_2 }    INPUT  FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_feature_input"    OUTPUT { FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_AttributeExposer_2_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_Tester_2 }    INPUT  FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_AttributeExposer_2_OUTPUT"    TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>assetType<closeparen>,$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_Tester_2)" != href ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    OUTPUT { PASSED FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_Tester_2_PASSED"         }    OUTPUT { FAILED FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_Tester_2_FAILED"         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_UUIDGenerator_2 }    INPUT  FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_Tester_2_PASSED"    OUTPUT { FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_UUIDGenerator_2_OUTPUT"             "uuidjoinkey" @UUID(SIMPLE, UUID_FORMAT, UUID_ONLY)              }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_UUIDGenerator_2 OUTPUT Splitter"   INPUT FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_UUIDGenerator_2_OUTPUT"   OUTPUT FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_UUIDGenerator_2_OUTPUT_0_X4L38ErJlMo="   OUTPUT FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_UUIDGenerator_2_OUTPUT_1_oizpGeDGxN8="
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttributeKeeperFactory    FACTORY_NAME { $(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_AttributeKeeper_2 }    INPUT  FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_UUIDGenerator_2_OUTPUT_1_oizpGeDGxN8="    KEEP_ATTRS { uuidjoinkey }    KEEP_LISTS { dataLayers<opencurly><closecurly> }    KEEP_FME_ATTRIBUTES Yes    BUILD_FEATURE_TABLES { NO }    OUTPUT_ON_ATTRIBUTE_CHANGE { <Unused> }    OUTPUT { OUTPUT FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_AttributeKeeper_2_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} ElementFactory    FACTORY_NAME { $(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_ListExploder_2 }    INPUT  FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_AttributeKeeper_2_OUTPUT"    LIST_NAME { "dataLayers{}" }    ELEMENT_NUMBER_FIELD { "_element_index" }    CLONE_GEOMETRY    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "INCOMING_IF_CONFLICT" }    INCOMING_PREFIX { "<Unused>" }    OUTPUT { ELEMENT FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_ListExploder_2_ELEMENTS"         @RemoveAttributes(ElementFactory.baseCloned)          }    OUTPUT { NOLIST FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_ListExploder_2_<REJECTED>"         @RemoveAttributes(ElementFactory.baseCloned)         fme_rejection_code MISSING_PARAMETER_LIST          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_Tester }    INPUT  FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_ListExploder_2_ELEMENTS"    TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>layerid<closeparen>,$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_Tester)" != "" ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    OUTPUT { PASSED FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_Tester_PASSED"         }
# -------------------------------------------------------------------------
DEFAULT_MACRO $(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_StringConcatenator_4e15c1ad_b502_44f2_94ff_449a7f8e26110_ATTRS_TO_EVALUATE
INCLUDE [    if {{OUTGOING} == {OUTGOING}} {       if {[string length {GeoAPIEndpoint}] == 0} { return; };       set attrs [list {GeoAPIEndpoint}];    } else {       set attrs [split {<Unused>} { }];    };    set clauses {};    foreach attr $attrs {       lappend clauses "ATTR";       lappend clauses "{";       lappend clauses $attr;       lappend clauses {"$($(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_DOMAIN$encode)<solidus>resources<solidus><at>Value<openparen>layerid<closeparen>.geojson"};       lappend clauses "}";    };    puts "MACRO $(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_StringConcatenator_4e15c1ad_b502_44f2_94ff_449a7f8e26110_ATTRS_TO_EVALUATE [join $clauses { }]"; ]
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_StringConcatenator }    INPUT  FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_Tester_PASSED"    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    $($(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_StringConcatenator_4e15c1ad_b502_44f2_94ff_449a7f8e26110_ATTRS_TO_EVALUATE)    OUTPUT { OUTPUT FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_StringConcatenator_OUTPUT"        }
# -------------------------------------------------------------------------
# Combine the two "file path attribute" parameters into one value.
DEFAULT_MACRO $(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_HTTPCaller_2_FILE_PATH_ATTR
INCLUDE [ 	if { {<Unused>} == {<Unused>} } { 		puts {MACRO $(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_HTTPCaller_2_FILE_PATH_ATTR "<Unused>"}; 	} else { 		puts {MACRO $(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_HTTPCaller_2_FILE_PATH_ATTR "<Unused>"}; 	} ]
FACTORY_DEF {*} HTTPFactory    FACTORY_NAME { $(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_HTTPCaller_2 }       INPUT  FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_StringConcatenator_OUTPUT"    TARGET_URL { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>GeoAPIEndpoint<closeparen>?<dollar>select=extent<openparen><at>Value<openparen>geomcol<closeparen><closeparen>,$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_HTTPCaller_2)" }    HTTP_METHOD { GET }    SAVE_FILE { NO }    OUTPUT_FILENAME { "<Unused>" }    OUTPUT_DIRECTORY { "<Unused>" }    FILE_EXTENSION { "<Unused>" }    TARGET_ATTR { "bbox_json" }    FILE_PATH_ATTR { $($(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_HTTPCaller_2_FILE_PATH_ATTR) }    UPLOAD_FILE { "<Unused>" }    UPLOAD_BODY { "<Unused>" }    UPLOAD_TYPE { <Unused> }    UPLOAD_CONTENT_TYPE { "<Unused>" }    COMBINED_MULTIPART_TABLE {  }    MULTIPART_CONTENT_TYPE { <Unused> }    REQUEST_HEADER_TABLE { X-App-Token;@EvaluateExpression(FDIV,STRING_ENCODED,$($(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_SocrataAppToken$encode),$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_HTTPCaller_2) }    ADDITIONAL_URL_PARAMETERS {  }    AUTH_USERNAME { "<Unused>" }    AUTH_PASSWORD { "<Unused>" }    AUTH_METHOD { "<Unused>" }    TARGET_ATTRIBUTE_ENCODING { auto-detect }    RESPONSE_HEADER_LIST_ATTR { "" }    STATUS_CODE_ATTR { "_http_status_code" }    ERROR_ATTR { "_error" }    CONNECTION_TIMEOUT_LENGTH { 60 }    TRANSFER_TIMEOUT_LENGTH { 90 }    FOLLOW_REDIRECTS { FOLLOW_WITH_ORIGINAL_METHOD }    REDIRECT_AUTH { ORIGINAL_DOMAIN_ONLY }    VERIFY_SSL_CERTIFICATES { No }    NAMED_CONNECTION { "<Unused>" }    USE_COOKIES { No }    MAX_TRANSFERS_IN_PROGRESS { 25 }    MAX_HTTP_VERSION { HTTP_2 }    RATE_LIMIT_MAX_REQUESTS { <Unused> }    RATE_LIMIT_INTERVAL_IN_SECONDS { <Unused> }    RATE_LIMIT_REQUEST_TIMING { <Unused> }    RETRY_FAILED_TRANSFERS { <Unused> }    RETRY_MAX_RETRIES { <Unused> }    RETRY_INITIAL_BACKOFF { <Unused> }    SPLIT_MULTIPART_RESPONSE { NO }    MULTIPART_RESPONSE_HEADER_LIST_ATTR { "<Unused>" }    MINIMUM_ENCRYPTION_LEVEL { "OS_DEFAULT" }    CLIENT_CERTIFICATE_TYPE { "NONE" }    CLIENT_CERTIFICATE_FROM_OS { "<Unused>" }    CLIENT_CERTIFICATE_FILE { "<Unused>" }    CLIENT_CERTIFICATE_PRIVATE_KEY_FILE { "<Unused>" }    CLIENT_CERTIFICATE_PASSWORD { "<Unused>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_HTTPCaller_2_Output"          }    OUTPUT { REJECTED FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_HTTPCaller_2_<REJECTED>"          }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_HTTPCaller_2_Output"    OUTPUT { FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,_http_status_code)        $($(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
