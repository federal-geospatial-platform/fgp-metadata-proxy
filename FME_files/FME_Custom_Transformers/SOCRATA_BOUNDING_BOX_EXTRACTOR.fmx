# -------------------------------------------------------------------------
Tcl2 proc $(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_ListRangeExtractor_minmaxer {} {    set firstTime 1;    set min {};    set max {};    foreach attr [FME_AttributeNames] {    		 regsub -all \"{\[0-9\]+}\" $attr \"{}\" flatAttr;        if {$flatAttr == \"dataLayers{}.north_bound_latitudes\" }        {          set attrVal [FME_GetAttribute $attr];          set checkAttr 1;          if {$attrVal == {} && [FME_IsAttributeNull $attr]}          {    	       set checkAttr 0;          };          if {$checkAttr} { 		         if {$firstTime} { 		           set min $attrVal; 		           set max $attrVal; 		           set firstTime 0; 		         } else { 		           if {$attrVal < $min} {set min $attrVal}; 		           if {$attrVal > $max} {set max $attrVal};  		         }; 		     }; 	     };    };    FME_SetAttribute {"minnorth"} $min;    FME_SetAttribute {"north_bound_latitude"} $max; }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_ListRangeExtractor }    INPUT  FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_FeatureMerger_2_MERGED"    OUTPUT { FEATURE_TYPE "$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_ListRangeExtractor_OUTPUT"         @Tcl2("$(SOCRATA_BOUNDING_BOX_EXTRACTOR_WORKSPACE_NAME)_ListRangeExtractor_minmaxer")          }
