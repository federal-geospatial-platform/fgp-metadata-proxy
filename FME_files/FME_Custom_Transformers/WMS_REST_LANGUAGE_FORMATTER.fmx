# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {$(WMS_REST_LANGUAGE_FORMATTER_WORKSPACE_NAME)_JSONExtractor__Rejected__1064519a_9c04_4530_a2c0_5cced6a486ef0} ]
# If the Logger was in a custom transformer, the custom transformer's name was not being
# properly logged -- instead we saw "$(<customXformerName_WORKSPACE_NAME)" being logged as the prefix of the
# message. By deferencing and expanding out the XFORMER_NAME below, and then "WWJD" encoding it when it is
# used in the @Log call via the $encode macro name suffix trick, we get the right result, and the right result
# safely.
MACRO LOGGABLE_XFORMER_NAME $(WMS_REST_LANGUAGE_FORMATTER_WORKSPACE_NAME)_JSONExtractor__Rejected_
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(WMS_REST_LANGUAGE_FORMATTER_WORKSPACE_NAME)_JSONExtractor__Rejected__Logger }    INPUT  FEATURE_TYPE "$(WMS_REST_LANGUAGE_FORMATTER_WORKSPACE_NAME)_JSONExtractor_<REJECTED>"    OUTPUT { FEATURE_TYPE "$(WMS_REST_LANGUAGE_FORMATTER_WORKSPACE_NAME)_JSONExtractor__Rejected__LOGGED"                  @Log(ENCODED, "$(LOGGABLE_XFORMER_NAME$encode):<space>@EvaluateExpression(FDIV,STRING_ENCODED,REJECTED:<space><at>Value<openparen>url<closeparen><lf><lf>body:<space><lf><at>Value<openparen>_response_body<closeparen>,$(WMS_REST_LANGUAGE_FORMATTER_WORKSPACE_NAME)_JSONExtractor__Rejected_)","20","20","",INFO,LOG_ONLY,$(FME_UUID_SAFE))                   }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(WMS_REST_LANGUAGE_FORMATTER_WORKSPACE_NAME)_JSONExtractor__Rejected_ LOGGED Transformer Output Nuker"   INPUT FEATURE_TYPE "$(WMS_REST_LANGUAGE_FORMATTER_WORKSPACE_NAME)_JSONExtractor__Rejected__LOGGED"
