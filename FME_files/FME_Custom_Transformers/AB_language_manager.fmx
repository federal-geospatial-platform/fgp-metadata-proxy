MACRO ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME $(AB_language_manager_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_XFORMER_NAME $(AB_language_manager_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
INCLUDE_CUSTOM_TRANSFORMER_VER ATTRIBUTE_UNEXPOSER:1
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(AB_language_manager_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Output Output Renamer/Nuker"   INPUT FEATURE_TYPE "$(AB_language_manager_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(AB_language_manager_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(AB_language_manager_WORKSPACE_NAME)_output1762274661 Output Collector"   INPUT FEATURE_TYPE "$(AB_language_manager_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(AB_language_manager_WORKSPACE_NAME)_output"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(AB_language_manager_WORKSPACE_NAME)_res_url_unknown_language1762274661 Output Collector"   INPUT FEATURE_TYPE "$(AB_language_manager_WORKSPACE_NAME)_Tester_PASSED"   OUTPUT FEATURE_TYPE "$(AB_language_manager_WORKSPACE_NAME)_res_url_unknown_language" @RemoveAttributes(order,resources_url,language,_list_index,language_error,_element_index) @RemoveAttributes(fme_regexp_match,language{})
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(AB_language_manager_WORKSPACE_NAME))}]
