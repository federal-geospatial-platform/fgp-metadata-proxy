space><space><space><space><space><space><space><space><space><space>self.dict<openbracket>url_key<closebracket><space>=<space>language<lf><space><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space>elif<space>order<space>==<space>2:<space><space><space><space><space><space><space><space><space><lf><lf><space><space><space><space><space><space><space><space><space><space><space>max_index=FME_utils.max_index_attribute_list<openparen>feature<comma><apos>resources<opencurly><closecurly>.url<apos><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space>for<space>j<space>in<space>range<openparen>max_index+1<closeparen>:<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space>url<space>=<space>feature.getAttribute<openparen><apos>resources<opencurly>%i<closecurly>.url<apos>%<openparen>j<closeparen><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space>if<space>url<space>not<space>in<space>self.dict.keys<openparen><closeparen>:<space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>#if<space>url<space>not<space>in<space>the<space>lookup<space>table<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>resources<opencurly>%i<closecurly>.language_error<apos>%<openparen>j<closeparen><comma><apos>yes<apos><closeparen><space><space><space>#add<space>a<space>list.attribute<space><apos>.language_error<apos><space>to<space>the<space><apos>resources<apos><space>list<space>and<space>set<space>it<space>to<space><apos>yes<apos><space><lf><space><space><space><space><spa