FACTORY_DEF * TeeFactory   FACTORY_NAME "$(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_Input1762274622 Input Splitter"   INPUT FEATURE_TYPE "$(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_Input"   OUTPUT FEATURE_TYPE "$(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_Input"
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttributeFactory    FACTORY_NAME { $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_AttributeExploder }    INPUT  FEATURE_TYPE "$(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_Input"    ATTR_NAME_LABEL { "_attr_name" }    ATTR_VALUE_LABEL { "_attr_value" }    KEEP_GEOMETRY { No }    KEEP_ATTRIBUTES { No }    IGNORE_ATTRIBUTES_CONTAINING_REGEX {  }    IGNORE_ATTRIBUTES_CASE_SENSITIVE { No }    EXPLODING_TYPE { EXPLODE_AS_LIST }    LIST_NAME { "_attr_list" }    COMMAND_PARM_EVALUATION SINGLE_PASS    OUTPUT { EXPLODED FEATURE_TYPE "$(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_AttributeExploder_OUTPUT"        }
