FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_ListElementCounter }    INPUT  FEATURE_TYPE "$(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_AttributeExploder_OUTPUT"    OUTPUT { FEATURE_TYPE "$(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_ListElementCounter_OUTPUT"         @SupplyAttributes(ENCODED, _element_count, @NumElements("_attr_list<opencurly><closecurly>",ENCODED))          }
