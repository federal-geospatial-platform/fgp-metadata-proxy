INCLUDE [puts {MACRO WB_OLD_CONTEXT_$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME) $(WB_CURRENT_CONTEXT)};          puts {MACRO WB_CURRENT_CONTEXT $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)}]
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_INPUT1762277785 Input Splitter"   INPUT FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_INPUT"   OUTPUT FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_INPUT"
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_AttributeExposer_2 }    INPUT  FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_INPUT"    OUTPUT { FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_AttributeExposer_2_OUTPUT"          }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "distributionList<opencurly><closecurly>"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_AttributeRemover_3_LIST_FUNC }    } else {        puts "MACRO $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_AttributeRemover_3_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_AttributeRemover_3 }    INPUT  FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_AttributeExposer_2_OUTPUT"    OUTPUT { FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_AttributeRemover_3_OUTPUT"        @RemoveAttributes(fme_encoded,)        $($(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_AttributeRemover_3_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_ListCopier_2 }    INPUT  FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_AttributeRemover_3_OUTPUT"    OUTPUT { FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_ListCopier_2_OUTPUT"         @CopyAttributes(ENCODED,EXACT_LIST_MATCH,distributionList{},resources<opencurly><closecurly>)          }
# -------------------------------------------------------------------------
Tcl2 proc $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_ListDuplicateRemover_3_removeDups {} {    set srcIndex 0;    regsub \"{}\" {distributionList{}.format} \"{$srcIndex}\"    listKeyAttrName;    regsub \"{}.*$\" {distributionList{}.format} \"\{\"          listBase;    regsub \"{}.*$\" {distributionList{}.format} \"\{*\"         listBasePattern;    regsub \"{(}.*)$\" {distributionList{}.format} {\1}          listSuffix;    regsub \"{}\" {distributionList{}.format} \"\\{\[0-9\]*\\}\" listPatternRegExp;    set listPatternRegExp \"^$listPatternRegExp\$\";    set listIndexRegExp   \"^$listBase\(\[0-9\]+\)\}.*\";    set attributeNames [FME_AttributeNames];    set COMMENT {      = Iterate over all attributes. For any that look like src_list{n}.something,      = keep a list in the associative array "listAttributesByIndex(n)". If they      = actually match the key on which we're comparing, store a "true" in the      = associative array "listKeyAttrNameExists()"    };    foreach attrname $attributeNames {       if [regsub $listIndexRegExp $attrname {\1} listIndex] {         lappend listAttributesByIndex($listIndex) $attrname;         if {$attrname ==  \"$listBase$listIndex$listSuffix\"} {           set listKeyAttrNameExists($attrname) true;         };       };    };    set destIndex 0;    set listElementsPattern {};    set haveMissingLast true;    if [catch { set haveNextKey $listKeyAttrNameExists($listKeyAttrName); }] { set haveNextKey false; };    while {[array size listKeyAttrNameExists] > 0 || $haveMissingLast } {        set keyVal [FME_GetAttribute $listKeyAttrName];        if {![info exists dups($keyVal)] && [info exists listAttributesByIndex($srcIndex)]} {            set listElementsPattern \"$listBase$srcIndex\}*\"; 				   set foundSibling 0;            set COMMENT {              = We already have the list of attributes associated with this index. Deal              = with each one of these.            };            foreach listAttrName $listAttributesByIndex($srcIndex)            {               set destAttrName [string replace $listAttrName 0                                 [expr [string length $listElementsPattern] - 3]                                 \"$listBase$destIndex\""];               set destAttrVal [FME_GetAttribute $listAttrName];               if {$destAttrVal == {} && [FME_IsAttributeNull $listAttrName]} {               	   set destAttrVal {FME_NULL_VALUE};               };               set holder($destAttrName) $destAttrVal;               if {$foundSibling == 0  } {                   set dups($keyVal) {};                   set foundSibling 1;               };            };            if {$foundSibling && $keyVal == {} && ![FME_AttributeExists $listKeyAttrName]}            {               set dups($keyVal) {};               set missingAttrName [string replace $listKeyAttrName 0                                 [expr [string length $listElementsPattern] - 3]                                 \"$listBase$destIndex\""];               set holder($missingAttrName) {FME_MISSING_VAL};            };            if {$foundSibling} {                incr destIndex;            };        };        if $haveNextKey {          unset listKeyAttrNameExists($listKeyAttrName);        };        incr srcIndex;        regsub \"{}\" {distributionList{}.format} \"{$srcIndex}\" listKeyAttrName;        if [catch { set haveNextKey $listKeyAttrNameExists($listKeyAttrName); }] { set haveNextKey false; };        if {[array size listKeyAttrNameExists] == 0} {            set COMMENT {              = Once we've exhausted all of the actual sort keys, keep looking for structured              = elements within the list that don't have an accompanying sort key.            };            set haveMissingLast [info exists listAttributesByIndex($srcIndex)];        };    };    foreach attrname $attributeNames { 		 if {[string match $listBasePattern $attrname]} { 		   FME_UnsetAttributes $attrname; 		 };    };    foreach newListAttrName [array names holder] {        if {$holder($newListAttrName) == {FME_NULL_VALUE}} {           FME_SetAttributeNull $newListAttrName        } elseif { $holder($newListAttrName) != {FME_MISSING_VAL} } {           FME_SetAttribute $newListAttrName $holder($newListAttrName);        };    }; };
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_ListDuplicateRemover_3 }    INPUT  FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_ListCopier_2_OUTPUT"    OUTPUT { FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_ListDuplicateRemover_3_OUTPUT"         @Tcl2("$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_ListDuplicateRemover_3_removeDups")          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_ListCopier }    INPUT  FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_ListDuplicateRemover_3_OUTPUT"    OUTPUT { FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_ListCopier_OUTPUT"         @CopyAttributes(ENCODED,EXACT_LIST_MATCH,projectionList{},resources<opencurly><closecurly>)          }
# -------------------------------------------------------------------------
Tcl2 proc $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_ListDuplicateRemover_2_removeDups {} {    set srcIndex 0;    regsub \"{}\" {projectionList{}.projection_name} \"{$srcIndex}\"    listKeyAttrName;    regsub \"{}.*$\" {projectionList{}.projection_name} \"\{\"          listBase;    regsub \"{}.*$\" {projectionList{}.projection_name} \"\{*\"         listBasePattern;    regsub \"{(}.*)$\" {projectionList{}.projection_name} {\1}          listSuffix;    regsub \"{}\" {projectionList{}.projection_name} \"\\{\[0-9\]*\\}\" listPatternRegExp;    set listPatternRegExp \"^$listPatternRegExp\$\";    set listIndexRegExp   \"^$listBase\(\[0-9\]+\)\}.*\";    set attributeNames [FME_AttributeNames];    set COMMENT {      = Iterate over all attributes. For any that look like src_list{n}.something,      = keep a list in the associative array "listAttributesByIndex(n)". If they      = actually match the key on which we're comparing, store a "true" in the      = associative array "listKeyAttrNameExists()"    };    foreach attrname $attributeNames {       if [regsub $listIndexRegExp $attrname {\1} listIndex] {         lappend listAttributesByIndex($listIndex) $attrname;         if {$attrname ==  \"$listBase$listIndex$listSuffix\"} {           set listKeyAttrNameExists($attrname) true;         };       };    };    set destIndex 0;    set listElementsPattern {};    set haveMissingLast true;    if [catch { set haveNextKey $listKeyAttrNameExists($listKeyAttrName); }] { set haveNextKey false; };    while {[array size listKeyAttrNameExists] > 0 || $haveMissingLast } {        set keyVal [FME_GetAttribute $listKeyAttrName];        if {![info exists dups($keyVal)] && [info exists listAttributesByIndex($srcIndex)]} {            set listElementsPattern \"$listBase$srcIndex\}*\"; 				   set foundSibling 0;            set COMMENT {              = We already have the list of attributes associated with this index. Deal              = with each one of these.            };            foreach listAttrName $listAttributesByIndex($srcIndex)            {               set destAttrName [string replace $listAttrName 0                                 [expr [string length $listElementsPattern] - 3]                                 \"$listBase$destIndex\""];               set destAttrVal [FME_GetAttribute $listAttrName];               if {$destAttrVal == {} && [FME_IsAttributeNull $listAttrName]} {               	   set destAttrVal {FME_NULL_VALUE};               };               set holder($destAttrName) $destAttrVal;               if {$foundSibling == 0  } {                   set dups($keyVal) {};                   set foundSibling 1;               };            };            if {$foundSibling && $keyVal == {} && ![FME_AttributeExists $listKeyAttrName]}            {               set dups($keyVal) {};               set missingAttrName [string replace $listKeyAttrName 0                                 [expr [string length $listElementsPattern] - 3]                                 \"$listBase$destIndex\""];               set holder($missingAttrName) {FME_MISSING_VAL};            };            if {$foundSibling} {                incr destIndex;            };        };        if $haveNextKey {          unset listKeyAttrNameExists($listKeyAttrName);        };        incr srcIndex;        regsub \"{}\" {projectionList{}.projection_name} \"{$srcIndex}\" listKeyAttrName;        if [catch { set haveNextKey $listKeyAttrNameExists($listKeyAttrName); }] { set haveNextKey false; };        if {[array size listKeyAttrNameExists] == 0} {            set COMMENT {              = Once we've exhausted all of the actual sort keys, keep looking for structured              = elements within the list that don't have an accompanying sort key.            };            set haveMissingLast [info exists listAttributesByIndex($srcIndex)];        };    };    foreach attrname $attributeNames { 		 if {[string match $listBasePattern $attrname]} { 		   FME_UnsetAttributes $attrname; 		 };    };    foreach newListAttrName [array names holder] {        if {$holder($newListAttrName) == {FME_NULL_VALUE}} {           FME_SetAttributeNull $newListAttrName        } elseif { $holder($newListAttrName) != {FME_MISSING_VAL} } {           FME_SetAttribute $newListAttrName $holder($newListAttrName);        };    }; };
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_ListDuplicateRemover_2 }    INPUT  FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_ListCopier_OUTPUT"    OUTPUT { FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_ListDuplicateRemover_2_OUTPUT"         @Tcl2("$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_ListDuplicateRemover_2_removeDups")          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_ListCopier_3 }    INPUT  FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_ListDuplicateRemover_2_OUTPUT"    OUTPUT { FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_ListCopier_3_OUTPUT"         @CopyAttributes(ENCODED,EXACT_LIST_MATCH,updateList{},resources<opencurly><closecurly>)          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_UUIDGenerator }    INPUT  FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_ListCopier_3_OUTPUT"    OUTPUT { FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_UUIDGenerator_OUTPUT"             "_uuid_update_list" @UUID(SIMPLE, UUID_FORMAT, UUID_ONLY)              }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_UUIDGenerator OUTPUT Splitter"   INPUT FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_UUIDGenerator_OUTPUT"   OUTPUT FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_0_22p5U+eurT4="   OUTPUT FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_1_u59FUiO0tls="
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "updateList<opencurly><closecurly>"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_0_22p5U+eurT4="    OUTPUT { FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,)        $($(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttributeKeeperFactory    FACTORY_NAME { $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_AttributeKeeper }    INPUT  FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_1_u59FUiO0tls="    KEEP_ATTRS { updateList<opencurly>0<closecurly>.resource_update_cycle_code,updateList<opencurly>0<closecurly>.resource_update_cycle_fr,updateList<opencurly>0<closecurly>.resource_update_cycle,_uuid_update_list }    KEEP_LISTS {  }    KEEP_FME_ATTRIBUTES Yes    BUILD_FEATURE_TABLES { NO }    OUTPUT_ON_ATTRIBUTE_CHANGE { <Unused> }    OUTPUT { OUTPUT FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_AttributeKeeper_OUTPUT"        }
# -------------------------------------------------------------------------
INCLUDE [if { {ATTRIBUTES} == {ATTRIBUTES} } {                puts "MACRO $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO ATTRIBUTES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {POLYGONS}} {                puts "MACRO $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {AGGREGATES}} {                puts "MACRO $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {POLYGONS}} {                puts "MACRO $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {AGGREGATES}} {                puts "MACRO $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} } {                puts "MACRO $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} } {                puts "MACRO $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          else {}; ]
FACTORY_DEF {*} ReferenceFactory    FACTORY_NAME { $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_FeatureMerger }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT REFERENCER FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_AttributeRemover_OUTPUT"    INPUT REFERENCEE FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_AttributeKeeper_OUTPUT"    REFERENCE_INFO { $($(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO) }    REFERENCE_TABLE { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_uuid_update_list<closeparen>,$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_FeatureMerger) @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_uuid_update_list<closeparen>,$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_FeatureMerger) AUTO }    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "REQUESTOR_IF_CONFLICT" }    IGNORE_NULLS { "No" }    HANDLE_NULL_MISSING_KEYS_LIKE_FME2013 { No }    LIST_ATTRS_TO_INCLUDE { <Unused> }    LIST_ATTRS_TO_INCLUDE_MODE { <Unused> }    MERGE_ATTRIBUTES Yes    MANAGE_FME_TYPE Yes    MODE COMPLETE    PROCESS_DUPLICATE_REFERENCEES { NO }    REFERENCEES_FIRST { No }    REJECT_INVALID_GEOM YES    CLEANING_TOLERANCE { <Unused> }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    COMPARE_WHITESPACE Yes    OUTPUT { COMPLETE FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_FeatureMerger_MERGED"         }    OUTPUT { REJECTED FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_FeatureMerger_<REJECTED>"         }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC }    } else {        puts "MACRO $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_AttributeRemover_2 }    INPUT  FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_FeatureMerger_MERGED"    OUTPUT { FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"        @RemoveAttributes(fme_encoded,_uuid_update_list)        $($(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Input Input Collector"   INPUT FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"   OUTPUT FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Input"
MACRO ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_XFORMER_NAME $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
INCLUDE_CUSTOM_TRANSFORMER_VER ATTRIBUTE_UNEXPOSER:1
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Output Output Renamer/Nuker"   INPUT FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_Terminator }    INPUT  FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_FeatureMerger_<REJECTED>"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"Feature<space>Merger<space>error:<space>Translation<space>Terminated")       @SupplyAttributes(_wb_termination_xformer,"$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_Terminator")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"Feature<space>Merger<space>error:<space>Translation<space>Terminated") }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_OUTPUT1762277785 Output Collector"   INPUT FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME)_OUTPUT"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(GMD_SECTION_DATA_EXTRACTION_WORKSPACE_NAME))}]
