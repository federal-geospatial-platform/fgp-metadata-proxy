# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_AttributeExposer }    INPUT  FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_Input_0_JMaRt5RcW14="    OUTPUT { FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_AttributeExposer_OUTPUT"          }
