FME_PYTHON_PATH "$(FME_MF_DIR)"
FACTORY_DEF {*} PythonFactory    FACTORY_NAME { $(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_PythonCaller_5 }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT  FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_AttributeExposer_OUTPUT"    SYMBOL_NAME { processFeature }    SOURCE_CODE { import<space>fme<lf>import<space>fmeobjects<lf>#<space>Template<space>Function<space>interface:<lf>#<space>When<space>using<space>this<space>function<comma><space>make<space>sure<space>its<space>name<space>is<space>set<space>as<space>the<space>value<space>of<lf>#<space>the<space><apos>Class<space>or<space>Function<space>to<space>Process<space>Features<apos><space>transformer<space>parameter<lf>def<space>processFeature<openparen>feature<closeparen>:<lf><space><space><space><space>list_contacts<space>=<space>feature.getAttribute<openparen><apos>contacts<apos><closeparen>.replace<openparen><apos><openparen><apos><comma><apos><opencurly><apos><closeparen>.replace<openparen><apos><closeparen><apos><comma><apos><closecurly><apos><closeparen><lf><space><space><space><space>list_contacts<space>=<space><apos><opencurly><quote>contacts<quote>:<apos><space>+<space>list_contacts<space>+<space><apos><closecurly><apos><lf><space><space><space><space><lf><space><space><space><space>feature.setAttribute<openparen><quote>contacts<quote><comma>list_contacts<closeparen> }    PY_OUTPUT_TAGS { PYOUTPUT <Rejected> }    OUTPUT { PYOUTPUT FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_PythonCaller_5_OUTPUT"         }    OUTPUT { <Rejected> FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_PythonCaller_5_<Rejected>"         }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_PythonCaller_5 <Rejected> Transformer Output Nuker"   INPUT FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_PythonCaller_5_<Rejected>"
# -------------------------------------------------------------------------
FACTORY_DEF {*} JSONQueryFactory    FACTORY_NAME { $(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_JSONFlattener_2 }    INPUT  FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_PythonCaller_5_OUTPUT"    MODE FLATTEN    JSON_DOCUMENT { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>contacts<closeparen>,$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_JSONFlattener_2)" }    READ_FROM_FILE { NO }    FILEPATH_OR_URL { "<Unused>" }    EXPLODE_QUERY "json"    RECURSIVE_FLATTEN { YES }    ERROR_LIST_ATTR { "_json_error" }    OUTPUT { EXPLODED FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_JSONFlattener_2_OUTPUT"        }    OUTPUT { REJECTED FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_JSONFlattener_2_<REJECTED>"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_Cloner_Cloner }    INPUT  FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_JSONFlattener_2_<REJECTED>"    NUMBER_OF_COPIES { "1" }    COPY_NUMBER_ATTRIBUTE { _copynum }    REJECT_INVALID YES
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_AttributeCreator_3 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_JSONFlattener_2_OUTPUT"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "_ordre" "SET_TO" "2" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "_type" "SET_TO" "features" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_AttributeCreator_3_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_ListCopier }    INPUT  FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_AttributeCreator_3_OUTPUT"    OUTPUT { FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_ListCopier_OUTPUT"         @CopyAttributes(ENCODED,EXACT_LIST_MATCH,contacts_brutes{},contacts<opencurly><closecurly>)          }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "contacts<opencurly><closecurly>"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_ListCopier_OUTPUT"    OUTPUT { FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,contacts)        $($(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
# -------------------------------------------------------------------------
# If we're doing LAST N features, then the multiplier comes in as 0.
# If we're doing First N, multiplier is -1.
# For RANDOM, we need to treat LAST N as if it was first N (i.e. have a -1)
# That is what the ? : does in the rate multiplier.
INCLUDE [ if { {-1} == {0} && {ORIGINAL} == {ORIGINAL} } {              puts "MACRO REAL_MODE LAST"; 	         puts "MACRO REAL_RATE 1"; 	      } else {              puts "MACRO REAL_MODE ORIGINAL";              puts "MACRO REAL_RATE [expr 1 * ( -1 ? -1 : -1 ) ]"; 	      } ]
FACTORY_DEF {*} SamplingFactory    FACTORY_NAME { $(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_Sampler }    COMMAND_PARM_EVALUATION SINGLE_PASS    SAMPLE_RATE { $(REAL_RATE) }    SAMPLE_ORDER { $(REAL_MODE) }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT  FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_Input_1_Cp/h6sZmw10="    OUTPUT { SAMPLED FEATURE_TYPE ___SAMPLED___ }
# This TeeFactory is needed because Sampler will still output features if it has no OUTPUT clauses specified.
# This way we behave nicely even if there are no output connections on the transformer. See PR#28886.
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_Sampler_Sampled }    INPUT FEATURE_TYPE ___SAMPLED___    OUTPUT { FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_Sampler_SAMPLED"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttributeKeeperFactory    FACTORY_NAME { $(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_AttributeKeeper_2 }    INPUT  FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_Sampler_SAMPLED"    KEEP_ATTRS {  }    KEEP_LISTS {  }    KEEP_FME_ATTRIBUTES Yes    BUILD_FEATURE_TABLES { No }    OUTPUT_ON_ATTRIBUTE_CHANGE {  }    OUTPUT { OUTPUT FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_AttributeKeeper_2_OUTPUT"        }
# -------------------------------------------------------------------------
# Combine the two "file path attribute" parameters into one value.
DEFAULT_MACRO $(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_HTTPCaller_FILE_PATH_ATTR
INCLUDE [ 	if { {<Unused>} == {<Unused>} } { 		puts {MACRO $(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_HTTPCaller_FILE_PATH_ATTR "<Unused>"}; 	} else { 		puts {MACRO $(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_HTTPCaller_FILE_PATH_ATTR "<Unused>"}; 	} ]
FACTORY_DEF {*} HTTPFactory    FACTORY_NAME { $(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_HTTPCaller }       INPUT  FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_AttributeKeeper_2_OUTPUT"    TARGET_URL { "https:<solidus><solidus>catalogue.data.gov.bc.ca<solidus>api<solidus>3<solidus>action<solidus>organization_list?all_fields=True" }    HTTP_METHOD { GET }    SAVE_FILE { NO }    OUTPUT_FILENAME { "<Unused>" }    OUTPUT_DIRECTORY { "<Unused>" }    FILE_EXTENSION { "<Unused>" }    TARGET_ATTR { "_response_body" }    FILE_PATH_ATTR { $($(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_HTTPCaller_FILE_PATH_ATTR) }    UPLOAD_FILE { "<Unused>" }    UPLOAD_BODY { "<Unused>" }    UPLOAD_TYPE { <Unused> }    UPLOAD_CONTENT_TYPE { "<Unused>" }    COMBINED_MULTIPART_TABLE {  }    MULTIPART_CONTENT_TYPE { <Unused> }    REQUEST_HEADER_TABLE {  }    ADDITIONAL_URL_PARAMETERS {  }    AUTH_USERNAME { "<Unused>" }    AUTH_PASSWORD { "<Unused>" }    AUTH_METHOD { "<Unused>" }    TARGET_ATTRIBUTE_ENCODING { auto-detect }    RESPONSE_HEADER_LIST_ATTR { "" }    STATUS_CODE_ATTR { "_http_status_code" }    ERROR_ATTR { "_error" }    CONNECTION_TIMEOUT_LENGTH { 60 }    TRANSFER_TIMEOUT_LENGTH { 90 }    FOLLOW_REDIRECTS { FOLLOW_WITH_GET }    REDIRECT_AUTH { ORIGINAL_DOMAIN_ONLY }    VERIFY_SSL_CERTIFICATES { No }    NAMED_CONNECTION { "<Unused>" }    USE_COOKIES { No }    MAX_TRANSFERS_IN_PROGRESS { 25 }    MAX_HTTP_VERSION { HTTP_2 }    RATE_LIMIT_MAX_REQUESTS { <Unused> }    RATE_LIMIT_INTERVAL_IN_SECONDS { <Unused> }    RATE_LIMIT_REQUEST_TIMING { <Unused> }    RETRY_FAILED_TRANSFERS { <Unused> }    RETRY_MAX_RETRIES { <Unused> }    RETRY_INITIAL_BACKOFF { <Unused> }    SPLIT_MULTIPART_RESPONSE { NO }    MULTIPART_RESPONSE_HEADER_LIST_ATTR { "<Unused>" }    MINIMUM_ENCRYPTION_LEVEL { "OS_DEFAULT" }    CLIENT_CERTIFICATE_TYPE { "NONE" }    CLIENT_CERTIFICATE_FROM_OS { "<Unused>" }    CLIENT_CERTIFICATE_FILE { "<Unused>" }    CLIENT_CERTIFICATE_PRIVATE_KEY_FILE { "<Unused>" }    CLIENT_CERTIFICATE_PASSWORD { "<Unused>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_HTTPCaller_Output"          }    OUTPUT { REJECTED FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_HTTPCaller_<REJECTED>"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} JSONQueryFactory    FACTORY_NAME { $(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_JSONFlattener }    INPUT  FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_HTTPCaller_Output"    MODE FLATTEN    JSON_DOCUMENT { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_response_body<closeparen>,$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_JSONFlattener)" }    READ_FROM_FILE { NO }    FILEPATH_OR_URL { "<Unused>" }    EXPLODE_QUERY "json"    RECURSIVE_FLATTEN { YES }    ERROR_LIST_ATTR { "_json_error" }    OUTPUT { EXPLODED FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_JSONFlattener_OUTPUT"        }    OUTPUT { REJECTED FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_JSONFlattener_<REJECTED>"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_AttributeCreator }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_JSONFlattener_OUTPUT"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "_ordre" "SET_TO" "1" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "_type" "SET_TO" "contacts" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_AttributeCreator_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} SortFactory    FACTORY_NAME { $(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_Sorter }    INPUT  FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_AttributeCreator_OUTPUT"    INPUT  FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_AttributeRemover_OUTPUT"    INPUT  FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_AttributeCreator_4_OUTPUT"    SORT_ALPHA_AS_UTF8 { YES }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    SORT_BY { _ordre NUMERIC ASCENDING }    OUTPUT { SORTED FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_Sorter_SORTED"          }
# -------------------------------------------------------------------------
FME_PYTHON_PATH "$(FME_MF_DIR)"
FACTORY_DEF {*} PythonFactory    FACTORY_NAME { $(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_PythonCaller }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT  FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_Sorter_SORTED"    SYMBOL_NAME { FeatureProcessor }    SOURCE_CODE { import<space>fme<lf>import<space>fmeobjects<lf>from<space>Python.FME_utils<space>import<space>FME_utils<lf><lf>#<space>Template<space>Function<space>interface:<lf>#<space>When<space>using<space>this<space>function<comma><space>make<space>sure<space>its<space>name<space>is<space>set<space>as<space>the<space>value<space>of<lf>#<space>the<space><apos>Class<space>or<space>Function<space>to<space>Process<space>Features<apos><space>transformer<space>parameter<lf>def<space>FeatureProcessor<openparen>feature<closeparen>:<lf><space><space><space><space>pass<lf><lf><space><space><space><space><lf><lf><space><space><space><space><lf><lf>#<space>Template<space>Class<space>Interface:<lf>#<space>When<space>using<space>this<space>class<comma><space>make<space>sure<space>its<space>name<space>is<space>set<space>as<space>the<space>value<space>of<lf>#<space>the<space><apos>Class<space>or<space>Function<space>to<space>Process<space>Features<apos><space>transformer<space>parameter<lf>class<space>FeatureProcessor<openparen>object<closeparen>:<lf><space><space><space><space>def<space>__init__<openparen>self<closeparen>:<lf><space><space><space><space><space><space><space><space>self.contacts=<opencurly><closecurly><lf><space><space><space><space>def<space>input<openparen>self<comma>feature<closeparen>:<lf><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space>if<space>feature.getAttribute<openparen><apos>_type<apos><closeparen>==<apos>contacts_LUT<apos>:<lf><space><space><space><space><space><space><space><space><space><space><space><space>self.contacts<openbracket>feature.getAttribute<openparen><apos>org_id<apos><closeparen><closebracket>=feature.getAttribute<openparen><apos>title<apos><closeparen><lf><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space>elif<space>feature.getAttribute<openparen><apos>_type<apos><closeparen>==<apos>contacts<apos>:<lf><space><space><space><space><space><space><space><space><space><space><space><space>max_index=FME_utils.max_index_attribute_list<openparen>feature<comma><apos>result<opencurly><closecurly><apos><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space><space><space><space><space>for<space>j<space>in<space>range<openparen>max_index+1<closeparen>:<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>self.contacts<openbracket>feature.getAttribute<openparen><apos>result<opencurly>%i<closecurly>.id<apos>%<openparen>j<closeparen><closeparen><closebracket>=feature.getAttribute<openparen><apos>result<opencurly>%i<closecurly>.title<apos>%<openparen>j<closeparen><closeparen><lf><space><space><space><space><space><space><space><space>else:<lf><space><space><space><space><space><space><space><space><space><space><space><space>max_index=FME_utils.max_index_attribute_list<openparen>feature<comma><apos>contacts_brutes<opencurly><closecurly><apos><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space>k=0<lf><space><space><space><space><space><space><space><space><space><space><space><space>for<space>j<space>in<space>range<openparen>max_index+1<closeparen>:<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>org=feature.getAttribute<openparen><apos>contacts_brutes<opencurly>%i<closecurly>.org<apos>%<openparen>j<closeparen><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>#valider<space>la<space>pr<u00e9>sence<space>de<space>email<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>if<space>not<space>feature.getAttribute<openparen><apos>contacts_brutes<opencurly>%i<closecurly>.email<apos>%<openparen>j<closeparen><closeparen>:<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>feature.removeAttrsWithPrefix<openparen><apos>contacts_brutes<opencurly>%i<closecurly><apos>%<openparen>j<closeparen><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>else:<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>contacts<opencurly>%i<closecurly>.name<apos>%<openparen>k<closeparen><comma>feature.getAttribute<openparen><apos>contacts_brutes<opencurly>%i<closecurly>.name<apos>%<openparen>j<closeparen><closeparen><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>contacts<opencurly>%i<closecurly>.email<apos>%<openparen>k<closeparen><comma>feature.getAttribute<openparen><apos>contacts_brutes<opencurly>%i<closecurly>.email<apos>%<openparen>j<closeparen><closeparen>.replace<openparen><apos><space><apos><comma><apos><apos><closeparen><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>contacts<opencurly>%i<closecurly>.role<apos>%<openparen>k<closeparen><comma>feature.getAttribute<openparen><apos>contacts_brutes<opencurly>%i<closecurly>.role<apos>%<openparen>j<closeparen><closeparen><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>if<space>org<space>in<space>self.contacts.keys<openparen><closeparen>:<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>contacts<opencurly>%i<closecurly>.org<apos>%<openparen>k<closeparen><comma>self.contacts<openbracket>org<closebracket>.rstrip<openparen><apos><space><apos><closeparen><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>else:<lf><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>contact_org_id<apos><comma>org<closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>k+=1<lf><space><space><space><space><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space><space><space><space><space>feature.removeAttrsWithPrefix<openparen><apos>contacts_brutes<apos><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space>self.pyoutput<openparen>feature<closeparen><lf><space><space><space><space>def<space>close<openparen>self<closeparen>:<lf><space><space><space><space><space><space><space><space>pass }    PY_OUTPUT_TAGS { PYOUTPUT <Rejected> }    OUTPUT { PYOUTPUT FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_PythonCaller_OUTPUT"         }    OUTPUT { <Rejected> FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_PythonCaller_<Rejected>"         }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_PythonCaller <Rejected> Transformer Output Nuker"   INPUT FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_PythonCaller_<Rejected>"
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_Tester_2 }    INPUT  FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_PythonCaller_OUTPUT"    TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>contact_org_id<closeparen>,$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_Tester_2)" = "" ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_Tester_2_PASSED"         }    OUTPUT { FAILED FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_Tester_2_FAILED"         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttributeKeeperFactory    FACTORY_NAME { $(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_AttributeKeeper }    INPUT  FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_Tester_2_FAILED"    KEEP_ATTRS { contact_org_id,id,title }    KEEP_LISTS {  }    KEEP_FME_ATTRIBUTES Yes    BUILD_FEATURE_TABLES { NO }    OUTPUT_ON_ATTRIBUTE_CHANGE { <Unused> }    OUTPUT { OUTPUT FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_AttributeKeeper_OUTPUT"        }
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_Terminator }    INPUT  FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_HTTPCaller_<REJECTED>"    INPUT  FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_JSONFlattener_<REJECTED>"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"Translation<space>Terminated")       @SupplyAttributes(_wb_termination_xformer,"$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_Terminator")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"Translation<space>Terminated") }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_Unknown_org_id1762275402 Output Collector"   INPUT FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_AttributeKeeper_OUTPUT"   OUTPUT FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_Unknown_org_id"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_Output1762275402 Output Collector"   INPUT FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_Tester_2_PASSED"   OUTPUT FEATURE_TYPE "$(BC_CONTACTS_MANAGER_WORKSPACE_NAME)_Output"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(BC_CONTACTS_MANAGER_WORKSPACE_NAME))}]
