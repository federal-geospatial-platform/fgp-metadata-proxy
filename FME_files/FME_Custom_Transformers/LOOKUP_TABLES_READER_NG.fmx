Tcl2 proc $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Creator_CoordSysRemover {} {   global FME_CoordSys;   set FME_CoordSys {}; }
MACRO $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Creator_XML     NOT_ACTIVATED
MACRO $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Creator_GEOJSON NOT_ACTIVATED
INCLUDE [ if { {Geometry Object} == {Geometry Object} } {            puts {MACRO $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Creator_XML *} } ]
INCLUDE [ if { {Geometry Object} == {GeoJSON} } {            puts {MACRO $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Creator_GEOJSON *} } ]
FACTORY_DEF {$($(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Creator_XML)} CreationFactory    FACTORY_NAME { $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Creator_XML_Creator }    CREATE_AT_END { no }    OUTPUT { FEATURE_TYPE _____CREATED______        @Geometry(FROM_ENCODED_STRING,<lt>?xml<space>version=<quote>1.0<quote><space>encoding=<quote>US_ASCII<quote><space>standalone=<quote>no<quote><space>?<gt><lt>geometry<gt><lt>null<solidus><gt><lt><solidus>geometry<gt>) }
