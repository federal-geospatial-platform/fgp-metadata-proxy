FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Creator_Cloner }    INPUT FEATURE_TYPE _____CREATED______        @Tcl2($(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Creator_CoordSysRemover)        @CoordSys()    NUMBER_OF_COPIES { 1 }    COPY_NUMBER_ATTRIBUTE { "_creation_instance" }    OUTPUT { FEATURE_TYPE "$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Creator_CREATED"        fme_feature_type $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Creator         }
FACTORY_DEF * BranchingFactory   FACTORY_NAME "$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Creator_CREATED Brancher -1 24"   INPUT FEATURE_TYPE "$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Creator_CREATED"   TARGET_FACTORY "$(WB_CURRENT_CONTEXT)_CREATOR_BRANCH_TARGET"   MAXIMUM_COUNT None   OUTPUT PASSED FEATURE_TYPE *
