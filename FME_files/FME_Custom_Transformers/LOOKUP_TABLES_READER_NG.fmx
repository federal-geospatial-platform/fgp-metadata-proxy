FACTORY_DEF {*} TestFactory FACTORY_NAME { $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_TestFilter } INPUT FEATURE_TYPE $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_TestFilter_INPUTLINE FEATURE_TABLE_SHIM_SUPPORT Yes PASSED_TEST_GROUP_OUTPUT FIRST TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_record_type<closeparen>,$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_TestFilter) = feature ENCODED } TEST { _csv_error ATTRIBUTE_IS_EMPTY "" ENCODED } BOOLEAN_OPERATOR AND COMPOSITE_TEST_EXPR "1 AND 2" OUTPUT PASSED_0 FEATURE_TYPE $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_TestFilter_CSV<space>OK TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_record_type<closeparen>,$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_TestFilter) = feature ENCODED } TEST { _csv_error ATTRIBUTE_HAS_A_VALUE "" ENCODED } BOOLEAN_OPERATOR AND COMPOSITE_TEST_EXPR "1 AND 2" OUTPUT PASSED_1 FEATURE_TYPE $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_TestFilter_CSV<space>ERROR TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_record_type<closeparen>,$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_TestFilter) = yaml ENCODED } TEST { _csv_error ATTRIBUTE_HAS_A_VALUE "" ENCODED } BOOLEAN_OPERATOR AND COMPOSITE_TEST_EXPR "1 AND 2" OUTPUT PASSED_2 FEATURE_TYPE $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_TestFilter_YAML<space>ERROR OUTPUT FAILED FEATURE_TYPE $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_TestFilter_OTHER
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "attribute<opencurly><closecurly>"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_TestFilter_CSV<space>OK"    OUTPUT { FEATURE_TYPE "$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,_creation_instance,_feature_type,_file2read,_file_error,_fme_home,_pt,_record_type,path_pt,path_shared,_csv_error,_csv_path,_yaml2read,csv_line_number,csv_number_of_fields,csv_total_number_of_columns)        $($(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Input Input Collector"   INPUT FEATURE_TYPE "$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_AttributeRemover_OUTPUT"   OUTPUT FEATURE_TYPE "$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Input"
MACRO ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_XFORMER_NAME $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
INCLUDE_CUSTOM_TRANSFORMER_VER ATTRIBUTE_UNEXPOSER:1
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Output Output Renamer/Nuker"   INPUT FEATURE_TYPE "$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Terminator_2 }    INPUT  FEATURE_TYPE "$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_TestFilter_CSV<space>ERROR"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"@EvaluateExpression(FDIV,STRING_ENCODED,Translation<space>Terminated.<space>Error<space>in<space>the<space>CSV<space>file<lf>Error:<space><at>Value<openparen>_csv_error<closeparen>,$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Terminator_2)")       @SupplyAttributes(_wb_termination_xformer,"$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Terminator_2")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"@EvaluateExpression(FDIV,STRING_ENCODED,Translation<space>Terminated.<space>Error<space>in<space>the<space>CSV<space>file<lf>Error:<space><at>Value<openparen>_csv_error<closeparen>,$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Terminator_2)") }
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Terminator_3 }    INPUT  FEATURE_TYPE "$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_TestFilter_YAML<space>ERROR"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"@EvaluateExpression(FDIV,STRING_ENCODED,Translation<space>Terminated.<space>Error<space>in<space>the<space>shema<space>YAML<lf>Error:<space><at>Value<openparen>_csv_error<closeparen>,$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Terminator_3)")       @SupplyAttributes(_wb_termination_xformer,"$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Terminator_3")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"@EvaluateExpression(FDIV,STRING_ENCODED,Translation<space>Terminated.<space>Error<space>in<space>the<space>shema<space>YAML<lf>Error:<space><at>Value<openparen>_csv_error<closeparen>,$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Terminator_3)") }
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Terminator_4 }    INPUT  FEATURE_TYPE "$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_TestFilter_OTHER"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"Translation<space>Terminated.<space>Unknow<space>error...")       @SupplyAttributes(_wb_termination_xformer,"$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Terminator_4")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"Translation<space>Terminated.<space>Unknow<space>error...") }
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Terminator }    INPUT  FEATURE_TYPE "$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Tester_1_FAILED"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"@EvaluateExpression(FDIV,STRING_ENCODED,ERROR:<space><at>Value<openparen>_file_error<closeparen>,$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Terminator)")       @SupplyAttributes(_wb_termination_xformer,"$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Terminator")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"@EvaluateExpression(FDIV,STRING_ENCODED,ERROR:<space><at>Value<openparen>_file_error<closeparen>,$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Terminator)") }
# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Logger_b49f16de_6460_4c1f_9ebf_4702daa999390} ]
# If the Logger was in a custom transformer, the custom transformer's name was not being
# properly logged -- instead we saw "$(<customXformerName_WORKSPACE_NAME)" being logged as the prefix of the
# message. By deferencing and expanding out the XFORMER_NAME below, and then "WWJD" encoding it when it is
# used in the @Log call via the $encode macro name suffix trick, we get the right result, and the right result
# safely.
MACRO LOGGABLE_XFORMER_NAME $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Logger
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Logger_Logger }    INPUT  FEATURE_TYPE "$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Tester_FAILED"    OUTPUT { FEATURE_TYPE "$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Logger_LOGGED"                  @Log(ENCODED, "$(LOGGABLE_XFORMER_NAME$encode):<space>***********************************************************<lf>***********************************************************<lf>Published<space>parameter:<space>FEATURE_TYPE<space>is<space>empty.<space>No<space>CSV<space>file<space>read.<lf>***********************************************************<lf>***********************************************************<lf>","20","20","",INFO,LOG_ONLY,$(FME_UUID_SAFE))                   }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Logger LOGGED Transformer Output Nuker"   INPUT FEATURE_TYPE "$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Logger_LOGGED"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Output1762277992 Output Collector"   INPUT FEATURE_TYPE "$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_Output"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME))}]
