INCLUDE [puts {MACRO WB_OLD_CONTEXT_$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME) $(WB_CURRENT_CONTEXT)};          puts {MACRO WB_CURRENT_CONTEXT $(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)}]
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_INPUT1762278491 Input Splitter"   INPUT FEATURE_TYPE "$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_INPUT"   OUTPUT FEATURE_TYPE "$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_INPUT"
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_AttributeExposer }    INPUT  FEATURE_TYPE "$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_INPUT"    OUTPUT { FEATURE_TYPE "$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_AttributeExposer_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_ListElementCounter }    INPUT  FEATURE_TYPE "$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_AttributeExposer_OUTPUT"    OUTPUT { FEATURE_TYPE "$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_ListElementCounter_OUTPUT"         @SupplyAttributes(ENCODED, _element_count, @NumElements("mapping_errors<opencurly><closecurly>",ENCODED))          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_Tester }    INPUT  FEATURE_TYPE "$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_ListElementCounter_OUTPUT"    TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_element_count<closeparen>,$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_Tester)" != 0 ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    OUTPUT { PASSED FEATURE_TYPE "$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_Tester_PASSED"         }    OUTPUT { FAILED FEATURE_TYPE "$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_Tester_FAILED"         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttributeKeeperFactory    FACTORY_NAME { $(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_AttributeKeeper }    INPUT  FEATURE_TYPE "$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_Tester_PASSED"    KEEP_ATTRS { id }    KEEP_LISTS { mapping_errors<opencurly><closecurly>.error }    KEEP_FME_ATTRIBUTES Yes    BUILD_FEATURE_TABLES { NO }    OUTPUT_ON_ATTRIBUTE_CHANGE { <Unused> }    OUTPUT { OUTPUT FEATURE_TYPE "$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_AttributeKeeper_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} ElementFactory    FACTORY_NAME { $(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_ListExploder }    INPUT  FEATURE_TYPE "$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_AttributeKeeper_OUTPUT"    LIST_NAME { "mapping_errors{}" }    ELEMENT_NUMBER_FIELD { "_element_index" }    CLONE_GEOMETRY    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "INCOMING_IF_CONFLICT" }    INCOMING_PREFIX { "<Unused>" }    OUTPUT { ELEMENT FEATURE_TYPE "$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_ListExploder_ELEMENTS"         @RemoveAttributes(ElementFactory.baseCloned)          }    OUTPUT { NOLIST FEATURE_TYPE "$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_ListExploder_<REJECTED>"         @RemoveAttributes(ElementFactory.baseCloned)         fme_rejection_code MISSING_PARAMETER_LIST          }
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_Terminator }    INPUT  FEATURE_TYPE "$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_ListExploder_<REJECTED>"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"Translation<space>Terminated")       @SupplyAttributes(_wb_termination_xformer,"$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_Terminator")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"Translation<space>Terminated") }
