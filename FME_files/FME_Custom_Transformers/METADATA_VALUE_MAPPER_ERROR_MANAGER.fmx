FACTORY_DEF * TeeFactory   FACTORY_NAME "$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_ERROR_OUTPUT1762278491 Output Collector"   INPUT FEATURE_TYPE "$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_ListExploder_ELEMENTS"   OUTPUT FEATURE_TYPE "$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_ERROR_OUTPUT"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_DATA_OUTPUT1762278491 Output Collector"   INPUT FEATURE_TYPE "$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_DATA_OUTPUT"
