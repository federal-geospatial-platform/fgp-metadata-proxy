FACTORY_DEF * TeeFactory   FACTORY_NAME "$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Input Input Collector"   INPUT FEATURE_TYPE "$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_Tester_FAILED"   OUTPUT FEATURE_TYPE "$(METADATA_VALUE_MAPPER_ERROR_MANAGER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Input"
