FACTORY_DEF {*} PythonFactory    FACTORY_NAME { $(CreatingHashKeyFromAttributes_WORKSPACE_NAME)_PythonCaller_2 }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT  FEATURE_TYPE "$(CreatingHashKeyFromAttributes_WORKSPACE_NAME)_AttributeCreator_4_OUTPUT"    SYMBOL_NAME { FeatureProcessor }    SOURCE_CODE { import<space>fme<lf>import<space>fmeobjects<lf>import<space>hashlib<lf>#<space>Template<space>Function<space>interface:<lf>#<space>When<space>using<space>this<space>function<comma><space>make<space>sure<space>its<space>name<space>is<space>set<space>as<space>the<space>value<space>of<lf>#<space>the<space><apos>Class<space>or<space>Function<space>to<space>Process<space>Features<apos><space>transformer<space>parameter<lf>def<space>processFeature<openparen>feature<closeparen>:<lf><space><space><space><space>pass<lf><lf>#<space>Template<space>Class<space>Interface:<lf>#<space>When<space>using<space>this<space>class<comma><space>make<space>sure<space>its<space>name<space>is<space>set<space>as<space>the<space>value<space>of<lf>#<space>the<space><apos>Class<space>or<space>Function<space>to<space>Process<space>Features<apos><space>transformer<space>parameter<lf>class<space>FeatureProcessor<openparen>object<closeparen>:<lf><space><space><space><space>def<space>__init__<openparen>self<closeparen>:<lf><space><space><space><space><space><space><space><space>pass<lf><space><space><space><space>def<space>input<openparen>self<comma>feature<closeparen>:<lf><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space>#Unique<space>ID<lf><space><space><space><space><space><space><space><space>name=feature.getAttribute<openparen><apos>UNIQUE_ATT<apos><closeparen><lf><space><space><space><space><space><space><space><space>#.replace<openparen><apos><backslash>n<apos><comma><space><apos><space><apos><closeparen>.replace<openparen><apos><backslash>r<apos><comma><space><apos><apos><closeparen>.replace<openparen><apos><backslash>t<apos><comma><apos><space><apos><closeparen>.lstrip<openparen><apos><space><apos><closeparen>.rstrip<openparen><apos><space><apos><closeparen><lf><space><space><space><space><space><space><space><space>name_hashkey=hashlib.sha256<openparen>name.encode<openparen><apos>utf-8<apos><closeparen><closeparen>.hexdigest<openparen><closeparen><lf><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>_hash_name<apos><comma>name_hashkey<closeparen><lf><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space>self.pyoutput<openparen>feature<closeparen><lf><space><space><space><space>def<space>close<openparen>self<closeparen>:<lf><space><space><space><space><space><space><space><space>pass }    OUTPUT { PYOUTPUT FEATURE_TYPE "$(CreatingHashKeyFromAttributes_WORKSPACE_NAME)_PythonCaller_2_OUTPUT"         }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(CreatingHashKeyFromAttributes_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(CreatingHashKeyFromAttributes_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(CreatingHashKeyFromAttributes_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(CreatingHashKeyFromAttributes_WORKSPACE_NAME)_PythonCaller_2_OUTPUT"    OUTPUT { FEATURE_TYPE "$(CreatingHashKeyFromAttributes_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,NAME_ATT)        $($(CreatingHashKeyFromAttributes_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(CreatingHashKeyFromAttributes_WORKSPACE_NAME)_AttributeKeeper_Output1762281205 Output Collector"   INPUT FEATURE_TYPE "$(CreatingHashKeyFromAttributes_WORKSPACE_NAME)_AttributeRemover_OUTPUT"   OUTPUT FEATURE_TYPE "$(CreatingHashKeyFromAttributes_WORKSPACE_NAME)_AttributeKeeper_Output"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(CreatingHashKeyFromAttributes_WORKSPACE_NAME))}]
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(UNIQUE_ID_CREATOR_WORKSPACE_NAME)_CreatingHashKeyFromUniqueAtt AttributeKeeper_Output Output Renamer/Nuker"   INPUT FEATURE_TYPE "$(UNIQUE_ID_CREATOR_WORKSPACE_NAME)_CreatingHashKeyFromUniqueAtt_AttributeKeeper_Output"   OUTPUT FEATURE_TYPE "$(UNIQUE_ID_CREATOR_WORKSPACE_NAME)_CreatingHashKeyFromUniqueAtt_AttributeKeeper_Output"
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    COMMAND_PARM_EVALUATION SINGLE_PASS    FACTORY_NAME { $(UNIQUE_ID_CREATOR_WORKSPACE_NAME)_AttributeRenamer_2 }    INPUT  FEATURE_TYPE "$(UNIQUE_ID_CREATOR_WORKSPACE_NAME)_CreatingHashKeyFromUniqueAtt_AttributeKeeper_Output" 	ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    MISSING_INPUT_ATTR_HANDLING { RENAME_SET_DEFAULT PRESERVE }    KEEP_OUTPUT_ATTRS_ONLY { no } 	ATTR_ACTION { "_hash_name" "id" "RENAME_SET_DEFAULT" "" }    OUTPUT { OUTPUT FEATURE_TYPE "$(UNIQUE_ID_CREATOR_WORKSPACE_NAME)_AttributeRenamer_2_OUTPUT"        }
