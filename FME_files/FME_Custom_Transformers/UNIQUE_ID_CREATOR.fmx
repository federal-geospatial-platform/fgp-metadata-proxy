FACTORY_DEF * TeeFactory   FACTORY_NAME "$(UNIQUE_ID_CREATOR_WORKSPACE_NAME)_UUID_4_FORMATTER INPUT Input Collector"   INPUT FEATURE_TYPE "$(UNIQUE_ID_CREATOR_WORKSPACE_NAME)_AttributeRenamer_2_OUTPUT"   OUTPUT FEATURE_TYPE "$(UNIQUE_ID_CREATOR_WORKSPACE_NAME)_UUID_4_FORMATTER_INPUT"
MACRO UUID_4_FORMATTER_WORKSPACE_NAME $(UNIQUE_ID_CREATOR_WORKSPACE_NAME)_UUID_4_FORMATTER
MACRO $(UUID_4_FORMATTER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(UUID_4_FORMATTER_WORKSPACE_NAME)_XFORMER_NAME $(UNIQUE_ID_CREATOR_WORKSPACE_NAME)_UUID_4_FORMATTER
INCLUDE_CUSTOM_TRANSFORMER_VER UUID_4_FORMATTER:1
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(UNIQUE_ID_CREATOR_WORKSPACE_NAME)_UUID_4_FORMATTER OUTPUT Output Renamer/Nuker"   INPUT FEATURE_TYPE "$(UNIQUE_ID_CREATOR_WORKSPACE_NAME)_UUID_4_FORMATTER_OUTPUT"   OUTPUT FEATURE_TYPE "$(UNIQUE_ID_CREATOR_WORKSPACE_NAME)_UUID_4_FORMATTER_OUTPUT"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(UNIQUE_ID_CREATOR_WORKSPACE_NAME)_OUTPUT1762281205 Output Collector"   INPUT FEATURE_TYPE "$(UNIQUE_ID_CREATOR_WORKSPACE_NAME)_UUID_4_FORMATTER_OUTPUT"   OUTPUT FEATURE_TYPE "$(UNIQUE_ID_CREATOR_WORKSPACE_NAME)_OUTPUT"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(UNIQUE_ID_CREATOR_WORKSPACE_NAME))}]
