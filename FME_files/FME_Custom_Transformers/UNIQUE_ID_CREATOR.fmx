FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(CreatingHashKeyFromAttributes_WORKSPACE_NAME)_AttributeCreator_4 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(CreatingHashKeyFromAttributes_WORKSPACE_NAME)_Cloner_Input"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    ATTR_ACTION { "" "UNIQUE_ATT" "SET_TO" "$($(CreatingHashKeyFromAttributes_WORKSPACE_NAME)_UNIQUE_ATT$encode)" }    OUTPUT { OUTPUT FEATURE_TYPE "$(CreatingHashKeyFromAttributes_WORKSPACE_NAME)_AttributeCreator_4_OUTPUT"        }
