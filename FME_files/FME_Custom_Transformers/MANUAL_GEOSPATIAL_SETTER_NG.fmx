# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {$(MANUAL_GEOSPATIAL_SETTER_NG_WORKSPACE_NAME)_Logger_55689cbb_5876_457d_98e2_7166fa6ad5c40} ]
# If the Logger was in a custom transformer, the custom transformer's name was not being
# properly logged -- instead we saw "$(<customXformerName_WORKSPACE_NAME)" being logged as the prefix of the
# message. By deferencing and expanding out the XFORMER_NAME below, and then "WWJD" encoding it when it is
# used in the @Log call via the $encode macro name suffix trick, we get the right result, and the right result
# safely.
MACRO LOGGABLE_XFORMER_NAME $(MANUAL_GEOSPATIAL_SETTER_NG_WORKSPACE_NAME)_Logger
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(MANUAL_GEOSPATIAL_SETTER_NG_WORKSPACE_NAME)_Logger_Logger }    INPUT  FEATURE_TYPE "$(MANUAL_GEOSPATIAL_SETTER_NG_WORKSPACE_NAME)_AttributeKeeper_OUTPUT"    OUTPUT { FEATURE_TYPE "$(MANUAL_GEOSPATIAL_SETTER_NG_WORKSPACE_NAME)_Logger_LOGGED"                  @Log(ENCODED, "$(LOGGABLE_XFORMER_NAME$encode):<space>@EvaluateExpression(FDIV,STRING_ENCODED,Data<space>record<space>with<space>id<space><at>Value<openparen>id<closeparen><space>missing<space>from<space>UnmappedGeoData<space>lookup<space>table<space>in<space>MANUAL_GEOSPATIAL_SETTER<space>transformer.<space><space>See<space>PROCESS_REPORT_MANUAL_TASKS.xls<space>file<space>in<space>XLS<space>directory<space>for<space>details.,$(MANUAL_GEOSPATIAL_SETTER_NG_WORKSPACE_NAME)_Logger)","20","20","",WARN,LOG_RECORD,$(FME_UUID_SAFE))                   }
