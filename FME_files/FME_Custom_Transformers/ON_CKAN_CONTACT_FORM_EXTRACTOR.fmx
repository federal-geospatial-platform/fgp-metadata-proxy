FACTORY_DEF {*} ReferenceFactory    FACTORY_NAME { $(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_FeatureMerger }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT REFERENCER FEATURE_TYPE "$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_AttributeExposer_2_OUTPUT"    INPUT REFERENCEE FEATURE_TYPE "$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_AttributeKeeper_2_OUTPUT"    REFERENCE_INFO { $($(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO) }    REFERENCE_TABLE { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>organization.id<closeparen>,$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_FeatureMerger) @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>id<closeparen>,$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_FeatureMerger) AUTO }    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "REQUESTOR_IF_CONFLICT" }    IGNORE_NULLS { "No" }    HANDLE_NULL_MISSING_KEYS_LIKE_FME2013 { No }    LIST_ATTRS_TO_INCLUDE { <Unused> }    LIST_ATTRS_TO_INCLUDE_MODE { <Unused> }    MERGE_ATTRIBUTES Yes    MANAGE_FME_TYPE Yes    MODE COMPLETE    PROCESS_DUPLICATE_REFERENCEES { NO }    REFERENCEES_FIRST { No }    REJECT_INVALID_GEOM YES    CLEANING_TOLERANCE { <Unused> }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    COMPARE_WHITESPACE Yes    OUTPUT { COMPLETE FEATURE_TYPE "$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_FeatureMerger_MERGED"         }    OUTPUT { INCOMPLETE FEATURE_TYPE "$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_FeatureMerger_UNMERGED_REQUESTOR"         }
