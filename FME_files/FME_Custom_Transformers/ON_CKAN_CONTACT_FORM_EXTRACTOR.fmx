DEFAULT_MACRO WB_CURRENT_CONTEXT
DEFAULT_MACRO ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME ""
INCLUDE [puts {MACRO WB_OLD_CONTEXT_$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME) $(WB_CURRENT_CONTEXT)};          puts {MACRO WB_CURRENT_CONTEXT $(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)}]
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_Input1762279528 Input Splitter"   INPUT FEATURE_TYPE "$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_Input"   OUTPUT FEATURE_TYPE "$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_Input"
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_Tester }    INPUT  FEATURE_TYPE "$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_Input"    CASE_INSENSITIVE_TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,$($(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_URL_VALIDATION$encode),$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_Tester)" = yes ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE "$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_Tester_PASSED"         }    OUTPUT { FAILED FEATURE_TYPE "$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_Tester_FAILED"         }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_Tester PASSED Splitter"   INPUT FEATURE_TYPE "$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_Tester_PASSED"   OUTPUT FEATURE_TYPE "$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_Tester_PASSED_0_EdB7TinNPI8="   OUTPUT FEATURE_TYPE "$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_Tester_PASSED_1_sJnAeJE4PXI="
# -------------------------------------------------------------------------
# If we're doing LAST N features, then the multiplier comes in as 0.
# If we're doing First N, multiplier is -1.
# For RANDOM, we need to treat LAST N as if it was first N (i.e. have a -1)
# That is what the ? : does in the rate multiplier.
INCLUDE [ if { {-1} == {0} && {ORIGINAL} == {ORIGINAL} } {              puts "MACRO REAL_MODE LAST"; 	         puts "MACRO REAL_RATE 1"; 	      } else {              puts "MACRO REAL_MODE ORIGINAL";              puts "MACRO REAL_RATE [expr 1 * ( -1 ? -1 : -1 ) ]"; 	      } ]
FACTORY_DEF {*} SamplingFactory    FACTORY_NAME { $(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_Sampler }    COMMAND_PARM_EVALUATION SINGLE_PASS    SAMPLE_RATE { $(REAL_RATE) }    SAMPLE_ORDER { $(REAL_MODE) }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT  FEATURE_TYPE "$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_Tester_PASSED_0_EdB7TinNPI8="    OUTPUT { SAMPLED FEATURE_TYPE ___SAMPLED___ }
# This TeeFactory is needed because Sampler will still output features if it has no OUTPUT clauses specified.
# This way we behave nicely even if there are no output connections on the transformer. See PR#28886.
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_Sampler_Sampled }    INPUT FEATURE_TYPE ___SAMPLED___    OUTPUT { FEATURE_TYPE "$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_Sampler_SAMPLED"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttributeKeeperFactory    FACTORY_NAME { $(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_AttributeKeeper }    INPUT  FEATURE_TYPE "$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_Sampler_SAMPLED"    KEEP_ATTRS {  }    KEEP_LISTS {  }    KEEP_FME_ATTRIBUTES Yes    BUILD_FEATURE_TABLES { NO }    OUTPUT_ON_ATTRIBUTE_CHANGE { <Unused> }    OUTPUT { OUTPUT FEATURE_TYPE "$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_AttributeKeeper_OUTPUT"        }
# -------------------------------------------------------------------------
# Combine the two "file path attribute" parameters into one value.
DEFAULT_MACRO $(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_HTTPCaller_FILE_PATH_ATTR
INCLUDE [ 	if { {<Unused>} == {<Unused>} } { 		puts {MACRO $(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_HTTPCaller_FILE_PATH_ATTR "<Unused>"}; 	} else { 		puts {MACRO $(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_HTTPCaller_FILE_PATH_ATTR "<Unused>"}; 	} ]
FACTORY_DEF {*} HTTPFactory    FACTORY_NAME { $(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_HTTPCaller }       INPUT  FEATURE_TYPE "$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_AttributeKeeper_OUTPUT"    TARGET_URL { "@EvaluateExpression(FDIV,STRING_ENCODED,$($(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_CKAN_ROOT$encode)<solidus>api<solidus>3<solidus>action<solidus>organization_list?include_extras=True<amp>all_fields=True,$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_HTTPCaller)" }    HTTP_METHOD { GET }    SAVE_FILE { NO }    OUTPUT_FILENAME { "<Unused>" }    OUTPUT_DIRECTORY { "<Unused>" }    FILE_EXTENSION { "<Unused>" }    TARGET_ATTR { "_response_body" }    FILE_PATH_ATTR { $($(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_HTTPCaller_FILE_PATH_ATTR) }    UPLOAD_FILE { "<Unused>" }    UPLOAD_BODY { "<Unused>" }    UPLOAD_TYPE { <Unused> }    UPLOAD_CONTENT_TYPE { "<Unused>" }    COMBINED_MULTIPART_TABLE {  }    MULTIPART_CONTENT_TYPE { <Unused> }    REQUEST_HEADER_TABLE { User-Agent;Mozilla<solidus>5.0<space><openparen>Windows<space>NT<space>10.0<semicolon><space>Win64<semicolon><space>x64<closeparen><space>AppleWebKit<solidus>537.36<space><openparen>KHTML<comma><space>like<space>Gecko<closeparen><space>Chrome<solidus>117.0.0.0<space>Safari<solidus>537.36 }    ADDITIONAL_URL_PARAMETERS {  }    AUTH_USERNAME { "<Unused>" }    AUTH_PASSWORD { "<Unused>" }    AUTH_METHOD { "<Unused>" }    TARGET_ATTRIBUTE_ENCODING { auto-detect }    RESPONSE_HEADER_LIST_ATTR { "" }    STATUS_CODE_ATTR { "_http_status_code" }    ERROR_ATTR { "_error" }    CONNECTION_TIMEOUT_LENGTH { 60 }    TRANSFER_TIMEOUT_LENGTH { 90 }    FOLLOW_REDIRECTS { FOLLOW_WITH_GET }    REDIRECT_AUTH { ORIGINAL_DOMAIN_ONLY }    VERIFY_SSL_CERTIFICATES { No }    NAMED_CONNECTION { "<Unused>" }    USE_COOKIES { No }    MAX_TRANSFERS_IN_PROGRESS { 25 }    MAX_HTTP_VERSION { HTTP_2 }    RATE_LIMIT_MAX_REQUESTS { <Unused> }    RATE_LIMIT_INTERVAL_IN_SECONDS { <Unused> }    RATE_LIMIT_REQUEST_TIMING { <Unused> }    RETRY_FAILED_TRANSFERS { <Unused> }    RETRY_MAX_RETRIES { <Unused> }    RETRY_INITIAL_BACKOFF { <Unused> }    SPLIT_MULTIPART_RESPONSE { NO }    MULTIPART_RESPONSE_HEADER_LIST_ATTR { "<Unused>" }    MINIMUM_ENCRYPTION_LEVEL { "OS_DEFAULT" }    CLIENT_CERTIFICATE_TYPE { "NONE" }    CLIENT_CERTIFICATE_FROM_OS { "<Unused>" }    CLIENT_CERTIFICATE_FILE { "<Unused>" }    CLIENT_CERTIFICATE_PRIVATE_KEY_FILE { "<Unused>" }    CLIENT_CERTIFICATE_PASSWORD { "<Unused>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_HTTPCaller_Output"          }    OUTPUT { REJECTED FEATURE_TYPE "$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_HTTPCaller_<REJECTED>"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} JSONQueryFactory    FACTORY_NAME { $(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_JSONFlattener }    INPUT  FEATURE_TYPE "$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_HTTPCaller_Output"    MODE FLATTEN    JSON_DOCUMENT { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_response_body<closeparen>,$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_JSONFlattener)" }    READ_FROM_FILE { NO }    FILEPATH_OR_URL { "<Unused>" }    EXPLODE_QUERY "json"    RECURSIVE_FLATTEN { YES }    ERROR_LIST_ATTR { "_json_error" }    OUTPUT { EXPLODED FEATURE_TYPE "$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_JSONFlattener_OUTPUT"        }    OUTPUT { REJECTED FEATURE_TYPE "$(ON_CKAN_CONTACT_FORM_EXTRACTOR_WORKSPACE_NAME)_JSONFlattener_<REJECTED>"        }
# -------------------------------------------------------------------------
