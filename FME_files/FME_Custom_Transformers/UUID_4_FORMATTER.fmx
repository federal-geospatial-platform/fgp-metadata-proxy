DEFAULT_MACRO $(UUID_4_FORMATTER_WORKSPACE_NAME)_StringConcatenator_1b9a03c6_d3cf_40de_94af_32655452feff0_ATTRS_TO_EVALUATE
INCLUDE [    if {{OUTGOING} == {OUTGOING}} {       if {[string length {id}] == 0} { return; };       set attrs [list {id}];    } else {       set attrs [split {<Unused>} { }];    };    set clauses {};    foreach attr $attrs {       lappend clauses "ATTR";       lappend clauses "{";       lappend clauses $attr;       lappend clauses {"<at>Value<openparen>id_substring_1<closeparen>-<at>Value<openparen>id_substring_2<closeparen>-<at>Value<openparen>id_substring_3<closeparen>-<at>Value<openparen>id_substring_4<closeparen>-<at>Value<openparen>id_substring_5<closeparen>"};       lappend clauses "}";    };    puts "MACRO $(UUID_4_FORMATTER_WORKSPACE_NAME)_StringConcatenator_1b9a03c6_d3cf_40de_94af_32655452feff0_ATTRS_TO_EVALUATE [join $clauses { }]"; ]
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(UUID_4_FORMATTER_WORKSPACE_NAME)_StringConcatenator }    INPUT  FEATURE_TYPE "$(UUID_4_FORMATTER_WORKSPACE_NAME)_SubstringExtractor_5_OUTPUT"    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    $($(UUID_4_FORMATTER_WORKSPACE_NAME)_StringConcatenator_1b9a03c6_d3cf_40de_94af_32655452feff0_ATTRS_TO_EVALUATE)    OUTPUT { OUTPUT FEATURE_TYPE "$(UUID_4_FORMATTER_WORKSPACE_NAME)_StringConcatenator_OUTPUT"        }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(UUID_4_FORMATTER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(UUID_4_FORMATTER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(UUID_4_FORMATTER_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(UUID_4_FORMATTER_WORKSPACE_NAME)_StringConcatenator_OUTPUT"    OUTPUT { FEATURE_TYPE "$(UUID_4_FORMATTER_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,id_substring_1,id_substring_5,id_substring_2,id_substring_3,id_substring_4)        $($(UUID_4_FORMATTER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(UUID_4_FORMATTER_WORKSPACE_NAME)_OUTPUT1762281311 Output Collector"   INPUT FEATURE_TYPE "$(UUID_4_FORMATTER_WORKSPACE_NAME)_AttributeRemover_OUTPUT"   OUTPUT FEATURE_TYPE "$(UUID_4_FORMATTER_WORKSPACE_NAME)_OUTPUT"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(UUID_4_FORMATTER_WORKSPACE_NAME))}]
