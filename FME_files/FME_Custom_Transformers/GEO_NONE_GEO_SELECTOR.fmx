FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_AttributeExposer_2 }    INPUT  FEATURE_TYPE "$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_TestFilter_LOG_ERROR"    OUTPUT { FEATURE_TYPE "$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_AttributeExposer_2_OUTPUT"          }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_AttributeExposer_2 OUTPUT Splitter"   INPUT FEATURE_TYPE "$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_AttributeExposer_2_OUTPUT"   OUTPUT FEATURE_TYPE "$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_AttributeExposer_2_OUTPUT_0_lKZWZ0Ot02E="   OUTPUT FEATURE_TYPE "$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_AttributeExposer_2_OUTPUT_1_HUNW5GnTqHE="
# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_Logger_4d630fd7_5822_4b91_b14d_adcab87d06780} ]
# If the Logger was in a custom transformer, the custom transformer's name was not being
# properly logged -- instead we saw "$(<customXformerName_WORKSPACE_NAME)" being logged as the prefix of the
# message. By deferencing and expanding out the XFORMER_NAME below, and then "WWJD" encoding it when it is
# used in the @Log call via the $encode macro name suffix trick, we get the right result, and the right result
# safely.
MACRO LOGGABLE_XFORMER_NAME $(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_Logger
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_Logger_Logger }    INPUT  FEATURE_TYPE "$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_AttributeExposer_2_OUTPUT_0_lKZWZ0Ot02E="    OUTPUT { FEATURE_TYPE "$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_Logger_LOGGED"                  @Log(ENCODED, "$(LOGGABLE_XFORMER_NAME$encode):<space>@EvaluateExpression(FDIV,STRING_ENCODED,ERROR<space>in<space>GEOSPATIAL_DATA_VALIDATOR<space>transforme:<space><at>value<openparen>_not_found_err_msg<closeparen><space><space>See<space>PROCESS_REPORT_MANUAL_TASKS.xls<space>file<space>in<space>XLS<space>directory<space>for<space>details.,$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_Logger)","20","20","",WARN,LOG_ONLY,$(FME_UUID_SAFE))                   }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_Logger LOGGED Transformer Output Nuker"   INPUT FEATURE_TYPE "$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_Logger_LOGGED"
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_Terminator }    INPUT  FEATURE_TYPE "$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_TestFilter_<lt>UNFILTERED<gt>"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"@EvaluateExpression(FDIV,STRING_ENCODED,Unknown<space>attribute<space>_geo_none_geo_status<space><at>Value<openparen>_geo_none_geo_status<closeparen>Translation<space>Terminated,$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_Terminator)")       @SupplyAttributes(_wb_termination_xformer,"$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_Terminator")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"@EvaluateExpression(FDIV,STRING_ENCODED,Unknown<space>attribute<space>_geo_none_geo_status<space><at>Value<openparen>_geo_none_geo_status<closeparen>Translation<space>Terminated,$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_Terminator)") }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_GEOSPATIAL1762277729 Output Collector"   INPUT FEATURE_TYPE "$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_AttributeCreator_11_OUTPUT"   OUTPUT FEATURE_TYPE "$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_GEOSPATIAL"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_NONE_GEOSPATIAL1762277729 Output Collector"   INPUT FEATURE_TYPE "$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_AttributeCreator_12_OUTPUT"   OUTPUT FEATURE_TYPE "$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_NONE_GEOSPATIAL"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_LOG_ERROR1762277729 Output Collector"   INPUT FEATURE_TYPE "$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_AttributeExposer_2_OUTPUT_1_HUNW5GnTqHE="   OUTPUT FEATURE_TYPE "$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_LOG_ERROR"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME))}]
