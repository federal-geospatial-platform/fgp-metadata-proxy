# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_PythonCaller_3_OUTPUT"    OUTPUT { FEATURE_TYPE "$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,_order,_creation_instance,_yaml_str)        $($(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_TestFilter_INPUT }    INPUT  FEATURE_TYPE "$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_AttributeRemover_OUTPUT"    OUTPUT { FEATURE_TYPE $(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_TestFilter_INPUTLINE }
FACTORY_DEF {*} TestFactory FACTORY_NAME { $(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_TestFilter } INPUT FEATURE_TYPE $(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_TestFilter_INPUTLINE FEATURE_TABLE_SHIM_SUPPORT Yes PASSED_TEST_GROUP_OUTPUT FIRST TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_geo_none_geo_status<closeparen>,$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_TestFilter) = geo ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_0 FEATURE_TYPE $(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_TestFilter_GEO TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_geo_none_geo_status<closeparen>,$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_TestFilter) = none_geo ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_1 FEATURE_TYPE $(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_TestFilter_NONE_GEO TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_geo_none_geo_status<closeparen>,$(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_TestFilter) = log_error ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_2 FEATURE_TYPE $(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_TestFilter_LOG_ERROR OUTPUT FAILED FEATURE_TYPE $(GEO_NONE_GEO_SELECTOR_WORKSPACE_NAME)_TestFilter_<lt>UNFILTERED<gt>
# -------------------------------------------------------------------------
