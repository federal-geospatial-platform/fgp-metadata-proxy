FME_PYTHON_PATH "$(FME_MF_DIR)"
FACTORY_DEF {*} PythonFactory    FACTORY_NAME { $(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_PythonCaller_2 }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT  FEATURE_TYPE "$(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_ListElementCounter_OUTPUT"    SYMBOL_NAME { processFeature }    SOURCE_CODE { import<space>fme<lf>import<space>fmeobjects<lf>#<space>Template<space>Function<space>interface:<lf>#<space>When<space>using<space>this<space>function<comma><space>make<space>sure<space>its<space>name<space>is<space>set<space>as<space>the<space>value<space>of<lf>#<space>the<space><apos>Class<space>or<space>Function<space>to<space>Process<space>Features<apos><space>transformer<space>parameter<lf>def<space>processFeature<openparen>feature<closeparen>:<lf><space><space><space><space>#Extracting<space>number<space>of<space>records<space>in<space>global<space>error<space>list<lf><space><space><space><space>#<space>starting<space>index<space>to<space>add<space>new<space>record<space>=<space>number<space>of<space>record.<lf><space><space><space><space>list_index=feature.getAttribute<openparen><apos>_element_count<apos><closeparen><lf><space><space><space><space><lf><space><space><space><space>if<space>feature.getAttribute<openparen><apos>mapping_errors_temp<opencurly><closecurly>.error<apos><closeparen>:<lf><space><space><space><space><lf><space><space><space><space><space><space><space><space>for<space>elem<space>in<space>feature.getAttribute<openparen><apos>mapping_errors_temp<opencurly><closecurly>.error<apos><closeparen>:<lf><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>mapping_errors<opencurly>%d<closecurly>.error<apos>%<openparen>list_index<closeparen><comma>elem<closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space>list_index=list_index+1<lf><space><space><space><space><space><space><space><space><space><space><space><space><lf><space><space><space><space><lf> }    PY_OUTPUT_TAGS { PYOUTPUT <Rejected> }    OUTPUT { PYOUTPUT FEATURE_TYPE "$(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_PythonCaller_2_OUTPUT"         }    OUTPUT { <Rejected> FEATURE_TYPE "$(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_PythonCaller_2_<Rejected>"         }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_PythonCaller_2 <Rejected> Transformer Output Nuker"   INPUT FEATURE_TYPE "$(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_PythonCaller_2_<Rejected>"
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "mapping_errors_temp<opencurly><closecurly>"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC }    } else {        puts "MACRO $(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_AttributeRemover_2 }    INPUT  FEATURE_TYPE "$(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_PythonCaller_2_OUTPUT"    INPUT  FEATURE_TYPE "$(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_Tester_2_FAILED"    OUTPUT { FEATURE_TYPE "$(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"        @RemoveAttributes(fme_encoded,att_2_map,english_mapping,original_value,code_mapping,real_value_english,code_value,_element_count,real_value_french,_priority,french_mapping)        $($(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Input Input Collector"   INPUT FEATURE_TYPE "$(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"   OUTPUT FEATURE_TYPE "$(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Input"
MACRO ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME $(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_XFORMER_NAME $(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
INCLUDE_CUSTOM_TRANSFORMER_VER ATTRIBUTE_UNEXPOSER:1
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Output Output Renamer/Nuker"   INPUT FEATURE_TYPE "$(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_OUTPUT1762278466 Output Collector"   INPUT FEATURE_TYPE "$(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_OUTPUT"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(METADATA_VALUE_MAPPER_WORKSPACE_NAME))}]
