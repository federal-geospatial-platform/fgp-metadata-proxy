#! <?xml version="1.0" encoding="UTF-8" ?>
#! <TRANSFORMER
# TRANSFORMER_BEGIN METADATA_VALUE_MAPPER,1,"""FGP Tools""",fe413901-7d2e-435a-ac34-5e25a5e79898,"Linked by Default",No,NO_PARALLELISM,,No,25241,YES,No,313,No,
# <p><strong>Description </strong></p>
# <p>This custom transformer corrects (maps) values to valid English values and valid French values equivalent and RI_CODES.  The name of the attribute to map and French, English and RI_CODES action are parametrizable.</p>
# <p><strong>Input Ports </strong></p>
# <p>LOOKUP_TABLE_INPUT: Input information from the lookup table</p>
# <p>DATA_INPUT: The input metadata records to process.</p>
# <p><strong>Output Ports </strong></p>
# <p>OUTPUT: The process output metdata records with value mapped.</p>
# <p><strong>Parameters </strong></p>
# <ul>
# <li>
# <p>ATT_TO_MAP: Name of the FME attribute to map in plain text (ex.: resources{}.format).  Do not use the Open Text Editor &gt; FME Feature Attribute option to select the attribute to map</p>
# </li>
# <li>
# <p>ERROR_NOT_MAPPED: Flag use to map data items values that cannot be found in the loopup tables. Can take 2 values: Yes: map data values not found; No: Do not map data values not found</p>
# </li>
# <li>
# <p>FRENCH_REFRESH: Flag use for updating French attribute value. Can take two value: Yes: update French attribute value; No do not update French atribute value</p>
# </li>
# <li>
# <p>ENGLISH_REFRESH: Flag use for updating English attribute value. Can take two value: Yes: update English attribute value; No do not update English attribute value</p>
# </li>
# <li>
# <p>CODE_REFRESH: Flag use for updating the RI_CODES. Can take two value: Yes: update the code; No do not update the code</p>
# </li>
# </ul>
# TRANSFORMER_END
#!   A0_PREVIEW_IMAGE="data:image/png;base64,"
#!   ARCGIS_COMPATIBILITY="ARCGIS_AUTO"
#!   ATTR_TYPE_ENCODING="SDF"
#!   BLOCKED_LOOPING="No"
#!   CATEGORY="&quot;FGP Tools&quot;"
