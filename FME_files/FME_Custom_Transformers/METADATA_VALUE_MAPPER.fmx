FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_Tester_2 }    INPUT  FEATURE_TYPE "$(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_PythonCaller_OUTPUT"    TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,$($(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_ERROR_NOT_MAPPED$encode),$(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_Tester_2)" = YES ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    OUTPUT { PASSED FEATURE_TYPE "$(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_Tester_2_PASSED"         }    OUTPUT { FAILED FEATURE_TYPE "$(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_Tester_2_FAILED"         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_AttributeExposer_2 }    INPUT  FEATURE_TYPE "$(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_Tester_2_PASSED"    OUTPUT { FEATURE_TYPE "$(METADATA_VALUE_MAPPER_WORKSPACE_NAME)_AttributeExposer_2_OUTPUT"          }
