FACTORY_DEF * TeeFactory   FACTORY_NAME "$(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_INPUT1762278323 Input Splitter"   INPUT FEATURE_TYPE "$(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_INPUT"   OUTPUT FEATURE_TYPE "$(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_INPUT_0_/BfpfIxBrgY="   OUTPUT FEATURE_TYPE "$(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_INPUT_1_duZgEYap3EQ="
# -------------------------------------------------------------------------
# If we're doing LAST N features, then the multiplier comes in as 0.
# If we're doing First N, multiplier is -1.
# For RANDOM, we need to treat LAST N as if it was first N (i.e. have a -1)
# That is what the ? : does in the rate multiplier.
INCLUDE [ if { {-1} == {0} && {ORIGINAL} == {ORIGINAL} } {              puts "MACRO REAL_MODE LAST"; 	         puts "MACRO REAL_RATE 1"; 	      } else {              puts "MACRO REAL_MODE ORIGINAL";              puts "MACRO REAL_RATE [expr 1 * ( -1 ? -1 : -1 ) ]"; 	      } ]
FACTORY_DEF {*} SamplingFactory    FACTORY_NAME { $(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_Sampler }    COMMAND_PARM_EVALUATION SINGLE_PASS    SAMPLE_RATE { $(REAL_RATE) }    SAMPLE_ORDER { $(REAL_MODE) }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT  FEATURE_TYPE "$(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_INPUT_0_/BfpfIxBrgY="    OUTPUT { SAMPLED FEATURE_TYPE ___SAMPLED___ }
# This TeeFactory is needed because Sampler will still output features if it has no OUTPUT clauses specified.
# This way we behave nicely even if there are no output connections on the transformer. See PR#28886.
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_Sampler_Sampled }    INPUT FEATURE_TYPE ___SAMPLED___    OUTPUT { FEATURE_TYPE "$(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_Sampler_SAMPLED"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_TestFilter_2_INPUT }    INPUT  FEATURE_TYPE "$(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_Sampler_SAMPLED"    OUTPUT { FEATURE_TYPE $(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_TestFilter_2_INPUTLINE }
FACTORY_DEF {*} TestFactory FACTORY_NAME { $(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_TestFilter_2 } INPUT FEATURE_TYPE $(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_TestFilter_2_INPUTLINE FEATURE_TABLE_SHIM_SUPPORT Yes PASSED_TEST_GROUP_OUTPUT FIRST TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>UpperCase<openparen>$($(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_LOCAL_SOURCE$encode)<closeparen>,$(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_TestFilter_2) = NO ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_0 FEATURE_TYPE $(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_TestFilter_2_PYCSW TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>UpperCase<openparen>$($(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_LOCAL_SOURCE$encode)<closeparen>,$(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_TestFilter_2) = YES ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_1 FEATURE_TYPE $(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_TestFilter_2_Local<space>Source OUTPUT FAILED FEATURE_TYPE $(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_TestFilter_2_<lt>UNFILTERED<gt>
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_TestFilter_2 <lt>UNFILTERED<gt> Transformer Output Nuker"   INPUT FEATURE_TYPE "$(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_TestFilter_2_<lt>UNFILTERED<gt>"
