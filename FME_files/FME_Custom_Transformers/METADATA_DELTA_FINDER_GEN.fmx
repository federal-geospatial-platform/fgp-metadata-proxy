Tcl2 proc $(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_ListSorter_3_sort {} {    set COMMENT {    = NOTE: algorithm below does not support nested lists.    };    regsub \"{}.*$\" {MD_Metadata.identificationInfo.MD_DataIdentification.descriptiveKeywords{}.MD_Keywords.thesaurusName.CI_Citation.title.CharacterString} \"\{\" listBase;    regsub \"{}.*$\" {MD_Metadata.identificationInfo.MD_DataIdentification.descriptiveKeywords{}.MD_Keywords.thesaurusName.CI_Citation.title.CharacterString} \"\" listName;    set listBaseLen [string length $listBase];    set listNameLen [expr $listBaseLen - 1];    set listValueExtension [string replace {MD_Metadata.identificationInfo.MD_DataIdentification.descriptiveKeywords{}.MD_Keywords.thesaurusName.CI_Citation.title.CharacterString} 0 $listBaseLen {}];    set kCloseBrace \"\}\";    set kAnyOtherCharacters {*};    set kPlaceholderMissingVal 1;    set kPlaceholderNullVal 2;    set kPlaceholderEmptyVal 3;    set COMMENT {    = To resolve PR 46315 (and friends), lets make a first pass to determine the full list of    = possible index numbers. Then we'll go through and make sure we have a KEY value for each    = of those.  We'll track what "keys" we added so that at the end we can REMOVE them so they stay MISSING.    };    set maxElementCount 0;    foreach attr [FME_AttributeNames] {       set COMMENT {       =    For each attribute "listattr{<index>}.count" and all related attributes       =    "listattr{<index>}<extension>", create a list of the form       =       {$listattr{<index>}.count <index>}, and keep a list of the extensions       =    for each index in the associative array listExtensions(<index>).       };       set attrStart [string range $attr 0 $listNameLen];       if { $attrStart == $listBase } {          set braceEnd [string first \} $attr $listBaseLen];          set index [string range $attr $listBaseLen [expr $braceEnd - 1]];          set extension [string range $attr [expr $braceEnd + 1] end];          if { [regexp {^[0-9