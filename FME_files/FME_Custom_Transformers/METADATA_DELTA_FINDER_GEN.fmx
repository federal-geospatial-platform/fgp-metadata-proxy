FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_ListElementCounter_2 }    INPUT  FEATURE_TYPE "$(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_ListSorter_2_OUTPUT"    OUTPUT { FEATURE_TYPE "$(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_ListElementCounter_2_OUTPUT"         @SupplyAttributes(ENCODED, _element_count_extent, @NumElements("MD_Metadata.identificationInfo.MD_DataIdentification.extent<opencurly><closecurly>",ENCODED))          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_Tester_4 }    INPUT  FEATURE_TYPE "$(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_ListElementCounter_2_OUTPUT"    TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_element_count_extent<closeparen>,$(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_Tester_4)" = 2 ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE "$(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_Tester_4_PASSED"         }    OUTPUT { FAILED FEATURE_TYPE "$(METADATA_DELTA_FINDER_GEN_WORKSPACE_NAME)_Tester_4_FAILED"         }
