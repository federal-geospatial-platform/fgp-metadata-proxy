FACTORY_DEF {*} PythonFactory    FACTORY_NAME { $(SPATIAL_TYPE_MAPPER_NG_WORKSPACE_NAME)_PythonCaller }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT  FEATURE_TYPE "$(SPATIAL_TYPE_MAPPER_NG_WORKSPACE_NAME)_ListSearcher_FOUND"    SYMBOL_NAME { set_spatial_representation }    SOURCE_CODE { from<space>Python.SPATIAL_TYPE_MAPPER_NG<space>import<space>set_spatial_representation<lf><space><space><space><space><lf><space><space><space><space><lf> }    PY_OUTPUT_TAGS { PYOUTPUT <Rejected> }    OUTPUT { PYOUTPUT FEATURE_TYPE "$(SPATIAL_TYPE_MAPPER_NG_WORKSPACE_NAME)_PythonCaller_OUTPUT"         }    OUTPUT { <Rejected> FEATURE_TYPE "$(SPATIAL_TYPE_MAPPER_NG_WORKSPACE_NAME)_PythonCaller_<Rejected>"         }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(SPATIAL_TYPE_MAPPER_NG_WORKSPACE_NAME)_PythonCaller <Rejected> Transformer Output Nuker"   INPUT FEATURE_TYPE "$(SPATIAL_TYPE_MAPPER_NG_WORKSPACE_NAME)_PythonCaller_<Rejected>"
