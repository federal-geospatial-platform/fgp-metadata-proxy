FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(SPATIAL_TYPE_MAPPER_NG_WORKSPACE_NAME)_Junction }    INPUT  FEATURE_TYPE "$(SPATIAL_TYPE_MAPPER_NG_WORKSPACE_NAME)_FeatureMerger_MERGED"    INPUT  FEATURE_TYPE "$(SPATIAL_TYPE_MAPPER_NG_WORKSPACE_NAME)_PythonCaller_OUTPUT"    OUTPUT { FEATURE_TYPE "$(SPATIAL_TYPE_MAPPER_NG_WORKSPACE_NAME)_Junction_Output"         }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "spatialType_histogram<opencurly><closecurly> spatial_trim<opencurly><closecurly>"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(SPATIAL_TYPE_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(SPATIAL_TYPE_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(SPATIAL_TYPE_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(SPATIAL_TYPE_MAPPER_NG_WORKSPACE_NAME)_Junction_Output"    OUTPUT { FEATURE_TYPE "$(SPATIAL_TYPE_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,_element_count,uuid,_list_index)        $($(SPATIAL_TYPE_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
