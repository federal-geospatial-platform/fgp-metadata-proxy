# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_Junction_3_Output"    OUTPUT { FEATURE_TYPE "$(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,_order,att_2_map,error_not_mapped,real_value,real_value_refresh,res_type_en_refresh,res_type_fr_refresh,resource_type_en,resource_type_fr)        $($(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_2 Input Input Collector"   INPUT FEATURE_TYPE "$(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_AttributeRemover_OUTPUT"   OUTPUT FEATURE_TYPE "$(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_2_Input"
MACRO ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME $(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_2
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_XFORMER_NAME $(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_2
INCLUDE_CUSTOM_TRANSFORMER_VER ATTRIBUTE_UNEXPOSER:1
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_2 Output Output Renamer/Nuker"   INPUT FEATURE_TYPE "$(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_2_Output"   OUTPUT FEATURE_TYPE "$(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_2_Output"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_OUTPUT1762278402 Output Collector"   INPUT FEATURE_TYPE "$(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_2_Output"   OUTPUT FEATURE_TYPE "$(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_OUTPUT"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_Unknown_Mime_Type1762278402 Output Collector"   INPUT FEATURE_TYPE "$(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_EMPTY_FORMAT_MAPPER_NG_UNKNOWN_MIME_TYPE"   OUTPUT FEATURE_TYPE "$(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_Unknown_Mime_Type"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME))}]
