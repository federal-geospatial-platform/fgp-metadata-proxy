# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {$(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_ListSearcher_2_03e5ec32_89a1_4079_825d_2d5a660c245b0} ]
# most of this is close to the code from listindexer but not exact beucase
# we have a type LIST_ATTR rather than type LIST_NAME so need
# to figure out the list name
Tcl2 proc $(FME_UUID_SAFE)_indexer {index prefix} {    set fullListAttrName [FME_DecodeText resources<opencurly><closecurly>.format];    set lastBrace [string last  \"{}\" $fullListAttrName];    set listAttr [string range $fullListAttrName 0 [expr $lastBrace+1]];    regsub \"{}\" $listAttr \"{$index}\" listWithIndex;    regsub \"{}\" $listAttr {} listBase;    set complexListExp "$listWithIndex\.";    set prefixLength [expr [string length $complexListExp]-1];    set prefix [FME_DecodeText $prefix];    foreach attr [FME_AttributeNames] {      set newAttr {};      if {$attr == $listWithIndex} {        set newAttr $listBase;      } elseif {[string first $complexListExp $attr] == 0} {        set newAttr [string replace $attr 0 $prefixLength];      };      if {$newAttr != {}} {          if {$prefix != {} } {            set newAttr $prefix$newAttr;          };          if {[string first {fme_} $newAttr] != 0} {              set first [string first {fme_} $newAttr];              lappend attrsToCopy $newAttr $attr;          };      };    };    if {[info exists attrsToCopy] && [llength $attrsToCopy] > 0} {      eval FME_Execute CopyAttributes $attrsToCopy;    }; }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_ListSearcher_2 }    INPUT  FEATURE_TYPE "$(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_PythonCaller_6_OUTPUT"    OUTPUT { FEATURE_TYPE $(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_ListSearcher_2__IndexedFeatures___         "$(FME_UUID_SAFE)" @SearchList(fme_encoded,"resources<opencurly><closecurly>.format","no_value",FIRST_MATCHED_ENCODED,CASE_SENSITIVE) }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_ListSearcher_2__Tester }    INPUT { FEATURE_TYPE $(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_ListSearcher_2__IndexedFeatures___ }    TEST { @Value($(FME_UUID_SAFE)) == "-1" }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    OUTPUT { PASSED FEATURE_TYPE  "$(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_ListSearcher_2_NOT_FOUND" @RemoveAttributes($(FME_UUID_SAFE)) }    OUTPUT { FAILED FEATURE_TYPE  $(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_ListSearcher_2__IndexFound__  }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_ListSearcher_2__Tester2 }    INPUT { FEATURE_TYPE $(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_ListSearcher_2__IndexFound__ }    TEST { NO == "NO" }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    OUTPUT { PASSED FEATURE_TYPE "$(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_ListSearcher_2_FOUND" @CopyAttributes(_list_index, $(FME_UUID_SAFE)) @RemoveAttributes($(FME_UUID_SAFE)) }    OUTPUT { FAILED FEATURE_TYPE "$(METADATA_FORMAT_MAPPER_NG_WORKSPACE_NAME)_ListSearcher_2_FOUND"  @Tcl2("$(FME_UUID_SAFE)_indexer {@Value($(FME_UUID_SAFE))} {<Unused>}") @CopyAttributes(_list_index, $(FME_UUID_SAFE)) @RemoveAttributes($(FME_UUID_SAFE)) }
