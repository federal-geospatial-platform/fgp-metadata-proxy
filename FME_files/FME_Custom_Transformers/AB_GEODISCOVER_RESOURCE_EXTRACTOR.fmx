# If the Logger was in a custom transformer, the custom transformer's name was not being
# properly logged -- instead we saw "$(<customXformerName_WORKSPACE_NAME)" being logged as the prefix of the
# message. By deferencing and expanding out the XFORMER_NAME below, and then "WWJD" encoding it when it is
# used in the @Log call via the $encode macro name suffix trick, we get the right result, and the right result
# safely.
MACRO LOGGABLE_XFORMER_NAME $(AB_GEODISCOVER_RESOURCE_EXTRACTOR_WORKSPACE_NAME)_Logger
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(AB_GEODISCOVER_RESOURCE_EXTRACTOR_WORKSPACE_NAME)_Logger_Logger }    INPUT  FEATURE_TYPE "$(AB_GEODISCOVER_RESOURCE_EXTRACTOR_WORKSPACE_NAME)_AttributeKeeper_4_OUTPUT"    OUTPUT { FEATURE_TYPE "$(AB_GEODISCOVER_RESOURCE_EXTRACTOR_WORKSPACE_NAME)_Logger_LOGGED"                  @Log(ENCODED, "$(LOGGABLE_XFORMER_NAME$encode):<space>@EvaluateExpression(FDIV,STRING_ENCODED,URL<space>with<space>value<space><at>Value<openparen>url_xml<closeparen><space>could<space>not<space>be<space>resolved<space>in<space>AB_GEODISCOVER_RESOURCE_EXTRACTOR.<space><space>See<space>GEODISCOVER_BROKER_URL<space>in<space>error<space>log<space>for<space>details.,$(AB_GEODISCOVER_RESOURCE_EXTRACTOR_WORKSPACE_NAME)_Logger)","20","20","",WARN,LOG_RECORD,$(FME_UUID_SAFE))                   }
