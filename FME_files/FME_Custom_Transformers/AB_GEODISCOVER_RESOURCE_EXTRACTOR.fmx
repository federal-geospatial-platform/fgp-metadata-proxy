FACTORY_DEF * TeeFactory   FACTORY_NAME "$(AB_GEODISCOVER_RESOURCE_EXTRACTOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Input Input Collector"   INPUT FEATURE_TYPE "$(AB_GEODISCOVER_RESOURCE_EXTRACTOR_WORKSPACE_NAME)_ListSorter_OUTPUT"   OUTPUT FEATURE_TYPE "$(AB_GEODISCOVER_RESOURCE_EXTRACTOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Input"
MACRO ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME $(AB_GEODISCOVER_RESOURCE_EXTRACTOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_XFORMER_NAME $(AB_GEODISCOVER_RESOURCE_EXTRACTOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
INCLUDE_CUSTOM_TRANSFORMER_VER ATTRIBUTE_UNEXPOSER:1
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(AB_GEODISCOVER_RESOURCE_EXTRACTOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Output Output Renamer/Nuker"   INPUT FEATURE_TYPE "$(AB_GEODISCOVER_RESOURCE_EXTRACTOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(AB_GEODISCOVER_RESOURCE_EXTRACTOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(AB_GEODISCOVER_RESOURCE_EXTRACTOR_WORKSPACE_NAME)_OUTPUT1762276478 Output Collector"   INPUT FEATURE_TYPE "$(AB_GEODISCOVER_RESOURCE_EXTRACTOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(AB_GEODISCOVER_RESOURCE_EXTRACTOR_WORKSPACE_NAME)_OUTPUT"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(AB_GEODISCOVER_RESOURCE_EXTRACTOR_WORKSPACE_NAME)_UNWORKING_URL1762276478 Output Collector"   INPUT FEATURE_TYPE "$(AB_GEODISCOVER_RESOURCE_EXTRACTOR_WORKSPACE_NAME)_Logger_LOGGED"   OUTPUT FEATURE_TYPE "$(AB_GEODISCOVER_RESOURCE_EXTRACTOR_WORKSPACE_NAME)_UNWORKING_URL"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(AB_GEODISCOVER_RESOURCE_EXTRACTOR_WORKSPACE_NAME))}]
