FACTORY_DEF * TeeFactory   FACTORY_NAME "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_INPUT1762280077 Input Splitter"   INPUT FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_INPUT"   OUTPUT FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_INPUT"
