FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_AttributeExposer }    INPUT  FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_INPUT"    OUTPUT { FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_AttributeExposer_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_UUIDGenerator }    INPUT  FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_AttributeExposer_OUTPUT"    OUTPUT { FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT"             "_uuid" @UUID(SIMPLE, UUID_FORMAT, UUID_ONLY)              }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_UUIDGenerator OUTPUT Splitter"   INPUT FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT"   OUTPUT FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_0_RID3Tx3QP5M="   OUTPUT FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_1_hNLAKvtUvXs="
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttributeKeeperFactory    FACTORY_NAME { $(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_AttributeKeeper }    INPUT  FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_0_RID3Tx3QP5M="    KEEP_ATTRS { _uuid }    KEEP_LISTS { resources<opencurly><closecurly> }    KEEP_FME_ATTRIBUTES Yes    BUILD_FEATURE_TABLES { NO }    OUTPUT_ON_ATTRIBUTE_CHANGE { <Unused> }    OUTPUT { OUTPUT FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_AttributeKeeper_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} ElementFactory    FACTORY_NAME { $(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_ListExploder }    INPUT  FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_AttributeKeeper_OUTPUT"    LIST_NAME { "resources{}" }    ELEMENT_NUMBER_FIELD { "_element_index" }    CLONE_GEOMETRY    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "INCOMING_IF_CONFLICT" }    INCOMING_PREFIX { "<Unused>" }    OUTPUT { ELEMENT FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_ListExploder_ELEMENTS"         @RemoveAttributes(ElementFactory.baseCloned)          }    OUTPUT { NOLIST FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_ListExploder_<REJECTED>"         @RemoveAttributes(ElementFactory.baseCloned)         fme_rejection_code MISSING_PARAMETER_LIST          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} StringReplacerFactory    FACTORY_NAME { $(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_StringReplacer }    INPUT  FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_ListExploder_ELEMENTS"    USE_REGEX { NO }    CASE_SENSITIVE { NO }    SOURCE_ATTRIBUTES { name }    FIND_TEXT { "_" }    REPLACE_TEXT { "<space>" }    REPLACE_NO_MATCH { "_FME_NO_OP_" }    OUTPUT { OUTPUT FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_StringReplacer_OUTPUT"          }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "resources<opencurly><closecurly>"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_1_hNLAKvtUvXs="    OUTPUT { FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,)        $($(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
# -------------------------------------------------------------------------
INCLUDE [if { {ATTRIBUTES} == {ATTRIBUTES} } {                puts "MACRO $(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO ATTRIBUTES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {POLYGONS}} {                puts "MACRO $(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {AGGREGATES}} {                puts "MACRO $(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO $(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {POLYGONS}} {                puts "MACRO $(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {AGGREGATES}} {                puts "MACRO $(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO $(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} } {                puts "MACRO $(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} } {                puts "MACRO $(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          else {}; ]
FACTORY_DEF {*} ReferenceFactory    FACTORY_NAME { $(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_FeatureMerger }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT REFERENCER FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_AttributeRemover_OUTPUT"    INPUT REFERENCEE FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_StringReplacer_OUTPUT"    REFERENCE_INFO { $($(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO) }    REFERENCE_TABLE { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_uuid<closeparen>,$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_FeatureMerger) @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_uuid<closeparen>,$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_FeatureMerger) AUTO }    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "REQUESTOR_IF_CONFLICT" }    IGNORE_NULLS { "No" }    HANDLE_NULL_MISSING_KEYS_LIKE_FME2013 { No }    LIST_NAME { "resources" }    LIST_ATTRS_TO_INCLUDE { <Unused> }    LIST_ATTRS_TO_INCLUDE_MODE { ALL }    MERGE_ATTRIBUTES Yes    MANAGE_FME_TYPE Yes    MODE COMPLETE    PROCESS_DUPLICATE_REFERENCEES { NO }    REFERENCEES_FIRST { No }    REJECT_INVALID_GEOM YES    CLEANING_TOLERANCE { <Unused> }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    COMPARE_WHITESPACE Yes    OUTPUT { COMPLETE FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_FeatureMerger_MERGED"         }    OUTPUT { REJECTED FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_FeatureMerger_<REJECTED>"         }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "resources<opencurly><closecurly>._uuid"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC }    } else {        puts "MACRO $(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_AttributeRemover_2 }    INPUT  FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_FeatureMerger_MERGED"    OUTPUT { FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"        @RemoveAttributes(fme_encoded,_uuid,_element_index)        $($(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Input Input Collector"   INPUT FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"   OUTPUT FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Input"
MACRO ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME $(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_XFORMER_NAME $(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
INCLUDE_CUSTOM_TRANSFORMER_VER ATTRIBUTE_UNEXPOSER:1
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Output Output Renamer/Nuker"   INPUT FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_Terminator }    INPUT  FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_ListExploder_<REJECTED>"    INPUT  FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_FeatureMerger_<REJECTED>"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"Feature<space>Merger<space>Error:<space>Translation<space>Terminated")       @SupplyAttributes(_wb_termination_xformer,"$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_Terminator")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"Feature<space>Merger<space>Error:<space>Translation<space>Terminated") }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_DATA_OUTPUT1762280077 Output Collector"   INPUT FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME)_DATA_OUTPUT"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(RESOURCE_NAME_UNDERSCORE_REMOVER_WORKSPACE_NAME))}]
