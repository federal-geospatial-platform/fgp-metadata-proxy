DEFAULT_MACRO WB_CURRENT_CONTEXT
DEFAULT_MACRO EMAIL_FORMAT_TESTER_WORKSPACE_NAME ""
INCLUDE [puts {MACRO WB_OLD_CONTEXT_$(EMAIL_FORMAT_TESTER_WORKSPACE_NAME) $(WB_CURRENT_CONTEXT)};          puts {MACRO WB_CURRENT_CONTEXT $(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)}]
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_INPUT1762277536 Input Splitter"   INPUT FEATURE_TYPE "$(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_INPUT"   OUTPUT FEATURE_TYPE "$(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_INPUT"
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_AttributeExposer_2 }    INPUT  FEATURE_TYPE "$(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_INPUT"    OUTPUT { FEATURE_TYPE "$(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_AttributeExposer_2_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_AttributeCreator_2 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_AttributeExposer_2_OUTPUT"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "default_email" "SET_TO" "$($(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_DEFAULT_CONTACT_EMAIL$encode)" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_AttributeCreator_2_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_UUIDGenerator }    INPUT  FEATURE_TYPE "$(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_AttributeCreator_2_OUTPUT"    OUTPUT { FEATURE_TYPE "$(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT"             "_uuidContacts" @UUID(SIMPLE, UUID_FORMAT, UUID_ONLY)              }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_UUIDGenerator OUTPUT Splitter"   INPUT FEATURE_TYPE "$(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT"   OUTPUT FEATURE_TYPE "$(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_0_K9oTQlWuFPs="   OUTPUT FEATURE_TYPE "$(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_1_Sg/v/EWJyuk="
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "contacts<opencurly><closecurly>"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_0_K9oTQlWuFPs="    OUTPUT { FEATURE_TYPE "$(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,)        $($(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
# -------------------------------------------------------------------------
