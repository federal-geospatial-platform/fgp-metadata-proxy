#! <?xml version="1.0" encoding="UTF-8" ?>
#! <TRANSFORMER
# TRANSFORMER_BEGIN EMAIL_FORMAT_TESTER,1,"""FGP Tools""",027b5850-cc4d-4476-bafc-da2c79436e87,"Linked by Default",No,NO_PARALLELISM,,No,25241,YES,No,313,No,
# <p><strong>Description </strong></p>
# <p>This custom transformer corrects wrongly formed email addresses.  It manages two cases: firstly when the email address do not contain the character"@", the email address is replaced by the default email adress; secondly when addresses are separated by coma, the email addresses are separated and placed into independant list of contacts{}.</p>
# <p><strong>Input Ports </strong></p>
# <ul>
# <li>INPUT: The input metadata records to process.</li>
# </ul>
# <p><strong>Output Ports </strong></p>
# <ul>
# <li>OUTPUT: The process output metadata records with email addresses corrected.</li>
# </ul>
# <p><strong>Parameters </strong></p>
# <ul>
# <li>DEFAULT_CONTACT_EMAIL: Name of the attribute containing the default email address or string character representing the default email address</li>
# </ul>
# TRANSFORMER_END
#!   A0_PREVIEW_IMAGE="data:image/png;base64,"
#!   ARCGIS_COMPATIBILITY="ARCGIS_AUTO"
#!   ATTR_TYPE_ENCODING="SDF"
