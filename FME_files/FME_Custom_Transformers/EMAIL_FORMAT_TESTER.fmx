# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_AttributeRemover_3_LIST_FUNC }    } else {        puts "MACRO $(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_AttributeRemover_3_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_AttributeRemover_3 }    INPUT  FEATURE_TYPE "$(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_AttributeSplitter_OUTPUT"    OUTPUT { FEATURE_TYPE "$(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_AttributeRemover_3_OUTPUT"        @RemoveAttributes(fme_encoded,email)        $($(EMAIL_FORMAT_TESTER_WORKSPACE_NAME)_AttributeRemover_3_LIST_FUNC)         }
