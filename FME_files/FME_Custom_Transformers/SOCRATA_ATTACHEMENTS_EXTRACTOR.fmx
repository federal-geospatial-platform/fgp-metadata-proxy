FACTORY_DEF * TeeFactory   FACTORY_NAME "$(SOCRATA_ATTACHEMENTS_EXTRACTOR_WORKSPACE_NAME)_Input1762280702 Input Splitter"   INPUT FEATURE_TYPE "$(SOCRATA_ATTACHEMENTS_EXTRACTOR_WORKSPACE_NAME)_Input"   OUTPUT FEATURE_TYPE "$(SOCRATA_ATTACHEMENTS_EXTRACTOR_WORKSPACE_NAME)_Input"
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(SOCRATA_ATTACHEMENTS_EXTRACTOR_WORKSPACE_NAME)_AttributeExposer_4 }    INPUT  FEATURE_TYPE "$(SOCRATA_ATTACHEMENTS_EXTRACTOR_WORKSPACE_NAME)_Input"    OUTPUT { FEATURE_TYPE "$(SOCRATA_ATTACHEMENTS_EXTRACTOR_WORKSPACE_NAME)_AttributeExposer_4_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(SOCRATA_ATTACHEMENTS_EXTRACTOR_WORKSPACE_NAME)_UUIDGenerator }    INPUT  FEATURE_TYPE "$(SOCRATA_ATTACHEMENTS_EXTRACTOR_WORKSPACE_NAME)_AttributeExposer_4_OUTPUT"    OUTPUT { FEATURE_TYPE "$(SOCRATA_ATTACHEMENTS_EXTRACTOR_WORKSPACE_NAME)_UUIDGenerator_OUTPUT"             "_uuid_attachement" @UUID(SIMPLE, UUID_FORMAT, UUID_ONLY)              }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(SOCRATA_ATTACHEMENTS_EXTRACTOR_WORKSPACE_NAME)_UUIDGenerator OUTPUT Splitter"   INPUT FEATURE_TYPE "$(SOCRATA_ATTACHEMENTS_EXTRACTOR_WORKSPACE_NAME)_UUIDGenerator_OUTPUT"   OUTPUT FEATURE_TYPE "$(SOCRATA_ATTACHEMENTS_EXTRACTOR_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_0_apQklzqfq4U="   OUTPUT FEATURE_TYPE "$(SOCRATA_ATTACHEMENTS_EXTRACTOR_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_1_SAVq6w16PZs="
# -------------------------------------------------------------------------
FACTORY_DEF {*} ElementFactory    FACTORY_NAME { $(SOCRATA_ATTACHEMENTS_EXTRACTOR_WORKSPACE_NAME)_ListExploder }    INPUT  FEATURE_TYPE "$(SOCRATA_ATTACHEMENTS_EXTRACTOR_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_0_apQklzqfq4U="    LIST_NAME { "metadata.attachments{}" }    ELEMENT_NUMBER_FIELD { "_element_index" }    CLONE_GEOMETRY    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "INCOMING_IF_CONFLICT" }    INCOMING_PREFIX { "<Unused>" }    OUTPUT { ELEMENT FEATURE_TYPE "$(SOCRATA_ATTACHEMENTS_EXTRACTOR_WORKSPACE_NAME)_ListExploder_ELEMENTS"         @RemoveAttributes(ElementFactory.baseCloned)          }    OUTPUT { NOLIST FEATURE_TYPE "$(SOCRATA_ATTACHEMENTS_EXTRACTOR_WORKSPACE_NAME)_ListExploder_<REJECTED>"         @RemoveAttributes(ElementFactory.baseCloned)         fme_rejection_code MISSING_PARAMETER_LIST          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TextEncoderFactory    FACTORY_NAME { $(SOCRATA_ATTACHEMENTS_EXTRACTOR_WORKSPACE_NAME)_TextEncoder }    INPUT  FEATURE_TYPE "$(SOCRATA_ATTACHEMENTS_EXTRACTOR_WORKSPACE_NAME)_ListExploder_ELEMENTS"    ACTION { URL_ENCODE }    RESULT_ATTR { "filename" }    VALUE_TO_ENCODE { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>filename<closeparen>,$(SOCRATA_ATTACHEMENTS_EXTRACTOR_WORKSPACE_NAME)_TextEncoder)" }    OUTPUT { OUTPUT FEATURE_TYPE "$(SOCRATA_ATTACHEMENTS_EXTRACTOR_WORKSPACE_NAME)_TextEncoder_OUTPUT"        }
