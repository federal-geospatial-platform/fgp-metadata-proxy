FACTORY_DEF {*} ListFactory    FACTORY_NAME { $(SOCRATA_ATTACHEMENTS_EXTRACTOR_WORKSPACE_NAME)_ListBuilder }    INPUT { FEATURE_TYPE $(SOCRATA_ATTACHEMENTS_EXTRACTOR_WORKSPACE_NAME)_ListBuilder_no_fme_type }    LIST_NAME { "attachement_resources" }    LIST_ATTRS_TO_INCLUDE { format name protocol url }    LIST_ATTRS_TO_INCLUDE_MODE { SELECTED }    GROUP_BY { _uuid_attachement }    FLUSH_WHEN_GROUPS_CHANGE { No }    OUTPUT { LIST FEATURE_TYPE "$(SOCRATA_ATTACHEMENTS_EXTRACTOR_WORKSPACE_NAME)_ListBuilder_OUTPUT"          }
