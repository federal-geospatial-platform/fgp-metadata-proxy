FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(DCAT_Reader_PEI_WORKSPACE_NAME)_AttributeCreator_8 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(DCAT_Reader_PEI_WORKSPACE_NAME)_AttributeCreator_3_OUTPUT_0_RbV6ITxM35A="    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "_type_requete" "SET_TO" "DCAT-PRIMARY" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(DCAT_Reader_PEI_WORKSPACE_NAME)_AttributeCreator_8_OUTPUT"        }
