MACRO ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME $(DCAT_Reader_PEI_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_3
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_XFORMER_NAME $(DCAT_Reader_PEI_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_3
INCLUDE_CUSTOM_TRANSFORMER_VER ATTRIBUTE_UNEXPOSER:1
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(DCAT_Reader_PEI_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_3 Output Output Renamer/Nuker"   INPUT FEATURE_TYPE "$(DCAT_Reader_PEI_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_3_Output"   OUTPUT FEATURE_TYPE "$(DCAT_Reader_PEI_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_3_Output"
# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {$(DCAT_Reader_PEI_WORKSPACE_NAME)_JSONFlattener_3__Rejected__2_2f8e26f4_4a9e_4b2b_887f_f4ea4e9269770} ]
# If the Logger was in a custom transformer, the custom transformer's name was not being
# properly logged -- instead we saw "$(<customXformerName_WORKSPACE_NAME)" being logged as the prefix of the
# message. By deferencing and expanding out the XFORMER_NAME below, and then "WWJD" encoding it when it is
# used in the @Log call via the $encode macro name suffix trick, we get the right result, and the right result
# safely.
MACRO LOGGABLE_XFORMER_NAME $(DCAT_Reader_PEI_WORKSPACE_NAME)_JSONFlattener_3__Rejected__2
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(DCAT_Reader_PEI_WORKSPACE_NAME)_JSONFlattener_3__Rejected__2_Logger }    INPUT  FEATURE_TYPE "$(DCAT_Reader_PEI_WORKSPACE_NAME)_JSONFlattener_4_<REJECTED>"    OUTPUT { FEATURE_TYPE "$(DCAT_Reader_PEI_WORKSPACE_NAME)_JSONFlattener_3__Rejected__2_LOGGED"                  @Log(ENCODED, "$(LOGGABLE_XFORMER_NAME$encode):<space>Feature is:","20","20","",INFO,LOG_ONLY,$(FME_UUID_SAFE))                   }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(DCAT_Reader_PEI_WORKSPACE_NAME)_JSONFlattener_3__Rejected__2 LOGGED Transformer Output Nuker"   INPUT FEATURE_TYPE "$(DCAT_Reader_PEI_WORKSPACE_NAME)_JSONFlattener_3__Rejected__2_LOGGED"
# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {$(DCAT_Reader_PEI_WORKSPACE_NAME)_TestFilter_2_Other_Error_2_38e50624_cdaf_4ef1_a716_65aa2d4433070} ]
# If the Logger was in a custom transformer, the custom transformer's name was not being
# properly logged -- instead we saw "$(<customXformerName_WORKSPACE_NAME)" being logged as the prefix of the
# message. By deferencing and expanding out the XFORMER_NAME below, and then "WWJD" encoding it when it is
# used in the @Log call via the $encode macro name suffix trick, we get the right result, and the right result
# safely.
MACRO LOGGABLE_XFORMER_NAME $(DCAT_Reader_PEI_WORKSPACE_NAME)_TestFilter_2_Other_Error_2
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(DCAT_Reader_PEI_WORKSPACE_NAME)_TestFilter_2_Other_Error_2_Logger }    INPUT  FEATURE_TYPE "$(DCAT_Reader_PEI_WORKSPACE_NAME)_TestFilter_7_Other<space>Error"    OUTPUT { FEATURE_TYPE "$(DCAT_Reader_PEI_WORKSPACE_NAME)_TestFilter_2_Other_Error_2_LOGGED"                  @Log(ENCODED, "$(LOGGABLE_XFORMER_NAME$encode):<space>Feature is:","20","20","",INFO,LOG_ONLY,$(FME_UUID_SAFE))                   }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(DCAT_Reader_PEI_WORKSPACE_NAME)_TestFilter_2_Other_Error_2 LOGGED Transformer Output Nuker"   INPUT FEATURE_TYPE "$(DCAT_Reader_PEI_WORKSPACE_NAME)_TestFilter_2_Other_Error_2_LOGGED"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(DCAT_Reader_PEI_WORKSPACE_NAME)_Output1762276619 Output Collector"   INPUT FEATURE_TYPE "$(DCAT_Reader_PEI_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_3_Output"   OUTPUT FEATURE_TYPE "$(DCAT_Reader_PEI_WORKSPACE_NAME)_Output"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(DCAT_Reader_PEI_WORKSPACE_NAME))}]
