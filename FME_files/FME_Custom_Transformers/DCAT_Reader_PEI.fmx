FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(DCAT_Reader_PEI_WORKSPACE_NAME)_AttributeCreator_3 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(DCAT_Reader_PEI_WORKSPACE_NAME)_Input"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "_url_dcat_primary" "SET_TO" "https:<solidus><solidus>data.princeedwardisland.ca<solidus>data.json" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "_url_dcat_secondary" "SET_TO" "https:<solidus><solidus>data.princeedwardisland.ca<solidus>api<solidus>v3<solidus>datasets?filter<openbracket>owner<closebracket>=pei_enterprise_admin<amp>page<openbracket>number<closebracket>=1<amp>page<openbracket>size<closebracket>=25" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(DCAT_Reader_PEI_WORKSPACE_NAME)_AttributeCreator_3_OUTPUT"        }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(DCAT_Reader_PEI_WORKSPACE_NAME)_AttributeCreator_3 OUTPUT Splitter"   INPUT FEATURE_TYPE "$(DCAT_Reader_PEI_WORKSPACE_NAME)_AttributeCreator_3_OUTPUT"   OUTPUT FEATURE_TYPE "$(DCAT_Reader_PEI_WORKSPACE_NAME)_AttributeCreator_3_OUTPUT_0_RbV6ITxM35A="   OUTPUT FEATURE_TYPE "$(DCAT_Reader_PEI_WORKSPACE_NAME)_AttributeCreator_3_OUTPUT_1_hcsL403r6Q0="
