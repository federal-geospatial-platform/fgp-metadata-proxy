# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {$(DCAT_Reader_PEI_WORKSPACE_NAME)_JSONFlattener__Rejected__2_9c592002_79bb_45a7_a32c_6a772f8f45940} ]
# If the Logger was in a custom transformer, the custom transformer's name was not being
# properly logged -- instead we saw "$(<customXformerName_WORKSPACE_NAME)" being logged as the prefix of the
# message. By deferencing and expanding out the XFORMER_NAME below, and then "WWJD" encoding it when it is
# used in the @Log call via the $encode macro name suffix trick, we get the right result, and the right result
# safely.
MACRO LOGGABLE_XFORMER_NAME $(DCAT_Reader_PEI_WORKSPACE_NAME)_JSONFlattener__Rejected__2
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(DCAT_Reader_PEI_WORKSPACE_NAME)_JSONFlattener__Rejected__2_Logger }    INPUT  FEATURE_TYPE "$(DCAT_Reader_PEI_WORKSPACE_NAME)_JSONFlattener_2_<REJECTED>"    OUTPUT { FEATURE_TYPE "$(DCAT_Reader_PEI_WORKSPACE_NAME)_JSONFlattener__Rejected__2_LOGGED"                  @Log(ENCODED, "$(LOGGABLE_XFORMER_NAME$encode):<space>Feature is:","20","20","",INFO,LOG_ONLY,$(FME_UUID_SAFE))                   }
