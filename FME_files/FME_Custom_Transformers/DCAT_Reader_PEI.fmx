FME_PYTHON_PATH "$(FME_MF_DIR)"
FACTORY_DEF {*} PythonFactory    FACTORY_NAME { $(DCAT_Reader_PEI_WORKSPACE_NAME)_PythonCaller_9 }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT  FEATURE_TYPE "$(DCAT_Reader_PEI_WORKSPACE_NAME)_AttributeCreator_8_OUTPUT"    SYMBOL_NAME { ManageHttpCall }    SOURCE_CODE { from<space>Python.DCAT_Reader<space>import<space>ManageHttpCall<lf> }    PY_OUTPUT_TAGS { PYOUTPUT <Rejected> }    OUTPUT { PYOUTPUT FEATURE_TYPE "$(DCAT_Reader_PEI_WORKSPACE_NAME)_PythonCaller_9_OUTPUT"         }    OUTPUT { <Rejected> FEATURE_TYPE "$(DCAT_Reader_PEI_WORKSPACE_NAME)_PythonCaller_9_<Rejected>"         }
