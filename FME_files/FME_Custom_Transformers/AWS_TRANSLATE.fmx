DEFAULT_MACRO WB_CURRENT_CONTEXT
DEFAULT_MACRO AWS_TRANSLATE_WORKSPACE_NAME ""
INCLUDE [puts {MACRO WB_OLD_CONTEXT_$(AWS_TRANSLATE_WORKSPACE_NAME) $(WB_CURRENT_CONTEXT)};          puts {MACRO WB_CURRENT_CONTEXT $(AWS_TRANSLATE_WORKSPACE_NAME)}]
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(AWS_TRANSLATE_WORKSPACE_NAME)_INPUT1762274943 Input Splitter"   INPUT FEATURE_TYPE "$(AWS_TRANSLATE_WORKSPACE_NAME)_INPUT"   OUTPUT FEATURE_TYPE "$(AWS_TRANSLATE_WORKSPACE_NAME)_INPUT"
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(AWS_TRANSLATE_WORKSPACE_NAME)_AttributeCreator }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(AWS_TRANSLATE_WORKSPACE_NAME)_INPUT"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "_aws_activation" "SET_TO" "$($(AWS_TRANSLATE_WORKSPACE_NAME)_ACTIVATE_TRANSLATION$encode)" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "_mode" "SET_TO" "$($(AWS_TRANSLATE_WORKSPACE_NAME)_MODE$encode)" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "_attr2translate" "SET_TO" "$($(AWS_TRANSLATE_WORKSPACE_NAME)_ATTR_2_TRANSLATE$encode)" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "_attrlist2translate" "SET_TO" "$($(AWS_TRANSLATE_WORKSPACE_NAME)_ATTR_LIST_2_TRANSLATE$encode)" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(AWS_TRANSLATE_WORKSPACE_NAME)_AttributeCreator_OUTPUT"        }
# -------------------------------------------------------------------------
FME_PYTHON_PATH "$(FME_MF_DIR)"
FACTORY_DEF {*} PythonFactory    FACTORY_NAME { $(AWS_TRANSLATE_WORKSPACE_NAME)_PythonCaller }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT  FEATURE_TYPE "$(AWS_TRANSLATE_WORKSPACE_NAME)_AttributeCreator_OUTPUT"    SYMBOL_NAME { process_feature }    SOURCE_CODE { from<space>Python.AWS_TRANSLATE<space>import<space>process_feature }    PY_OUTPUT_TAGS { PYOUTPUT <Rejected> }    OUTPUT { PYOUTPUT FEATURE_TYPE "$(AWS_TRANSLATE_WORKSPACE_NAME)_PythonCaller_OUTPUT"         }    OUTPUT { <Rejected> FEATURE_TYPE "$(AWS_TRANSLATE_WORKSPACE_NAME)_PythonCaller_<Rejected>"         }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(AWS_TRANSLATE_WORKSPACE_NAME)_PythonCaller <Rejected> Transformer Output Nuker"   INPUT FEATURE_TYPE "$(AWS_TRANSLATE_WORKSPACE_NAME)_PythonCaller_<Rejected>"
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(AWS_TRANSLATE_WORKSPACE_NAME)_TestFilter_INPUT }    INPUT  FEATURE_TYPE "$(AWS_TRANSLATE_WORKSPACE_NAME)_PythonCaller_OUTPUT"    OUTPUT { FEATURE_TYPE $(AWS_TRANSLATE_WORKSPACE_NAME)_TestFilter_INPUTLINE }
FACTORY_DEF {*} TestFactory FACTORY_NAME { $(AWS_TRANSLATE_WORKSPACE_NAME)_TestFilter } INPUT FEATURE_TYPE $(AWS_TRANSLATE_WORKSPACE_NAME)_TestFilter_INPUTLINE FEATURE_TABLE_SHIM_SUPPORT Yes PASSED_TEST_GROUP_OUTPUT FIRST TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_translation_status<closeparen>,$(AWS_TRANSLATE_WORKSPACE_NAME)_TestFilter) = 0 ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_0 FEATURE_TYPE $(AWS_TRANSLATE_WORKSPACE_NAME)_TestFilter_SUCCESS OUTPUT FAILED FEATURE_TYPE $(AWS_TRANSLATE_WORKSPACE_NAME)_TestFilter_FAILURE
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(AWS_TRANSLATE_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(AWS_TRANSLATE_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(AWS_TRANSLATE_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(AWS_TRANSLATE_WORKSPACE_NAME)_TestFilter_SUCCESS"    OUTPUT { FEATURE_TYPE "$(AWS_TRANSLATE_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,_attr2translate,_attrlist2translate,_aws_activation,_mode,_translation_status)        $($(AWS_TRANSLATE_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(AWS_TRANSLATE_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Input Input Collector"   INPUT FEATURE_TYPE "$(AWS_TRANSLATE_WORKSPACE_NAME)_AttributeRemover_OUTPUT"   OUTPUT FEATURE_TYPE "$(AWS_TRANSLATE_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Input"
MACRO ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME $(AWS_TRANSLATE_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_XFORMER_NAME $(AWS_TRANSLATE_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
INCLUDE_CUSTOM_TRANSFORMER_VER ATTRIBUTE_UNEXPOSER:1
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(AWS_TRANSLATE_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Output Output Renamer/Nuker"   INPUT FEATURE_TYPE "$(AWS_TRANSLATE_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(AWS_TRANSLATE_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(AWS_TRANSLATE_WORKSPACE_NAME)_OUTPUT1762274943 Output Collector"   INPUT FEATURE_TYPE "$(AWS_TRANSLATE_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(AWS_TRANSLATE_WORKSPACE_NAME)_OUTPUT"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(AWS_TRANSLATE_WORKSPACE_NAME)_TRANSLATION_PROBLEM1762274943 Output Collector"   INPUT FEATURE_TYPE "$(AWS_TRANSLATE_WORKSPACE_NAME)_TestFilter_FAILURE"   OUTPUT FEATURE_TYPE "$(AWS_TRANSLATE_WORKSPACE_NAME)_TRANSLATION_PROBLEM"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(AWS_TRANSLATE_WORKSPACE_NAME))}]
