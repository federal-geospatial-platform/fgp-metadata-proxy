FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(ATTRIBUTE_MAPPER_AND_LENGTH_CHECKER_WORKSPACE_NAME)_Tester_2 }    INPUT  FEATURE_TYPE "$(ATTRIBUTE_MAPPER_AND_LENGTH_CHECKER_WORKSPACE_NAME)_ListConcatenator_OUTPUT"    TEST { _to_long_value_concatenated ATTRIBUTE_HAS_A_VALUE "" ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE "$(ATTRIBUTE_MAPPER_AND_LENGTH_CHECKER_WORKSPACE_NAME)_Tester_2_PASSED"         }    OUTPUT { FAILED FEATURE_TYPE "$(ATTRIBUTE_MAPPER_AND_LENGTH_CHECKER_WORKSPACE_NAME)_Tester_2_FAILED"         }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(ATTRIBUTE_MAPPER_AND_LENGTH_CHECKER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(ATTRIBUTE_MAPPER_AND_LENGTH_CHECKER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(ATTRIBUTE_MAPPER_AND_LENGTH_CHECKER_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(ATTRIBUTE_MAPPER_AND_LENGTH_CHECKER_WORKSPACE_NAME)_Tester_2_FAILED"    OUTPUT { FEATURE_TYPE "$(ATTRIBUTE_MAPPER_AND_LENGTH_CHECKER_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,_to_long_value_concatenated,att_2_map,char_limit)        $($(ATTRIBUTE_MAPPER_AND_LENGTH_CHECKER_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
