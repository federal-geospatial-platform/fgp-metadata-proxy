# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {$(ATTRIBUTE_MAPPER_AND_LENGTH_CHECKER_WORKSPACE_NAME)_ListConcatenator_dc598abe_b11f_42b2_a0c8_4cad6c8f4bcb0} ]
Tcl2 set $(FME_UUID_SAFE)__separator [FME_DecodeText {<semicolon>}];      regsub -all \"{}\" [FME_DecodeText {_to_long_value<opencurly><closecurly>}] [FME_DecodeText {<opencurly><backslash>d+<closecurly>}] $(FME_UUID_SAFE)__listPattern;      set $(FME_UUID_SAFE)__listPattern ^$$(FME_UUID_SAFE)__listPattern$;
Tcl2 proc $(FME_UUID_SAFE)__Concatenate {} {   upvar \#0 $(FME_UUID_SAFE)__separator separator             $(FME_UUID_SAFE)__listPattern listPattern;   set allAttrs [lsort -dictionary [FME_AttributeNames]];   set keepEmptyParts [string equal {Yes} {No}];   set result {};   foreach attrName $allAttrs {     if {[regexp $listPattern $attrName]} {       set attrValue [FME_GetAttribute $attrName];       if {$keepEmptyParts || $attrValue != {}} {         lappend result $attrValue;       };     };   };   FME_SetAttribute [FME_DecodeText {"_to_long_value_concatenated"}] [join $result $separator]; }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(ATTRIBUTE_MAPPER_AND_LENGTH_CHECKER_WORKSPACE_NAME)_ListConcatenator }    INPUT  FEATURE_TYPE "$(ATTRIBUTE_MAPPER_AND_LENGTH_CHECKER_WORKSPACE_NAME)_AttributeExposer_2_OUTPUT"    OUTPUT { FEATURE_TYPE "$(ATTRIBUTE_MAPPER_AND_LENGTH_CHECKER_WORKSPACE_NAME)_ListConcatenator_OUTPUT"         @Tcl2($(FME_UUID_SAFE)__Concatenate)          }
