FME_PYTHON_PATH "$(FME_MF_DIR)"
FACTORY_DEF {*} PythonFactory    FACTORY_NAME { $(NT_language_manager_WORKSPACE_NAME)_PythonCaller_6 }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT  FEATURE_TYPE "$(NT_language_manager_WORKSPACE_NAME)_Sorter_SORTED"    SYMBOL_NAME { FeatureProcessor }    SOURCE_CODE { import<space>fme<lf>import<space>fmeobjects<lf>from<space>Python.FME_utils<space>import<space>FME_utils<lf><space><lf>class<space>FeatureProcessor<openparen>object<closeparen>:<lf><space><space><space><space>def<space>__init__<openparen>self<closeparen>:<lf><space><space><space><space><space><space><space><space>self.dict<space>=<space><opencurly><closecurly><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>#empty<space>dictionary<space>that<space>will<space>contain<space>key<space><openparen>url<closeparen><space>and<space>value<space><openparen>language<closeparen><space>of<space>the<space>look-up<space>table<lf><space><space><space><space><space><space><space><space><lf><space><space><space><space>def<space>input<openparen>self<comma>feature<closeparen>:<lf><space><space><space><space><space><space><space><space>order=feature.getAttribute<openparen><apos>order<apos><closeparen><lf><space><space><space><space><space><space><space><space>if<space>order<space>==<space>1:<space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>#create<space>dictionary<space>from<space>look-up<space>table<space><openparen>key:url<semicolon>value:language<closeparen><lf><space><space><space><space><space><space><space><space><space><space><space>url_key<space>=<space>feature.getAttribute<openparen><apos>resources_url<apos><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space>language<space>=<space>feature.getAttribute<openparen><apos>resources_language<apos><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space>self.dict<openbracket>url_key<closebracket><space>=<space>language<lf><space><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space>elif<space>order<space>==<space>2:<space><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space><space><space><space>max_index=FME_utils.max_index_attribute_list<openparen>feature<comma><apos>resources<opencurly><closecurly>.url<apos><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space>for<space>j<space>in<space>range<openparen>max_index+1<closeparen>:<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space>url<space>=<space>feature.getAttribute<openparen><apos>resources<opencurly>%i<closecurly>.url<apos>%<openparen>j<closeparen><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space>if<space>url<space>not<space>in<space>self.dict.keys<openparen><closeparen>:<space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>#if<space>url<space>not<space>in<space>the<space>lookup<space>table<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>resources<opencurly>%i<closecurly>.language_error<apos>%<openparen>j<closeparen><comma><apos>yes<apos><closeparen><space><space><space>#add<space>a<space>list.attribute<space><apos>.language_error<apos><space>to<space>the<space><apos>resources<apos><space>list<space>and<space>set<space>it<space>to<space><apos>yes<apos><space><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space>else:<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>if<space>self.dict<openbracket>url<closebracket><space>!=<space><apos>english<apos>:<space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>#if<space>the<space>language<space>value<space>not<space>the<space>default<space>value<space>english<space><openparen><apos>english<apos><closeparen><semicolon><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>resources<opencurly>%i<closecurly>.language<apos>%<openparen>j<closeparen><comma>self.dict<openbracket>url<closebracket><closeparen><space><space><space><space><space><space><space><space>#set<space>the<space>language<space>value<space>contained<space>in<space>the<space>look-up<space>table<lf><space><space><space><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space><space><space><space>self.pyoutput<openparen>feature<closeparen><lf><lf><space><space><space><space>def<space>close<openparen>self<closeparen>:<lf><space><space><space><space><space><space><space><space><space><space><space>pass }    PY_OUTPUT_TAGS { PYOUTPUT <Rejected> }    OUTPUT { PYOUTPUT FEATURE_TYPE "$(NT_language_manager_WORKSPACE_NAME)_PythonCaller_6_OUTPUT"         }    OUTPUT { <Rejected> FEATURE_TYPE "$(NT_language_manager_WORKSPACE_NAME)_PythonCaller_6_<Rejected>"         }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NT_language_manager_WORKSPACE_NAME)_PythonCaller_6 <Rejected> Transformer Output Nuker"   INPUT FEATURE_TYPE "$(NT_language_manager_WORKSPACE_NAME)_PythonCaller_6_<Rejected>"
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(NT_language_manager_WORKSPACE_NAME)_AttributeExposer_2 }    INPUT  FEATURE_TYPE "$(NT_language_manager_WORKSPACE_NAME)_PythonCaller_6_OUTPUT"    OUTPUT { FEATURE_TYPE "$(NT_language_manager_WORKSPACE_NAME)_AttributeExposer_2_OUTPUT"          }
# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {$(NT_language_manager_WORKSPACE_NAME)_ListSearcher_0d207047_4870_49f2_bc14_689e503602020} ]
# most of this is close to the code from listindexer but not exact beucase
# we have a type LIST_ATTR rather than type LIST_NAME so need
# to figure out the list name
Tcl2 proc $(FME_UUID_SAFE)_indexer {index prefix} {    set fullListAttrName [FME_DecodeText resources<opencurly><closecurly>.language_error];    set lastBrace [string last  \"{}\" $fullListAttrName];    set listAttr [string range $fullListAttrName 0 [expr $lastBrace+1]];    regsub \"{}\" $listAttr \"{$index}\" listWithIndex;    regsub \"{}\" $listAttr {} listBase;    set complexListExp "$listWithIndex\.";    set prefixLength [expr [string length $complexListExp]-1];    set prefix [FME_DecodeText $prefix];    foreach attr [FME_AttributeNames] {      set newAttr {};      if {$attr == $listWithIndex} {        set newAttr $listBase;      } elseif {[string first $complexListExp $attr] == 0} {        set newAttr [string replace $attr 0 $prefixLength];      };      if {$newAttr != {}} {          if {$prefix != {} } {            set newAttr $prefix$newAttr;          };          if {[string first {fme_} $newAttr] != 0} {              set first [string first {fme_} $newAttr];              lappend attrsToCopy $newAttr $attr;          };      };    };    if {[info exists attrsToCopy] && [llength $attrsToCopy] > 0} {      eval FME_Execute CopyAttributes $attrsToCopy;    }; }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(NT_language_manager_WORKSPACE_NAME)_ListSearcher }    INPUT  FEATURE_TYPE "$(NT_language_manager_WORKSPACE_NAME)_AttributeExposer_2_OUTPUT"    OUTPUT { FEATURE_TYPE $(NT_language_manager_WORKSPACE_NAME)_ListSearcher__IndexedFeatures___         "$(FME_UUID_SAFE)" @SearchList(fme_encoded,"resources<opencurly><closecurly>.language_error","yes",REGULAR_EXPRESSION_ENCODED,CASE_SENSITIVE) }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(NT_language_manager_WORKSPACE_NAME)_ListSearcher__Tester }    INPUT { FEATURE_TYPE $(NT_language_manager_WORKSPACE_NAME)_ListSearcher__IndexedFeatures___ }    TEST { @Value($(FME_UUID_SAFE)) == "-1" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE  "$(NT_language_manager_WORKSPACE_NAME)_ListSearcher_NOT_FOUND" @RemoveAttributes($(FME_UUID_SAFE)) }    OUTPUT { FAILED FEATURE_TYPE  $(NT_language_manager_WORKSPACE_NAME)_ListSearcher__IndexFound__  }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(NT_language_manager_WORKSPACE_NAME)_ListSearcher__Tester2 }    INPUT { FEATURE_TYPE $(NT_language_manager_WORKSPACE_NAME)_ListSearcher__IndexFound__ }    TEST { NO == "NO" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE "$(NT_language_manager_WORKSPACE_NAME)_ListSearcher_FOUND" @CopyAttributes(_list_index, $(FME_UUID_SAFE)) @RemoveAttributes($(FME_UUID_SAFE)) }    OUTPUT { FAILED FEATURE_TYPE "$(NT_language_manager_WORKSPACE_NAME)_ListSearcher_FOUND"  @Tcl2("$(FME_UUID_SAFE)_indexer {@Value($(FME_UUID_SAFE))} {<Unused>}") @CopyAttributes(_list_index, $(FME_UUID_SAFE)) @RemoveAttributes($(FME_UUID_SAFE)) }
# -------------------------------------------------------------------------
FACTORY_DEF {*} ElementFactory    FACTORY_NAME { $(NT_language_manager_WORKSPACE_NAME)_ListExploder }    INPUT  FEATURE_TYPE "$(NT_language_manager_WORKSPACE_NAME)_ListSearcher_FOUND"    LIST_NAME { "resources{}" }    ELEMENT_NUMBER_FIELD { "_element_index" }    CLONE_GEOMETRY    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "INCOMING_IF_CONFLICT" }    INCOMING_PREFIX { "<Unused>" }    OUTPUT { ELEMENT FEATURE_TYPE "$(NT_language_manager_WORKSPACE_NAME)_ListExploder_ELEMENTS"         @RemoveAttributes(ElementFactory.baseCloned)          }    OUTPUT { NOLIST FEATURE_TYPE "$(NT_language_manager_WORKSPACE_NAME)_ListExploder_<REJECTED>"         @RemoveAttributes(ElementFactory.baseCloned)         fme_rejection_code MISSING_PARAMETER_LIST          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(NT_language_manager_WORKSPACE_NAME)_Tester }    INPUT  FEATURE_TYPE "$(NT_language_manager_WORKSPACE_NAME)_ListExploder_ELEMENTS"    CASE_INSENSITIVE_TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>language_error<closeparen>,$(NT_language_manager_WORKSPACE_NAME)_Tester)" CONTAINS yes ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE "$(NT_language_manager_WORKSPACE_NAME)_Tester_PASSED"         }
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(NT_language_manager_WORKSPACE_NAME)_Terminator }    INPUT  FEATURE_TYPE "$(NT_language_manager_WORKSPACE_NAME)_ListExploder_<REJECTED>"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"Translation<space>Terminated")       @SupplyAttributes(_wb_termination_xformer,"$(NT_language_manager_WORKSPACE_NAME)_Terminator")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"Translation<space>Terminated") }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(NT_language_manager_WORKSPACE_NAME)_Junction_5 }    INPUT  FEATURE_TYPE "$(NT_language_manager_WORKSPACE_NAME)_ListSearcher_3_NOT_FOUND"    INPUT  FEATURE_TYPE "$(NT_language_manager_WORKSPACE_NAME)_ListSearcher_NOT_FOUND"    OUTPUT { FEATURE_TYPE "$(NT_language_manager_WORKSPACE_NAME)_Junction_5_Output"         }
# -------------------------------------------------------------------------
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NT_language_manager_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Input Input Collector"   INPUT FEATURE_TYPE "$(NT_language_manager_WORKSPACE_NAME)_Junction_5_Output"   OUTPUT FEATURE_TYPE "$(NT_language_manager_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Input"
MACRO ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME $(NT_language_manager_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_XFORMER_NAME $(NT_language_manager_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
INCLUDE_CUSTOM_TRANSFORMER_VER ATTRIBUTE_UNEXPOSER:1
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NT_language_manager_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Output Output Renamer/Nuker"   INPUT FEATURE_TYPE "$(NT_language_manager_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(NT_language_manager_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NT_language_manager_WORKSPACE_NAME)_output1762279357 Output Collector"   INPUT FEATURE_TYPE "$(NT_language_manager_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(NT_language_manager_WORKSPACE_NAME)_output"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NT_language_manager_WORKSPACE_NAME)_res_url_unknown_language1762279357 Output Collector"   INPUT FEATURE_TYPE "$(NT_language_manager_WORKSPACE_NAME)_Tester_PASSED"   OUTPUT FEATURE_TYPE "$(NT_language_manager_WORKSPACE_NAME)_res_url_unknown_language" @RemoveAttributes(order,resources_url,name,_list_index,language_error,_element_index)
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(NT_language_manager_WORKSPACE_NAME))}]
