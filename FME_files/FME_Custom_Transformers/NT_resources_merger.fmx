FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(NT_resources_merger_WORKSPACE_NAME)_TestFilter_INPUT }    INPUT  FEATURE_TYPE "$(NT_resources_merger_WORKSPACE_NAME)_AttributeRemover_OUTPUT"    OUTPUT { FEATURE_TYPE $(NT_resources_merger_WORKSPACE_NAME)_TestFilter_INPUTLINE }
FACTORY_DEF {*} TestFactory FACTORY_NAME { $(NT_resources_merger_WORKSPACE_NAME)_TestFilter } INPUT FEATURE_TYPE $(NT_resources_merger_WORKSPACE_NAME)_TestFilter_INPUTLINE FEATURE_TABLE_SHIM_SUPPORT Yes PASSED_TEST_GROUP_OUTPUT FIRST TEST_GROUP CASE_INSENSITIVE_TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>notes<closeparen>,$(NT_resources_merger_WORKSPACE_NAME)_TestFilter) CONTAINS @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>title<closeparen>,$(NT_resources_merger_WORKSPACE_NAME)_TestFilter) ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_0 FEATURE_TYPE $(NT_resources_merger_WORKSPACE_NAME)_TestFilter_notes<space>CONTAINS<space>title OUTPUT FAILED FEATURE_TYPE $(NT_resources_merger_WORKSPACE_NAME)_TestFilter_<lt>UNFILTERED<gt>
