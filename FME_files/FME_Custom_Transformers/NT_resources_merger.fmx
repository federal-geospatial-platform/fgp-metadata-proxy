FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NT_resources_merger_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_3 Input Input Collector"   INPUT FEATURE_TYPE "$(NT_resources_merger_WORKSPACE_NAME)_Junction_Output"   INPUT FEATURE_TYPE "$(NT_resources_merger_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"   OUTPUT FEATURE_TYPE "$(NT_resources_merger_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_3_Input"
MACRO ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME $(NT_resources_merger_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_3
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_XFORMER_NAME $(NT_resources_merger_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_3
INCLUDE_CUSTOM_TRANSFORMER_VER ATTRIBUTE_UNEXPOSER:1
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NT_resources_merger_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_3 Output Output Renamer/Nuker"   INPUT FEATURE_TYPE "$(NT_resources_merger_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_3_Output"   OUTPUT FEATURE_TYPE "$(NT_resources_merger_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_3_Output"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NT_resources_merger_WORKSPACE_NAME)_Legend_or_UserGuide_in_title1762279457 Output Collector"   INPUT FEATURE_TYPE "$(NT_resources_merger_WORKSPACE_NAME)_AttributeCreator_2_OUTPUT"   INPUT FEATURE_TYPE "$(NT_resources_merger_WORKSPACE_NAME)_AttributeCreator_3_OUTPUT"   INPUT FEATURE_TYPE "$(NT_resources_merger_WORKSPACE_NAME)_AttributeCreator_5_OUTPUT"   OUTPUT FEATURE_TYPE "$(NT_resources_merger_WORKSPACE_NAME)_Legend_or_UserGuide_in_title" @RemoveAttributes(new_title,new_notes,notes) @RemoveAttributes(fme_regexp_match,resources{}.name,resources{}.format,resources{}.url,resources{})
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NT_resources_merger_WORKSPACE_NAME)_Output1762279457 Output Collector"   INPUT FEATURE_TYPE "$(NT_resources_merger_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_3_Output"   OUTPUT FEATURE_TYPE "$(NT_resources_merger_WORKSPACE_NAME)_Output"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(NT_resources_merger_WORKSPACE_NAME))}]
