FACTORY_DEF {*} DuplicateRemoverFactory    FACTORY_NAME { $(NT_resources_merger_WORKSPACE_NAME)_DuplicateFilter_2 }    COMMAND_PARM_EVALUATION SINGLE_PASS    SUPPORTS_FEATURE_TABLES    INPUT  FEATURE_TYPE "$(NT_resources_merger_WORKSPACE_NAME)_FeatureMerger_3_UNUSED_SUPPLIER"    INPUT  FEATURE_TYPE "$(NT_resources_merger_WORKSPACE_NAME)_FeatureMerger_2_UNUSED_SUPPLIER"    KEY_ATTRIBUTES { id }    INPUT_IS_ORDERED { NO }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { UNIQUE FEATURE_TYPE "$(NT_resources_merger_WORKSPACE_NAME)_DuplicateFilter_2_UNIQUE"         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(NT_resources_merger_WORKSPACE_NAME)_AttributeCreator_2 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(NT_resources_merger_WORKSPACE_NAME)_DuplicateFilter_2_UNIQUE"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "erreur_NT_resources_merger" "SET_TO" "id_data<space>n<apos>est<space>pas<space>valide<space>ou<space>est<space>aussi<space>dans<space>id_legend_user_manual" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(NT_resources_merger_WORKSPACE_NAME)_AttributeCreator_2_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(NT_resources_merger_WORKSPACE_NAME)_TestFilter_6_INPUT }    INPUT  FEATURE_TYPE "$(NT_resources_merger_WORKSPACE_NAME)_FeatureMerger_3_UNMERGED_REQUESTOR"    OUTPUT { FEATURE_TYPE $(NT_resources_merger_WORKSPACE_NAME)_TestFilter_6_INPUTLINE }
FACTORY_DEF {*} TestFactory FACTORY_NAME { $(NT_resources_merger_WORKSPACE_NAME)_TestFilter_6 } INPUT FEATURE_TYPE $(NT_resources_merger_WORKSPACE_NAME)_TestFilter_6_INPUTLINE FEATURE_TABLE_SHIM_SUPPORT Yes PASSED_TEST_GROUP_OUTPUT FIRST TEST_GROUP CASE_INSENSITIVE_TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>title<closeparen>,$(NT_resources_merger_WORKSPACE_NAME)_TestFilter_6) CONTAINS Legend ENCODED } CASE_INSENSITIVE_TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>title<closeparen>,$(NT_resources_merger_WORKSPACE_NAME)_TestFilter_6) CONTAINS User<space>Guide ENCODED } CASE_INSENSITIVE_TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>title<closeparen>,$(NT_resources_merger_WORKSPACE_NAME)_TestFilter_6) CONTAINS User<space>Manual ENCODED } CASE_INSENSITIVE_TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>title<closeparen>,$(NT_resources_merger_WORKSPACE_NAME)_TestFilter_6) CONTAINS Instruction ENCODED } CASE_INSENSITIVE_TEST { ignore_merge_metadata CONTAINS yes ENCODED } BOOLEAN_OPERATOR COMPOSITE COMPOSITE_TEST_EXPR "( 1 OR 2 OR 3 OR 4 ) AND (NOT 5 )" OUTPUT PASSED_0 FEATURE_TYPE $(NT_resources_merger_WORKSPACE_NAME)_TestFilter_6_title<space>contains<space><apos>Lengend<space>or<space>User<space>Guide<apos> OUTPUT FAILED FEATURE_TYPE $(NT_resources_merger_WORKSPACE_NAME)_TestFilter_6_<lt>UNFILTERED<gt>
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(NT_resources_merger_WORKSPACE_NAME)_AttributeCreator_3 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(NT_resources_merger_WORKSPACE_NAME)_TestFilter_6_title<space>contains<space><apos>Lengend<space>or<space>User<space>Guide<apos>"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "erreur_NT_resources_merger" "SET_TO" "titre<space>contient<space><apos>userguide<apos><comma><space><apos>legend<apos><comma><space><apos>user<space>manual<apos><space>ou<space><apos>instructions<apos><space>et<space>id<space>n<apos>est<space>pas<space>dans<space>NT_metadata_merger<space><openparen>id_legend_user_manual<closeparen>" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(NT_resources_merger_WORKSPACE_NAME)_AttributeCreator_3_OUTPUT"        }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(NT_resources_merger_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC }    } else {        puts "MACRO $(NT_resources_merger_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(NT_resources_merger_WORKSPACE_NAME)_AttributeRemover_2 }    INPUT  FEATURE_TYPE "$(NT_resources_merger_WORKSPACE_NAME)_TestFilter_6_<lt>UNFILTERED<gt>"    OUTPUT { FEATURE_TYPE "$(NT_resources_merger_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"        @RemoveAttributes(fme_encoded,ignore_merge_metadata)        $($(NT_resources_merger_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC)         }
