FACTORY_DEF {*} ElementFactory    FACTORY_NAME { $(NT_resources_merger_WORKSPACE_NAME)_ListExploder }    INPUT  FEATURE_TYPE "$(NT_resources_merger_WORKSPACE_NAME)_AttributeRenamer_OUTPUT_0_JlEBrhTlay8="    INPUT  FEATURE_TYPE "$(NT_resources_merger_WORKSPACE_NAME)_FeatureMerger_3_MERGED_1_ExguomjmfVI="    LIST_NAME { "resources{}" }    ELEMENT_NUMBER_FIELD { "_element_index" }    CLONE_GEOMETRY    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "INCOMING_IF_CONFLICT" }    INCOMING_PREFIX { "<Unused>" }    OUTPUT { ELEMENT FEATURE_TYPE "$(NT_resources_merger_WORKSPACE_NAME)_ListExploder_ELEMENTS"         @RemoveAttributes(ElementFactory.baseCloned)          }
