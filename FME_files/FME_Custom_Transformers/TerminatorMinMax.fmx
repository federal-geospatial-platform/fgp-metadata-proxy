FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(TerminatorMinMax_WORKSPACE_NAME)_TestFilter_5_INPUT }    INPUT  FEATURE_TYPE "$(TerminatorMinMax_WORKSPACE_NAME)_TestFilter_4_VALIDE"    OUTPUT { FEATURE_TYPE $(TerminatorMinMax_WORKSPACE_NAME)_TestFilter_5_INPUTLINE }
FACTORY_DEF {*} TestFactory FACTORY_NAME { $(TerminatorMinMax_WORKSPACE_NAME)_TestFilter_5 } INPUT FEATURE_TYPE $(TerminatorMinMax_WORKSPACE_NAME)_TestFilter_5_INPUTLINE FEATURE_TABLE_SHIM_SUPPORT Yes PASSED_TEST_GROUP_OUTPUT FIRST TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_TMSource<closeparen>,$(TerminatorMinMax_WORKSPACE_NAME)_TestFilter_5) = EntiteBidon ENCODED } BOOLEAN_OPERATOR OR OUTPUT PASSED_0 FEATURE_TYPE $(TerminatorMinMax_WORKSPACE_NAME)_TestFilter_5_EntiteBidon OUTPUT FAILED FEATURE_TYPE $(TerminatorMinMax_WORKSPACE_NAME)_TestFilter_5_<lt>UNFILTERED<gt>
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(TerminatorMinMax_WORKSPACE_NAME)_TestFilter_5 EntiteBidon Transformer Output Nuker"   INPUT FEATURE_TYPE "$(TerminatorMinMax_WORKSPACE_NAME)_TestFilter_5_EntiteBidon"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(TerminatorMinMax_WORKSPACE_NAME)_TestFilter_5 <lt>UNFILTERED<gt> Splitter"   INPUT FEATURE_TYPE "$(TerminatorMinMax_WORKSPACE_NAME)_TestFilter_5_<lt>UNFILTERED<gt>"   OUTPUT FEATURE_TYPE "$(TerminatorMinMax_WORKSPACE_NAME)_TestFilter_5_<lt>UNFILTERED<gt>_0_FfdCkhF/d1M="   OUTPUT FEATURE_TYPE "$(TerminatorMinMax_WORKSPACE_NAME)_TestFilter_5_<lt>UNFILTERED<gt>_1_kwB+lsTTWl8="
