DEFAULT_MACRO WB_CURRENT_CONTEXT
DEFAULT_MACRO TerminatorMinMax_WORKSPACE_NAME ""
INCLUDE [puts {MACRO WB_OLD_CONTEXT_$(TerminatorMinMax_WORKSPACE_NAME) $(WB_CURRENT_CONTEXT)};          puts {MACRO WB_CURRENT_CONTEXT $(TerminatorMinMax_WORKSPACE_NAME)}]
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(TerminatorMinMax_WORKSPACE_NAME)_INPUT1764085821 Input Splitter"   INPUT FEATURE_TYPE "$(TerminatorMinMax_WORKSPACE_NAME)_INPUT"   OUTPUT FEATURE_TYPE "$(TerminatorMinMax_WORKSPACE_NAME)_INPUT"
# -------------------------------------------------------------------------
Tcl2 proc $(TerminatorMinMax_WORKSPACE_NAME)_Creator_2_CoordSysRemover {} {   global FME_CoordSys;   set FME_CoordSys {}; }
MACRO $(TerminatorMinMax_WORKSPACE_NAME)_Creator_2_XML     NOT_ACTIVATED
MACRO $(TerminatorMinMax_WORKSPACE_NAME)_Creator_2_GEOJSON NOT_ACTIVATED
INCLUDE [ if { {Geometry Object} == {Geometry Object} } {            puts {MACRO $(TerminatorMinMax_WORKSPACE_NAME)_Creator_2_XML *} } ]
INCLUDE [ if { {Geometry Object} == {GeoJSON} } {            puts {MACRO $(TerminatorMinMax_WORKSPACE_NAME)_Creator_2_GEOJSON *} } ]
FACTORY_DEF {$($(TerminatorMinMax_WORKSPACE_NAME)_Creator_2_XML)} CreationFactory    FACTORY_NAME { $(TerminatorMinMax_WORKSPACE_NAME)_Creator_2_XML_Creator }    CREATE_AT_END { no }    OUTPUT { FEATURE_TYPE _____CREATED______        @Geometry(FROM_ENCODED_STRING,<lt>?xml<space>version=<quote>1.0<quote><space>encoding=<quote>US_ASCII<quote><space>standalone=<quote>no<quote><space>?<gt><lt>geometry<gt><lt>null<solidus><gt><lt><solidus>geometry<gt>) }
