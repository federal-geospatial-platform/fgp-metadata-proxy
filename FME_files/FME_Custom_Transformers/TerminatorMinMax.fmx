Tcl2 proc $(TerminatorMinMax_WORKSPACE_NAME)_ParameterFetcher_2_doFetch {} {    foreach {name val} {"_TMMessageUtilisateur {$($(TerminatorMinMax_WORKSPACE_NAME)_Message$encode)}"} {         if { [string match {*<at>*} $val] == 1 } {             set val [FME_Execute EvaluateExpression {STRING} $val {$(TerminatorMinMax_WORKSPACE_NAME)_ParameterFetcher_2}];         } elseif {[string match {*FME_CONDITIONAL*} $val] == 1} {             set val [FME_Execute EvaluateExpression {STRING} $val {$(TerminatorMinMax_WORKSPACE_NAME)_ParameterFetcher_2}];         } else {             set val [FME_DecodeTextOrAttr $val];         };       FME_SetAttribute [FME_DecodeText $name] $val    } }
