# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {$(TerminatorMinMax_WORKSPACE_NAME)_Logger_0a9dcbe4_aa2a_4618_beda_31274a9059a80} ]
# If the Logger was in a custom transformer, the custom transformer's name was not being
# properly logged -- instead we saw "$(<customXformerName_WORKSPACE_NAME)" being logged as the prefix of the
# message. By deferencing and expanding out the XFORMER_NAME below, and then "WWJD" encoding it when it is
# used in the @Log call via the $encode macro name suffix trick, we get the right result, and the right result
# safely.
MACRO LOGGABLE_XFORMER_NAME $(TerminatorMinMax_WORKSPACE_NAME)_Logger
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(TerminatorMinMax_WORKSPACE_NAME)_Logger_Logger }    INPUT  FEATURE_TYPE "$(TerminatorMinMax_WORKSPACE_NAME)_StringConcatenator_2_OUTPUT"    OUTPUT { FEATURE_TYPE "$(TerminatorMinMax_WORKSPACE_NAME)_Logger_LOGGED"                  @Log(ENCODED, "$(LOGGABLE_XFORMER_NAME$encode):<space>@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_TMMessagePersonalis<u00e9><closeparen>,$(TerminatorMinMax_WORKSPACE_NAME)_Logger)","0","1","",INFO,LOG_RECORD,$(FME_UUID_SAFE))                   }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(TerminatorMinMax_WORKSPACE_NAME)_Logger LOGGED Transformer Output Nuker"   INPUT FEATURE_TYPE "$(TerminatorMinMax_WORKSPACE_NAME)_Logger_LOGGED"
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(TerminatorMinMax_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(TerminatorMinMax_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(TerminatorMinMax_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(TerminatorMinMax_WORKSPACE_NAME)_TestFilter_5_<lt>UNFILTERED<gt>_1_kwB+lsTTWl8="    INPUT  FEATURE_TYPE "$(TerminatorMinMax_WORKSPACE_NAME)_TestFilter_7_SURPLUS"    OUTPUT { FEATURE_TYPE "$(TerminatorMinMax_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,_TMSource,_TMcreation_instance,_TMCount,_TMinAttributBidon,_TMinNbElementsAvecBidon,_TMNbElements,_TMTypeTest,_TMValide)        $($(TerminatorMinMax_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(TerminatorMinMax_WORKSPACE_NAME)_OUTPUT1764085821 Output Collector"   INPUT FEATURE_TYPE "$(TerminatorMinMax_WORKSPACE_NAME)_AttributeRemover_OUTPUT"   OUTPUT FEATURE_TYPE "$(TerminatorMinMax_WORKSPACE_NAME)_OUTPUT"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(TerminatorMinMax_WORKSPACE_NAME))}]
