# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(DCAT_Reader_MB_SK_WORKSPACE_NAME)_AttributeRemover_3_LIST_FUNC }    } else {        puts "MACRO $(DCAT_Reader_MB_SK_WORKSPACE_NAME)_AttributeRemover_3_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(DCAT_Reader_MB_SK_WORKSPACE_NAME)_AttributeRemover_3 }    INPUT  FEATURE_TYPE "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_Junction_14_Output"    OUTPUT { FEATURE_TYPE "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_AttributeRemover_3_OUTPUT"        @RemoveAttributes(fme_encoded,_status_code,_status_code_description,_response_body_P,_response_body_S,_url_dcat_primary,_url_dcat_secondary,DCAT_P_title_copy,DCAT_S_slug_id_copy)        $($(DCAT_Reader_MB_SK_WORKSPACE_NAME)_AttributeRemover_3_LIST_FUNC)         }
