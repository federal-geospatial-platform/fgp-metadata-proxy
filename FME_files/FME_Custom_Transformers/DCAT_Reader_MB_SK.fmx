index=FME_utils.max_index_attribute_list<openparen>feature<comma><apos>notes2<opencurly><closecurly><apos><closeparen><lf><space><space><space><space>for<space>j<space>in<space>range<openparen>max_index+1<closeparen>:<lf><space><space><space><space><space><space><space><space>name_notes2=<apos>notes2<apos>+<apos>_<apos>+str<openparen>j+1<closeparen><lf><space><space><space><space><space><space><space><space>feature.setAttribute<openparen>name_notes2<comma>feature.getAttribute<openparen><apos>notes2<opencurly>%i<closecurly><apos>%<openparen>j<closeparen><closeparen><closeparen><lf><lf>#date<space>modification<lf><space><space><space><space>max_index=FME_utils.max_index_attribute_list<openparen>feature<comma><apos>date_modified<opencurly><closecurly><apos><closeparen><lf><space><space><space><space>for<space>j<space>in<space>range<openparen>max_index+1<closeparen>:<lf><space><space><space><space><space><space><space><space>name_date_modified=<apos>date_modified<apos>+<apos>_<apos>+str<openparen>j+1<closeparen><lf><space><space><space><space><space><space><space><space>feature.setAttribute<openparen>name_date_modified<comma>feature.getAttribute<openparen><apos>date_modified<opencurly>%i<closecurly><apos>%<openparen>j<closeparen><closeparen><closeparen><lf><lf>#collection<space>date<space>start<lf><space><space><space><space>max_index=FME_utils.max_index_attribute_list<openparen>feature<comma><apos>DCAT_S_attributes.metadata.metadata.dataIdInfo.dataExt<opencurly><closecurly>.tempEle.TempExtent.exTemp.TM_Period.tmBegin<apos><closeparen><lf><space><space><space><space>for<space>j<space>in<space>range<openparen>max_index+1<closeparen>:<lf><space><space><space><space><space><space><space><space>name_coll_start=<apos>coll_start<apos>+<apos>_<apos>+str<openparen>j+1<closeparen><lf><space><space><space><space><space><space><space><space>feature.setAttribute<openparen>name_coll_start<comma>feature.getAttribute<openparen><apos>DCAT_S_attributes.metadata.metadata.dataIdInfo.dataExt<opencurly>%i<closecurly>.tempEle.TempExtent.exTemp.TM_Period.tmBegin<apos>%<openparen>j<closeparen><closeparen><closeparen><lf><lf>#collection<space>date<space>end<lf><space><space><space><space>max_index=FME_utils.max_index_attribute_list<openparen>feature<comma><apos>DCAT_S_attributes.metadata.metadata.dataIdInfo.dataExt<opencurly><closecurly>.tempEle.TempExtent.exTemp.TM_Period.tmEnd<apos><closeparen><lf><space><space><space><space>for<space>j<space>in<space>range<openparen>max_index+1<closeparen>:<lf><space><space><space><space><space><space><space><space>name_coll_end=<apos>coll_end<apos>+<apos>_<apos>+str<openparen>j+1<closeparen><lf><space><space><space><space><space><space><space><space>feature.setAttribute<openparen>name_coll_end<comma>feature.getAttribute<openparen><apos>DCAT_S_attributes.metadata.metadata.dataIdInfo.dataExt<opencurly>%i<closecurly>.tempEle.TempExtent.exTemp.TM_Period.tmEnd<apos>%<openparen>j<closeparen><closeparen><closeparen><lf><space><space><space><space><space><space><space><space> }    PY_OUTPUT_TAGS { PYOUTPUT <Rejected> }    OUTPUT { PYOUTPUT FEATURE_TYPE "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_PythonCaller_11_OUTPUT"         }    OUTPUT { <Rejected> FEATURE_TYPE "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_PythonCaller_11_<Rejected>"         }
