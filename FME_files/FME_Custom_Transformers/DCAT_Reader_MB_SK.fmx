INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "DCAT_S_attributes.categories<opencurly><closecurly> DCAT_S_attributes.metadata.metadata.dataIdInfo.dataExt<opencurly><closecurly> DCAT_S_attributes.metadata.metadata.dataIdInfo.dataExt<opencurly><closecurly>.tempEle.TempExtent.exTemp.TM_Period.tmBegin DCAT_S_attributes.metadata.metadata.dataIdInfo.dataExt<opencurly><closecurly>.tempEle.TempExtent.exTemp.TM_Period.tmEnd date_modified<opencurly><closecurly> notes1<opencurly><closecurly> notes2<opencurly><closecurly>"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(DCAT_Reader_MB_SK_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(DCAT_Reader_MB_SK_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
