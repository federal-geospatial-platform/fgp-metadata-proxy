# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(DCAT_Reader_MB_SK_WORKSPACE_NAME)_Terminator }    INPUT  FEATURE_TYPE "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_FeatureMerger_8_UNUSED_SUPPLIER"    INPUT  FEATURE_TYPE "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_FeatureMerger_3_<REJECTED>"    INPUT  FEATURE_TYPE "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_FeatureMerger_8_<REJECTED>"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"Translation<space>Terminated")       @SupplyAttributes(_wb_termination_xformer,"$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_Terminator")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"Translation<space>Terminated") }
# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_JSONFlattener_3__Rejected__2_cf417b8a_d5c9_43bb_971c_ccf3f948c1130} ]
# If the Logger was in a custom transformer, the custom transformer's name was not being
# properly logged -- instead we saw "$(<customXformerName_WORKSPACE_NAME)" being logged as the prefix of the
# message. By deferencing and expanding out the XFORMER_NAME below, and then "WWJD" encoding it when it is
# used in the @Log call via the $encode macro name suffix trick, we get the right result, and the right result
# safely.
MACRO LOGGABLE_XFORMER_NAME $(DCAT_Reader_MB_SK_WORKSPACE_NAME)_JSONFlattener_3__Rejected__2
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(DCAT_Reader_MB_SK_WORKSPACE_NAME)_JSONFlattener_3__Rejected__2_Logger }    INPUT  FEATURE_TYPE "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_JSONFlattener_4_<REJECTED>"    OUTPUT { FEATURE_TYPE "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_JSONFlattener_3__Rejected__2_LOGGED"                  @Log(ENCODED, "$(LOGGABLE_XFORMER_NAME$encode):<space>Feature is:","20","20","",INFO,LOG_ONLY,$(FME_UUID_SAFE))                   }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_JSONFlattener_3__Rejected__2 LOGGED Transformer Output Nuker"   INPUT FEATURE_TYPE "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_JSONFlattener_3__Rejected__2_LOGGED"
# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_TestFilter_2_Other_Error_2_472c34a6_8588_441c_8411_2666ff17ba3f0} ]
# If the Logger was in a custom transformer, the custom transformer's name was not being
# properly logged -- instead we saw "$(<customXformerName_WORKSPACE_NAME)" being logged as the prefix of the
# message. By deferencing and expanding out the XFORMER_NAME below, and then "WWJD" encoding it when it is
# used in the @Log call via the $encode macro name suffix trick, we get the right result, and the right result
# safely.
MACRO LOGGABLE_XFORMER_NAME $(DCAT_Reader_MB_SK_WORKSPACE_NAME)_TestFilter_2_Other_Error_2
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(DCAT_Reader_MB_SK_WORKSPACE_NAME)_TestFilter_2_Other_Error_2_Logger }    INPUT  FEATURE_TYPE "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_TestFilter_7_Other<space>Error"    OUTPUT { FEATURE_TYPE "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_TestFilter_2_Other_Error_2_LOGGED"                  @Log(ENCODED, "$(LOGGABLE_XFORMER_NAME$encode):<space>Feature is:","20","20","",INFO,LOG_ONLY,$(FME_UUID_SAFE))                   }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_TestFilter_2_Other_Error_2 LOGGED Transformer Output Nuker"   INPUT FEATURE_TYPE "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_TestFilter_2_Other_Error_2_LOGGED"
