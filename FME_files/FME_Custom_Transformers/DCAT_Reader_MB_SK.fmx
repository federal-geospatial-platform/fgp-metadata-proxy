FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(DCAT_Reader_MB_SK_WORKSPACE_NAME)_TestFilter_3_Other_Error_2_Logger }    INPUT  FEATURE_TYPE "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_TestFilter_6_Other<space>Error"    OUTPUT { FEATURE_TYPE "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_TestFilter_3_Other_Error_2_LOGGED"                  @Log(ENCODED, "$(LOGGABLE_XFORMER_NAME$encode):<space>Feature is:","20","20","",INFO,LOG_ONLY,$(FME_UUID_SAFE))                   }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_TestFilter_3_Other_Error_2 LOGGED Transformer Output Nuker"   INPUT FEATURE_TYPE "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_TestFilter_3_Other_Error_2_LOGGED"
