ecurly>.tempEle.TempExtent.exTemp.TM_Period.tmBegin<apos>%<openparen>j<closeparen><closeparen><closeparen><lf><lf>#collection<space>date<space>end<lf><space><space><space><space>max_index=FME_utils.max_index_attribute_list<openparen>feature<comma><apos>DCAT_S_attributes.metadata.metadata.dataIdInfo.dataExt<opencurly><closecurly>.tempEle.TempExtent.exTemp.TM_Period.tmEnd<apos><closeparen><lf><space><space><space><space>for<space>j<space>in<space>range<openparen>max_index+1<closeparen>:<lf><space><space><space><space><space><space><space><space>name_coll_end=<apos>coll_end<apos>+<apos>_<apos>+str<openparen>j+1<closeparen><lf><space><space><space><space><space><space><space><space>feature.setAttribute<openparen>name_coll_end<comma>feature.getAttribute<openparen><apos>DCAT_S_attributes.metadata.metadata.dataIdInfo.dataExt<opencurly>%i<closecurly>.tempEle.TempExtent.exTemp.TM_Period.tmEnd<apos>%<openparen>j<closeparen><closeparen><closeparen><lf><space><space><space><space><space><space><space><space> }    PY_OUTPUT_TAGS { PYOUTPUT <Rejected> }    OUTPUT { PYOUTPUT FEATURE_TYPE "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_PythonCaller_12_OUTPUT"         }    OUTPUT { <Rejected> FEATURE_TYPE "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_PythonCaller_12_<Rejected>"         }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_PythonCaller_12 <Rejected> Transformer Output Nuker"   INPUT FEATURE_TYPE "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_PythonCaller_12_<Rejected>"
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "DCAT_S_attributes.categories<opencurly><closecurly> DCAT_S_attributes.metadata.metadata.dataIdInfo.dataExt<opencurly><closecurly> DCAT_S_attributes.metadata.metadata.dataIdInfo.dataExt<opencurly><closecurly>.tempEle.TempExtent.exTemp.TM_Period.tmBegin DCAT_S_attributes.metadata.metadata.dataIdInfo.dataExt<opencurly><closecurly>.tempEle.TempExtent.exTemp.TM_Period.tmEnd date_modified<opencurly><closecurly> notes1<opencurly><closecurly> notes2<opencurly><closecurly>"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(DCAT_Reader_MB_SK_WORKSPACE_NAME)_AttributeRemover_4_LIST_FUNC }    } else {        puts "MACRO $(DCAT_Reader_MB_SK_WORKSPACE_NAME)_AttributeRemover_4_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
