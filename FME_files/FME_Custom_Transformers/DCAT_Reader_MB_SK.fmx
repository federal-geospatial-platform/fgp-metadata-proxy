FACTORY_DEF {*} ReferenceFactory    FACTORY_NAME { $(DCAT_Reader_MB_SK_WORKSPACE_NAME)_FeatureMerger }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT REFERENCER FEATURE_TYPE "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_TestFilter_10_output"    INPUT REFERENCEE FEATURE_TYPE "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_AttributeCreator_17_OUTPUT"    REFERENCE_INFO { $($(DCAT_Reader_MB_SK_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO) }    REFERENCE_TABLE { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_attr_name<closeparen>,$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_FeatureMerger) @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_attr_name<closeparen>,$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_FeatureMerger) AUTO @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_attr_value<closeparen>,$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_FeatureMerger) @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_attr_value<closeparen>,$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_FeatureMerger) AUTO @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>id<closeparen>,$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_FeatureMerger) @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>id<closeparen>,$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_FeatureMerger) AUTO }    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "REQUESTOR_IF_CONFLICT" }    IGNORE_NULLS { "No" }    HANDLE_NULL_MISSING_KEYS_LIKE_FME2013 { No }    LIST_ATTRS_TO_INCLUDE { <Unused> }    LIST_ATTRS_TO_INCLUDE_MODE { <Unused> }    MERGE_ATTRIBUTES Yes    MANAGE_FME_TYPE Yes    MODE COMPLETE    PROCESS_DUPLICATE_REFERENCEES { NO }    REFERENCEES_FIRST { No }    REJECT_INVALID_GEOM YES    CLEANING_TOLERANCE { <Unused> }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    COMPARE_WHITESPACE Yes    OUTPUT { COMPLETE FEATURE_TYPE "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_FeatureMerger_MERGED"         }    OUTPUT { INCOMPLETE FEATURE_TYPE "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_FeatureMerger_UNMERGED_REQUESTOR"         }    OUTPUT { UNREFERENCED FEATURE_TYPE "$(DCAT_Reader_MB_SK_WORKSPACE_NAME)_FeatureMerger_UNUSED_SUPPLIER"         }
