DEFAULT_MACRO WB_CURRENT_CONTEXT
DEFAULT_MACRO RESOURCES_VALIDATOR_WORKSPACE_NAME ""
INCLUDE [puts {MACRO WB_OLD_CONTEXT_$(RESOURCES_VALIDATOR_WORKSPACE_NAME) $(WB_CURRENT_CONTEXT)};          puts {MACRO WB_CURRENT_CONTEXT $(RESOURCES_VALIDATOR_WORKSPACE_NAME)}]
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_INPUT1762280130 Input Splitter"   INPUT FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_INPUT"   OUTPUT FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_INPUT"
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeExposer }    INPUT  FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_INPUT"    OUTPUT { FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeExposer_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_UUIDGenerator }    INPUT  FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeExposer_OUTPUT"    OUTPUT { FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_UUIDGenerator_OUTPUT"             "_uuid" @UUID(SIMPLE, UUID_FORMAT, UUID_ONLY)              }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_UUIDGenerator OUTPUT Splitter"   INPUT FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_UUIDGenerator_OUTPUT"   OUTPUT FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_0_m82vGzsboi0="   OUTPUT FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_1_fVyn80rwy70="
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "resources<opencurly><closecurly>"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC }    } else {        puts "MACRO $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeRemover_2 }    INPUT  FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_0_m82vGzsboi0="    OUTPUT { FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"        @RemoveAttributes(fme_encoded,)        $($(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttributeKeeperFactory    FACTORY_NAME { $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeKeeper }    INPUT  FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_1_fVyn80rwy70="    KEEP_ATTRS { title,_uuid }    KEEP_LISTS { resources<opencurly><closecurly> }    KEEP_FME_ATTRIBUTES Yes    BUILD_FEATURE_TABLES { NO }    OUTPUT_ON_ATTRIBUTE_CHANGE { <Unused> }    OUTPUT { OUTPUT FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeKeeper_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} ElementFactory    FACTORY_NAME { $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_ListExploder }    INPUT  FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeKeeper_OUTPUT"    LIST_NAME { "resources{}" }    ELEMENT_NUMBER_FIELD { "_element_index" }    CLONE_GEOMETRY    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "INCOMING_IF_CONFLICT" }    INCOMING_PREFIX { "<Unused>" }    OUTPUT { ELEMENT FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_ListExploder_ELEMENTS"         @RemoveAttributes(ElementFactory.baseCloned)          }    OUTPUT { NOLIST FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_ListExploder_<REJECTED>"         @RemoveAttributes(ElementFactory.baseCloned)         fme_rejection_code MISSING_PARAMETER_LIST          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_Tester }    INPUT  FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_ListExploder_ELEMENTS"    TEST { url ATTRIBUTE_HAS_A_VALUE "" ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    OUTPUT { PASSED FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_Tester_PASSED"         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_Tester_2 }    INPUT  FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_Tester_PASSED"    TEST { format ATTRIBUTE_HAS_A_VALUE "" ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    OUTPUT { PASSED FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_Tester_2_PASSED"         }    OUTPUT { FAILED FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_Tester_2_FAILED"         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeCreator }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_Tester_2_FAILED"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "format" "SET_TO" "other" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeCreator_OUTPUT"        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_Tester_3 }    INPUT  FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_Tester_2_PASSED"    INPUT  FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeCreator_OUTPUT"    TEST { name ATTRIBUTE_HAS_A_VALUE "" ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    OUTPUT { PASSED FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_Tester_3_PASSED"         }    OUTPUT { FAILED FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_Tester_3_FAILED"         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeCreator_2 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_Tester_3_FAILED"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "name" "SET_TO" "<at>Value<openparen>title<closeparen>" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeCreator_2_OUTPUT"        }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_Tester_3_PASSED"    INPUT  FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeCreator_2_OUTPUT"    OUTPUT { FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,title)        $($(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_ListBuilder_fme_type_remover }    INPUT  FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeRemover_OUTPUT"    OUTPUT { FEATURE_TYPE $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_ListBuilder_no_fme_type       @RemoveAttributes(fme_type,fme_geometry) }
FACTORY_DEF {*} ListFactory    FACTORY_NAME { $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_ListBuilder }    INPUT { FEATURE_TYPE $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_ListBuilder_no_fme_type }    LIST_NAME { "resources" }    LIST_ATTRS_TO_INCLUDE { <Unused> }    LIST_ATTRS_TO_INCLUDE_MODE { ALL }    GROUP_BY { _uuid }    FLUSH_WHEN_GROUPS_CHANGE { No }    OUTPUT { LIST FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_ListBuilder_OUTPUT"          }
# -------------------------------------------------------------------------
INCLUDE [if { {ATTRIBUTES} == {ATTRIBUTES} } {                puts "MACRO $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO ATTRIBUTES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {POLYGONS}} {                puts "MACRO $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {AGGREGATES}} {                puts "MACRO $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {POLYGONS}} {                puts "MACRO $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {AGGREGATES}} {                puts "MACRO $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} } {                puts "MACRO $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} } {                puts "MACRO $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          else {}; ]
FACTORY_DEF {*} ReferenceFactory    FACTORY_NAME { $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_FeatureMerger }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT REFERENCER FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"    INPUT REFERENCEE FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_ListBuilder_OUTPUT"    REFERENCE_INFO { $($(RESOURCES_VALIDATOR_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO) }    REFERENCE_TABLE { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_uuid<closeparen>,$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_FeatureMerger) @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_uuid<closeparen>,$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_FeatureMerger) AUTO }    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "REQUESTOR_IF_CONFLICT" }    IGNORE_NULLS { "No" }    HANDLE_NULL_MISSING_KEYS_LIKE_FME2013 { No }    LIST_ATTRS_TO_INCLUDE { <Unused> }    LIST_ATTRS_TO_INCLUDE_MODE { <Unused> }    MERGE_ATTRIBUTES Yes    MANAGE_FME_TYPE Yes    MODE COMPLETE    PROCESS_DUPLICATE_REFERENCEES { NO }    REFERENCEES_FIRST { No }    REJECT_INVALID_GEOM YES    CLEANING_TOLERANCE { <Unused> }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    COMPARE_WHITESPACE Yes    OUTPUT { COMPLETE FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_FeatureMerger_MERGED"         }    OUTPUT { REJECTED FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_FeatureMerger_<REJECTED>"         }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "resources<opencurly><closecurly>._element_index resources<opencurly><closecurly>._uuid"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeRemover_3_LIST_FUNC }    } else {        puts "MACRO $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeRemover_3_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeRemover_3 }    INPUT  FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_FeatureMerger_MERGED"    OUTPUT { FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeRemover_3_OUTPUT"        @RemoveAttributes(fme_encoded,_uuid,_element_index)        $($(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeRemover_3_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Input Input Collector"   INPUT FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_AttributeRemover_3_OUTPUT"   OUTPUT FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Input"
MACRO ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(ATTRIBUTE_UNEXPOSER_WORKSPACE_NAME)_XFORMER_NAME $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER
INCLUDE_CUSTOM_TRANSFORMER_VER ATTRIBUTE_UNEXPOSER:1
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER Output Output Renamer/Nuker"   INPUT FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_Terminator_2 }    INPUT  FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_FeatureMerger_<REJECTED>"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"ERROR:<space>Lost<space>of<space>data<space>in<space>featureMerger")       @SupplyAttributes(_wb_termination_xformer,"$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_Terminator_2")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"ERROR:<space>Lost<space>of<space>data<space>in<space>featureMerger") }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(RESOURCES_VALIDATOR_WORKSPACE_NAME)_Cloner_Cloner }    INPUT  FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_ListExploder_<REJECTED>"    NUMBER_OF_COPIES { "1" }    COPY_NUMBER_ATTRIBUTE { _copynum }    REJECT_INVALID YES
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_OUTPUT1762280130 Output Collector"   INPUT FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_ATTRIBUTE_UNEXPOSER_Output"   OUTPUT FEATURE_TYPE "$(RESOURCES_VALIDATOR_WORKSPACE_NAME)_OUTPUT"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(RESOURCES_VALIDATOR_WORKSPACE_NAME))}]
