FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_AttributeCreator_6 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE "$(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_DuplicateFilter_UNIQUE"    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "url" "SET_TO" "$($(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_DOMAIN$encode)<solidus>datasets<solidus><at>Value<openparen>id<closeparen>" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "format" "SET_TO" "HTML" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_AttributeCreator_6_OUTPUT"        }
