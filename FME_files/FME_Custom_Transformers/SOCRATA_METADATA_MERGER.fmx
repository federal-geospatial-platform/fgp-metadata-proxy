FACTORY_DEF {*} AttributeKeeperFactory    FACTORY_NAME { $(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_AttributeKeeper_5 }    INPUT  FEATURE_TYPE "$(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_AttributeCreator_6_OUTPUT"    KEEP_ATTRS { name,url,protocol,format,resourceType_fr,_seriesID,resourceType_en }    KEEP_LISTS {  }    KEEP_FME_ATTRIBUTES Yes    BUILD_FEATURE_TABLES { NO }    OUTPUT_ON_ATTRIBUTE_CHANGE { <Unused> }    OUTPUT { OUTPUT FEATURE_TYPE "$(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_AttributeKeeper_5_OUTPUT"        }
# -------------------------------------------------------------------------
INCLUDE [if { {ATTRIBUTES} == {ATTRIBUTES} } {                puts "MACRO $(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO ATTRIBUTES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {POLYGONS}} {                puts "MACRO $(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO GEOM_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {AGGREGATES}} {                puts "MACRO $(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO $(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO GEOM_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {POLYGONS}} {                puts "MACRO $(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO GEOM_AND_ATTR_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {AGGREGATES}} {                puts "MACRO $(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO $(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO GEOM_AND_ATTR_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} } {                puts "MACRO $(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} } {                puts "MACRO $(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          else {}; ]
FACTORY_DEF {*} ReferenceFactory    FACTORY_NAME { $(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_FeatureMerger_2 }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT REFERENCER FEATURE_TYPE "$(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_FeatureMerger_UNMERGED_REQUESTOR"    INPUT REFERENCEE FEATURE_TYPE "$(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_AttributeKeeper_5_OUTPUT"    REFERENCE_INFO { $($(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_FeatureMerger_2_REFERENCE_INFO) }    REFERENCE_TABLE { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>id<closeparen>,$(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_FeatureMerger_2) @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_seriesID<closeparen>,$(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_FeatureMerger_2) AUTO }    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "REQUESTOR_IF_CONFLICT" }    IGNORE_NULLS { "No" }    HANDLE_NULL_MISSING_KEYS_LIKE_FME2013 { No }    LIST_NAME { "advancedViewResources" }    LIST_ATTRS_TO_INCLUDE { format url }    LIST_ATTRS_TO_INCLUDE_MODE { SELECTED }    MERGE_ATTRIBUTES Yes    MANAGE_FME_TYPE Yes    MODE COMPLETE    PROCESS_DUPLICATE_REFERENCEES { NO }    REFERENCEES_FIRST { No }    REJECT_INVALID_GEOM YES    CLEANING_TOLERANCE { <Unused> }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    COMPARE_WHITESPACE Yes    OUTPUT { COMPLETE FEATURE_TYPE "$(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_FeatureMerger_2_MERGED"         }    OUTPUT { INCOMPLETE FEATURE_TYPE "$(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_FeatureMerger_2_UNMERGED_REQUESTOR"         }    OUTPUT { UNREFERENCED FEATURE_TYPE "$(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_FeatureMerger_2_UNUSED_SUPPLIER"         }    OUTPUT { REJECTED FEATURE_TYPE "$(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_FeatureMerger_2_<REJECTED>"         }
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_Terminator_2 }    INPUT  FEATURE_TYPE "$(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_FeatureMerger_2_<REJECTED>"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"Translation<space>Terminated")       @SupplyAttributes(_wb_termination_xformer,"$(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_Terminator_2")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"Translation<space>Terminated") }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_Output1762281036 Output Collector"   INPUT FEATURE_TYPE "$(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_FeatureMerger_2_MERGED"   INPUT FEATURE_TYPE "$(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_FeatureMerger_2_UNMERGED_REQUESTOR"   OUTPUT FEATURE_TYPE "$(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_Output"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_UnmergedAdvancedView1762281036 Output Collector"   INPUT FEATURE_TYPE "$(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_FeatureMerger_2_UNUSED_SUPPLIER"   OUTPUT FEATURE_TYPE "$(SOCRATA_METADATA_MERGER_WORKSPACE_NAME)_UnmergedAdvancedView"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(SOCRATA_METADATA_MERGER_WORKSPACE_NAME))}]
