DEFAULT_MACRO $(ZipExtractor_WORKSPACE_NAME)_ROOT_FOLDER 
DEFAULT_MACRO $(ZipExtractor_WORKSPACE_NAME)_REPLACE No
DEFAULT_MACRO $(ZipExtractor_WORKSPACE_NAME)_RECURSIVE No
DEFAULT_MACRO $(ZipExtractor_WORKSPACE_NAME)_PRESERVE No
DEFAULT_MACRO $(ZipExtractor_WORKSPACE_NAME)_EXT_S 
DEFAULT_MACRO $(ZipExtractor_WORKSPACE_NAME)_EXT_N 
#! START_HEADER
