#! <TRANSFORMERS>
#! <TRANSFORMER
#!   IDENTIFIER="1"
#!   TYPE="ParameterFetcher"
#!   VERSION="4"
#!   POSITION="46.9997 -49"
#!   BOUNDING_RECT="46.9997 -49 0 0"
#!   ORDER="5e+14"
#!   PARMS_EDITED="true"
#!   ENABLED="true"
#!   LAST_PARM_EDIT="15575"
#! >
#!     <OUTPUT_FEAT NAME="OUTPUT"/>
#!     <FEAT_COLLAPSED COLLAPSED="0"/>
#!     <XFORM_ATTR ATTR_NAME="__unzipper.zip_path" IS_USER_CREATED="false" FEAT_INDEX="0" />
#!     <XFORM_ATTR ATTR_NAME="__unzipper.root_folder" IS_USER_CREATED="false" FEAT_INDEX="0" />
#!     <XFORM_ATTR ATTR_NAME="__unzipper.replace" IS_USER_CREATED="false" FEAT_INDEX="0" />
#!     <XFORM_ATTR ATTR_NAME="__unzipper.recursive" IS_USER_CREATED="false" FEAT_INDEX="0" />
#!     <XFORM_ATTR ATTR_NAME="__unzipper.preserve" IS_USER_CREATED="false" FEAT_INDEX="0" />
#!     <XFORM_ATTR ATTR_NAME="__unzipper.ext_s" IS_USER_CREATED="false" FEAT_INDEX="0" />
#!     <XFORM_ATTR ATTR_NAME="__unzipper.ext_n" IS_USER_CREATED="false" FEAT_INDEX="0" />
#!     <XFORM_PARM PARM_NAME="PARAMETERS_GROUP" PARM_VALUE=""/>
#!     <XFORM_PARM PARM_NAME="ATTR_LIST" PARM_VALUE="__unzipper.zip_path {$(ZIP_PATH)} __unzipper.root_folder {$(ROOT_FOLDER)} __unzipper.replace {$(REPLACE)} __unzipper.recursive {$(RECURSIVE)} __unzipper.preserve {$(PRESERVE)} __unzipper.ext_s {$(EXT_S)} __unzipper.ext_n {$(EXT_N)}"/>
#!     <XFORM_PARM PARM_NAME="XFORMER_GROUP" PARM_VALUE=""/>
#!     <XFORM_PARM PARM_NAME="XFORMER_NAME" PARM_VALUE="ParameterFetcher"/>
#! </TRANSFORMER>
#! <TRANSFORMER
#!   IDENTIFIER="2"
#!   TYPE="PythonCaller"
#!   VERSION="4"
#!   POSITION="590.125 -49"
#!   BOUNDING_RECT="590.125 -49 0 0"
#!   ORDER="5e+14"
#!   PARMS_EDITED="true"
#!   ENABLED="true"
#!   LAST_PARM_EDIT="17725"
#! >
#!     <OUTPUT_FEAT NAME="OUTPUT"/>
#!     <FEAT_COLLAPSED COLLAPSED="0"/>
#!     <XFORM_ATTR ATTR_NAME="path_unix" IS_USER_CREATED="false" FEAT_INDEX="0" />
#!     <XFORM_ATTR ATTR_NAME="path_windows" IS_USER_CREATED="false" FEAT_INDEX="0" />
#!     <XFORM_ATTR ATTR_NAME="path_depth" IS_USER_CREATED="false" FEAT_INDEX="0" />
#!     <XFORM_ATTR ATTR_NAME="__unzipper.flag" IS_USER_CREATED="false" FEAT_INDEX="0" />
#!     <XFORM_ATTR ATTR_NAME="_error_message" IS_USER_CREATED="false" FEAT_INDEX="0" />
#!     <XFORM_PARM PARM_NAME="PARAMETERS_GROUP" PARM_VALUE=""/>
#!     <XFORM_PARM PARM_NAME="PYTHONSYMBOL" PARM_VALUE="ZipExtractor"/>
#!     <XFORM_PARM PARM_NAME="NEW_ATTRIBUTES" PARM_VALUE="path_unix path_windows path_depth __unzipper.flag _error_message"/>
#!     <XFORM_PARM PARM_NAME="LIST_ATTRS" PARM_VALUE=""/>
#!     <XFORM_PARM PARM_NAME="TRANSFORMER_GROUP" PARM_VALUE=""/>
#!     <XFORM_PARM PARM_NAME="ADVANCED_GROUP" PARM_VALUE=""/>
#!     <XFORM_PARM PARM_NAME="PYTHONSOURCE" PARM_VALUE="#&lt;space&gt;2016-01-21&lt;comma&gt;&lt;space&gt;Takashi&lt;space&gt;Iijima&lt;comma&gt;&lt;space&gt;Original&lt;space&gt;Implementation&lt;lf&gt;#&lt;space&gt;2016-01-23&lt;comma&gt;&lt;space&gt;Takashi&lt;space&gt;Iijima&lt;comma&gt;&lt;space&gt;Updated:&lt;lf&gt;#&lt;space&gt;-&lt;space&gt;added&lt;space&gt;function&lt;space&gt;to&lt;space&gt;check&lt;space&gt;file&lt;space&gt;extension&lt;space&gt;to&lt;space&gt;prevent&lt;space&gt;extracting&lt;space&gt;non-archiver&lt;space&gt;zip&lt;space&gt;files.&lt;space&gt;e.g.&lt;space&gt;Excel&lt;space&gt;&lt;openparen&gt;*.xlsx&lt;closeparen&gt;&lt;space&gt;etc.&lt;lf&gt;#&lt;space&gt;-&lt;space&gt;added&lt;space&gt;codes&lt;space&gt;to&lt;space&gt;create&lt;space&gt;desitnation&lt;space&gt;root&lt;space&gt;folder&lt;space&gt;if&lt;space&gt;it&lt;space&gt;is&lt;space&gt;specified&lt;space&gt;but&lt;space&gt;doesn&lt;apos&gt;t&lt;space&gt;exist.&lt;lf&gt;#&lt;space&gt;-&lt;space&gt;added&lt;space&gt;option&lt;space&gt;to&lt;space&gt;preserve&lt;space&gt;nested&lt;space&gt;zip&lt;space&gt;files&lt;space&gt;after&lt;space&gt;unzipping&lt;space&gt;them.&lt;lf&gt;#&lt;space&gt;-&lt;space&gt;added&lt;space&gt;&lt;quote&gt;path_depth&lt;quote&gt;&lt;space&gt;attribute&lt;space&gt;to&lt;space&gt;output&lt;space&gt;features.&lt;lf&gt;#&lt;space&gt;2016-01-25&lt;comma&gt;&lt;space&gt;Takashi&lt;space&gt;Iijima&lt;comma&gt;&lt;space&gt;Updated&lt;space&gt;to&lt;space&gt;trim&lt;space&gt;leading&lt;space&gt;and&lt;space&gt;trailing&lt;space&gt;whitespaces&lt;space&gt;of&lt;space&gt;specified&lt;space&gt;path&lt;space&gt;strings.&lt;lf&gt;#&lt;space&gt;2018-06-14&lt;comma&gt;&lt;space&gt;Takashi&lt;space&gt;Iijima&lt;comma&gt;&lt;space&gt;Added&lt;space&gt;Allowable&lt;space&gt;Source&lt;solidus&gt;Nested&lt;space&gt;Zip&lt;space&gt;File&lt;space&gt;Extention&lt;openparen&gt;s&lt;closeparen&gt;&lt;space&gt;parameter.&lt;lf&gt;#&lt;space&gt;2019-01-13&lt;comma&gt;&lt;space&gt;Takashi&lt;space&gt;Iijima&lt;comma&gt;&lt;space&gt;Fixed&lt;space&gt;the&lt;space&gt;destination&lt;space&gt;folder&lt;space&gt;name&lt;space&gt;derived&lt;space&gt;from&lt;space&gt;zip&lt;space&gt;filename&lt;space&gt;which&lt;space&gt;has&lt;space&gt;non-4-letters&lt;space&gt;suffix&lt;space&gt;&lt;openparen&gt;e.g.&lt;space&gt;&lt;quote&gt;.xlsx&lt;quote&gt;&lt;closeparen&gt;.&lt;lf&gt;#&lt;space&gt;2020-01-13&lt;comma&gt;&lt;space&gt;Takashi&lt;space&gt;Iijima&lt;comma&gt;&lt;space&gt;Changed&lt;space&gt;Default&lt;space&gt;Python&lt;space&gt;Interpreter&lt;space&gt;to&lt;space&gt;3.6+&lt;comma&gt;&lt;space&gt;saved&lt;space&gt;with&lt;space&gt;FME&lt;space&gt;2017.1.2.1&lt;lf&gt;&lt;lf&gt;import&lt;space&gt;fmeobjects&lt;comma&gt;&lt;space&gt;zipfile&lt;comma&gt;&lt;space&gt;os&lt;lf&gt;&lt;lf&gt;class&lt;space&gt;ZipExtractor&lt;openparen&gt;object&lt;closeparen&gt;:&lt;lf&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;def&lt;space&gt;__init__&lt;openparen&gt;self&lt;closeparen&gt;:&lt;lf&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;self.logger&lt;space&gt;=&lt;space&gt;fmeobjects.FMELogFile&lt;openparen&gt;&lt;closeparen&gt;&lt;lf&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;self.kFlagFile&lt;space&gt;=&lt;space&gt;&lt;apos&gt;file&lt;apos&gt;&lt;lf&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;self.kFlagDirectory&lt;space&gt;=&lt;space&gt;&lt;apos&gt;directory&lt;apos&gt;&lt;lf&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;self.kFlagReject&lt;space&gt;=&lt;space&gt;&lt;apos&gt;reject&lt;apos&gt;&lt;lf&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;&lt;space&gt;self.kFlagTerminate&lt;space&gt;=&lt;space&gt;&lt;apos&gt;terminate&lt;apos&gt;&lt;lf&gt;&lt;space&gt;&