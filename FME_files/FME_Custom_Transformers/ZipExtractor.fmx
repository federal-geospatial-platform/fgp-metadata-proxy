#! <?xml version="1.0" encoding="UTF-8" ?>
#! <TRANSFORMER
# TRANSFORMER_BEGIN ZipExtractor,1,Workflows,aa009d4d-1d85-4764-84c3-6ccc000f1720,"Embedded by Default",No,NO_PARALLELISM,,No,17725,YES,No,36
# <p style=" margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;">
#     <span style=" font-family:'Verdana';">Extracts files archived in a zip file, and then outputs features for every extracted file and directory.</span>
# </p>
# <p style=" margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;">
#     <span style=" font-family:'Verdana';">Each resulting feature has two attributes storing full path string of an extracted file/directory - </span>
#     <span style=" font-family:'Verdana'; color:#aa0000;">"path_unix"</span>
#     <span style=" font-family:'Verdana';">(UNIX style) and </span>
#     <span style=" font-family:'Verdana'; color:#aa0000;">"path_windows"</span>
#     <span style=" font-family:'Verdana';">(Windows style), and also has an attribute that indicates the depth of the file/directory in the extracted directory hierarchy - </span>
#     <span style=" font-family:'Verdana'; color:#aa0000;">"path_depth" </span>
#     <span style=" font-family:'Verdana';">(integer starting from 1).</span>
# </p>
# <p style=" margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;">
#     <span style=" font-family:'Verdana';">The features containing file path will be output through the File port, and the features containing directory path will be output through the Directory port. </span>
# </p>
# <p style="-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;">
#     <br/>
# </p>
# <p style=" margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;">
#     <span style=" font-family:'Verdana';">All the extracted files will be saved into a subfolder under the folder specified with the "Destination Root Folder" parameter. The subfolder name will be the same as the source zip file name without extension. For example, if the source zip file name is </span>
#     <span style=" font-family:'Verdana'; color:#aa0000;">"data.zip"</span>
#     <span style=" font-family:'Verdana';">and the specified root folder path is </span>
#     <span style=" font-family:'Verdana'; color:#aa0000;">"C:\root"</span>
#     <span style=" font-family:'Verdana';">, extracted files will be saved into </span>
#     <span style=" font-family:'Verdana'; color:#aa0000;">"C:\root\data"</span>
#     <span style=" font-family:'Verdana';">.</span>
# </p>
# <p style="-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;">
#     <br/>
# </p>
# <p style=" margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;">
#     <span style=" font-family:'Verdana';">If the same name folder exists under the specified root folder, a number will be added to the destination subfolder name as suffix to differentiate from the existing folder, by default. e.g. </span>
#     <span style=" font-family:'Verdana'; color:#aa0000;">"C:\root\data_1"</span>
#     <span style=" font-family:'Verdana';">, </span>
#     <span style=" font-family:'Verdana'; color:#aa0000;">"C:\root\data_2"</span>
#     <span style=" font-family:'Verdana';">, and so on. </span>
#     <span style=" font-family:'Verdana'; font-size:medium; color:#000000;">If you set "Yes" to the "Replace Existing Destination Subfolder" parameter, the existing subfolder and all files within it will be removed, and then the destination subfolder will be created newly.</span>
# </p>
# <p style="-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;">
#     <br/>
# </p>
# <p style=" margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;">
#     <span style=" font-family:'Verdana'; font-size:medium; color:#000000;">By default, this transformer will NOT unzip zip files that are archived (nested) in the source zip file. If you set "Yes" to the "Unzip Nested Zip Files Recursively" parameter, this transformer unzips all the nested zip files recursively.</span>
# </p>
# <p style="-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;">
#     <br/>
# </p>
# <p style=" margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;">
#     <span style=" font-family:'Verdana';">All attributes of the input feature will be propagated to the output features, but the geometry and coordinate system will not be preserved.</span>
# </p>
# <p style="-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; font-family:'Verdana';">
#     <br/>
# </p>
# <p style=" margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;">
#     <span style=" font-family:'Verdana';">If the specified source zip file or destination root folder is invalid, the input feature will be output through the &lt;Rejected&gt; port.</span>
# </p>
# <p style="-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;">
#     <br/>
# </p>
# <p style=" margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;">
#     <span style=" font-family:'Verdana';">Note: The Unzipper (FME Hub) can also be used to unzip a zip file. The ZipExtractor may be useful if you need to specify the destination root folder and/or to unzip nested zip file(s).</span>
# </p>
# 
# TRANSFORMER_END
#!   WORKSPACE_VERSION="1"
#!   DOC_EXTENTS="2307.49 404.878"
#!   MARKDOWN_USAGE=""
#!   ATTR_TYPE_ENCODING="SDF"
#!   SHOW_ANNOTATIONS="true"
#!   FME_BUILD_NUM="17725"
#!   FMX_ATTRIBUTE_PROPOGATION_MODE="AUTO"
#!   SHOW_INFO_NODES="true"
#!   FMX_INSERT_MODE="Embedded by Default"
#!   FME_PROCESS_COUNT="NO_PARALLELISM"
#!   CATEGORY="Workflows"
#!   USE_MARKDOWN="NO"
#!   PYTHON_COMPATIBILITY="36"
#!   FME_LINKED_TRANSFORMER_VERSION="1"
#!   EXPLICIT_BOOKMARK_ORDER="false"
#!   HISTORY="2016-01-21,Takashi&lt;space&gt;Iijima,Original&lt;space&gt;Implementation,2016-01-23,Takashi&lt;space&gt;Iijima,Updated&lt;space&gt;not&lt;space&gt;to&lt;space&gt;extract&lt;space&gt;non-archive&lt;space&gt;files&lt;space&gt;which&lt;space&gt;are&lt;space&gt;valid&lt;space&gt;as&lt;space&gt;zip.&lt;space&gt;e.g.&lt;space&gt;Excel&lt;space&gt;&lt;openparen&gt;*.xlsx&lt;closeparen&gt;&lt;space&gt;etc.,2016-01-23,Takashi&lt;space&gt;Iijima,Added&lt;space&gt;&lt;quote&gt;Preserve&lt;space&gt;Nested&lt;space&gt;Zip&lt;space&gt;Files&lt;quote&gt;&lt;space&gt;parameter.&lt;space&gt;Added&lt;space&gt;&lt;quote&gt;path_depth&lt;quote&gt;&lt;space&gt;attribute&lt;space&gt;to&lt;space&gt;output&lt;space&gt;features.,2016-01-25,Takashi&lt;space&gt;Iijima,Updated&lt;space&gt;to&lt;space&gt;trim&lt;space&gt;leading&lt;space&gt;and&lt;space&gt;trailing&lt;space&gt;whitespaces&lt;space&gt;of&lt;space&gt;specified&lt;space&gt;path&lt;space&gt;strings.,2018-06-14,Takashi&lt;space&gt;Iijima,Added&lt;space&gt;Allowable&lt;space&gt;Source&lt;solidus&gt;Nested&lt;space&gt;Zip&lt;space&gt;File&lt;space&gt;Extention&lt;openparen&gt;s&lt;closeparen&gt;&lt;space&gt;parameter.,2019-01-13,Takashi&lt;space&gt;Iijima,Fixed&lt;space&gt;the&lt;space&gt;destination&lt;space&gt;folder&lt;space&gt;name&lt;space&gt;derived&lt;space&gt;from&lt;space&gt;zip&lt;space&gt;filename&lt;space&gt;which&lt;space&gt;has&lt;space&gt;non-4-letters&lt;space&gt;suffix&lt;space&gt;&lt;openparen&gt;e.g.&lt;space&gt;&lt;quote&gt;.xlsx&lt;quote&gt;&lt;closeparen&gt;.,2020-01-13,Takashi&lt;space&gt;Iijima,Changed&lt;space&gt;Default&lt;space&gt;Python&lt;space&gt;Interpreter&lt;space&gt;to&lt;space&gt;3.6+&lt;comma&gt;&lt;space&gt;saved&lt;space&gt;with&lt;space&gt;FME&lt;space&gt;2017.1.2.1"
#!   VIEW_POSITION="-697.507 152.502"
#!   PASSWORD=""
#!   TITLE="ZipExtractor"
#!   FME_PROCESS_GROUP_BY=""
#!   FME_PROCESS_GROUPS_ORDERED="No"
#!   ITERATION_COUNT_ATTR=""
#!   FME_SERVER_SERVICES=""
#!   LAST_SAVE_DATE="2020-01-13T16:46:42"
#!   XFORM_DEPRECATED="No"
#!   DOC_TOP_LEFT="-524 -271.376"
#!   FME_DOCUMENT_PRIORGUID=""
#!   MARKDOWN_DESCRIPTION=""
#!   ZOOM_SCALE="100"
#!   LAST_SAVE_BUILD="FME(R) 2017.1.2.1 (20180117 - Build 17725 - WIN64)"
#!   DESCRIPTION="&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;Extracts files archived in a zip file, and then outputs features for every extracted file and directory.&lt;/span&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;Each resulting feature has two attributes storing full path string of an extracted file/directory - &lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;; color:#aa0000;&quot;&gt;&quot;path_unix&quot;&lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;(UNIX style) and &lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;; color:#aa0000;&quot;&gt;&quot;path_windows&quot;&lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;(Windows style), and also has an attribute that indicates the depth of the file/directory in the extracted directory hierarchy - &lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;; color:#aa0000;&quot;&gt;&quot;path_depth&quot; &lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;(integer starting from 1).&lt;/span&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;The features containing file path will be output through the File port, and the features containing directory path will be output through the Directory port. &lt;/span&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;br/&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;All the extracted files will be saved into a subfolder under the folder specified with the &quot;Destination Root Folder&quot; parameter. The subfolder name will be the same as the source zip file name without extension. For example, if the source zip file name is &lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;; color:#aa0000;&quot;&gt;&quot;data.zip&quot;&lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;and the specified root folder path is &lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;; color:#aa0000;&quot;&gt;&quot;C:\root&quot;&lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;, extracted files will be saved into &lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;; color:#aa0000;&quot;&gt;&quot;C:\root\data&quot;&lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;.&lt;/span&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;br/&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;If the same name folder exists under the specified root folder, a number will be added to the destination subfolder name as suffix to differentiate from the existing folder, by default. e.g. &lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;; color:#aa0000;&quot;&gt;&quot;C:\root\data_1&quot;&lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;, &lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;; color:#aa0000;&quot;&gt;&quot;C:\root\data_2&quot;&lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;, and so on. &lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;; font-size:medium; color:#000000;&quot;&gt;If you set &quot;Yes&quot; to the &quot;Replace Existing Destination Subfolder&quot; parameter, the existing subfolder and all files within it will be removed, and then the destination subfolder will be created newly.&lt;/span&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;br/&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;; font-size:medium; color:#000000;&quot;&gt;By default, this transformer will NOT unzip zip files that are archived (nested) in the source zip file. If you set &quot;Yes&quot; to the &quot;Unzip Nested Zip Files Recursively&quot; parameter, this transformer unzips all the nested zip files recursively.&lt;/span&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;br/&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;All attributes of the input feature will be propagated to the output features, but the geometry and coordinate system will not be preserved.&lt;/span&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; font-family:&apos;Verdana&apos;;&quot;&gt;&#10;    &lt;br/&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;If the specified source zip file or destination root folder is invalid, the input feature will be output through the &amp;lt;Rejected&amp;gt; port.&lt;/span&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;br/&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;Note: The Unzipper (FME Hub) can also be used to unzip a zip file. The ZipExtractor may be useful if you need to specify the destination root folder and/or to unzip nested zip file(s).&lt;/span&gt;&#10;&lt;/p&gt;&#10;"
#!   BLOCKED_LOOPING="No"
#!   FME_DOCUMENT_GUID="aa009d4d-1d85-4764-84c3-6ccc000f1720"
#!   WARN_INVALID_XFORM_PARAM="Yes"
#!   USAGE="&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;; font-weight:600; color:#0000ff;&quot;&gt;Parameters&lt;/span&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; font-family:&apos;Verdana&apos;;&quot;&gt;&#10;    &lt;br/&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;; color:#005500;&quot;&gt;Source Zip File&lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;:&lt;/span&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;Specify a zip file that should be extracted. The zip file name has to end with the extension &quot;.zip&quot; (case insensitive) by default, but optionally, you can also specify any extension(s) which this transformer should attempt to extract as a zip file. See the Allowable Source/Nested Zip File Extensions parameter.&lt;/span&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; font-family:&apos;Verdana&apos;;&quot;&gt;&#10;    &lt;br/&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;; color:#005500;&quot;&gt;Destination Root Folder&lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;:&lt;/span&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;Specify a folder in which a subfolder containing all extracted files should be created. If you leave this parameter blank, this transformer treats the folder containing the source zip file as the destination root folder.&lt;/span&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;All the extracted files will be saved into a subfolder under the root folder. The subfolder name will be the same as the source zip file name without extension. For example, if the source zip file name is &lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;; color:#aa0000;&quot;&gt;&quot;data.zip&quot;&lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;and the specified root folder path is &lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;; color:#aa0000;&quot;&gt;&quot;C:\root&quot;&lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;, extracted files will be saved into &lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;; color:#aa0000;&quot;&gt;&quot;C:\root\data&quot;&lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;.&lt;/span&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; font-family:&apos;Verdana&apos;;&quot;&gt;&#10;    &lt;br/&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;; color:#005500;&quot;&gt;Replace Existing Destination Subfolder&lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;:&lt;/span&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;By default, a number will be added to the destination subfolder name as suffix if the same name folder exists under the spcified root folder. e.g. &lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;; color:#aa0000;&quot;&gt;&quot;C:\root\data_1&quot;&lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;, &lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;; color:#aa0000;&quot;&gt;&quot;C:\root\data_2&quot;&lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;, and so on. If you set &quot;Yes&quot; to this parameter, the existing subfolder and all files within it will be removed, and then the destination subfolder will be created newly. &lt;/span&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; font-family:&apos;Verdana&apos;;&quot;&gt;&#10;    &lt;br/&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;; color:#005500;&quot;&gt;Unzip Nested Zip Files Recursively&lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;:&lt;/span&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;By default, this transformer will NOT unzip zip files that are archived (nested) in the source zip file. If you set &quot;Yes&quot; to this parameter, this transformer unzips all the nested zip files recursively.&lt;/span&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; font-family:&apos;Verdana&apos;;&quot;&gt;&#10;    &lt;br/&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;; color:#005500;&quot;&gt;Preserve Nested Zip Files&lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;:&lt;/span&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;By default, zip files nested in the source zip file will be removed after unzipping them, when the &quot;Unzip Nested Zip Files Recursively&quot; parameter is set to &quot;Yes&quot;. If you set &quot;Yes&quot; to this parameter, the nested zip files will also be preserved.&lt;/span&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;This parameter affects the result only when the &quot;Unzip Nested Zip Files Recursively&quot; parameter is set to &quot;Yes&quot;. When the &quot;Unzip Nested Zip Files Recursively&quot; is set to &quot;No&quot;, nested zip files always will be preserved regardless of this parameter.&lt;/span&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; font-family:&apos;Verdana&apos;;&quot;&gt;&#10;    &lt;br/&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;; color:#005500;&quot;&gt;Allowable Source/Nested Zip File Extension(s)&lt;/span&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;:&lt;/span&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;By default, this transformer accepts only zip files whose name end with the extension &quot;.zip&quot; (case insensitive). However, if you want to extract zip files with other extension, you can specify allowable extention(s) via these parameters, with space-separated format when specifying two or more.&lt;/span&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;Here, &quot;Source Zip File&quot; means that the top level zip file which would be set to the Source Zip File parameter; &quot;Nested Zip File&quot;means that internal zip file(s) which have been archived within the source zip file.&lt;/span&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;If you leave the parameter field blank (it&apos;s the default), only &quot;.zip&quot; (case insensitive) will be allowable as zip file extension.&lt;/span&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;Note that &quot;zip&quot; won&apos;t be allowable if you have set one or more extension other than &quot;.zip&quot; to the parameter. If you want to allow &quot;.zip&quot; and other extension(s) simultaneously, specify all possible extensions including &quot;.zip&quot; with the parameter.&lt;/span&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&#10;    &lt;span style=&quot; font-family:&apos;Verdana&apos;;&quot;&gt;The leading dot &quot;.&quot; of extensions can be omitted.&lt;/span&gt;&#10;&lt;/p&gt;&#10;&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; font-family:&apos;Verdana&apos;;&quot;&gt;&#10;    &lt;br/&gt;&#10;&lt;/p&gt;&#10;"
#!   MAX_LOOP_ITERATIONS=""
