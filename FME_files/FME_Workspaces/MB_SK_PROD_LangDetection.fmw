INCLUDE [ if {{$(ACTIVATE_GEO$encode)} == {}} { puts_real {Parameter 'ACTIVATE_GEO' must be given a value.}; exit 1; }; ]
INCLUDE [ if {{$(ACTIVATE_NON_GEO$encode)} == {}} { puts_real {Parameter 'ACTIVATE_NON_GEO' must be given a value.}; exit 1; }; ]
INCLUDE [ if {{$(LOCAL_SOURCE_METADATA_DELTA_FINDER$encode)} == {}} { puts_real {Parameter 'LOCAL_SOURCE_METADATA_DELTA_FINDER' must be given a value.}; exit 1; }; ]
INCLUDE [ if {{$(P-T_ABBR$encode)} == {}} { puts_real {Parameter 'P-T_ABBR' must be given a value.}; exit 1; }; ]
INCLUDE [ if {{$(METADATA_OVERWRITE$encode)} == {}} { puts_real {Parameter 'METADATA_OVERWRITE' must be given a value.}; exit 1; }; ]
INCLUDE [ if {{$(IN_OUT_WORKING_DIR$encode)} == {}} { puts_real {Parameter 'IN_OUT_WORKING_DIR' must be given a value.}; exit 1; }; ]
INCLUDE [ if {{$(URL_VALIDATION$encode)} == {}} { puts_real {Parameter 'URL_VALIDATION' must be given a value.}; exit 1; }; ]
INCLUDE [ if {{$(VALIDATE_INSERT_PCT_JSON$encode)} == {}} { puts_real {Parameter 'VALIDATE_INSERT_PCT_JSON' must be given a value.}; exit 1; }; ]
INCLUDE [ if {{$(VALIDATE_INSERT_PCT_XML$encode)} == {}} { puts_real {Parameter 'VALIDATE_INSERT_PCT_XML' must be given a value.}; exit 1; }; ]
#! START_HEADER
#! START_WB_HEADER
READER_TYPE MULTI_READER
WRITER_TYPE MULTI_WRITER
WRITER_KEYWORD PRIMARY_DEST
PRIMARY_DEST_DATASET_ORDER BY_ID
PRIMARY_DEST_FIRST_WRITER_ID 0
PRIMARY_DEST_TYPE{0} MULTI_WRITER
PRIMARY_DEST_KEYWORD{0} TEXTLINE_1_FANOUT
TEXTLINE_1_FANOUT_TYPE{*} TEXTLINE
TEXTLINE_1_FANOUT_KEYWORD{*} TEXTLINE_1
TEXTLINE_1_FANOUT_DATASET_ORDER BY_INPUT
PRIMARY_DEST_TYPE{1} MULTI_WRITER
PRIMARY_DEST_KEYWORD{1} TEXTLINE_2_FANOUT
TEXTLINE_2_FANOUT_TYPE{*} TEXTLINE
TEXTLINE_2_FANOUT_KEYWORD{*} TEXTLINE_2
TEXTLINE_2_FANOUT_DATASET_ORDER BY_INPUT
PRIMARY_DEST_TYPE{2} MULTI_WRITER
PRIMARY_DEST_KEYWORD{2} TEXTLINE_3_FANOUT
TEXTLINE_3_FANOUT_TYPE{*} TEXTLINE
TEXTLINE_3_FANOUT_KEYWORD{*} TEXTLINE_3
TEXTLINE_3_FANOUT_DATASET_ORDER BY_INPUT
PRIMARY_DEST_TYPE{3} MULTI_WRITER
PRIMARY_DEST_KEYWORD{3} XLSXW_1_FANOUT
XLSXW_1_FANOUT_TYPE{*} XLSXW
XLSXW_1_FANOUT_KEYWORD{*} XLSXW_1
XLSXW_1_FANOUT_DATASET_ORDER BY_INPUT
PRIMARY_DEST_TYPE{4} MULTI_WRITER
PRIMARY_DEST_KEYWORD{4} TEXTLINE_4_FANOUT
TEXTLINE_4_FANOUT_TYPE{*} TEXTLINE
TEXTLINE_4_FANOUT_KEYWORD{*} TEXTLINE_4
TEXTLINE_4_FANOUT_DATASET_ORDER BY_INPUT
#! END_WB_HEADER
#! START_WB_HEADER
MACRO WB_KEYWORD "TEXTLINE_1"
#! END_WB_HEADER
#! START_DEST_HEADER TEXTLINE TEXTLINE_1
# =====================================================================
# The following GUI line prompts for a directory to be used as the
# the destination for the TextLine files. The user input is stored in
# a macro, which is then used to define the dataset to be written.
#! END_DEST_HEADER
#! START_WB_HEADER
DEFAULT_MACRO DestDataset
INCLUDE [ if {"$(DestDataset)" != ""} {                          \
 puts {DEFAULT_MACRO DestDataset_TEXTLINE_1 $(DestDataset)}         \
 } ]
#! END_WB_HEADER
#! START_DEST_HEADER TEXTLINE TEXTLINE_1
DEFAULT_MACRO DestDataset_TEXTLINE_1 $(OUT_XML_PASSED_DIR)
GUI FILENAME DestDataset_TEXTLINE_1 Text/Compressed_Text_Files(*.txt;*.txt.gz)|*.txt;*.txt.gz|Text_Files(*.txt)|*.txt|Compressed_Text_Files(*.txt.gz)|*.txt.gz|All_files(*.*)|*.* Destination Text File File:
# =====================================================================
# The following GUI line prompts for the overwrite flag. The default is
# YES. Possible values are YES or NO. Any value other than NO or
# no is interpreted as YES.
DEFAULT_MACRO TEXTLINE_OUT_OVERWRITE_FILE_TEXTLINE_1 YES
TEXTLINE_1_OVERWRITE_FILE "$(TEXTLINE_OUT_OVERWRITE_FILE_TEXTLINE_1)"
GUI CHOICE TEXTLINE_OUT_OVERWRITE_FILE_TEXTLINE_1 YES%NO Overwrite Existing File:
# =====================================================================
# Set the type of encoding for the output file
DEFAULT_MACRO TEXTLINE_OUT_ENCODING_TEXTLINE_1 UTF-8
TEXTLINE_1_ENCODING "$(TEXTLINE_OUT_ENCODING_TEXTLINE_1)"
GUI OPTIONAL STRING_OR_CHOICE TEXTLINE_OUT_ENCODING_TEXTLINE_1 UTF-8%UTF-16LE%UTF-16BE%ANSI%BIG5%SJIS%CP437%CP708%CP720%CP737%CP775%CP850%CP852%CP855%CP857%CP860%CP861%CP862%CP863%CP864%CP865%CP866%CP869%CP932%CP936%CP950%CP1250%CP1251%CP1252%CP1253%CP1254%CP1255%CP1256%CP1257%CP1258%ISO8859-1%ISO8859-2%ISO8859-3%ISO8859-4%ISO8859-5%ISO8859-6%ISO8859-7%ISO8859-8%ISO8859-9%ISO8859-13%ISO8859-15 Character Encoding (optional):
# =====================================================================
# Set line termination character
DEFAULT_MACRO TEXTLINE_OUT_END_OF_LINE_TEXTLINE_1 
TEXTLINE_1_END_OF_LINE "$(TEXTLINE_OUT_END_OF_LINE_TEXTLINE_1)"
GUI OPTIONAL CHOICE TEXTLINE_OUT_END_OF_LINE_TEXTLINE_1 Windows%Unix%Macintosh Line Termination:
# =====================================================================
# Set the mime type. Note -- it is actually only used inside of workspaces
# as a FORMAT_PARAMETER which even then is parsed only by the FME Server
# Repository Manager
DEFAULT_MACRO TEXTLINE_OUT_MIME_TYPE_TEXTLINE_1 text/plain
TEXTLINE_1_MIME_TYPE "$(TEXTLINE_OUT_MIME_TYPE_TEXTLINE_1)"
TEXTLINE_1_DATASET "$(DestDataset_TEXTLINE_1)"
TEXTLINE_1_GENERATE_FME_BUILD_NUM 6210
#! END_DEST_HEADER
#! START_WB_HEADER
MACRO WB_KEYWORD "TEXTLINE_2"
#! END_WB_HEADER
#! START_DEST_HEADER TEXTLINE TEXTLINE_2
# =====================================================================
# The following GUI line prompts for a folder to be used as the
# the destination for the TextLine files. The user input is stored in
# a macro, which is then used to define the dataset to be written.
#! END_DEST_HEADER
#! START_WB_HEADER
DEFAULT_MACRO DestDataset
INCLUDE [ if {"$(DestDataset)" != ""} {                          \
 puts {DEFAULT_MACRO DestDataset_TEXTLINE_2 $(DestDataset)}         \
 } ]
#! END_WB_HEADER
#! START_DEST_HEADER TEXTLINE TEXTLINE_2
DEFAULT_MACRO DestDataset_TEXTLINE_2 $(OUT_XML_FAILED_DIR)
GUI FILENAME DestDataset_TEXTLINE_2 Text/Compressed_Text_Files(*.txt;*.txt.gz)|*.txt;*.txt.gz|Text_Files(*.txt)|*.txt|Compressed_Text_Files(*.txt.gz)|*.txt.gz|All_files(*)|* Destination Text File:
DEFAULT_MACRO TEXTLINE_OUT_FME_GROUP_NAMED1_TEXTLINE_2 
GUI OPTIONAL DISCLOSUREGROUP TEXTLINE_OUT_FME_GROUP_NAMED1_TEXTLINE_2 TEXTLINE_OUT_OVERWRITE_FILE_TEXTLINE_2 Writer Parameters
# =====================================================================
# The following GUI line prompts for the overwrite flag. The default is
# YES. Possible values are YES or NO. Any value other than NO or
# no is interpreted as YES.
DEFAULT_MACRO TEXTLINE_OUT_OVERWRITE_FILE_TEXTLINE_2 YES
TEXTLINE_2_OVERWRITE_FILE "$(TEXTLINE_OUT_OVERWRITE_FILE_TEXTLINE_2)"
GUI CHOICE TEXTLINE_OUT_OVERWRITE_FILE_TEXTLINE_2 YES%NO Overwrite Existing File:
DEFAULT_MACRO TEXTLINE_OUT_FME_GROUP_NAMED2_TEXTLINE_2 FME_DISCLOSURE_OPEN
GUI OPTIONAL DISCLOSUREGROUP TEXTLINE_OUT_FME_GROUP_NAMED2_TEXTLINE_2 TEXTLINE_OUT_END_OF_LINE_TEXTLINE_2%TEXTLINE_OUT_WRITE_LAST_EOL_TEXTLINE_2%TEXTLINE_OUT_ENCODING_TEXTLINE_2%TEXTLINE_OUT_WRITE_UTF8_BOM_TEXTLINE_2 File Contents
# =====================================================================
# Set the type of encoding for the output file
# =====================================================================
# Set line termination character
DEFAULT_MACRO TEXTLINE_OUT_END_OF_LINE_TEXTLINE_2 System
TEXTLINE_2_END_OF_LINE "$(TEXTLINE_OUT_END_OF_LINE_TEXTLINE_2)"
GUI CHOICE TEXTLINE_OUT_END_OF_LINE_TEXTLINE_2 System%Windows%Unix%Macintosh%Source%None Line Termination:
# =====================================================================
# Set whether to write the last line termination character
