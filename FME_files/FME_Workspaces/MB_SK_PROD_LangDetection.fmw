DEFAULT_MACRO FME_SHAREDRESOURCE_DATA C:\Data

DEFAULT_MACRO ACTIVATE_GEO Yes

DEFAULT_MACRO ACTIVATE_NON_GEO Yes

DEFAULT_MACRO ACTIVATE_TRANSLATION Yes

DEFAULT_MACRO CATALOGUE_READER_SELECT Yes

DEFAULT_MACRO FORCED_PYCSW_URL 

DEFAULT_MACRO IN_FFS_TESTING_FILE 

DEFAULT_MACRO LOCAL_SOURCE_METADATA_DELTA_FINDER No

DEFAULT_MACRO LOCAL_WRITER No

DEFAULT_MACRO P-T_ABBR SK

DEFAULT_MACRO METADATA_OVERWRITE NO

DEFAULT_MACRO IN_OUT_WORKING_DIR $(FME_SHAREDRESOURCE_DATA)\PT_Harvester

DEFAULT_MACRO SAMPLE_SIZE 0

DEFAULT_MACRO URL_VALIDATION Yes

DEFAULT_MACRO VALIDATE_INSERT_PCT_JSON Yes

DEFAULT_MACRO VALIDATE_INSERT_PCT_XML Yes

DEFAULT_MACRO FME_USER_PARAM_PRIVATE_GRP 

DEFAULT_MACRO IN_CSV_LOOKUPTABLES_DIR $(IN_OUT_WORKING_DIR)\LOOKUP_TABLES

DEFAULT_MACRO IN_GMD_XML_TEMPLATE_DIR $(IN_OUT_WORKING_DIR)\XML_TEMPLATES

DEFAULT_MACRO IN_TBS_JSON_TEMPLATE_DIR $(IN_OUT_WORKING_DIR)\JSON_TEMPLATES

DEFAULT_MACRO LOG_FILE $(IN_OUT_WORKING_DIR)\$(P-T_ABBR)\LOG\$(P-T_ABBR).log

DEFAULT_MACRO OUT_JSON_LOCAL_DIR $(IN_OUT_WORKING_DIR)\$(P-T_ABBR)\JSON_LOCAL

DEFAULT_MACRO OUT_XLS_NOTIFICATION_DIR $(IN_OUT_WORKING_DIR)\$(P-T_ABBR)\XLS

DEFAULT_MACRO OUT_XML_FAILED_DIR $(IN_OUT_WORKING_DIR)\$(P-T_ABBR)\XML_FAILED

DEFAULT_MACRO OUT_XML_LOCAL_DIR $(IN_OUT_WORKING_DIR)\$(P-T_ABBR)\XML_LOCAL

DEFAULT_MACRO OUT_XML_PASSED_DIR $(IN_OUT_WORKING_DIR)\$(P-T_ABBR)\XML_PASSED

DEFAULT_MACRO IN_CSV_LOOKUP_TABLES_DIR $(IN_OUT_WORKING_DIR)\LOOKUP_TABLES

DEFAULT_MACRO FME_SHAREDRESOURCE_TEMP C:\Users\bcrepeau\OneDrive - NRCan RNCan\Bureau\PT\MB_Sk\MB\traductionAWS

