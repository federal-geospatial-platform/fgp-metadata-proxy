INCLUDE [ FME_CleanseFMEUUID {StatisticsCalculator_Summary_3_968727a2_393f_44ea_9378_396d6ce7debf0} ]
# If the Logger was in a custom transformer, the custom transformer's name was not being
# properly logged -- instead we saw "$(<customXformerName_WORKSPACE_NAME)" being logged as the prefix of the
# message. By deferencing and expanding out the XFORMER_NAME below, and then "WWJD" encoding it when it is
# used in the @Log call via the $encode macro name suffix trick, we get the right result, and the right result
# safely.
MACRO LOGGABLE_XFORMER_NAME StatisticsCalculator_Summary_3
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { StatisticsCalculator_Summary_3_Logger }    INPUT  FEATURE_TYPE METADATA_DELTA_FINDER_GEN_2_Statistics    INPUT  FEATURE_TYPE METADATA_DELTA_FINDER_GEN_4_Statistics    INPUT  FEATURE_TYPE Junction_7_Output    OUTPUT { FEATURE_TYPE StatisticsCalculator_Summary_3_LOGGED                  @Log(ENCODED, "$(LOGGABLE_XFORMER_NAME$encode):<space>@EvaluateExpression(FDIV,STRING_ENCODED,<lf>************************<lf>****<space>Unchanged<space>Report<space>****<lf>************************<lf><lf><at>Value<openparen>_real_count<closeparen><space>features<space>were<space>unchanged<lf><lf>************************<lf>************************<lf>************************<lf>,StatisticsCalculator_Summary_3)","<Unused>","20","",INFO,NONE,$(FME_UUID_SAFE))                   }
