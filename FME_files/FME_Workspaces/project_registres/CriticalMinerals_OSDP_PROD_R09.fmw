FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME AttributeCreator_9    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE PythonCaller_4_OUTPUT    MULTI_FEATURE_MODE NO    NULL_ATTR_MODE NO_OP     ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV     ATTR_ACTION { "" "Keywords<space><openparen>EN<closeparen>" "SET_TO" "<at>Value<openparen>KeywordsEN<closeparen>" }      ATTR_ACTION { "" "Keywords<space><openparen>FR<closeparen>" "SET_TO" "<at>Value<openparen>KeywordsFR<closeparen>" }    OUTPUT OUTPUT FEATURE_TYPE AttributeCreator_9_OUTPUT
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "commodity_list_EN<opencurly><closecurly> commodity_list_FR<opencurly><closecurly>"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO AttributeRemover_6_LIST_FUNC }    } else {        puts "MACRO AttributeRemover_6_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME AttributeRemover_6    INPUT  FEATURE_TYPE StringReplacer_OUTPUT    INPUT  FEATURE_TYPE AttributeCreator_9_OUTPUT    OUTPUT { FEATURE_TYPE AttributeRemover_6_OUTPUT        @RemoveAttributes(fme_encoded,KeywordsEN,KeywordsFR)        $(AttributeRemover_6_LIST_FUNC)         }
# -------------------------------------------------------------------------
Tcl2 proc StringConcatenator_evaluator {} {    if {{OUTGOING} == {OUTGOING}} {      set attr [FME_DecodeText {UUID_generator}];      if {[string length $attr] == 0} { return; };      set attrs [list [FME_EncodeText $attr]];    } else {      set attrAll {<Unused>};      if {[string length $attrAll] == 0} { return; };      set attrs [split {<Unused>} { }];    };    set parmList {{EvaluateExpression} {ATTR_CREATE_EXPR_PROPOGATE_MISSING_FDIV}};    foreach attr $attrs {     lappend parmList $attr;     lappend parmList {"<at>Value<openparen>Title<space><openparen>EN<closeparen><closeparen><at>Value<openparen>Coverage.Geometry<closeparen>"};    };    lappend parmList {StringConcatenator};    eval FME_Execute $parmList; }
FACTORY_DEF * TeeFactory    FACTORY_NAME StringConcatenator    INPUT  FEATURE_TYPE AttributeRemover_6_OUTPUT    OUTPUT FEATURE_TYPE StringConcatenator_OUTPUT         @Tcl2("StringConcatenator_evaluator ")
