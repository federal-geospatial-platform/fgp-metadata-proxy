MACRO $(Execute_Python_3.7_Library_WORKSPACE_NAME)_Execution_Parameters <openbracket><lf><opencurly><quote>parametersAreAttributeNames<quote>:False<closecurly><comma><lf><opencurly><lf><space><space><quote>source<quote>:<quote>$(FME_SHAREDRESOURCE_DATA$encode)<backslash>DDR<backslash>Conditioning_Data<backslash>900A_OSDP<backslash>GeoDCAT<backslash>NRCAN-MINING-<at>Value<openparen>_feature_type<opencurly>0<closecurly>._datestamp<closeparen>.csv<quote><comma><lf><space><space><quote>destination<quote>:<quote>$(FME_SHAREDRESOURCE_DATA$encode)<backslash>DDR<backslash>Conditioning_Data<backslash>900A_OSDP<backslash>last_900A_file.csv<quote><lf><closecurly><comma><lf><closebracket>
