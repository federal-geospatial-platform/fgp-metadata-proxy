MACRO FeatureReader_31_OUTPUT_PORTS_ENCODED 
MACRO FeatureReader_31_DIRECTIVES SKIP_DUPLICATE_DELIMITERS,No,FEATURE_TYPE_NAME,FORMAT_NAME,ENCODING,windows-1252,DATA_START_LINE,2,TRIM_FIELD_NAME_WHITESPACE,Yes,TRIM_FEATURE_TYPE_NAME,Yes,CASE_SENSITIVE_FIELD_NAMES,Yes,FIELD_QUALIFIER_ESCAPE_CHARACTER,<lt>quote<gt>,DELIMITER,<lt>comma<gt>,SCAN_MAX_ROWS,10000,PRESERVE_SOURCE_ENCODING,No,ENFORCE_STRICT_SCHEMA,No,TRIM_FIELD_NAME_QUALIFIERS,Yes,READ_SKIPPED_LINES,No,SCAN_ADDITIONAL_FIELDS,No,FIELD_QUALIFIER_CHARACTER,<lt>quote<gt>,QUERY_FEATURE_TYPES_FOR_MERGE_FILTERS,Yes,SCAN_TYPES,Yes,USE_CUSTOM_SCHEMA,NO,FIELD_NAMES_LINE,1,TRIM_FIELD_VALUE_QUALIFIERS,Yes,CHUNK_SIZE,100000
# Always provide an INTERACTION, otherwise the factory defaults to ENVELOPE_INTERSECTS
INCLUDE [if { ( {NONE} == {<Unused>} ) || ( {($INTERACT_OPTIONS)} == {} ) } {             puts {MACRO FCTQUERY_INTERACTION_LINE FCTQUERY_INTERACTION NONE};          } else {             puts {MACRO FCTQUERY_INTERACTION_LINE FCTQUERY_INTERACTION "NONE"};          }         ]
