FACTORY_DEF * PythonFactory    FACTORY_NAME PythonCaller_5    INPUT  FEATURE_TYPE DateTimeConverter_7_OUTPUT    SYMBOL_NAME FeatureProcessor    PYTHON_NAMESPACE FMEOBJECTS    SOURCE_CODE import<space>fme<lf>import<space>fmeobjects<lf>#<space>Template<space>Function<space>interface:<lf>#<space>When<space>using<space>this<space>function<comma><space>make<space>sure<space>its<space>name<space>is<space>set<space>as<space>the<space>value<space>of<lf>#<space>the<space><apos>Class<space>or<space>Function<space>to<space>Process<space>Features<apos><space>transformer<space>parameter<lf>def<space>processFeature<openparen>feature<closeparen>:<lf><space><space><space><space>pass<lf><lf>#<space>Template<space>Class<space>Interface:<lf>#<space>When<space>using<space>this<space>class<comma><space>make<space>sure<space>its<space>name<space>is<space>set<space>as<space>the<space>value<space>of<lf>#<space>the<space><apos>Class<space>or<space>Function<space>to<space>Process<space>Features<apos><space>transformer<space>parameter<lf>class<space>FeatureProcessor<openparen>object<closeparen>:<lf><space><space><space><space>def<space>__init__<openparen>self<closeparen>:<lf><space><space><space><space><space><space><space><space>pass<lf><space><space><space><space>def<space>input<openparen>self<comma>feature<closeparen>:<lf><space><space><space><space><space><space><space><space>mois=<opencurly><closecurly><lf><space><space><space><space><space><space><space><space>mois<openbracket><apos>January<apos><closebracket>=<apos>janvier<apos><lf><space><space><space><space><space><space><space><space>mois<openbracket><apos>February<apos><closebracket>=<apos>f<u00e9>vrier<apos><lf><space><space><space><space><space><space><space><space>mois<openbracket><apos>March<apos><closebracket>=<apos>mars<apos><lf><space><space><space><space><space><space><space><space>mois<openbracket><apos>April<apos><closebracket>=<apos>avril<apos><lf><space><space><space><space><space><space><space><space>mois<openbracket><apos>May<apos><closebracket>=<apos>mai<apos><lf><space><space><space><space><space><space><space><space>mois<openbracket><apos>June<apos><closebracket>=<apos>juin<apos><lf><space><space><space><space><space><space><space><space>mois<openbracket><apos>July<apos><closebracket>=<apos>juillet<apos><lf><space><space><space><space><space><space><space><space>mois<openbracket><apos>August<apos><closebracket>=<apos>ao<u00fb>t<apos><lf><space><space><space><space><space><space><space><space>mois<openbracket><apos>September<apos><closebracket>=<apos>septembre<apos><lf><space><space><space><space><space><space><space><space>mois<openbracket><apos>October<apos><closebracket>=<apos>octobre<apos><lf><space><space><space><space><space><space><space><space>mois<openbracket><apos>November<apos><closebracket>=<apos>novembre<apos><lf><space><space><space><space><space><space><space><space>mois<openbracket><apos>December<apos><closebracket>=<apos>d<u00e9>cembre<apos><lf><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space>fr=False<lf><space><space><space><space><space><space><space><space>for<space>keys<space>in<space>mois:<lf><space><space><space><space><space><space><space><space><space><space><space><space>if<space>keys<space>in<space>feature.getAttribute<openparen><apos>_citationDate_fr<apos><closeparen>:<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>_citationDate_fr<apos><comma>feature.getAttribute<openparen><apos>_citationDate_fr<apos><closeparen>.replace<openparen>keys<comma>mois<openbracket>keys<closebracket><closeparen><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>fr=True<lf><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space>if<space>not<space>fr:<lf><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>_error_date<apos><comma><apos>Impossible<space>de<space>mapper<space>la<space>date<space>%s<space>en<space>fran<u00e7>ais<apos>%<openparen>feature.getAttribute<openparen><apos>_citationDate_fr<apos><closeparen><closeparen><closeparen><lf><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space>self.pyoutput<openparen>feature<closeparen><lf><space><space><space><space>def<space>close<openparen>self<closeparen>:<lf><space><space><space><space><space><space><space><space>pass    OUTPUT PYOUTPUT FEATURE_TYPE PythonCaller_5_OUTPUT
# -------------------------------------------------------------------------
FACTORY_DEF * TestFactory    FACTORY_NAME Tester_4    INPUT  FEATURE_TYPE PythonCaller_5_OUTPUT    TEST "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_error_date<closeparen>,Tester_4)" = "" ENCODED    BOOLEAN_OPERATOR OR    COMPOSITE_TEST_EXPR "1"    FEATURE_TABLE_SHIM_SUPPORT Yes    PRESERVE_FEATURE_ORDER PER_OUTPUT_PORT    OUTPUT PASSED FEATURE_TYPE Tester_4_PASSED    OUTPUT FAILED FEATURE_TYPE Tester_4_FAILED
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF * TestFactory    FACTORY_NAME Terminator_3    INPUT  FEATURE_TYPE Tester_4_FAILED    TEST "$(_WB_BYPASS_TERMINATION)" == Yes    OUTPUT PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_error_date<closeparen>,Terminator_3)")       @SupplyAttributes(_wb_termination_xformer,"Terminator_3")       @SupplyAttributes(_wb_termination_feature,Yes)    OUTPUT FAILED FEATURE_TYPE * @Abort(ENCODED,"@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_error_date<closeparen>,Terminator_3)")
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME AttributeCreator_22    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE Tester_4_PASSED    MULTI_FEATURE_MODE NO    NULL_ATTR_MODE NO_OP     ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV     ATTR_ACTION { "" "Citation.Value<space><openparen>EN<closeparen><openbracket>1<closebracket>" "SET_TO" "<at>Value<openparen>Creator<space><openparen>EN<closeparen><closeparen><space><openparen><at>Value<openparen>_citationDate_en<closeparen><closeparen>.<space><at>Value<openparen>Title<space><openparen>EN<closeparen><closeparen>.<space>Natural<space>Resources<space>Canada<comma><space>Open<space>Science<space>and<space>Data<space>Platform.<space>https:<solidus><solidus>osdp-psdo.canada.ca<solidus>dp<solidus>en<solidus>search<solidus>metadata<solidus><at>Value<openparen>Contributor<space>System<closeparen>-1-<at>Value<openparen>Identifier.Artifact<closeparen>" }      ATTR_ACTION { "" "Citation.Value<space><openparen>FR<closeparen><openbracket>1<closebracket>" "SET_TO" "<at>Value<openparen>Creator<space><openparen>FR<closeparen><closeparen><space><openparen><at>Value<openparen>_citationDate_fr<closeparen><closeparen>.<space><at>Value<openparen>Title<space><openparen>FR<closeparen><closeparen>.<space>Ressources<space>naturelles<space>Canada<comma><space>Plateforme<space>de<space>science<space>et<space>de<space>donn<u00e9>es<space>ouvertes.<space>https:<solidus><solidus>osdp-psdo.canada.ca<solidus>dp<solidus>fr<solidus>recherche<solidus>metadonnees<solidus><at>Value<openparen>Contributor<space>System<closeparen>-1-<at>Value<openparen>Identifier.Artifact<closeparen>" }    OUTPUT OUTPUT FEATURE_TYPE AttributeCreator_22_OUTPUT
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO AttributeRemover_3_LIST_FUNC }    } else {        puts "MACRO AttributeRemover_3_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME AttributeRemover_3    INPUT  FEATURE_TYPE AttributeCreator_22_OUTPUT    OUTPUT { FEATURE_TYPE AttributeRemover_3_OUTPUT        @RemoveAttributes(fme_encoded,_citationDate_en,_citationDate_fr,_error_date,Address,Adresse,Ann<u00e9>e,City,Dataset_Name_EN,Dataset_Name_FR,Dataset_UUID,Keywords_EN,Keywords_FR,Latitude,Local<space>land<space>use,Longitude,Province,ProvinceFR,Refined<space>Topic,Report<space>year,Title_EN_prefix,Title_FR_prefix,Units,Unit<u00e9>,Ville,Address_EN,Address_FR,Classification<space>de<space>l<apos>industrie,Company<space>name,Desc_Emission_UNITS_EN,Desc_Emission_UNITS_FR,Desc_Location_EN,Desc_Location_FR,Desc_Static_EN,Desc_Static_FR,Desc_company_name_EN,Desc_company_name_FR,Desc_facility_name_EN,Desc_facility_name_FR,D<u00e9>tails<space>de<space>l<apos>installation,Emissions,Facility<space>ID,Facility<space>details,Facility<space>information,Facility<space>name,Facility_details_EN,Facility_details_FR,Facility_info_EN,Facility_info_FR,Facility_name_EN,Facility_name_FR,ID<space>de<space>l<apos>installation,ID_number_EN,ID_number_FR,Industry<space>classification,Industry<space>classification<space>link,Information<space>de<space>l<apos>installation,Lien<space>vers<space>la<space>classification<space>des<space>industries,NPRI<space>ID,Nom<space>de<space>l<apos>entreprise,Nom<space>de<space>l<apos>installation,Nom<space>de<space>la<space>soci<u00e9>t<u00e9>,Num<u00e9>ro<space>INRP,PostalCode,Title_Facility_Name_EN,Title_Facility_Name_FR,Total<space>emissions,Year_EN,Year_FR,Postal<space>code)        $(AttributeRemover_3_LIST_FUNC)         }
# -------------------------------------------------------------------------
INCLUDE [if { {ATTRIBUTES} == {ATTRIBUTES} } {                puts "MACRO FeatureMerger_REFERENCE_INFO ATTRIBUTES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {POLYGONS}} {                puts "MACRO FeatureMerger_REFERENCE_INFO GEOM_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {AGGREGATES}} {                puts "MACRO FeatureMerger_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO FeatureMerger_REFERENCE_INFO GEOM_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {POLYGONS}} {                puts "MACRO FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {AGGREGATES}} {                puts "MACRO FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} } {                puts "MACRO FeatureMerger_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} } {                puts "MACRO FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          else {}; ]
FACTORY_DEF {*} ReferenceFactory    FACTORY_NAME FeatureMerger    FLUSH_WHEN_GROUPS_CHANGE No    INPUT REFERENCER FEATURE_TYPE Tester_2_PASSED    INPUT REFERENCEE FEATURE_TYPE AttributeRemover_3_OUTPUT    REFERENCE_INFO $(FeatureMerger_REFERENCE_INFO)    REFERENCE_TABLE @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>Identifier.Artifact<closeparen>,FeatureMerger) @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>Identifier.Artifact<closeparen>,FeatureMerger) AUTO @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>Contributor<space>System<closeparen>,FeatureMerger) @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>Contributor<space>System<closeparen>,FeatureMerger) AUTO    ATTR_ACCUM_MODE "HANDLE_CONFLICT"    ATTR_CONFLICT_RES "SUPPLIER_IF_CONFLICT"    IGNORE_NULLS "No"    HANDLE_NULL_MISSING_KEYS_LIKE_FME2013 No    LIST_ATTRS_TO_INCLUDE { <Unused> }    LIST_ATTRS_TO_INCLUDE_MODE <Unused>    MERGE_ATTRIBUTES Yes    MANAGE_FME_TYPE Yes    MODE COMPLETE    PROCESS_DUPLICATE_REFERENCEES NO    REFERENCEES_FIRST No    REJECT_INVALID_GEOM YES    CLEANING_TOLERANCE <Unused>    OUTPUT COMPLETE FEATURE_TYPE FeatureMerger_MERGED    OUTPUT INCOMPLETE FEATURE_TYPE FeatureMerger_UNMERGED_REQUESTOR    OUTPUT UNREFERENCED FEATURE_TYPE FeatureMerger_UNUSED_SUPPLIER
