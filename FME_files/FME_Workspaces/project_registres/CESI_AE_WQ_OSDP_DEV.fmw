DEFAULT_MACRO WB_CURRENT_CONTEXT
MACRO VariableSetter_3_VAR DateStamp
INCLUDE [    if {{Global} == {Local}} {       puts {MACRO VariableSetter_3_VAR $(WB_CURRENT_CONTEXT)_DateStamp};    };    proc stripEvaluateExpression {val} {       if [regexp {@EvaluateExpression\([^)]*STRING_ENCODED,([^,]*),.+\)} $val -> unwrapped] {          return $unwrapped       } else {          return $val       };    };    set strippedValue [stripEvaluateExpression {@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_datetime<closeparen>,VariableSetter_3)}];    puts "MACRO VariableSetter_3_VALUE $strippedValue"; ]
