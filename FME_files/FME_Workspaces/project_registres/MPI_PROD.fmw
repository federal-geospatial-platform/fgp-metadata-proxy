# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "geometry.paths<opencurly><closecurly> geometry.paths<opencurly><closecurly>.array<opencurly><closecurly> geometry.paths<opencurly><closecurly>.array<opencurly><closecurly>.array<opencurly><closecurly>"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO AttributeRemover_5_LIST_FUNC }    } else {        puts "MACRO AttributeRemover_5_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME AttributeRemover_5    INPUT  FEATURE_TYPE AttributeCreator_17_OUTPUT    OUTPUT { FEATURE_TYPE AttributeRemover_5_OUTPUT        @RemoveAttributes(fme_encoded,Capital_Cost<openparen><dollar>M<closeparen>,Capital_Cost_EN,Capital_Cost_FR,Capital_Cost_Range<openparen><dollar>M<closeparen>,Clean_Technology_EN,Clean_Technology_FR,Clean_Technology_Type_EN,Clean_Technology_Type_FR,Company_Name,Cost_Formatted,Desc_CleanTechType_EN,Desc_CleanTechType_FR,Desc_CompName_EN,Desc_CompName_FR,Desc_Cost_EN,Desc_Cost_FR,Desc_ProjName_EN,Desc_ProjName_FR,Desc_Sector_EN,Desc_Sector_FR,Desc_SpecType_EN,Desc_SpecType_FR,Desc_Static_EN,Desc_Static_FR,Desc_Status_EN,Desc_Status_FR,Display_code,Location_EN,Location_FR,OBJECTID,Project_ID,Project_Name_EN,Project_Name_FR,Province,Province_EN,Province_FR,Sector_EN,Sector_FR,Specific_Type_EN,Specific_Type_FR,Status_EN,Status_FR,UNIQUE_ATT,UUID_generator,features,geometry.x,geometry.y,geometryType,id,latitude,longitude)        $(AttributeRemover_5_LIST_FUNC)         }
