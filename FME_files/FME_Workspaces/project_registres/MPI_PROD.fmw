FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME AttributeCreator_4    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE AttributeRounder_OUTPUT    MULTI_FEATURE_MODE NO    NULL_ATTR_MODE NO_OP     ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV     ATTR_ACTION { "" "longitude" "SET_TO" "<at>Value<openparen>_points<opencurly>0<closecurly>.x<closeparen>" }      ATTR_ACTION { "" "latitude" "SET_TO" "<at>Value<openparen>_points<opencurly>0<closecurly>.y<closeparen>" }      ATTR_ACTION { "" "Coverage.Geometry" "SET_TO" "POINT<openparen><at>Value<openparen>longitude<closeparen><space><at>Value<openparen>latitude<closeparen><closeparen>" }    OUTPUT OUTPUT FEATURE_TYPE AttributeCreator_4_OUTPUT
