DEFAULT_MACRO WB_CURRENT_CONTEXT
MACRO VariableRetriever_4_VAR DateLastUpdate
INCLUDE [if {{Global} == {Local}} {   puts {MACRO VariableRetriever_4_VAR $(WB_CURRENT_CONTEXT)_DateLastUpdate}; };
FACTORY_DEF * TeeFactory    FACTORY_NAME VariableRetriever_4    INPUT  FEATURE_TYPE FeatureMerger_3_MERGED    INPUT  FEATURE_TYPE FeatureMerger_3_UNUSED_SUPPLIER    OUTPUT FEATURE_TYPE VariableRetriever_4_OUTPUT        @GlobalVariable(fme_encoded,$(VariableRetriever_4_VAR),fme_result_attribute,_datelastupdate)
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME AttributeCreator_21    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE VariableRetriever_4_OUTPUT    MULTI_FEATURE_MODE NO    NULL_ATTR_MODE NO_OP     ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV     ATTR_ACTION { "" "Date.LastUpdate" "SET_TO" "<at>Value<openparen>_datelastupdate<closeparen>" }    OUTPUT OUTPUT FEATURE_TYPE AttributeCreator_21_OUTPUT
# -------------------------------------------------------------------------
FACTORY_DEF * SortFactory    FACTORY_NAME FeatureHolder    INPUT  FEATURE_TYPE AttributeCreator_19_OUTPUT    INPUT  FEATURE_TYPE AttributeCreator_21_OUTPUT    OUTPUT SORTED FEATURE_TYPE FeatureHolder_OUTPUT
# -------------------------------------------------------------------------
FACTORY_DEF {*} DuplicateRemoverFactory    FACTORY_NAME DuplicateFilter    COMMAND_PARM_EVALUATION SINGLE_PASS    SUPPORTS_FEATURE_TABLES    INPUT  FEATURE_TYPE FeatureHolder_OUTPUT    KEY_ATTRIBUTES { Identifier.Artifact }    INPUT_IS_ORDERED NO    PRESERVE_FEATURE_ORDER PER_OUTPUT_PORT    OUTPUT DUPLICATE FEATURE_TYPE DuplicateFilter_DUPLICATE    OUTPUT UNIQUE FEATURE_TYPE DuplicateFilter_UNIQUE
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF * TestFactory    FACTORY_NAME Terminator_5    INPUT  FEATURE_TYPE DuplicateFilter_DUPLICATE    TEST "$(_WB_BYPASS_TERMINATION)" == Yes    OUTPUT PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"Translation<space>Terminated<lf><lf>Doublons<space>UUID")       @SupplyAttributes(_wb_termination_xformer,"Terminator_5")       @SupplyAttributes(_wb_termination_feature,Yes)    OUTPUT FAILED FEATURE_TYPE * @Abort(ENCODED,"Translation<space>Terminated<lf><lf>Doublons<space>UUID")
# -------------------------------------------------------------------------
DEFAULT_MACRO WB_CURRENT_CONTEXT
MACRO VariableRetriever_2_VAR DateStamp
INCLUDE [if {{Global} == {Local}} {   puts {MACRO VariableRetriever_2_VAR $(WB_CURRENT_CONTEXT)_DateStamp}; };
FACTORY_DEF * TeeFactory    FACTORY_NAME VariableRetriever_2    INPUT  FEATURE_TYPE DuplicateFilter_UNIQUE    OUTPUT FEATURE_TYPE VariableRetriever_2_OUTPUT        @GlobalVariable(fme_encoded,$(VariableRetriever_2_VAR),fme_result_attribute,_datestamp)
# -------------------------------------------------------------------------
DEFAULT_MACRO WB_CURRENT_CONTEXT
MACRO VariableRetriever_3_VAR DateLastSync
INCLUDE [if {{Global} == {Local}} {   puts {MACRO VariableRetriever_3_VAR $(WB_CURRENT_CONTEXT)_DateLastSync}; };
FACTORY_DEF * TeeFactory    FACTORY_NAME VariableRetriever_3    INPUT  FEATURE_TYPE VariableRetriever_2_OUTPUT    OUTPUT FEATURE_TYPE VariableRetriever_3_OUTPUT        @GlobalVariable(fme_encoded,$(VariableRetriever_3_VAR),fme_result_attribute,RecordKeeper.LastSyncTS)
# -------------------------------------------------------------------------
