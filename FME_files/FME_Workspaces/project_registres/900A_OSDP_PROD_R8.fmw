Tcl2 proc $(Messages_WORKSPACE_NAME)_StringConcatenator_evaluator {} {    if {{SELECTED} == {OUTGOING}} {      set attr [FME_DecodeText {<Unused>}];      if {[string length $attr] == 0} { return; };      set attrs [list [FME_EncodeText $attr]];    } else {      set attrAll {_json_message};      if {[string length $attrAll] == 0} { return; };      set attrs [split {_json_message} { }];    };    set parmList {{EvaluateExpression} {ATTR_CREATE_EXPR_PROPOGATE_MISSING_FDIV}};    foreach attr $attrs {     lappend parmList $attr;     lappend parmList {"<opencurly><quote>MessageList<quote><space>:<space><openbracket><at>Value<openparen>_json_message<closeparen><closebracket><closecurly>"};    };    lappend parmList {$(Messages_WORKSPACE_NAME)_StringConcatenator};    eval FME_Execute $parmList; }
