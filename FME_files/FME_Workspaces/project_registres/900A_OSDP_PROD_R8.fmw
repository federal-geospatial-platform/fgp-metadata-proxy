FACTORY_DEF * TeeFactory   FACTORY_NAME "UNIQUE_ID_CREATOR INPUT Input Collector"   INPUT FEATURE_TYPE Tester_FAILED   OUTPUT FEATURE_TYPE UNIQUE_ID_CREATOR_INPUT
MACRO UNIQUE_ID_CREATOR_WORKSPACE_NAME UNIQUE_ID_CREATOR
MACRO $(UNIQUE_ID_CREATOR_WORKSPACE_NAME)_XFORMER_NAME UNIQUE_ID_CREATOR
MACRO $(UNIQUE_ID_CREATOR_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(UNIQUE_ID_CREATOR_WORKSPACE_NAME)___COMPOUND_PARAMETERS 
MACRO $(UNIQUE_ID_CREATOR_WORKSPACE_NAME)_UNIQUE_ATT @Value(900A_UUID_string)
INCLUDE_CUSTOM_TRANSFORMER_VER UNIQUE_ID_CREATOR:1
FACTORY_DEF * TeeFactory   FACTORY_NAME "UNIQUE_ID_CREATOR OUTPUT Output Renamer/Nuker"   INPUT FEATURE_TYPE UNIQUE_ID_CREATOR_OUTPUT   OUTPUT FEATURE_TYPE UNIQUE_ID_CREATOR_OUTPUT
