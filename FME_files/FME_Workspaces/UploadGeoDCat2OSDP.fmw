FACTORY_DEF {*} PythonFactory    FACTORY_NAME { PythonCaller }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT  FEATURE_TYPE AttributeCreator_2_OUTPUT    INPUT  FEATURE_TYPE AttributeCreator_4_OUTPUT    SYMBOL_NAME { decryptSecret }    SOURCE_CODE { import<space>fme<lf>import<space>fmeobjects<lf>import<space>os<lf>import<space>sys<lf><lf>def<space>getWorkingEnvironment<openparen><closeparen>:<lf><space><space><space><space>engineName<space>=<space>os.environ<openbracket><apos>COMPUTERNAME<apos><closebracket><lf><space><space><space><space>env<space>=<space>engineName<openbracket>:3<closebracket>.upper<openparen><closeparen><lf><space><space><space><space>#logMessage<openparen><apos><gt><gt><gt><space>env<space>=<space><apos>+env<closeparen><lf><lf><space><space><space><space>from<space>DDR.Registry<space>import<space>EnvironmentSelector<lf><space><space><space><space>try:<lf><space><space><space><space><space><space><space><space>workingEnvironment<space>=<space>EnvironmentSelector<openbracket>env<closebracket><lf><space><space><space><space>except<space>Exception<space>as<space>ex:<lf><space><space><space><space><space><space><space><space>workingEnvironment<space>=<space><apos>LOCAL<apos><lf><space><space><space><space>return<space>workingEnvironment<lf><lf><lf>def<space>decryptSecret<openparen>feature<comma><space>parameterReceived<space>=<space>None<closeparen>:<lf><lf><space><space><space><space>import<space>boto3<lf><lf><space><space><space><space><lf><lf><space><space><space><space>def<space>getSecret<openparen>feature<comma><space>secret_name<comma><space>region_name<closeparen>:<lf><space><space><space><space><space><space><space><space>session<space>=<space>boto3.session.Session<openparen><closeparen><lf><space><space><space><space><space><space><space><space>client<space>=<space>session.client<openparen><lf><space><space><space><space><space><space><space><space><space><space><space><space>service_name=<apos>secretsmanager<apos><comma><lf><space><space><space><space><space><space><space><space><space><space><space><space>region_name=region_name<comma><lf><space><space><space><space><space><space><space><space><closeparen><lf><space><space><space><space><space><space><space><space>get_secret_value_response<space>=<space>client.get_secret_value<openparen><lf><space><space><space><space><space><space><space><space><space><space><space><space>SecretId=secret_name<lf><space><space><space><space><space><space><space><space><closeparen><lf><space><space><space><space><space><space><space><space>return<space>get_secret_value_response<lf><lf><space><space><space><space>def<space>simpleDecrypt<openparen>feature<comma><space>parameterReceived<closeparen>:<lf><space><space><space><space><space><space><space><space>inputAttribute<space>=<space>eval<openparen>parameterReceived<openbracket><apos>inputAttribute<apos><closebracket><closeparen><lf><space><space><space><space><space><space><space><space>outputAttribute<space>=<space>parameterReceived<openbracket><apos>outputAttribute<apos><closebracket><lf><space><space><space><space><space><space><space><space>secret_name<space>=<space><quote><solidus><quote>+getWorkingEnvironment<openparen><closeparen>.lower<openparen><closeparen>+<quote><solidus><quote>+inputAttribute<openbracket><apos>name<apos><closebracket><lf><space><space><space><space><space><space><space><space>region_name<space>=<space>inputAttribute<openbracket><apos>region<apos><closebracket><lf><space><space><space><space><space><space><space><space>get_secret_value_response<space>=<space>getSecret<openparen>feature<comma><space>secret_name<comma><space>region_name<closeparen><lf><space><space><space><space><space><space><space><space>if<space><apos>SecretString<apos><space>in<space>get_secret_value_response:<lf><space><space><space><space><space><space><space><space><space><space><space><space>text_secret_data<space>=<space>get_secret_value_response<openbracket><apos>SecretString<apos><closebracket><lf><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen>outputAttribute<comma><space>text_secret_data<closeparen><lf><lf><space><space><space><space>if<space>parameterReceived<space>is<space>None:<lf><space><space><space><space><space><space><space><space>try:<lf><space><space><space><space><space><space><space><space><space><space><space><space>inputParameter<space>=<space>eval<openparen>feature.getAttribute<openparen><apos>_Execution_Parameters<apos><closeparen>.replace<openparen><apos><backslash>n<apos><comma><space><apos><apos><closeparen><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space>key_list<space>=<space>inputParameter<openbracket><apos>key_list<apos><closebracket><lf><space><space><space><space><space><space><space><space><space><space><space><space>secret_name<space>=<space><quote><solidus><quote>+getWorkingEnvironment<openparen><closeparen>.lower<openparen><closeparen>+<quote><solidus><quote>+feature.getAttribute<openparen>inputParameter<openbracket><apos>name<apos><closebracket><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space>region_name<space>=<space>feature.getAttribute<openparen>inputParameter<openbracket><apos>region<apos><closebracket><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space>get_secret_value_response<space>=<space>getSecret<openparen>feature<comma><space>secret_name<comma><space>region_name<closeparen><lf><lf><space><space><space><space><space><space><space><space><space><space><space><space>if<space><apos>SecretString<apos><space>in<space>get_secret_value_response:<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>text_secret_data<space>=<space>eval<openparen>get_secret_value_response<openbracket><apos>SecretString<apos><closebracket><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>for<space>key<space>in<space>key_list:<lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>#logMessage<openparen><apos><gt><gt><gt><space><apos>+key<openbracket><quote>outputAttribute<quote><closebracket>+<apos><space>=<space><apos>+text_secret_data<openbracket>key<openbracket><quote>inputAttribute<quote><closebracket><closebracket><closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen>key<openbracket><quote>outputAttribute<quote><closebracket><comma><space>text_secret_data<openbracket>key<openbracket><quote>inputAttribute<quote><closebracket><closebracket><closeparen><lf><lf><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><quote>Execution.status<quote><comma><space>0<closeparen><lf><lf><space><space><space><space><space><space><space><space>except:<lf><space><space><space><space><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><quote>Execution.status<quote><comma><space>1<closeparen><lf><space><space><space><space><space><space><space><space><lf><space><space><space><space>else:<lf><space><space><space><space><space><space><space><space>simpleDecrypt<openparen>feature<comma><space>parameterReceived<closeparen> }    PY_OUTPUT_TAGS { PYOUTPUT <Rejected> }    OUTPUT { PYOUTPUT FEATURE_TYPE PythonCaller_OUTPUT         }    OUTPUT { <Rejected> FEATURE_TYPE PythonCaller_<Rejected>         }
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF * TeeFactory FACTORY_NAME PythonCaller_<Rejected> INPUT FEATURE_TYPE PythonCaller_<Rejected>  NO_LOGGING   OUTPUT FAILED FEATURE_TYPE * @Abort(ENCODED, PythonCaller<space>output<space>a<space><lt>Rejected<gt><space>feature.<space><space>To<space>continue<space>translation<space>when<space>features<space>are<space>rejected<comma><space>change<space><apos>Workspace<space>Parameters<apos><space><gt><space>Translation<space><gt><space><apos>Rejected<space>Feature<space>Handling<apos><space>to<space><apos>Continue<space>Translation<apos>)
