FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { AttributeCreator_3 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE FeatureReader_PATH    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "destination_path" "SET_TO" "Project<solidus>Request<solidus><at>Value<openparen>path_filename<closeparen>" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "source_file" "SET_TO" "<at>Value<openparen>path_windows<closeparen>" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "_Execution_Parameters" "SET_TO" "<opencurly><lf><apos>iam_role<apos>:<apos>S3_file_upload.iam_role<apos><comma><lf><apos>ftp_path<apos>:<apos>destination_path<apos><comma><lf><apos>fme_server_path<apos>:<apos>source_file<apos><comma><lf><apos>s3_ftp_bucket<apos>:<apos>s3_ftp_bucket<apos><comma><lf><apos>bucket_owner_id<apos>:<apos>S3_file_upload.bucket_owner_id<apos><lf><closecurly>" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE AttributeCreator_3_OUTPUT        }
