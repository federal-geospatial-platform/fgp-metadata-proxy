INCLUDE PYTHON
def ParamFunc():
  import fme

  return FME_MacroValues['FME_MF_NAME'].split('_')[0]
value = ParamFunc()
macroName = 'P-T_ABBR'
if value == None:
  return { macroName : u'' }
else:
  import six
  try:
    value = six.text_type(value)
  except UnicodeDecodeError:
    value = six.text_type(value, 'utf-8')
  return { macroName : value }
END_INCLUDE
DEFAULT_MACRO FME_SHAREDRESOURCE_DATA C:\Data

