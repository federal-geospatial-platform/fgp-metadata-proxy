#! <SUBDOCUMENTS>
#! <SUBDOCUMENT
#!   NAME="MV_CATALOGUE_READER"
#!   ARCGIS_COMPATIBILITY=""
#!   CATEGORY="FGP Tools"
#!   DESCRIPTION="&lt;p&gt;&lt;strong&gt;Description&lt;/strong&gt;&lt;/p&gt;&#10;&lt;p&gt;This Custom Transformer is used to read the metadata of the NewFoundLand &amp;amp; Labrador open data portal.  The portal is not offering a public APi to access the metdata information so, this custom transformer is reading all the XHTML code and flatten it in order to parse it and extract the needed metadata information.  The metadata extraction is done is two passes. The first passes to extrat the name and the url of each dataset.  A second pass is done to read the complete set of  metadata of each url (one url per dataset).&lt;/p&gt;&#10;&lt;p&gt;Note: There is no option to read only one record with a specific identifier.&lt;/p&gt;&#10;&lt;p&gt;&lt;strong&gt;Input Ports&lt;/strong&gt;&lt;/p&gt;&#10;&lt;ul&gt;&#10;&lt;li&gt;Input: One feature to start the extraction of all the records from the NewFoundLand &amp;amp; Labrador open data portal.&lt;/li&gt;&#10;&lt;/ul&gt;&#10;&lt;p&gt;&lt;strong&gt;Output Ports&lt;/strong&gt;&lt;/p&gt;&#10;&lt;ul&gt;&#10;&lt;li&gt;Résultats: All the records read from the NewFoundLand &amp;amp; Labrador open data portal&lt;/li&gt;&#10;&lt;/ul&gt;&#10;&lt;p&gt;&lt;strong&gt;Parameters&lt;/strong&gt;&lt;/p&gt;&#10;&lt;ul&gt;&#10;&lt;li&gt;URL_ROOT: URL of the  NewFoundLand &amp;amp; Labrador open data portal.&lt;/li&gt;&#10;&lt;li&gt;URL_DATASET_GEO: URL prefix of the metadata of the geospatial datasets.&lt;/li&gt;&#10;&lt;li&gt;URL_DATASET_NON_GEO: URL prefix of the metadata of the non geospatial datasets.&lt;/li&gt;&#10;&lt;/ul&gt;"
#!   DOC_DYNAMIC_INPUT_ATTRS="0"
#!   DOC_EXTENTS="7667.18 2500.03"
#!   DOC_TOP_LEFT="-3390.63 -1558.18"
#!   FME_DOCUMENT_GUID="af5f6371-c338-4713-868e-ee7669f853a7"
#!   FME_DOCUMENT_PRIORGUID="5d256c39-6da6-4c16-a2a9-d665968633c7"
#!   FME_NAMES_ENCODING="UTF-8"
#!   FME_PROCESS_COUNT="NO_PARALLELISM"
#!   FME_PROCESS_GROUPS_ORDERED="No"
#!   FME_PROCESS_GROUP_BY=""
#!   FME_PROCESS_PRESERVE_GROUP_ATTR="No"
#!   FMX_ATTRIBUTE_PROPOGATION_MODE="AUTO"
#!   GUID="af5f6371-c338-4713-868e-ee7669f853a7"
#!   HISTORY="20&lt;solidus&gt;05&lt;solidus&gt;2022,Daniel&lt;space&gt;Pilon,Version&lt;space&gt;"
#!   IS_VISIBLE="true"
#!   LAST_SAVE_BUILD="FME(R) 2020.0.0.0 (20200309 - Build 20200 - WIN32)"
#!   LAST_SAVE_DATE="2022-05-26T10:58:47"
#!   MARKDOWN_DESCRIPTION="**Description**&#10;&#10;This Custom Transformer is used to read the metadata of the NewFoundLand &amp; Labrador open data portal.  The portal is not offering a public APi to access the metdata information so, this custom transformer is reading all the XHTML code and flatten it in order to parse it and extract the needed metadata information.  The metadata extraction is done is two passes. The first passes to extrat the name and the url of each dataset.  A second pass is done to read the complete set of  metadata of each url (one url per dataset).&#10;&#10;Note: There is no option to read only one record with a specific identifier.&#10;&#10;**Input Ports**&#10;&#10;  - Input: One feature to start the extraction of all the records from the NewFoundLand &amp; Labrador open data portal.&#10;&#10;**Output Ports**&#10;&#10;  - Résultats: All the records read from the NewFoundLand &amp; Labrador open data portal&#10;&#10;**Parameters**&#10; &#10;  - URL_ROOT: URL of the  NewFoundLand &amp; Labrador open data portal.&#10;  - URL_DATASET_GEO: URL prefix of the metadata of the geospatial datasets.&#10;  - URL_DATASET_NON_GEO: URL prefix of the metadata of the non geospatial datasets."
#!   MARKDOWN_USAGE=""
#!   PYTHON_COMPATIBILITY=""
#!   REPLACED_BY=""
