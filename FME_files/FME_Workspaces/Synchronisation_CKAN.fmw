FACTORY_DEF {*} DateTimeConverterFactory    FACTORY_NAME { DateTimeConverter_2 }    DATETIME_ATTR { "local_date server_date" }    IN_FORMAT { "" }    OUT_FORMAT { "%Y%m%d%H%M%S" }    REPAIR_INPUT { "YES" }    PASSTHROUGH { "NO" }    INPUT  FEATURE_TYPE FeatureMerger_MERGED    OUTPUT { OUTPUT FEATURE_TYPE DateTimeConverter_2_OUTPUT        }    OUTPUT { REJECTED FEATURE_TYPE DateTimeConverter_2_<REJECTED>        }
