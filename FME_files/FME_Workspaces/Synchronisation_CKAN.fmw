FACTORY_DEF {*} AttributeKeeperFactory    FACTORY_NAME { AttributeKeeper_6 }    INPUT  FEATURE_TYPE StringReplacer_OUTPUT    KEEP_ATTRS { id,local_date,path_to_file,ckan_root,ckan_key }    KEEP_LISTS {  }    KEEP_FME_ATTRIBUTES Yes    BUILD_FEATURE_TABLES { NO }    OUTPUT_ON_ATTRIBUTE_CHANGE { <Unused> }    OUTPUT { OUTPUT FEATURE_TYPE AttributeKeeper_6_OUTPUT        }
