MACRO $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_FEATURE_TYPE Default_$(P-T_ABBR)
MACRO $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_CSV_PATH $(IN_CSV_LOOKUP_TABLES_DIR)
MACRO $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_PT $(P-T_ABBR$encode)
MACRO $(LOOKUP_TABLES_READER_NG_WORKSPACE_NAME)_CSV_ENCODING utf-8
