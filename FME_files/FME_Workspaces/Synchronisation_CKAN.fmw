FACTORY_DEF * TeeFactory   FACTORY_NAME "LOOKUP_TABLES_READER_NG Output Output Renamer/Nuker"   INPUT FEATURE_TYPE LOOKUP_TABLES_READER_NG_Output   OUTPUT FEATURE_TYPE LOOKUP_TABLES_READER_NG_Output
