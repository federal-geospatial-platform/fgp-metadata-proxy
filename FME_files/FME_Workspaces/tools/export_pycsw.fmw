# -------------------------------------------------------------------------
FACTORY_DEF {*} XFMapFactory    FACTORY_NAME { XMLFlattener }    INPUT  FEATURE_TYPE XMLFragmenter_FRAGMENTS    XML_STREAM { "xml_fragment"    }    XFMAP_FEATURE_PATHS_EXPRESSION { "gmd:fileIdentifier" }    XFMAP_FEATURE_PATHS_STRUCTURE { "<lt>structure<space><space><lf>separator=<quote>.<quote><space><lf>map-empty-elements=<quote>yes<quote><space><lf>matched-prefix=<quote>attributes<quote><space><lf>matched-attributes=<quote>yes<quote><space><lf>cardinality=<quote>+<opencurly>?<closecurly><quote><lf>except-expression=<quote><quote><lf>structure-prefix=<quote><quote><lf>child-position-attribute=<quote><quote><lf>attribute-identifier=<quote><quote><lf>ui-mode=<quote>basic<quote><solidus><gt>" }    IGNORE_DATASET_EXTERNAL_DTD { No }    DISABLE_EXTERNAL_ENTITY_PROCESSING { Yes }    ENTITY_RESOLVER { Yes }    OUTPUT_ONE_FEATURE_PER_INPUT yes    OUTPUT { MAPPED FEATURE_TYPE XMLFlattener_OUTPUT       }    OUTPUT { INVALID FEATURE_TYPE XMLFlattener_<REJECTED>        }
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF * TeeFactory FACTORY_NAME XMLFlattener_<Rejected> INPUT FEATURE_TYPE XMLFlattener_<REJECTED>  NO_LOGGING   OUTPUT FAILED FEATURE_TYPE * @Abort(ENCODED, XMLFlattener<space>output<space>a<space><lt>Rejected<gt><space>feature.<space><space>To<space>continue<space>translation<space>when<space>features<space>are<space>rejected<comma><space>change<space><apos>Workspace<space>Parameters<apos><space><gt><space>Translation<space><gt><space><apos>Rejected<space>Feature<space>Handling<apos><space>to<space><apos>Continue<space>Translation<apos>)
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { AttributeExposer }    INPUT  FEATURE_TYPE XMLFlattener_OUTPUT    OUTPUT { FEATURE_TYPE AttributeExposer_OUTPUT          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} StringValueFactory    FACTORY_NAME { AttributeSplitter }    INPUT  FEATURE_TYPE AttributeExposer_OUTPUT    FACTORY_MODE ATTRIBUTE_SPLITTER    ATTR_NAME { xml_fragment }       DELIMITER { <lt>gmd:fileIdentifier<gt> }       FIELD_QUALIFIER { "" }       TRIM_TYPE { BOTH }       LIST_NAME { _list }       DROP_EMPTY_PARTS { NO }    OUTPUT { OUTPUT FEATURE_TYPE AttributeSplitter_OUTPUT          }
