#!     <XFORM_PARM PARM_NAME="ATTR_TABLE" PARM_VALUE="&quot;&quot; filename SET_TO &lt;at&gt;Value&lt;openparen&gt;_list&lt;opencurly&gt;1&lt;closecurly&gt;&lt;closeparen&gt; varchar&lt;openparen&gt;200&lt;closeparen&gt;  url SET_TO $(ENV)&lt;solidus&gt;fmerest&lt;solidus&gt;v3&lt;solidus&gt;repositories&lt;solidus&gt;PT_Harvester&lt;solidus&gt;items varchar&lt;openparen&gt;200&lt;closeparen&gt;  _shared_customs SET_TO &lt;at&gt;LowerCase&lt;openparen&gt;$(SHARED_CUSTOMS)&lt;closeparen&gt; varchar&lt;openparen&gt;200&lt;closeparen&gt;  filename_lower SET_TO &lt;at&gt;LowerCase&lt;openparen&gt;&lt;at&gt;Value&lt;openparen&gt;_list&lt;opencurly&gt;1&lt;closecurly&gt;&lt;closeparen&gt;&lt;closeparen&gt; varchar&lt;openparen&gt;200&lt;closeparen&gt;"/>
