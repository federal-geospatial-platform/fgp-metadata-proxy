# Combine the two "file path attribute" parameters into one value.
DEFAULT_MACRO HTTPCaller_7_FILE_PATH_ATTR
INCLUDE [ 	if { {<Unused>} == {<Unused>} } { 		puts {MACRO HTTPCaller_7_FILE_PATH_ATTR "<Unused>"}; 	} else { 		puts {MACRO HTTPCaller_7_FILE_PATH_ATTR "<Unused>"}; 	} ]
