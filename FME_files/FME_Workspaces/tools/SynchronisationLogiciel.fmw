# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {ListSearcher_2_cd370ac0_920d_49fd_a34c_6ceee7c10a9337} ]
# most of this is close to the code from listindexer but not exact beucase
# we have a type LIST_ATTR rather than type LIST_NAME so need
# to figure out the list name
Tcl2 proc $(FME_UUID_SAFE)_indexer {index prefix} {    set fullListAttrName [FME_DecodeText _shared_customs<opencurly><closecurly>];    set lastBrace [string last  \"{}\" $fullListAttrName];    set listAttr [string range $fullListAttrName 0 [expr $lastBrace+1]];    regsub \"{}\" $listAttr \"{$index}\" listWithIndex;    regsub \"{}\" $listAttr {} listBase;    set complexListExp "$listWithIndex\.";    set prefixLength [expr [string length $complexListExp]-1];    set prefix [FME_DecodeText $prefix];    foreach attr [FME_AttributeNames] {      set newAttr {};      if {$attr == $listWithIndex} {        set newAttr $listBase;      } elseif {[string first $complexListExp $attr] == 0} {        set newAttr [string replace $attr 0 $prefixLength];      };      if {$newAttr != {}} {          if {$prefix != {} } {            set newAttr $prefix$newAttr;          };          if {[string first {fme_} $newAttr] != 0} {              set first [string first {fme_} $newAttr];              lappend attrsToCopy $newAttr $attr;          };      };    };    if {[info exists attrsToCopy] && [llength $attrsToCopy] > 0} {      eval FME_Execute CopyAttributes $attrsToCopy;    }; }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { ListSearcher_2 }    INPUT  FEATURE_TYPE AttributeSplitter_2_OUTPUT    OUTPUT { FEATURE_TYPE ListSearcher_2__IndexedFeatures___         "$(FME_UUID_SAFE)" @SearchList(fme_encoded,"_shared_customs<opencurly><closecurly>","@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>filename_lower<closeparen>,ListSearcher_2)",FIRST_MATCHED_ENCODED,CASE_SENSITIVE) }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { ListSearcher_2__Tester }    INPUT { FEATURE_TYPE ListSearcher_2__IndexedFeatures___ }    TEST { @Value($(FME_UUID_SAFE)) == "-1" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE  ListSearcher_2_NOT_FOUND @RemoveAttributes($(FME_UUID_SAFE)) }    OUTPUT { FAILED FEATURE_TYPE  ListSearcher_2__IndexFound__  }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { ListSearcher_2__Tester2 }    INPUT { FEATURE_TYPE ListSearcher_2__IndexFound__ }    TEST { NO == "NO" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE ListSearcher_2_FOUND @CopyAttributes(_list_index, $(FME_UUID_SAFE)) @RemoveAttributes($(FME_UUID_SAFE)) }    OUTPUT { FAILED FEATURE_TYPE ListSearcher_2_FOUND  @Tcl2("$(FME_UUID_SAFE)_indexer {@Value($(FME_UUID_SAFE))} {<Unused>}") @CopyAttributes(_list_index, $(FME_UUID_SAFE)) @RemoveAttributes($(FME_UUID_SAFE)) }
