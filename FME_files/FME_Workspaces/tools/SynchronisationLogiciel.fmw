th<closeparen>,TestFilter_3) ENDS_WITH .fmw ENCODED } CASE_INSENSITIVE_TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>path<closeparen>,TestFilter_3) NOT_CONTAINS tools ENCODED } BOOLEAN_OPERATOR AND COMPOSITE_TEST_EXPR "1 AND 2 AND 3" OUTPUT PASSED_3 FEATURE_TYPE TestFilter_3_Workspace TEST_GROUP CASE_INSENSITIVE_TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>path<closeparen>,TestFilter_3) BEGINS_WITH XML_TEMPLATES<solidus> ENCODED } CASE_INSENSITIVE_TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>path<closeparen>,TestFilter_3) ENDS_WITH .xml ENCODED } CASE_INSENSITIVE_TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>path<closeparen>,TestFilter_3) BEGINS_WITH JSON_TEMPLATES<solidus> ENCODED } CASE_INSENSITIVE_TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>path<closeparen>,TestFilter_3) ENDS_WITH .json ENCODED } BOOLEAN_OPERATOR COMPOSITE COMPOSITE_TEST_EXPR "( 1 AND 2 ) OR ( 3 AND 4 )" OUTPUT PASSED_4 FEATURE_TYPE TestFilter_3_Templates<space>XML<solidus>JSON OUTPUT FAILED FEATURE_TYPE TestFilter_3_<lt>UNFILTERED<gt>
