FACTORY_DEF {*} TestFactory FACTORY_NAME { TestFilter_5 } INPUT FEATURE_TYPE TestFilter_5_INPUTLINE FEATURE_TABLE_SHIM_SUPPORT Yes PASSED_TEST_GROUP_OUTPUT FIRST TEST_GROUP CASE_INSENSITIVE_TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>path<closeparen>,TestFilter_5) BEGINS_WITH FME_Custom_Transformers<solidus> ENCODED } CASE_INSENSITIVE_TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>path<closeparen>,TestFilter_5) ENDS_WITH .fmx ENCODED } BOOLEAN_OPERATOR AND COMPOSITE_TEST_EXPR "1 AND 2" OUTPUT PASSED_0 FEATURE_TYPE TestFilter_5_Custom TEST_GROUP CASE_INSENSITIVE_TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>path<closeparen>,TestFilter_5) BEGINS_WITH FME_Custom_Transformers<solidus>Python ENCODED } CASE_INSENSITIVE_TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>path<closeparen>,TestFilter_5) ENDS_WITH .py ENCODED } CASE_INSENSITIVE_TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>path<closeparen>,TestFilter_5) NOT_CONTAINS __init__.py ENCODED } BOOLEAN_OPERATOR AND COMPOSITE_TEST_EXPR "1 AND 2 AND 3" OUTPUT PASSED_1 FEATURE_TYPE TestFilter_5_Python TEST_GROUP CASE_INSENSITIVE_TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>path<closeparen>,TestFilter_5) BEGINS_WITH LOOKUP_TABLES<solidus> ENCODED } CASE_INSENSITIVE_TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>path<closeparen>,TestFilter_5) ENDS_WITH .csv ENCODED } CASE_INSENSITIVE_TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>path<closeparen>,TestFilter_5) ENDS_WITH .yaml ENCODED } BOOLEAN_OPERATOR COMPOSITE COMPOSITE_TEST_EXPR "1 AND ( 2 OR 3 )" OUTPUT PASSED_2 FEATURE_TYPE TestFilter_5_csv<solidus>yaml TEST_GROUP CASE_INSENSITIVE_TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>path<closeparen>,TestFilter_5) BEGINS_WITH FME_Workspaces<solidus> ENCODED } CASE_INSENSITIVE_TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>path<closeparen>,TestFilter_5) ENDS_WITH .fmw ENCODED } CASE_INSENSITIVE_TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>path<closeparen>,TestFilter_5) NOT_CONTAINS tools ENCODED } BOOLEAN_OPERATOR AND COMPOSITE_TEST_EXPR "1 AND 2 AND 3" OUTPUT PASSED_3 FEATURE_TYPE TestFilter_5_Workspace TEST_GROUP CASE_INSENSITIVE_TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>path<closeparen>,TestFilter_5) BEGINS_WITH XML_TEMPLATES<solidus> ENCODED } CASE_INSENSITIVE_TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>path<closeparen>,TestFilter_5) ENDS_WITH .xml ENCODED } CASE_INSENSITIVE_TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>path<closeparen>,TestFilter_5) BEGINS_WITH JSON_TEMPLATES<solidus> ENCODED } CASE_INSENSITIVE_TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>path<closeparen>,TestFilter_5) ENDS_WITH .json ENCODED } BOOLEAN_OPERATOR COMPOSITE COMPOSITE_TEST_EXPR "( 1 AND 2 ) OR ( 3 AND 4 )" OUTPUT PASSED_4 FEATURE_TYPE TestFilter_5_Templates<space>XML<solidus>JSON OUTPUT FAILED FEATURE_TYPE TestFilter_5_<lt>UNFILTERED<gt>
