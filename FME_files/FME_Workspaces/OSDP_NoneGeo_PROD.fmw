j<closeparen><closeparen><closeparen><lf><lf><space><space><space><space><space><space><space><space>#resource.ServiceProtocol<lf><space><space><space><space><space><space><space><space>url<space>=<space>feature.getAttribute<openparen><apos>resources<opencurly>%i<closecurly>.url<apos>%<openparen>j<closeparen><closeparen><lf><space><space><space><space><space><space><space><space>ServiceProtocol<space>=<space>urlparse<openparen>url<closeparen>.scheme.upper<openparen><closeparen><space><space>#get<space>protocol<space>of<space>url<lf><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space>if<space>ServiceProtocol<space>in<space><openbracket><apos>HTTP<apos><comma><apos>HTTPS<apos><comma><apos>FTP<apos><closebracket>:<lf><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>Resource<opencurly>%i<closecurly>.ServiceProtocol<apos>%<openparen>j<closeparen><comma>ServiceProtocol<closeparen><lf><space><space><space><space><space><space><space><space>elif<space>ServiceProtocol<space>in<space><openbracket><apos>AMQP<apos><comma><apos>AMQPS<apos><closebracket>:<lf><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>Resource<opencurly>%i<closecurly>.ServiceProtocol<apos>%<openparen>j<closeparen><comma><apos>OASIS:AMQP<apos><closeparen><lf><space><space><space><space><space><space><space><space>else:<lf><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>Resource<opencurly>%i<closecurly>.ServiceProtocol<apos>%<openparen>j<closeparen><comma><apos>HTTPS<apos><closeparen><space>#if<space>the<space>protocol<space>is<space>neither<space>HTTP<comma><space>HTTPS<comma><space>FTP<comma><space>AMQP<space>or<space>AMQPS<comma><space>default<space>value<space>of<space><apos>HTTPS<apos><space>is<space>added<lf><lf><space><space><space><space><space><space><space><space>#resource.language<space><lf><space><space><space><space><space><space><space><space>#Produit<space>une<space>liste<space>ou<space>non<space>....<space>Voir<space>le<space>code<space>subs<u00e9>quent<lf><space><space><space><space><space><space><space><space>language=feature.getAttribute<openparen><apos>resources<opencurly>%i<closecurly>.language<apos>%<openparen>j<closeparen><closeparen><lf><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space>#Pour<space>Yukon<comma><space>la<space>langue<space>est<space>pas<space>en<space>liste<space>donc<space>on<space>doit<space>la<space>mettre<space>en<space>liste.<lf><space><space><space><space><space><space><space><space>if<space>type<openparen>language<closeparen><space>is<space>list:<lf><space><space><space><space><space><space><space><space><space><space><space><space>pass<lf><space><space><space><space><space><space><space><space>else:<lf><space><space><space><space><space><space><space><space><space><space><space><space>language=<openbracket>language<closebracket><lf><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space><lf><lf><space><space><space><space><space><space><space><space>if<space><apos>en<apos><space>in<space>language<space>and<space><apos>fr<apos><space>in<space>language:<lf><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>Resource<opencurly>%i<closecurly>.Language<apos>%<openparen>j<closeparen><comma><apos>eng<semicolon><space>fre<apos><closeparen><lf><space><space><space><space><space><space><space><space>elif<space><apos>en<apos><space>in<space>language<space>and<space><apos>fr<apos><space>not<space>in<space>language:<lf><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>Resource<opencurly>%i<closecurly>.Language<apos>%<openparen>j<closeparen><comma><apos>eng<apos><closeparen><lf><space><space><space><space><space><space><space><space>elif<space><apos>fr<apos><space>in<space>language<space>and<space><apos>en<apos><space>not<space>in<space>language:<lf><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>Resource<opencurly>%i<closecurly>.Language<apos>%<openparen>j<closeparen><comma><apos>fre<apos><closeparen><space><space><space><space><space><lf><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space>#resource.name<lf><space><space><space><space><space><space><space><space>name_en<space>=<space>feature.getAttribute<openparen><apos>resources<opencurly>%i<closecurly>.name_translated.en<apos>%<openparen>j<closeparen><closeparen><lf><space><space><space><space><space><space><space><space>name_fr<space>=<space>feature.getAttribute<openparen><apos>resources<opencurly>%i<closecurly>.name_translated.fr<apos>%<openparen>j<closeparen><closeparen><lf><space><space><space><space><space><space><space><space>name_en_t_fr<space>=<space>feature.getAttribute<openparen><apos>resources<opencurly>%i<closecurly>.name_translated.en-t-fr<apos>%<openparen>j<closeparen><closeparen><lf><space><space><space><space><space><space><space><space>name_fr_t_en<space>=<space>feature.getAttribute<openparen><apos>resources<opencurly>%i<closecurly>.name_translated.fr-t-en<apos>%<openparen>j<closeparen><closeparen><space><space><lf><space><space><space><space><space><space><space><space>#name_en<lf><space><space><space><space><space><space><space><space>if<space>name_en<space>is<space>None:<lf><space><space><space><space><space><space><space><space><space><space><space>name_en<space>=<space>name_en_t_fr<lf><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>Resource<opencurly>%i<closecurly>.Name<space><openparen>EN<closeparen><apos>%<openparen>j<closeparen><comma>name_en<closeparen><lf><space><space><space><space><space><space><space><space>#name_fr<lf><space><space><space><space><space><space><space><space>if<space>name_fr<space>is<space>None:<lf><space><space><space><space><space><space><space><space><space><space><space>name_fr<space>=<space>name_fr_t_en<lf><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>Resource<opencurly>%i<closecurly>.Name<space><openparen>FR<closeparen><apos>%<openparen>j<closeparen><comma>name_fr<closeparen><lf><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space>#resource.url<lf><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>Resource<opencurly>%i<closecurly>.URL<space><openparen>EN<closeparen><apos>%<openparen>j<closeparen><comma>url<closeparen><lf><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>Resource<opencurly>%i<closecurly>.URL<space><openparen>FR<closeparen><apos>%<openparen>j<closeparen><comma>url<closeparen><lf><lf><lf><space><space><space><space><lf><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space><lf><lf><lf> }    PY_OUTPUT_TAGS { PYOUTPUT <Rejected> }    OUTPUT { PYOUTPUT FEATURE_TYPE PythonCaller_7_OUTPUT         }    OUTPUT { <Rejected> FEATURE_TYPE PythonCaller_7_<Rejected>         }
