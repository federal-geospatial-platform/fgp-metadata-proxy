DEFAULT_MACRO START_DATETIME
DEFAULT_MACRO END_DATETIME
DEFAULT_MACRO OPERATOR
DEFAULT_MACRO YEARS
DEFAULT_MACRO MONTHS
DEFAULT_MACRO DAYS
DEFAULT_MACRO HOURS
DEFAULT_MACRO MINUTES
DEFAULT_MACRO SECONDS
DEFAULT_MACRO ISO_INTERVAL
DEFAULT_MACRO EXPRESSION
DEFAULT_MACRO RESULT_TYPE
DEFAULT_MACRO RESULT_INTERVAL
DEFAULT_MACRO RESULT_DATETIME
DEFAULT_MACRO RESULT
DEFAULT_MACRO $(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_DateTimeCalculator_EXPRESSION expression
DEFAULT_MACRO $(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_DateTimeCalculator_RESULT_ATTR attr
INCLUDE [    proc stripEvaluateExpression {val} {       if {[regexp {@EvaluateExpression\([^)]*STRING_ENCODED,([^,]*),.+\)} $val -> unwrapped] && [string first {FME_CONDITIONAL:} $unwrapped] < 0}  {          return $unwrapped       } else {          return $val       };    }; ]
INCLUDE [    set start_datetime_stripped [stripEvaluateExpression {@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>date<closeparen>,$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_DateTimeCalculator)}];    set end_datetime_stripped [stripEvaluateExpression {@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_timestamp<closeparen>,$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_DateTimeCalculator)}];    set years_stripped [stripEvaluateExpression {$(YEARS)}];    set months_stripped [stripEvaluateExpression {$(MONTHS)}];    set days_stripped [stripEvaluateExpression {$(DAYS)}];    set hours_stripped [stripEvaluateExpression {$(HOURS)}];    set minutes_stripped [stripEvaluateExpression {$(MINUTES)}];    set seconds_stripped [stripEvaluateExpression {$(SECONDS)}];    set iso_interval_stripped [stripEvaluateExpression {$(ISO_INTERVAL)}];    set result_type_stripped [stripEvaluateExpression {DAYS}];    set expression {};    set result_attr {};    if { "DATETIMECALC_3_CALCULATE_INTERVAL" eq "DATETIMECALC_1_ADD_INTERVAL" ||         "DATETIMECALC_3_CALCULATE_INTERVAL" eq "DATETIMECALC_2_ADD_ISO_INTERVAL" } {       set interval $iso_interval_stripped;       if { "DATETIMECALC_3_CALCULATE_INTERVAL" eq "DATETIMECALC_1_ADD_INTERVAL" } {          set interval <at>DateTimeIntervalCreate<openparen><quote>$years_stripped<quote><comma><quote>$months_stripped<quote><comma><quote>$days_stripped<quote><comma><quote>$hours_stripped<quote><comma><quote>$minutes_stripped<quote><comma><quote>$seconds_stripped<quote><closeparen>;       };       set signed_interval $interval;       if { "$(OPERATOR)" eq "SUBTRACT" } {          set signed_interval <at>DateTimeIntervalNegate<openparen><quote>$interval<quote><closeparen>;       };       set result_attr {$(RESULT_DATETIME)};       set expression <at>DateTimeAdd<openparen><quote>$start_datetime_stripped<quote><comma><quote>$signed_interval<quote><closeparen>;    } elseif { "DATETIMECALC_3_CALCULATE_INTERVAL" eq "DATETIMECALC_3_CALCULATE_INTERVAL" } {       set result_attr {_result_interval};       set expression <at>DateTimeDiff<openparen><quote>$end_datetime_stripped<quote><comma><quote>$start_datetime_stripped<quote><comma><quote>$result_type_stripped<quote><closeparen>;    } elseif { "DATETIMECALC_3_CALCULATE_INTERVAL" eq "DATETIMECALC_4_EXPRESSION" } {       set result_attr {$(RESULT)};       set expression {$(EXPRESSION)};    };    puts "MACRO $(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_DateTimeCalculator_EXPRESSION $expression";    puts "MACRO $(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_DateTimeCalculator_RESULT_ATTR $result_attr"; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_DateTimeCalculator_1 }    INPUT  FEATURE_TYPE "$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_SubstringExtractor_OUTPUT"    OUTPUT { FEATURE_TYPE __TEST_NULL__       @EvaluateExpression(ATTR_CREATE_EXPR_PROPAGATE_MISSING_FDIV,$($(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_DateTimeCalculator_RESULT_ATTR),"$($(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_DateTimeCalculator_EXPRESSION)",$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_DateTimeCalculator) }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_DateTimeCalculator_2 }    INPUT FEATURE_TYPE __TEST_NULL__    TEST { "$($(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_DateTimeCalculator_RESULT_ATTR)" ATTRIBUTE_VALUE_NULL "" ENCODED }    PRESERVE_FEATURE_ORDER PER_OUTPUT_PORT    OUTPUT { PASSED FEATURE_TYPE "$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_DateTimeCalculator_<REJECTED>"       fme_rejection_code "INVALID_INPUT"        }    OUTPUT { FAILED FEATURE_TYPE "$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_DateTimeCalculator_OUTPUT"        }
