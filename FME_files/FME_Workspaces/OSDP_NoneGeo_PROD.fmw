FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_Tester_6 }    INPUT  FEATURE_TYPE "$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_DateTimeCalculator_OUTPUT"    TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_result_interval<closeparen>,$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_Tester_6)" < 7 ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE "$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_Tester_6_PASSED"         }
