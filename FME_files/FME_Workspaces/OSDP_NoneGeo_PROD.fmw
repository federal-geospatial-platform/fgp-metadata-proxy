FACTORY_DEF * TeeFactory FACTORY_NAME PythonCaller_7_<Rejected> INPUT FEATURE_TYPE PythonCaller_7_<Rejected>  NO_LOGGING   OUTPUT FAILED FEATURE_TYPE * @Abort(ENCODED, PythonCaller_7<space>output<space>a<space><lt>Rejected<gt><space>feature.<space><space>To<space>continue<space>translation<space>when<space>features<space>are<space>rejected<comma><space>change<space><apos>Workspace<space>Parameters<apos><space><gt><space>Translation<space><gt><space><apos>Rejected<space>Feature<space>Handling<apos><space>to<space><apos>Continue<space>Translation<apos>)
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { AttributeExposer_3 }    INPUT  FEATURE_TYPE PythonCaller_7_OUTPUT    OUTPUT { FEATURE_TYPE AttributeExposer_3_OUTPUT          }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "keywords.en-t-fr<opencurly><closecurly> keywords.en<opencurly><closecurly> keywords.fr-t-en<opencurly><closecurly> keywords.fr<opencurly><closecurly> subject<opencurly><closecurly> topic_category<opencurly><closecurly> subject_fr<opencurly><closecurly> subject_tbs<opencurly><closecurly> subject_tbs<opencurly><closecurly>_fr resources<opencurly><closecurly>"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO AttributeRemover_3_LIST_FUNC }    } else {        puts "MACRO AttributeRemover_3_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { AttributeRemover_3 }    INPUT  FEATURE_TYPE AttributeExposer_3_OUTPUT    OUTPUT { FEATURE_TYPE AttributeRemover_3_OUTPUT        @RemoveAttributes(fme_encoded,Subject<space>Topic<space><openparen>FR<closeparen>)        $(AttributeRemover_3_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF * TeeFactory   FACTORY_NAME "PairedResourcesManager Input Input Collector"   INPUT FEATURE_TYPE AttributeRemover_3_OUTPUT   OUTPUT FEATURE_TYPE PairedResourcesManager_Input
MACRO PairedResourcesManager_WORKSPACE_NAME PairedResourcesManager
MACRO $(PairedResourcesManager_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(PairedResourcesManager_WORKSPACE_NAME)_XFORMER_NAME PairedResourcesManager
MACRO $(PairedResourcesManager_WORKSPACE_NAME)_SUB_DOC_NAME PairedResourcesManager
MACRO $(PairedResourcesManager_WORKSPACE_NAME)_SUB_DOC_NAME PairedResourcesManager
DEFAULT_MACRO PairedResourcesManager_WORKSPACE_NAME ""
INCLUDE [puts {MACRO WB_OLD_CONTEXT_$(PairedResourcesManager_WORKSPACE_NAME) $(WB_CURRENT_CONTEXT)};          puts {MACRO WB_CURRENT_CONTEXT $(PairedResourcesManager_WORKSPACE_NAME)}]
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(PairedResourcesManager_WORKSPACE_NAME)_Input1762282591 Input Splitter"   INPUT FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_Input"   OUTPUT FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_Input"
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(PairedResourcesManager_WORKSPACE_NAME)_AttributeExposer }    INPUT  FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_Input"    OUTPUT { FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_AttributeExposer_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(PairedResourcesManager_WORKSPACE_NAME)_UUIDGenerator }    INPUT  FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_AttributeExposer_OUTPUT"    OUTPUT { FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_UUIDGenerator_OUTPUT"         "_uuid_paired_record" @UUID()          }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(PairedResourcesManager_WORKSPACE_NAME)_UUIDGenerator OUTPUT Splitter"   INPUT FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_UUIDGenerator_OUTPUT"   OUTPUT FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_0_0UJ7T6Mtf4g="   OUTPUT FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_1_Ltu/celPOVQ="
# -------------------------------------------------------------------------
FACTORY_DEF {*} ElementFactory    FACTORY_NAME { $(PairedResourcesManager_WORKSPACE_NAME)_ListExploder }    INPUT  FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_0_0UJ7T6Mtf4g="    LIST_NAME { "Resource{}" }    ELEMENT_NUMBER_FIELD { "_element_index" }    CLONE_GEOMETRY    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "INCOMING_IF_CONFLICT" }    INCOMING_PREFIX { "<Unused>" }    OUTPUT { ELEMENT FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_ListExploder_ELEMENTS"         @RemoveAttributes(ElementFactory.baseCloned)          }    OUTPUT { NOLIST FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_ListExploder_<REJECTED>"         @RemoveAttributes(ElementFactory.baseCloned)         fme_rejection_code MISSING_PARAMETER_LIST          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(PairedResourcesManager_WORKSPACE_NAME)_ListBuilder_fme_type_remover }    INPUT  FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_ListExploder_ELEMENTS"    OUTPUT { FEATURE_TYPE $(PairedResourcesManager_WORKSPACE_NAME)_ListBuilder_no_fme_type       @RemoveAttributes(fme_type,fme_geometry) }
FACTORY_DEF {*} ListFactory    FACTORY_NAME { $(PairedResourcesManager_WORKSPACE_NAME)_ListBuilder }    INPUT { FEATURE_TYPE $(PairedResourcesManager_WORKSPACE_NAME)_ListBuilder_no_fme_type }    LIST_NAME { "Resource_grouped" }    LIST_ATTRS_TO_INCLUDE { Language URL<space><openparen>EN<closeparen> URL<space><openparen>FR<closeparen> }    LIST_ATTRS_TO_INCLUDE_MODE { SELECTED }    GROUP_BY { Format "Name (EN)" "Name (FR)" ServiceProtocol Type _uuid_paired_record }    FLUSH_WHEN_GROUPS_CHANGE { No }    OUTPUT { LIST FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_ListBuilder_OUTPUT"          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(PairedResourcesManager_WORKSPACE_NAME)_ListElementCounter }    INPUT  FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_ListBuilder_OUTPUT"    OUTPUT { FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_ListElementCounter_OUTPUT"         "_element_count" @NumElements("Resource_grouped<opencurly><closecurly>",ENCODED)          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(PairedResourcesManager_WORKSPACE_NAME)_Tester }    INPUT  FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_ListElementCounter_OUTPUT"    TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_element_count<closeparen>,$(PairedResourcesManager_WORKSPACE_NAME)_Tester)" = 2 ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_Tester_PASSED"         }    OUTPUT { FAILED FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_Tester_FAILED"         }
# -------------------------------------------------------------------------
Tcl2 proc $(PairedResourcesManager_WORKSPACE_NAME)_ListHistogrammer_histo {} {    foreach attr [FME_AttributeNames] {    		 regsub -all \"{\[0-9\]+}\" $attr \"{}\" flatAttr;        if {$flatAttr == \"Resource_grouped{}.Language\" }        {          set attrVal [FME_GetAttribute $attr];          if {$attrVal == {} && [FME_IsAttributeNull $attr]}          {    	         set attrVal {FME_NULL_VALUE};          }; 	       if {[info exists histogram($attrVal)]} { 	           incr histogram($attrVal); 	       } else { 	           set histogram($attrVal) 1; 	       };        };    };    set toSort {};    foreach {name value} [array get histogram] {        lappend s $name $value;        lappend toSort $s;        unset s;    };    set sortedHisto [lsort -integer -decreasing -index end $toSort];    set spot 0;    foreach nameCount $sortedHisto {        set rootName "_histogram{$spot}";        set valueAttr "$rootName.value";        set countAttr "$rootName.count";        if {[lindex $nameCount 0] == {FME_NULL_VALUE}} { 	       FME_SetAttributeNull $valueAttr; 	     } else { 	       FME_SetAttribute $valueAttr [lindex $nameCount 0];        };        FME_SetAttribute $countAttr [lindex $nameCount end];        incr spot;    } }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(PairedResourcesManager_WORKSPACE_NAME)_ListHistogrammer }    INPUT  FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_Tester_PASSED"    OUTPUT { FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_ListHistogrammer_OUTPUT"         @Tcl2("$(PairedResourcesManager_WORKSPACE_NAME)_ListHistogrammer_histo")          }
# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {$(PairedResourcesManager_WORKSPACE_NAME)_ListSearcher_356913c2_cdce_41b0_b43c_d3d0a51a2bbc0} ]
# most of this is close to the code from listindexer but not exact beucase
# we have a type LIST_ATTR rather than type LIST_NAME so need
# to figure out the list name
Tcl2 proc $(FME_UUID_SAFE)_indexer {index prefix} {    set fullListAttrName [FME_DecodeText _histogram<opencurly><closecurly>.value];    set lastBrace [string last  \"{}\" $fullListAttrName];    set listAttr [string range $fullListAttrName 0 [expr $lastBrace+1]];    regsub \"{}\" $listAttr \"{$index}\" listWithIndex;    regsub \"{}\" $listAttr {} listBase;    set complexListExp "$listWithIndex\.";    set prefixLength [expr [string length $complexListExp]-1];    set prefix [FME_DecodeText $prefix];    foreach attr [FME_AttributeNames] {      set newAttr {};      if {$attr == $listWithIndex} {        set newAttr $listBase;      } elseif {[string first $complexListExp $attr] == 0} {        set newAttr [string replace $attr 0 $prefixLength];      };      if {$newAttr != {}} {          if {$prefix != {} } {            set newAttr $prefix$newAttr;          };          if {[string first {fme_} $newAttr] != 0} {              set first [string first {fme_} $newAttr];              lappend attrsToCopy $newAttr $attr;          };      };    };    if {[info exists attrsToCopy] && [llength $attrsToCopy] > 0} {      eval FME_Execute CopyAttributes $attrsToCopy;    }; }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(PairedResourcesManager_WORKSPACE_NAME)_ListSearcher }    INPUT  FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_ListHistogrammer_OUTPUT"    OUTPUT { FEATURE_TYPE $(PairedResourcesManager_WORKSPACE_NAME)_ListSearcher__IndexedFeatures___         "$(FME_UUID_SAFE)" @SearchList(fme_encoded,"_histogram<opencurly><closecurly>.value","fre",FIRST_MATCHED_ENCODED) }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(PairedResourcesManager_WORKSPACE_NAME)_ListSearcher__Tester }    INPUT { FEATURE_TYPE $(PairedResourcesManager_WORKSPACE_NAME)_ListSearcher__IndexedFeatures___ }    TEST { @Value($(FME_UUID_SAFE)) == "-1" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE  "$(PairedResourcesManager_WORKSPACE_NAME)_ListSearcher_NOT_FOUND" @RemoveAttributes($(FME_UUID_SAFE)) }    OUTPUT { FAILED FEATURE_TYPE  $(PairedResourcesManager_WORKSPACE_NAME)_ListSearcher__IndexFound__  }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(PairedResourcesManager_WORKSPACE_NAME)_ListSearcher__Tester2 }    INPUT { FEATURE_TYPE $(PairedResourcesManager_WORKSPACE_NAME)_ListSearcher__IndexFound__ }    TEST { YES == "NO" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_ListSearcher_FOUND" @CopyAttributes(toto, $(FME_UUID_SAFE)) @RemoveAttributes($(FME_UUID_SAFE)) }    OUTPUT { FAILED FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_ListSearcher_FOUND"  @Tcl2("$(FME_UUID_SAFE)_indexer {@Value($(FME_UUID_SAFE))} {_fre.}") @CopyAttributes(toto, $(FME_UUID_SAFE)) @RemoveAttributes($(FME_UUID_SAFE)) }
# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {$(PairedResourcesManager_WORKSPACE_NAME)_ListSearcher_2_d5327964_032b_46f5_8d5e_6196fd2aaeca0} ]
# most of this is close to the code from listindexer but not exact beucase
# we have a type LIST_ATTR rather than type LIST_NAME so need
# to figure out the list name
Tcl2 proc $(FME_UUID_SAFE)_indexer {index prefix} {    set fullListAttrName [FME_DecodeText _histogram<opencurly><closecurly>.value];    set lastBrace [string last  \"{}\" $fullListAttrName];    set listAttr [string range $fullListAttrName 0 [expr $lastBrace+1]];    regsub \"{}\" $listAttr \"{$index}\" listWithIndex;    regsub \"{}\" $listAttr {} listBase;    set complexListExp "$listWithIndex\.";    set prefixLength [expr [string length $complexListExp]-1];    set prefix [FME_DecodeText $prefix];    foreach attr [FME_AttributeNames] {      set newAttr {};      if {$attr == $listWithIndex} {        set newAttr $listBase;      } elseif {[string first $complexListExp $attr] == 0} {        set newAttr [string replace $attr 0 $prefixLength];      };      if {$newAttr != {}} {          if {$prefix != {} } {            set newAttr $prefix$newAttr;          };          if {[string first {fme_} $newAttr] != 0} {              set first [string first {fme_} $newAttr];              lappend attrsToCopy $newAttr $attr;          };      };    };    if {[info exists attrsToCopy] && [llength $attrsToCopy] > 0} {      eval FME_Execute CopyAttributes $attrsToCopy;    }; }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(PairedResourcesManager_WORKSPACE_NAME)_ListSearcher_2 }    INPUT  FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_ListSearcher_FOUND"    OUTPUT { FEATURE_TYPE $(PairedResourcesManager_WORKSPACE_NAME)_ListSearcher_2__IndexedFeatures___         "$(FME_UUID_SAFE)" @SearchList(fme_encoded,"_histogram<opencurly><closecurly>.value","eng",FIRST_MATCHED_ENCODED) }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(PairedResourcesManager_WORKSPACE_NAME)_ListSearcher_2__Tester }    INPUT { FEATURE_TYPE $(PairedResourcesManager_WORKSPACE_NAME)_ListSearcher_2__IndexedFeatures___ }    TEST { @Value($(FME_UUID_SAFE)) == "-1" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE  "$(PairedResourcesManager_WORKSPACE_NAME)_ListSearcher_2_NOT_FOUND" @RemoveAttributes($(FME_UUID_SAFE)) }    OUTPUT { FAILED FEATURE_TYPE  $(PairedResourcesManager_WORKSPACE_NAME)_ListSearcher_2__IndexFound__  }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(PairedResourcesManager_WORKSPACE_NAME)_ListSearcher_2__Tester2 }    INPUT { FEATURE_TYPE $(PairedResourcesManager_WORKSPACE_NAME)_ListSearcher_2__IndexFound__ }    TEST { YES == "NO" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_ListSearcher_2_FOUND" @CopyAttributes(toto, $(FME_UUID_SAFE)) @RemoveAttributes($(FME_UUID_SAFE)) }    OUTPUT { FAILED FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_ListSearcher_2_FOUND"  @Tcl2("$(FME_UUID_SAFE)_indexer {@Value($(FME_UUID_SAFE))} {_eng.}") @CopyAttributes(toto, $(FME_UUID_SAFE)) @RemoveAttributes($(FME_UUID_SAFE)) }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(PairedResourcesManager_WORKSPACE_NAME)_Tester_2 }    INPUT  FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_ListSearcher_2_FOUND"    TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_eng.count<closeparen>,$(PairedResourcesManager_WORKSPACE_NAME)_Tester_2)" = 1 ENCODED } TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_fre.count<closeparen>,$(PairedResourcesManager_WORKSPACE_NAME)_Tester_2)" = 1 ENCODED }    BOOLEAN_OPERATOR { COMPOSITE }    COMPOSITE_TEST_EXPR { "1 AND 2" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_Tester_2_PASSED"         }    OUTPUT { FAILED FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_Tester_2_FAILED"         }
