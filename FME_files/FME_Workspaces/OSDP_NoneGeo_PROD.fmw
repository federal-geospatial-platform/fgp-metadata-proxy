# -------------------------------------------------------------------------
FACTORY_DEF {*} AttributeKeeperFactory    FACTORY_NAME { AttributeKeeper }    INPUT  FEATURE_TYPE DateTimeConverter_2_OUTPUT    KEEP_ATTRS { _timestamp }    KEEP_LISTS {  }    KEEP_FME_ATTRIBUTES Yes    BUILD_FEATURE_TABLES { No }    OUTPUT_ON_ATTRIBUTE_CHANGE {  }    OUTPUT { OUTPUT FEATURE_TYPE AttributeKeeper_OUTPUT        }
