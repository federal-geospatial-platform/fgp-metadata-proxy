# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_Logger_2_01ae237b_2209_4fd1_9e93_baf56e5f669b0} ]
# If the Logger was in a custom transformer, the custom transformer's name was not being
# properly logged -- instead we saw "$(<customXformerName_WORKSPACE_NAME)" being logged as the prefix of the
# message. By deferencing and expanding out the XFORMER_NAME below, and then "WWJD" encoding it when it is
# used in the @Log call via the $encode macro name suffix trick, we get the right result, and the right result
# safely.
MACRO LOGGABLE_XFORMER_NAME $(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_Logger_2
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_Logger_2_Logger }    INPUT  FEATURE_TYPE "$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_AttributeCreator_10_OUTPUT"    OUTPUT { FEATURE_TYPE "$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_Logger_2_LOGGED"                  @Log(ENCODED, "$(LOGGABLE_XFORMER_NAME$encode):<space>@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>valeur<closeparen><space><at>Value<openparen>_message<closeparen>,$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_Logger_2)","<Unused>","20","",INFO,NONE,$(FME_UUID_SAFE))                   }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_Logger_2 LOGGED Transformer Output Nuker"   INPUT FEATURE_TYPE "$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_Logger_2_LOGGED"
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_DELETE1762282591 Output Collector"   INPUT FEATURE_TYPE "$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_AttributeCreator_6_OUTPUT"   OUTPUT FEATURE_TYPE "$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_DELETE" @RemoveAttributes(_type)
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_UPDATE1762282591 Output Collector"   INPUT FEATURE_TYPE "$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_FeatureMerger_2_UNMERGED_REQUESTOR"   OUTPUT FEATURE_TYPE "$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_UPDATE" @RemoveAttributes(_type)
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME))}]
