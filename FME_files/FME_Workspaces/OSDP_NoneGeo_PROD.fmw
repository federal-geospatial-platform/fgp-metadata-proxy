#! <?xml version="1.0" encoding="UTF-8" ?>
#! <WORKSPACE
#    Command line to run this workspace:
#        "C:\Program Files\fme\fme-form2025.0.3\fme.exe" C:\Users\stpoulin\Documents\Repos\2025_11-04-25_upgraded_2025_0_3\fgp-metadata-proxy-master\FME_files\FME_Workspaces_Upgraded\OSDP_NoneGeo_PROD.fmw
