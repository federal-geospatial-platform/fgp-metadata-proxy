FACTORY_DEF {*} ElementFactory    FACTORY_NAME { $(PairedResourcesManager_WORKSPACE_NAME)_ListExploder_2 }    INPUT  FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_Tester_FAILED"    INPUT  FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_ListSearcher_NOT_FOUND"    INPUT  FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_ListSearcher_2_NOT_FOUND"    INPUT  FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_Tester_2_FAILED"    LIST_NAME { "Resource_grouped{}" }    ELEMENT_NUMBER_FIELD { "_element_index" }    CLONE_GEOMETRY    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "INCOMING_IF_CONFLICT" }    INCOMING_PREFIX { "<Unused>" }    OUTPUT { ELEMENT FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_ListExploder_2_ELEMENTS"         @RemoveAttributes(ElementFactory.baseCloned)          }    OUTPUT { NOLIST FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_ListExploder_2_<REJECTED>"         @RemoveAttributes(ElementFactory.baseCloned)         fme_rejection_code MISSING_PARAMETER_LIST          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(PairedResourcesManager_WORKSPACE_NAME)_Junction }    INPUT  FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_ListExploder_2_ELEMENTS"    INPUT  FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_AttributeKeeper_OUTPUT"    OUTPUT { FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_Junction_Output"         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(PairedResourcesManager_WORKSPACE_NAME)_ListBuilder_2_fme_type_remover }    INPUT  FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_Junction_Output"    OUTPUT { FEATURE_TYPE $(PairedResourcesManager_WORKSPACE_NAME)_ListBuilder_2_no_fme_type       @RemoveAttributes(fme_type,fme_geometry) }
FACTORY_DEF {*} ListFactory    FACTORY_NAME { $(PairedResourcesManager_WORKSPACE_NAME)_ListBuilder_2 }    INPUT { FEATURE_TYPE $(PairedResourcesManager_WORKSPACE_NAME)_ListBuilder_2_no_fme_type }    LIST_NAME { "Resource" }    LIST_ATTRS_TO_INCLUDE { Format Language Name<space><openparen>EN<closeparen> Name<space><openparen>FR<closeparen> ServiceProtocol Type URL<space><openparen>EN<closeparen> URL<space><openparen>FR<closeparen> }    LIST_ATTRS_TO_INCLUDE_MODE { SELECTED }    GROUP_BY { _uuid_paired_record }    FLUSH_WHEN_GROUPS_CHANGE { No }    OUTPUT { LIST FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_ListBuilder_2_OUTPUT"          }
