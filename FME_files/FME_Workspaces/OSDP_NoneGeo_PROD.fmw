# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "Resource<opencurly><closecurly>"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(PairedResourcesManager_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC }    } else {        puts "MACRO $(PairedResourcesManager_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(PairedResourcesManager_WORKSPACE_NAME)_AttributeRemover }    INPUT  FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_UUIDGenerator_OUTPUT_1_Ltu/celPOVQ="    OUTPUT { FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_AttributeRemover_OUTPUT"        @RemoveAttributes(fme_encoded,)        $($(PairedResourcesManager_WORKSPACE_NAME)_AttributeRemover_LIST_FUNC)         }
# -------------------------------------------------------------------------
INCLUDE [if { {ATTRIBUTES} == {ATTRIBUTES} } {                puts "MACRO $(PairedResourcesManager_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO ATTRIBUTES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {POLYGONS}} {                puts "MACRO $(PairedResourcesManager_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {AGGREGATES}} {                puts "MACRO $(PairedResourcesManager_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO $(PairedResourcesManager_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {POLYGONS}} {                puts "MACRO $(PairedResourcesManager_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {AGGREGATES}} {                puts "MACRO $(PairedResourcesManager_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO $(PairedResourcesManager_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} } {                puts "MACRO $(PairedResourcesManager_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} } {                puts "MACRO $(PairedResourcesManager_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          else {}; ]
FACTORY_DEF {*} ReferenceFactory    FACTORY_NAME { $(PairedResourcesManager_WORKSPACE_NAME)_FeatureMerger }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT REFERENCER FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_AttributeRemover_OUTPUT"    INPUT REFERENCEE FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_ListBuilder_2_OUTPUT"    REFERENCE_INFO { $($(PairedResourcesManager_WORKSPACE_NAME)_FeatureMerger_REFERENCE_INFO) }    REFERENCE_TABLE { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_uuid_paired_record<closeparen>,$(PairedResourcesManager_WORKSPACE_NAME)_FeatureMerger) @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_uuid_paired_record<closeparen>,$(PairedResourcesManager_WORKSPACE_NAME)_FeatureMerger) AUTO }    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "REQUESTOR_IF_CONFLICT" }    IGNORE_NULLS { "No" }    HANDLE_NULL_MISSING_KEYS_LIKE_FME2013 { No }    LIST_ATTRS_TO_INCLUDE { <Unused> }    LIST_ATTRS_TO_INCLUDE_MODE { <Unused> }    MERGE_ATTRIBUTES Yes    MANAGE_FME_TYPE Yes    MODE COMPLETE    PROCESS_DUPLICATE_REFERENCEES { NO }    REFERENCEES_FIRST { No }    REJECT_INVALID_GEOM YES    CLEANING_TOLERANCE { <Unused> }    OUTPUT { COMPLETE FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_FeatureMerger_MERGED"         }    OUTPUT { INCOMPLETE FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_FeatureMerger_UNMERGED_REQUESTOR"         }    OUTPUT { UNREFERENCED FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_FeatureMerger_UNUSED_SUPPLIER"         }    OUTPUT { REJECTED FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_FeatureMerger_<REJECTED>"         }
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF * TeeFactory FACTORY_NAME "$(PairedResourcesManager_WORKSPACE_NAME)_FeatureMerger_<Rejected>" INPUT FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_FeatureMerger_<REJECTED>"  NO_LOGGING   OUTPUT FAILED FEATURE_TYPE * @Abort(ENCODED, PairedResourcesManager_FeatureMerger<space>output<space>a<space><lt>Rejected<gt><space>feature.<space><space>To<space>continue<space>translation<space>when<space>features<space>are<space>rejected<comma><space>change<space><apos>Workspace<space>Parameters<apos><space><gt><space>Translation<space><gt><space><apos>Rejected<space>Feature<space>Handling<apos><space>to<space><apos>Continue<space>Translation<apos>)
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(PairedResourcesManager_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC }    } else {        puts "MACRO $(PairedResourcesManager_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(PairedResourcesManager_WORKSPACE_NAME)_AttributeRemover_2 }    INPUT  FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_FeatureMerger_MERGED"    OUTPUT { FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"        @RemoveAttributes(fme_encoded,_uuid_paired_record)        $($(PairedResourcesManager_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC)         }
# -------------------------------------------------------------------------
# The default behaviour is to abort on any feature entering the transformer.
# If Workbench has set the _WB_BYPASS_TERMINATION macro to a value of "Yes",
# then the features will instead be passed through with a feature type of
# __WB_BYPASS_TERMINATOR__, which Workbench will send to a visualizer or
# somesuch.
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF {*} TestFactory    FACTORY_NAME { $(PairedResourcesManager_WORKSPACE_NAME)_Terminator_3 }    INPUT  FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_FeatureMerger_UNMERGED_REQUESTOR"    INPUT  FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_FeatureMerger_UNUSED_SUPPLIER"    TEST { "$(_WB_BYPASS_TERMINATION)" == Yes }    OUTPUT { PASSED FEATURE_TYPE __WB_BYPASS_TERMINATOR__       @SupplyAttributes(_wb_termination_feature_type,@FeatureType())       @SupplyAttributes(ENCODED,_wb_termination_message,"Translation<space>Terminated")       @SupplyAttributes(_wb_termination_xformer,"$(PairedResourcesManager_WORKSPACE_NAME)_Terminator_3")       @SupplyAttributes(_wb_termination_feature,Yes) }    OUTPUT { FAILED FEATURE_TYPE * @Abort(ENCODED,"Translation<space>Terminated") }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(PairedResourcesManager_WORKSPACE_NAME)_Output1762282591 Output Collector"   INPUT FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"   OUTPUT FEATURE_TYPE "$(PairedResourcesManager_WORKSPACE_NAME)_Output"
INCLUDE [puts {MACRO WB_CURRENT_CONTEXT $(WB_OLD_CONTEXT_$(PairedResourcesManager_WORKSPACE_NAME))}]
FACTORY_DEF * TeeFactory   FACTORY_NAME "PairedResourcesManager Output Output Renamer/Nuker"   INPUT FEATURE_TYPE PairedResourcesManager_Output   OUTPUT FEATURE_TYPE PairedResourcesManager_Output
# -------------------------------------------------------------------------
Tcl2 proc ListSorter_sort {} {    set COMMENT {    = NOTE: algorithm below does not support nested lists.    };    regsub \"{}.*$\" {Resource{}.URL (EN)} \"\{\" listBase;    regsub \"{}.*$\" {Resource{}.URL (EN)} \"\" listName;    set listBaseLen [string length $listBase];    set listNameLen [expr $listBaseLen - 1];    set listValueExtension [string replace {Resource{}.URL (EN)} 0 $listBaseLen {}];    set kCloseBrace \"\}\";    set kAnyOtherCharacters {*};    set kPlaceholderMissingVal 1;    set kPlaceholderNullVal 2;    set kPlaceholderEmptyVal 3;    set COMMENT {    = To resolve PR 46315 (and friends), lets make a first pass to determine the full list of    = possible index numbers. Then we'll go through and make sure we have a KEY value for each    = of those.  We'll track what "keys" we added so that at the end we can REMOVE them so they stay MISSING.    };    set maxElementCount 0;    foreach attr [FME_AttributeNames] {       set COMMENT {       =    For each attribute "listattr{<index>}.count" and all related attributes       =    "listattr{<index>}<extension>", create a list of the form       =       {$listattr{<index>}.count <index>}, and keep a list of the extensions       =    for each index in the associative array listExtensions(<index>).       };       set attrStart [string range $attr 0 $listNameLen];       if { $attrStart == $listBase } {          set braceEnd [string first \} $attr $listBaseLen];          set index [string range $attr $listBaseLen [expr $braceEnd - 1]];          set extension [string range $attr [expr $braceEnd + 1] end];          if { [regexp {^[0-9]+$} $index] == 1 } {             lappend listExtensions($index) $extension;             set attrsToRename($attr) 1;             set COMMENT {Keep track of the maximum index value};             if { [expr $index > $maxElementCount] } {                set maxElementCount $index;             }          };       }    };    set curElement 0;    set COMMENT {    = Now that we have a list of the actual element numbers included in the list. Lets whip through and make sure    = we have an actual element for each of the "key" parts of the list we want to sort. If we don't, we'll    = make an element there with an empty value.  Note that we can't easily separate and sort NULL < missing < empty,    = but we'll live with that shortcoming in here as long as it is documented.    };    catch {unset emptyPlaceholder};    set toSort {};    set placeholdersToSort {};    foreach curElement [lsort -integer -unique [array names listExtensions]] {       set COMMENT {       =    We found that there is at least some kind of element at this index in the list       =    so we need to ensure there is a key element at this index. If it is missing,       =    NULL or an empty string, then we save it to a separate array of placehoder values of 1, 2 or       =    3, respectively, so that can be deterministically sorted separately from the other       =    elements, and then tacked on at either the beginning of the end later on.       };       set COMMENT {Minimum float is taken from std::numeric_limits<T>::lowest() cppreference web page.};       set indexKeyElementAttr $listBase$curElement$kCloseBrace$listValueExtension;       if { ! [FME_AttributeExists $indexKeyElementAttr ] } {           set COMMENT {The key value attribute didn't exist, so put it on a separate placeholder list for sorting};           lappend placeholdersToSort [list $kPlaceholderMissingVal $curElement];           set emptyPlaceholder($curElement) $kPlaceholderMissingVal;       } elseif { [FME_IsAttributeNull $indexKeyElementAttr] } {           set COMMENT {Key attribute exists but is null, so put it on a separate placeholder list for sorting};           set emptyPlaceholder($curElement) $kPlaceholderNullVal;           lappend placeholdersToSort [list $kPlaceholderNullVal $curElement];       } elseif { [FME_GetAttribute $indexKeyElementAttr] == {} } {           set COMMENT {Key attribute exists but is empty, so put it on a separate placeholder list for sorting};           set emptyPlaceholder($curElement) $kPlaceholderEmptyVal;           lappend placeholdersToSort [list $kPlaceholderEmptyVal $curElement];       } else {           lappend toSort [list [FME_GetAttribute $indexKeyElementAttr] $curElement]       };    };    set COMMENT {    =    Sort the {$listattr{<index>} <index>} by index 0 (attr value). If we had (1,2,3) placeholders    =    for missing, NULL, or empty values, we sort those as well, and then tack them onto the    =    proper end of the resulting list.    };    set sortedAttrs [lsort   -index 0 $toSort];    set sortedPlaceholders [lsort   -index 0 $placeholdersToSort];    set COMMMENT {    =    If there were placeholders for null/missing/empty, put them at the beginning    =    or end of the sortedAttrs, depending on sort order    };    if { {} != {} } {       set sortedAttrs [concat $sortedAttrs $sortedPlaceholders];    } else {       set sortedAttrs [concat $sortedPlaceholders $sortedAttrs];    };    set destIndex 0;    set COMMENT {    =    For each list within sortedAttrs, iterate over the list, renaming    =    "listattr{<index>}<extension>" to    =    "listattr{<newIndex>}<extension>"    };    catch {unset nullRemap};    set renameAttrsFrom {};    set renameAttrsTo {};    foreach pair $sortedAttrs {       set elementNum [lindex $pair 1];       set nullRemap($destIndex) $elementNum;       set newAttrBase "$listName\{$destIndex\}";       set oldAttrBase "$listName\{$elementNum\}";       foreach extension $listExtensions($elementNum) {          lappend renameAttrsFrom $oldAttrBase$extension;          lappend renameAttrsTo $newAttrBase$extension;          unset attrsToRename($oldAttrBase$extension);       };       incr destIndex    };    set COMMENT {    =    If any attributes were list attributes but did not contain the    =    structure extension on which we were sorting, they must be cleaned up.    };    set attrs [array names attrsToRename];    if {[llength $attrs]} { eval FME_UnsetAttributes $attrs };    FME_RenameAttribute -list $renameAttrsTo $renameAttrsFrom;    set COMMENT {    =    = Lastly, go through and any of the MISSING, EMPTY, or NULL key values and set appropriately.  We'll have preserved their    = parallel list structure friends, but we need to restore the moved key to its original state: missing, blank or NULL    =    };    set curElement 0;    while { $curElement <= $maxElementCount } {        if { [info exists nullRemap($curElement)] } {            set origIndex $nullRemap($curElement);            if { [info exists emptyPlaceholder($origIndex)] } {                set COMMENT {Get rid of the sidecar attribute and key attribute too};                set indexKeyElementAttr $listBase$curElement$kCloseBrace$listValueExtension;                set value $emptyPlaceholder($origIndex);                if {$value == $kPlaceholderNullVal} {                  FME_SetAttributeNull $indexKeyElementAttr;                } elseif { $value == $kPlaceholderMissingVal } {                    FME_UnsetAttributes $indexKeyElementAttr;                } else {                  FME_SetAttribute $indexKeyElementAttr {};                };             };        };        incr curElement;    }; }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { ListSorter }    INPUT  FEATURE_TYPE PairedResourcesManager_Output    OUTPUT { FEATURE_TYPE ListSorter_OUTPUT         @Tcl2("ListSorter_sort")          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { ListElementCounter }    INPUT  FEATURE_TYPE ListSorter_OUTPUT    OUTPUT { FEATURE_TYPE ListElementCounter_OUTPUT         @SupplyAttributes(ENCODED, Resource<space>Total, @NumElements("Resource<opencurly><closecurly>",ENCODED))          }
