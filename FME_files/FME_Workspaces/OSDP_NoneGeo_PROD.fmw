INCLUDE [    set expression {<at>DateTimeCast<openparen><at>DateTimeNow<openparen>utc<comma>feature<closeparen><comma>datetime<closeparen>};    if { {NO} eq {NO} } {        set expression <at>TimeZoneRemove<openparen>$expression<closeparen>;    };    if { {YES} eq {NO} } {        set expression <at>DateTimeRound<openparen>$expression<comma>down<comma>seconds<comma>1<closeparen>;    };    puts "MACRO DateTimeStamper_EXPRESSION $expression"; ]
