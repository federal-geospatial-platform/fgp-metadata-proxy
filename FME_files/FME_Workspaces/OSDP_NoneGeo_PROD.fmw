# -------------------------------------------------------------------------
# Since the Tcl "END" index specification starts at -1 for the second
# last character, and we've defined -1 to be the last charater, we've got
# small bit of fiddling to do
Tcl2 proc $(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_SubstringExtractor_fixLastIndex {lastValue} {     if {$lastValue < -1} {         incr lastValue;         return "end$lastValue";     }     elseif {$lastValue == -1} {         return "end";     }     else {         return $lastValue;     } }
Tcl2 proc $(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_SubstringExtractor_extract {startIdx endIdx} {     FME_SetAttribute [FME_DecodeText date]         [string range [FME_DecodeTextOrAttr @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>path_rootname<closeparen>,$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_SubstringExtractor)]                       [$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_SubstringExtractor_fixLastIndex $startIdx]                       [$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_SubstringExtractor_fixLastIndex $endIdx]]     }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_SubstringExtractor }    INPUT  FEATURE_TYPE "$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_Tester_5_PASSED"    OUTPUT { FEATURE_TYPE "$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_SubstringExtractor_OUTPUT"         @Tcl2("$(NON_GEO_HISTORIC_MANAGER_WORKSPACE_NAME)_SubstringExtractor_extract -8 -1")          }
