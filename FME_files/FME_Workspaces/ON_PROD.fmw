# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {StatisticsCalculator_Summary_2_beacd887_ae3f_4e94_83dc_070c45cc38fb3} ]
# If the Logger was in a custom transformer, the custom transformer's name was not being
# properly logged -- instead we saw "$(<customXformerName_WORKSPACE_NAME)" being logged as the prefix of the
# message. By deferencing and expanding out the XFORMER_NAME below, and then "WWJD" encoding it when it is
# used in the @Log call via the $encode macro name suffix trick, we get the right result, and the right result
# safely.
MACRO LOGGABLE_XFORMER_NAME StatisticsCalculator_Summary_2
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { StatisticsCalculator_Summary_2_Logger }    INPUT  FEATURE_TYPE METADATA_DELTA_FINDER_GEN_2_Statistics    OUTPUT { FEATURE_TYPE StatisticsCalculator_Summary_2_LOGGED                  @Log(ENCODED, "$(LOGGABLE_XFORMER_NAME$encode):<space>@EvaluateExpression(FDIV,STRING_ENCODED,<lf>************************<lf>****<space>None<space>Geo<space>Unchanged<space>Report<space>****<lf>************************<lf><lf><at>Value<openparen>_real_count<closeparen><space>features<space>were<space>unchanged<lf><lf>************************<lf>************************<lf>************************<lf>,StatisticsCalculator_Summary_2)","<Unused>","20","",INFO,NONE,$(FME_UUID_SAFE))                   }
FACTORY_DEF * TeeFactory   FACTORY_NAME "StatisticsCalculator_Summary_2 LOGGED Transformer Output Nuker"   INPUT FEATURE_TYPE StatisticsCalculator_Summary_2_LOGGED
