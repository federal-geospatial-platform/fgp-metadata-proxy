FACTORY_DEF {*} TeeFactory    FACTORY_NAME { AttributeExposer_5 }    INPUT  FEATURE_TYPE PythonCaller_OUTPUT    OUTPUT { FEATURE_TYPE AttributeExposer_5_OUTPUT          }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO AttributeRemover_LIST_FUNC }    } else {        puts "MACRO AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { AttributeRemover }    INPUT  FEATURE_TYPE AttributeExposer_5_OUTPUT    OUTPUT { FEATURE_TYPE AttributeRemover_OUTPUT        @RemoveAttributes(fme_encoded,_response_body,xml_fragment)        $(AttributeRemover_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { AttributeExposer_7 }    INPUT  FEATURE_TYPE AttributeRemover_OUTPUT    OUTPUT { FEATURE_TYPE AttributeExposer_7_OUTPUT          }
# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {ListSearcher_f0772564_f3e1_4b4e_ae78_99f5680d021c0} ]
# most of this is close to the code from listindexer but not exact beucase
# we have a type LIST_ATTR rather than type LIST_NAME so need
# to figure out the list name
Tcl2 proc $(FME_UUID_SAFE)_indexer {index prefix} {    set fullListAttrName [FME_DecodeText URI<opencurly><closecurly>];    set lastBrace [string last  \"{}\" $fullListAttrName];    set listAttr [string range $fullListAttrName 0 [expr $lastBrace+1]];    regsub \"{}\" $listAttr \"{$index}\" listWithIndex;    regsub \"{}\" $listAttr {} listBase;    set complexListExp "$listWithIndex\.";    set prefixLength [expr [string length $complexListExp]-1];    set prefix [FME_DecodeText $prefix];    foreach attr [FME_AttributeNames] {      set newAttr {};      if {$attr == $listWithIndex} {        set newAttr $listBase;      } elseif {[string first $complexListExp $attr] == 0} {        set newAttr [string replace $attr 0 $prefixLength];      };      if {$newAttr != {}} {          if {$prefix != {} } {            set newAttr $prefix$newAttr;          };          if {[string first {fme_} $newAttr] != 0} {              set first [string first {fme_} $newAttr];              lappend attrsToCopy $newAttr $attr;          };      };    };    if {[info exists attrsToCopy] && [llength $attrsToCopy] > 0} {      eval FME_Execute CopyAttributes $attrsToCopy;    }; }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { ListSearcher }    INPUT  FEATURE_TYPE AttributeExposer_7_OUTPUT    OUTPUT { FEATURE_TYPE ListSearcher__IndexedFeatures___         "$(FME_UUID_SAFE)" @SearchList(fme_encoded,"URI<opencurly><closecurly>","https:<solidus><solidus>raw.githubusercontent.com<solidus>federal-geospatial-platform<solidus>fgp-metadata-proxy<solidus>master<solidus>images<solidus>resampled",REGULAR_EXPRESSION_ENCODED,CASE_SENSITIVE) }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { ListSearcher__Tester }    INPUT { FEATURE_TYPE ListSearcher__IndexedFeatures___ }    TEST { @Value($(FME_UUID_SAFE)) == "-1" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { FAILED FEATURE_TYPE  ListSearcher__IndexFound__  }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { ListSearcher__Tester2 }    INPUT { FEATURE_TYPE ListSearcher__IndexFound__ }    TEST { YES == "NO" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE ListSearcher_FOUND @CopyAttributes(_list_index, $(FME_UUID_SAFE)) @RemoveAttributes($(FME_UUID_SAFE)) }    OUTPUT { FAILED FEATURE_TYPE ListSearcher_FOUND  @Tcl2("$(FME_UUID_SAFE)_indexer {@Value($(FME_UUID_SAFE))} {thumbnail}") @CopyAttributes(_list_index, $(FME_UUID_SAFE)) @RemoveAttributes($(FME_UUID_SAFE)) }
# -------------------------------------------------------------------------
FACTORY_DEF {*} StringValueFactory    FACTORY_NAME { AttributeSplitter_3 }    INPUT  FEATURE_TYPE ListSearcher_FOUND    FACTORY_MODE ATTRIBUTE_SPLITTER    ATTR_NAME { thumbnailURI }       DELIMITER { <solidus> }       FIELD_QUALIFIER { "" }       TRIM_TYPE { BOTH }       LIST_NAME { _list }       DROP_EMPTY_PARTS { NO }    OUTPUT { OUTPUT FEATURE_TYPE AttributeSplitter_3_OUTPUT          }
# -------------------------------------------------------------------------
Tcl2 proc ListIndexer_2_indexer {index numElements prefix suffix} {    if {$index < 0 } {       set index [expr $numElements + $index];    };    regsub \"{}\" {_list{}} \"{$index}\" listWithIndex;    regsub \"{}\" {_list{}} {} listBase;    set complexListExp "$listWithIndex\.";    set prefixLength [expr [string length $complexListExp]-1];    set prefix [FME_DecodeText $prefix];    set suffix [FME_DecodeText $suffix];    foreach attr [FME_AttributeNames] {      set newAttr {};      if {$attr == $listWithIndex} {        set newAttr $listBase;      } elseif {[string first $complexListExp $attr] == 0} {        set newAttr [string replace $attr 0 $prefixLength];      };      if {$newAttr != {}} {          if {$prefix != {} } {            set newAttr $prefix$newAttr;          };          if {$suffix != {} } {            set newAttr $newAttr$suffix;          };          if {[string first {fme_} $newAttr] != 0} {              set first [string first {fme_} $newAttr];              lappend attrsToCopy $newAttr $attr;          };      };    };    if {[info exists attrsToCopy] && [llength $attrsToCopy] > 0} {      eval FME_Execute CopyAttributes $attrsToCopy;    }; }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { ListIndexer_2_IntTester }    INPUT  FEATURE_TYPE AttributeSplitter_3_OUTPUT    TEST { "-2" TYPE INT ENCODED }    PRESERVE_FEATURE_ORDER PER_OUTPUT_PORT    OUTPUT { PASSED FEATURE_TYPE __toOutput__ }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { ListIndexer_2_ListIndexer }    INPUT FEATURE_TYPE __toOutput__    TEST { "-2" >= 0 }    OUTPUT PASSED FEATURE_TYPE ListIndexer_2_OUTPUT @Tcl2("ListIndexer_2_indexer -2 0 {} {}")    OUTPUT FAILED FEATURE_TYPE ListIndexer_2_OUTPUT @Tcl2("ListIndexer_2_indexer -2 @NumElements(_list{}) {} {}")
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { AttributeCreator_12 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE ListIndexer_2_OUTPUT    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "PT" "SET_TO" "<at>Value<openparen>_list<closeparen>" "varchar<openparen>200<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE AttributeCreator_12_OUTPUT        }
